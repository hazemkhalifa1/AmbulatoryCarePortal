{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "EmailSettings": {
    "SmtpServer": "",
    "SmtpPort": 587,
    "EnableSsl": true,
    "SenderEmail": "",
    "SenderName": "",
    "Username": "",
    "Password": ""
  },
  "FileUploadSettings": {
    "MaxFileSizeBytes": 20971520,
    "AllowedExtensions": [
      ".pdf",
      ".doc",
      ".docx",
      ".jpg",
      ".jpeg",
      ".png",
      ".xslx",
      ".xls"
    ],
    "BasePath": "wwwroot/uploads"
  },
  "NotificationSettings": {
    "ExpiryWarningDays": [
      30,
      14,
      7
    ],
    "CheckIntervalMinutes": 60
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Security": {
    "AdminPassword": ""
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}
