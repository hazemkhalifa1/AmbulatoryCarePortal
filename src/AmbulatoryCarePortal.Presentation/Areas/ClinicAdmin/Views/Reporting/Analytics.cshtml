@model AnalyticsViewModel

@{
    ViewData["Title"] = Localizer.T("Report.AnalyticsTitle", Model.AnalyticsType);
    var insightBadge = (string type) => type switch
    {
        "Success" => "success",
        "Warning" => "warning",
        "Info" => "info",
        "Danger" => "danger",
        _ => "secondary"
    };
    var insightIcon = (string type) => type switch
    {
        "Success" => "fa-check-circle",
        "Warning" => "fa-exclamation-triangle",
        "Info" => "fa-info-circle",
        "Danger" => "fa-times-circle",
        _ => "fa-circle"
    };
    var trendIcon = (string dir) => dir switch
    {
        "Up" => "fa-arrow-up text-success",
        "Down" => "fa-arrow-down text-danger",
        _ => "fa-minus text-muted"
    };
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("Report.AnalyticsTitle", Model.AnalyticsType),
    Icon = "fa-chart-pie",
    Subtitle = Localizer.T("Report.AnalyticsDashboard"),
    Breadcrumb = ""
}' />

@if (Model.ChartData != null && Model.ChartData.Any())
{
    <div class="row">
        @foreach (var chart in Model.ChartData)
        {
            var chartId = $"chart-{chart.Title.Replace(" ", "-").ToLower()}";
            <div class="col-lg-6 col-md-12 mb-4">
                <div class="card card-primary h-100">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="fas fa-chart-simple me-2"></i>@chart.Title</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="@chartId"
                                data-chart-type="@chart.ChartType"
                                data-labels='@System.Text.Json.JsonSerializer.Serialize(chart.Labels)'
                                data-values='@System.Text.Json.JsonSerializer.Serialize(chart.Values)'
                                style="min-height: 280px;" role="img" aria-label="@chart.Title chart"></canvas>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.Insights != null && Model.Insights.Any())
{
    <div class="row mb-3">
        <div class="col-12">
            <h4><i class="fas fa-lightbulb me-2"></i>@Localizer.T("Report.Insights")</h4>
        </div>
        @foreach (var insight in Model.Insights)
        {
            <div class="col-lg-6 col-md-12 mb-4">
                <div class="card card-primary h-100 border-@insightBadge(insight.Type)">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="fas @insightIcon(insight.Type) me-2"></i>@insight.Title
                        </h5>
                        <span class="status-pill @insightBadge(insight.Type)">@insight.Type</span>
                    </div>
                    <div class="card-body">
                        <p class="card-text">@insight.Description</p>
                        @if (!string.IsNullOrEmpty(insight.Recommendation))
                        {
                            <div class="alert alert-@insightBadge(insight.Type) mb-0 py-2" role="alert">
                                <i class="fas fa-lightbulb me-1"></i>
                                <strong>@Localizer.T("Report.Recommendation"):</strong> @insight.Recommendation
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.Trends != null && Model.Trends.Any())
{
    <div class="row mb-3">
        <div class="col-12">
            <h4><i class="fas fa-chart-line me-2"></i>@Localizer.T("Report.PerformanceTrends")</h4>
        </div>
        <div class="col-12">
            <div class="card card-primary">
                <div class="card-body p-0">
                    <div class="table-container">
                        <table class="table table-hover" id="trendsTable">
                            <thead>
                                <tr>
                                    <th>@Localizer.T("Report.Metric")</th>
                                    <th>@Localizer.T("Report.ChangePercent")</th>
                                    <th>@Localizer.T("Report.Direction")</th>
                                    <th>@Localizer.T("Report.Period")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var trend in Model.Trends)
                                {
                                    <tr>
                                        <td class="fw-semibold">@trend.Metric</td>
                                        <td>
                                            <span class="status-pill @(trend.ChangePercentage >= 0 ? "complete" : "inactive")">
                                                @(trend.ChangePercentage >= 0 ? "+" : "")@trend.ChangePercentage.ToString("F1")%
                                            </span>
                                        </td>
                                        <td>
                                            <i class="fas @trendIcon(trend.Direction) fa-lg me-1"></i>
                                            <span>@trend.Direction</span>
                                        </td>
                                        <td class="text-muted">@trend.Period</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
