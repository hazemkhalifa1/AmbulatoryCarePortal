@model List<ReportTypeOptionViewModel>

@{
    ViewData["Title"] = Localizer.T("Page.ReportingCenter");
    var getIcon = (string type) => type switch
    {
        "Compliance" => "fa-shield-halved",
        "KPI" => "fa-chart-line",
        "Audit" => "fa-history",
        "Checklist" => "fa-square-check",
        "HR" => "fa-users",
        _ => "fa-file-lines"
    };
    var getColor = (string type) => type switch
    {
        "Compliance" => "primary",
        "KPI" => "success",
        "Audit" => "info",
        "Checklist" => "warning",
        "HR" => "danger",
        _ => "secondary"
    };
    var getBuilderAction = (string type) => type switch
    {
        "Compliance" => nameof(ReportingController.ComplianceReportBuilder),
        "KPI" => nameof(ReportingController.KPIReportBuilder),
        "Audit" => nameof(ReportingController.AuditReportBuilder),
        "Checklist" => nameof(ReportingController.ChecklistReportBuilder),
        "HR" => nameof(ReportingController.HRReportBuilder),
        _ => nameof(ReportingController.Index)
    };
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("Page.ReportingCenter"),
    Icon = "fa-print",
    Breadcrumb = ""
}' />

<div class="row g-4 mb-4">
    @foreach (var report in Model)
    {
        <div class="col-lg-4 col-md-6">
            <div class="card card-primary h-100">
                <div class="card-body">
                    <div class="d-flex align-items-start mb-3">
                        <div class="me-3" style="font-size: 2rem; color: var(--color-@(getColor(report.Type)));">
                            <i class="fas @getIcon(report.Type)"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h5 class="mb-1">@report.DisplayName</h5>
                            <p class="text-muted small mb-2">@report.Description</p>
                            <div>
                                @foreach (var fmt in report.SupportedFormats)
                                {
                                    <span class="badge bg-@(getColor(report.Type)) me-1">@fmt</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top-0">
                    <a asp-action="@getBuilderAction(report.Type)" class="btn btn-@(getColor(report.Type)) w-100">
                        <i class="fas fa-file-export"></i> @Localizer.T("Report.GenerateReport")
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<div class="card card-primary">
    <div class="card-header">
        <h3><i class="fas fa-envelope"></i>@Localizer.T("Report.EmailReport")</h3>
    </div>
    <form method="post" asp-action="EmailReport">
        @Html.AntiForgeryToken()
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <div class="form-group">
                        <label for="reportType" class="form-label">@Localizer.T("Report.ReportType") <span class="text-danger">*</span></label>
                        <select name="reportType" id="reportType" class="form-select" required>
                            <option value="">@Localizer.T("Report.SelectReport")</option>
                            @foreach (var report in Model)
                            {
                                <option value="@report.Type">@report.DisplayName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="form-group">
                        <label for="recipients" class="form-label">@Localizer.T("Report.Recipients") <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                            <input type="text" name="recipients" id="recipients" class="form-control" placeholder="email1@example.com, email2@example.com" required />
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-paper-plane"></i> @Localizer.T("Report.SendReport")
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var recipientInput = document.getElementById('recipients');
            if (recipientInput) {
                recipientInput.form.addEventListener('submit', function (e) {
                    if (!recipientInput.value.trim()) {
                        e.preventDefault();
                        recipientInput.classList.add('is-invalid');
                        return false;
                    }
                });
                recipientInput.addEventListener('input', function () {
                    if (this.value.trim()) {
                        this.classList.remove('is-invalid');
                    }
                });
            }
        });
    </script>
}
