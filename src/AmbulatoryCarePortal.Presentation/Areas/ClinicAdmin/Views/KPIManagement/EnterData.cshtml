@model KPIEntryViewModel

@{
    ViewData["Title"] = @Localizer.T("Page.EnterKPIData");
}

<div class="row fade-in">
    <div class="col-sm-6">
        <h3><i class="fas fa-pen text-success me-2"></i>@Localizer.T("Page.EnterKPIData")</h3>
    </div>
    <div class="col-sm-6 text-end">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>@Localizer.T("HR.BackToList")
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card card-success">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-chart-line"></i> @Model.KPIName</h3>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="detail-row">
                            <span class="detail-label">@Localizer.T("KPI.KPIName")</span>
                            <span class="detail-value">@Model.KPIName</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">@Localizer.T("Common.Frequency")</span>
                            <span class="detail-value"><span class="badge badge-secondary">@Model.Frequency</span></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-row">
                            <span class="detail-label">@Localizer.T("KPI.TargetValue")</span>
                            <span class="detail-value fs-5 text-primary fw-bold">@Model.TargetValue.ToString("N2")</span>
                        </div>
                    </div>
                </div>

                <form asp-action="EnterData" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="KPIId" />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PeriodMonth" class="form-label">@Localizer.T("KPI.PeriodMonth") <span class="required">*</span></label>
                                <select asp-for="PeriodMonth" class="form-select">
                                    @for (int m = 1; m <= 12; m++)
                                    {
                                        <option value="@m">@m - @(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                                    }
                                </select>
                                <span asp-validation-for="PeriodMonth" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PeriodYear" class="form-label">@Localizer.T("KPI.PeriodYear") <span class="required">*</span></label>
                                <select asp-for="PeriodYear" class="form-select">
                                    @for (int y = DateTime.UtcNow.Year - 2; y <= DateTime.UtcNow.Year + 1; y++)
                                    {
                                        <option value="@y">@y</option>
                                    }
                                </select>
                                <span asp-validation-for="PeriodYear" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="ActualValue" class="form-label">@Localizer.T("KPI.ActualValue") <span class="required">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-calculator"></i></span>
                            <input asp-for="ActualValue" class="form-control" type="number" step="0.01" min="0" />
                        </div>
                        <span asp-validation-for="ActualValue" class="invalid-feedback"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Notes" class="form-label">@Localizer.T("Common.Description")</label>
                        <textarea asp-for="Notes" class="form-control" rows="3"
                                  placeholder="@Localizer.T("KPI.DataNotesPlaceholder")"></textarea>
                        <span asp-validation-for="Notes" class="invalid-feedback"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">@Localizer.T("Common.Evidence")</label>
                        <input type="file" name="evidenceFile" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.doc,.docx,.xlsx" />
                        <small class="text-muted">@Localizer.T("KPI.UploadEvidenceHelp")</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save me-1"></i>@Localizer.T("Button.Save")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-1"></i>@Localizer.T("Button.Cancel")
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-info">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-info-circle"></i> @Localizer.T("KPI.EntryInfo")</h3>
            </div>
            <div class="card-body">
                <div class="detail-row">
                    <span class="detail-label"><i class="fas fa-calendar text-info me-1"></i> @Localizer.T("KPI.DefaultPeriod")</span>
                    <span class="detail-value">@Localizer.T("KPI.CurrentMonthYear")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label"><i class="fas fa-calculator text-info me-1"></i> @Localizer.T("KPI.Achievement")</span>
                    <span class="detail-value">Actual / Target &times; 100%</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label"><i class="fas fa-file text-info me-1"></i> @Localizer.T("Common.Evidence")</span>
                    <span class="detail-value">@Localizer.T("KPI.UploadEvidenceHelp")</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
