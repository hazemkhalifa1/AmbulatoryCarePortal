@model CreateKPIViewModel

@{
    ViewData["Title"] = "Create New KPI";
}

<div class="row mb-3">
    <div class="col-sm-6">
        <h3 class="mb-0"><i class="fas fa-plus-circle text-primary me-2"></i>Create New KPI</h3>
    </div>
    <div class="col-sm-6 text-end">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Back to List
        </a>
    </div>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-md-8">
            <div class="card card-primary card-outline">
                <div class="card-header">
                    <h5 class="card-title mb-0"><i class="fas fa-info-circle me-1"></i>KPI Details</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Enter KPI name in English" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="NameAr" class="form-label">Name (Arabic)</label>
                            <input asp-for="NameAr" class="form-control" placeholder="أدخل اسم المؤشر" dir="rtl" />
                            <span asp-validation-for="NameAr" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="TargetValue" class="form-label">Target Value <span class="text-danger">*</span></label>
                            <input asp-for="TargetValue" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="TargetValue" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Frequency" class="form-label">Frequency <span class="text-danger">*</span></label>
                            <select asp-for="Frequency" class="form-select">
                                <option value="">-- Select Frequency --</option>
                                @foreach (var freq in Model.Frequencies)
                                {
                                    <option value="@freq">@freq</option>
                                }
                            </select>
                            <span asp-validation-for="Frequency" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DepartmentId" class="form-label">Department <span class="text-danger">*</span></label>
                        <select asp-for="DepartmentId" class="form-select">
                            <option value="">-- Select Department --</option>
                            @foreach (var dept in Model.AvailableDepartments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-info card-outline">
                <div class="card-header">
                    <h5 class="card-title mb-0"><i class="fas fa-cog me-1"></i>Advanced Settings</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="CalculationFormula" class="form-label">Calculation Formula</label>
                        <textarea asp-for="CalculationFormula" class="form-control" rows="3"
                                  placeholder="e.g., (Numerator / Denominator) * 100"></textarea>
                        <span asp-validation-for="CalculationFormula" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EvidenceRequired" class="form-label">Evidence Required</label>
                        <textarea asp-for="EvidenceRequired" class="form-control" rows="3"
                                  placeholder="Describe what evidence is needed"></textarea>
                        <span asp-validation-for="EvidenceRequired" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EscalationRule" class="form-label">Escalation Rule</label>
                        <textarea asp-for="EscalationRule" class="form-control" rows="3"
                                  placeholder="e.g., Escalate if below 50% for 2 consecutive months"></textarea>
                        <span asp-validation-for="EscalationRule" class="text-danger small"></span>
                    </div>
                </div>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-save me-1"></i>Create KPI
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
