@model CreateKPIViewModel

@{
    ViewData["Title"] = "Create New KPI";
}

<div class="row fade-in">
    <div class="col-sm-6">
        <h3><i class="fas fa-plus-circle text-primary me-2"></i>Create New KPI</h3>
    </div>
    <div class="col-sm-6 text-end">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Back to List
        </a>
    </div>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-md-8">
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-info-circle"></i> KPI Details</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Name" class="form-label">Name <span class="required">*</span></label>
                                <input asp-for="Name" class="form-control" placeholder="Enter KPI name in English" />
                                <span asp-validation-for="Name" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="NameAr" class="form-label">Name (Arabic)</label>
                                <input asp-for="NameAr" class="form-control" placeholder="أدخل اسم المؤشر" dir="rtl" />
                                <span asp-validation-for="NameAr" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="TargetValue" class="form-label">Target Value <span class="required">*</span></label>
                                <input asp-for="TargetValue" class="form-control" type="number" step="0.01" min="0" />
                                <span asp-validation-for="TargetValue" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Frequency" class="form-label">Frequency <span class="required">*</span></label>
                                <select asp-for="Frequency" class="form-select">
                                    <option value="">-- Select Frequency --</option>
                                    @foreach (var freq in Model.Frequencies)
                                    {
                                        <option value="@freq">@freq</option>
                                    }
                                </select>
                                <span asp-validation-for="Frequency" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="DepartmentId" class="form-label">Department <span class="required">*</span></label>
                        <select asp-for="DepartmentId" class="form-select">
                            <option value="">-- Select Department --</option>
                            @foreach (var dept in Model.AvailableDepartments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        </select>
                        <span asp-validation-for="DepartmentId" class="invalid-feedback"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-cog"></i> Advanced Settings</h3>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label asp-for="CalculationFormula" class="form-label">Calculation Formula</label>
                        <textarea asp-for="CalculationFormula" class="form-control" rows="3"
                                  placeholder="e.g., (Numerator / Denominator) * 100"></textarea>
                        <span asp-validation-for="CalculationFormula" class="invalid-feedback"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="EvidenceRequired" class="form-label">Evidence Required</label>
                        <textarea asp-for="EvidenceRequired" class="form-control" rows="3"
                                  placeholder="Describe what evidence is needed"></textarea>
                        <span asp-validation-for="EvidenceRequired" class="invalid-feedback"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="EscalationRule" class="form-label">Escalation Rule</label>
                        <textarea asp-for="EscalationRule" class="form-control" rows="3"
                                  placeholder="e.g., Escalate if below 50% for 2 consecutive months"></textarea>
                        <span asp-validation-for="EscalationRule" class="invalid-feedback"></span>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary btn-block">
                        <i class="fas fa-save"></i> Create KPI
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
