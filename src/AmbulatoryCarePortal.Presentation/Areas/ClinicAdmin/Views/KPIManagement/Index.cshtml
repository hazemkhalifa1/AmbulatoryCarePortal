@model List<KPIDetailViewModel>

@{
    ViewData["Title"] = "KPI Monitoring";
}

<div class="row fade-in">
    <div class="col-sm-6">
        <h3><i class="fas fa-chart-line text-primary me-2"></i>KPI Monitoring</h3>
    </div>
    <div class="col-sm-6 text-end">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Create New KPI
        </a>
    </div>
</div>

<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-filter"></i> Filter KPIs</h3>
        <div class="card-tools">
            <form method="get" asp-action="Index" id="filterForm" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small">Search</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" name="searchTerm" class="form-control" placeholder="Search by KPI name..." value="@ViewBag.SearchTerm" aria-label="Search KPIs" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Frequency</label>
                    <select name="frequencyFilter" class="form-select" onchange="this.form.submit()" aria-label="Filter by frequency">
                        <option value="">All Frequencies</option>
                        <option value="Daily" selected="@(ViewBag.FrequencyFilter == "Daily")">Daily</option>
                        <option value="Weekly" selected="@(ViewBag.FrequencyFilter == "Weekly")">Weekly</option>
                        <option value="Monthly" selected="@(ViewBag.FrequencyFilter == "Monthly")">Monthly</option>
                        <option value="Quarterly" selected="@(ViewBag.FrequencyFilter == "Quarterly")">Quarterly</option>
                        <option value="Annually" selected="@(ViewBag.FrequencyFilter == "Annually")">Annually</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Department</label>
                    <select name="departmentFilter" class="form-select" onchange="this.form.submit()" aria-label="Filter by department">
                        <option value="">All Departments</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-primary w-100">
                        <i class="fas fa-undo me-1"></i>Reset
                    </a>
                </div>
            </form>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table table-hover" id="kpiTable">
                <thead>
                    <tr>
                        <th>KPI Name</th>
                        <th class="text-end">Target Value</th>
                        <th class="text-end">Latest Entry</th>
                        <th class="text-center">Achievement Rate</th>
                        <th class="text-center">Frequency</th>
                        <th class="text-center">Entries</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            var rateColor = item.AchievementRate >= 100 ? "bg-success" :
                                item.AchievementRate >= 75 ? "bg-info" :
                                item.AchievementRate >= 50 ? "bg-warning" : "bg-danger";
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.KPI.Name</div>
                                    @if (!string.IsNullOrEmpty(item.KPI.NameAr))
                                    {
                                        <small class="text-muted">@item.KPI.NameAr</small>
                                    }
                                </td>
                                <td class="text-end">@item.KPI.TargetValue.ToString("N2")</td>
                                <td class="text-end">
                                    @if (item.LatestEntry != null)
                                    {
                                        <span>@item.LatestEntry.ActualValue.ToString("N2")</span>
                                        <small class="text-muted d-block">/ @item.KPI.TargetValue.ToString("N2")</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No data</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center gap-2" style="min-width:140px;">
                                        <div class="progress flex-grow-1" style="height:8px;">
                                            <div class="progress-bar @rateColor" role="progressbar"
                                                 style="width:@Math.Min(item.AchievementRate, 100)%"
                                                 aria-valuenow="@item.AchievementRate" aria-valuemin="0" aria-valuemax="100" aria-label="Achievement rate @item.AchievementRate.ToString("N2")%">
                                            </div>
                                        </div>
                                        <small class="text-nowrap fw-semibold">@item.AchievementRate.ToString("N2")%</small>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-secondary">@item.KPI.Frequency</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge badge-info">@item.TotalEntries</span>
                                </td>
                                <td class="text-center">
                                    <div class="actions-cell">
                                        <a asp-action="EnterData" asp-route-kpiId="@item.KPI.Id"
                                           class="btn btn-sm btn-success" title="Enter Data" aria-label="Enter data for @item.KPI.Name">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <a asp-action="ViewAnalytics" asp-route-id="@item.KPI.Id"
                                           class="btn btn-sm btn-info" title="View Analytics" aria-label="View analytics for @item.KPI.Name">
                                            <i class="fas fa-chart-bar"></i>
                                        </a>
                                        <a asp-action="Compare" class="btn btn-sm btn-warning" title="Compare" aria-label="Compare KPIs">
                                            <i class="fas fa-arrows-alt-h"></i>
                                        </a>
                                        <a asp-action="Export" asp-route-kpiId="@item.KPI.Id" asp-route-format="excel"
                                           class="btn btn-sm btn-secondary" title="Export" aria-label="Export @item.KPI.Name">
                                            <i class="fas fa-download"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <i class="fas fa-inbox empty-icon"></i>
                                    <h4>No KPIs Found</h4>
                                    <p>No KPIs match your criteria. Click "Create New KPI" to get started.</p>
                                    <a asp-action="Create" class="btn btn-primary">Create New KPI</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (ViewBag.TotalPages > 1)
    {
        <div class="card-footer">
            <div class="table-footer">
                <div class="pagination-info">Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages (@ViewBag.TotalCount total KPIs)</div>
                <ul class="pagination">
                    <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage - 1)"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-frequencyFilter="@ViewBag.FrequencyFilter"
                           asp-route-departmentFilter="@ViewBag.DepartmentFilter"
                           aria-label="Previous page">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@i"
                               asp-route-searchTerm="@ViewBag.SearchTerm"
                               asp-route-frequencyFilter="@ViewBag.FrequencyFilter"
                               asp-route-departmentFilter="@ViewBag.DepartmentFilter"
                               aria-label="Page @i">
                                @i
                            </a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(ViewBag.CurrentPage + 1)"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-frequencyFilter="@ViewBag.FrequencyFilter"
                           asp-route-departmentFilter="@ViewBag.DepartmentFilter"
                           aria-label="Next page">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    }
    else
    {
        <div class="card-footer text-center text-muted small">
            @ViewBag.TotalCount KPI(s) found
        </div>
    }
</div>

@section Scripts {
    <script>
        $(function () {
            var deptFilter = '@ViewBag.DepartmentFilter';
            if (deptFilter) {
                $('select[name="departmentFilter"]').val(deptFilter);
            }
        });
    </script>
}
