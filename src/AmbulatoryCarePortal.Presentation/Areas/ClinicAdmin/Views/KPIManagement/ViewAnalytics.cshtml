@model KPIAnalyticsViewModel

@{
    ViewData["Title"] = @Localizer.T("Page.KPIAnalytics");
}

<div class="row fade-in">
    <div class="col-sm-6">
        <h3><i class="fas fa-chart-bar text-info me-2"></i>@Localizer.T("Page.KPIAnalytics")</h3>
    </div>
    <div class="col-sm-6 text-end">
        <a asp-action="EnterData" asp-route-kpiId="@Model.KPI.Id" class="btn btn-success me-1">
            <i class="fas fa-pen me-1"></i>@Localizer.T("Page.EnterKPIData")
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>@Localizer.T("HR.BackToList")
        </a>
    </div>
</div>

<div class="card card-info mb-4">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-bullseye"></i> @Model.KPI.Name
            @if (!string.IsNullOrEmpty(Model.KPI.NameAr))
            {
                <small class="text-muted ms-2">@Model.KPI.NameAr</small>
            }
        </h3>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("KPI.TargetValue")</span>
                    <span class="detail-value fs-5 fw-bold">@Model.KPI.TargetValue.ToString("N2")</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Common.Frequency")</span>
                    <span class="detail-value"><span class="badge badge-secondary fs-6">@Model.KPI.Frequency</span></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("KPI.TotalEntries")</span>
                    <span class="detail-value fs-5 fw-bold">@Model.TotalEntries</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("KPI.LastEntry")</span>
                    <span class="detail-value fw-bold">@(Model.LastEntryDate != DateTime.MinValue ? Model.LastEntryDate.ToString("MMM dd, yyyy") : Localizer.T("HR.NA"))</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4 fade-in">
    <div class="col-lg-3 col-6">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>@Model.AverageAchievement.ToString("N2")%</h3>
                <p>@Localizer.T("KPI.AverageAchievement")</p>
            </div>
            <div class="icon"><i class="fas fa-percentage"></i></div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>@Model.HighestAchievement.ToString("N2")%</h3>
                <p>@Localizer.T("KPI.HighestAchievement")</p>
            </div>
            <div class="icon"><i class="fas fa-arrow-up"></i></div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>@Model.LowestAchievement.ToString("N2")%</h3>
                <p>@Localizer.T("KPI.LowestAchievement")</p>
            </div>
            <div class="icon"><i class="fas fa-arrow-down"></i></div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box @(Model.Trend == "Increasing" ? "bg-success" : Model.Trend == "Decreasing" ? "bg-danger" : "bg-secondary")">
            <div class="inner">
                <h3>
                    @if (Model.Trend == "Increasing")
                    {
                        <i class="fas fa-arrow-up me-1"></i>
                    }
                    else if (Model.Trend == "Decreasing")
                    {
                        <i class="fas fa-arrow-down me-1"></i>
                    }
                    else
                    {
                        <i class="fas fa-minus me-1"></i>
                    }
                    @(Model.TrendPercentage >= 0 ? "+" : "")@Model.TrendPercentage.ToString("N2")%
                </h3>
                <p>@Localizer.T("KPI.Trend") (@Model.Trend)</p>
            </div>
            <div class="icon">
                @if (Model.Trend == "Increasing")
                {
                    <i class="fas fa-chart-line"></i>
                }
                else if (Model.Trend == "Decreasing")
                {
                    <i class="fas fa-chart-line fa-rotate-180"></i>
                }
                else
                {
                    <i class="fas fa-minus"></i>
                }
            </div>
        </div>
    </div>
</div>

<div class="card card-info">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-table"></i> @Localizer.T("KPI.EntryHistory")</h3>
    </div>
    <div class="card-body p-0">
        <div class="table-container">
            <table class="table table-hover" id="entryHistoryTable">
                <thead>
                    <tr>
                        <th>@Localizer.T("Common.Period")</th>
                        <th class="text-end">@Localizer.T("KPI.ActualValue")</th>
                        <th class="text-end">@Localizer.T("KPI.TargetValue")</th>
                        <th class="text-center">@Localizer.T("KPI.AchievementPercent")</th>
                        <th>@Localizer.T("Common.Description")</th>
                        <th class="text-center">@Localizer.T("Common.Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Entries.Any())
                    {
                        @foreach (var entry in Model.Entries)
                        {
                            var pct = entry.ActualValue > 0 && Model.KPI.TargetValue > 0
                                ? Math.Round((entry.ActualValue / Model.KPI.TargetValue) * 100, 2)
                                : 0m;
                            var barColor = pct >= 100 ? "bg-success" : pct >= 75 ? "bg-info" : pct >= 50 ? "bg-warning" : "bg-danger";
                            <tr>
                                <td>
                                    <span class="fw-semibold">@(new DateTime(entry.PeriodYear, entry.PeriodMonth, 1).ToString("MMM yyyy"))</span>
                                    <small class="d-block text-muted">@entry.PeriodYear-@entry.PeriodMonth.ToString("D2")</small>
                                </td>
                                <td class="text-end">@entry.ActualValue.ToString("N2")</td>
                                <td class="text-end">@Model.KPI.TargetValue.ToString("N2")</td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center gap-2" style="min-width:130px;">
                                        <div class="progress flex-grow-1">
                                            <div class="progress-bar @barColor" role="progressbar"
                                                 style="width:@Math.Min(pct, 100)%"
                                                 aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100" aria-label="@Localizer.T("KPI.AchievementPercent") @pct.ToString("N2")%">
                                            </div>
                                        </div>
                                        <small class="text-nowrap fw-semibold">@pct.ToString("N2")%</small>
                                    </div>
                                </td>
                                <td class="text-muted small text-truncate" style="max-width:200px;">@entry.Notes</td>
                                <td class="text-center">
                                    <div class="actions-cell">
                                        <a asp-action="Export" asp-route-kpiId="@Model.KPI.Id" asp-route-format="excel"
                                           class="btn btn-sm btn-secondary" title="@Localizer.T("KPI.Export")" aria-label="@Localizer.T("KPI.Export")">
                                            <i class="fas fa-download"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <i class="fas fa-database empty-icon"></i>
                                    <h4>@Localizer.T("KPI.NoEntries")</h4>
                                    <p>@Localizer.T("KPI.NoEntries")</p>
                                    <a asp-action="EnterData" asp-route-kpiId="@Model.KPI.Id" class="btn btn-success">@Localizer.T("Page.EnterKPIData")</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.TotalEntries > 12)
    {
        <div class="card-footer text-center text-muted small">
            @Localizer.T("KPI.LatestEntriesNote", Model.TotalEntries)
        </div>
    }
</div>
