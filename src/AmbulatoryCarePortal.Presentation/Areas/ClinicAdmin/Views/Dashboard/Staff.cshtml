@model AmbulatoryCarePortal.Application.Common.PagedResult<HrStaffDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? "HR Staff Management";
}

<div class="fade-in">
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-users"></i> Staff Management
                <small class="ml-2 text-muted" dir="rtl">إدارة الموظفين</small>
            </h3>
            <div class="card-tools">
                <a href="@Url.Action("Create", "HRManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-primary" aria-label="Add new staff member">
                    <i class="fas fa-plus"></i> Add Staff
                </a>
            </div>
        </div>

        <div class="card-body">
            <div class="table-container">
                <div class="table-toolbar">
                    <div class="search-box">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" class="form-control" id="tableSearch" data-table-search="staffTable" placeholder="Search staff..." aria-label="Search staff" />
                    </div>
                </div>

                <table class="table table-hover" id="staffTable" role="table" aria-label="Staff members">
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Position</th>
                            <th scope="col">Department</th>
                            <th scope="col">Documents</th>
                            <th scope="col">Status</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Data.Any())
                        {
                            @foreach (var staff in Model.Data)
                            {
                                <tr>
                                    <td>
                                        <strong>@staff.FullNameEn</strong>
                                        @if (!string.IsNullOrEmpty(staff.FullNameAr))
                                        {
                                            <br /><small dir="rtl">@staff.FullNameAr</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge badge-info">
                                            @switch (staff.StaffType)
                                            {
                                                case StaffType.Doctor:
                                                    <i class="fas fa-user-md"></i>
                                                    break;
                                                case StaffType.Nurse:
                                                    <i class="fas fa-notes-medical"></i>
                                                    break;
                                                case StaffType.Admin:
                                                    <i class="fas fa-user-tie"></i>
                                                    break;
                                                case StaffType.Pharmacist:
                                                    <i class="fas fa-pills"></i>
                                                    break;
                                                case StaffType.Lab:
                                                    <i class="fas fa-flask"></i>
                                                    break;
                                                case StaffType.XR:
                                                    <i class="fas fa-x-ray"></i>
                                                    break;
                                                case StaffType.Dentist:
                                                    <i class="fas fa-tooth"></i>
                                                    break;
                                            }
                                            @staff.StaffType
                                        </span>
                                    </td>
                                    <td>@staff.DepartmentName</td>
                                    <td>
                                        <span class="badge badge-secondary">@staff.DocumentCount</span>
                                    </td>
                                    <td>
                                        @if (staff.IsActive)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="actions-cell">
                                            <a href="@Url.Action("Details", "HRManagement", new { area = "ClinicAdmin", id = staff.Id })" class="btn btn-sm btn-info" title="View" aria-label="View staff details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", "HRManagement", new { area = "ClinicAdmin", id = staff.Id })" class="btn btn-sm btn-warning" title="Edit" aria-label="Edit staff member">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Documents", "HRManagement", new { area = "ClinicAdmin", staffId = staff.Id })" class="btn btn-sm btn-primary" title="Documents" aria-label="View staff documents">
                                                <i class="fas fa-folder-open"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fas fa-users fa-2x mb-2 d-block"></i>
                                    No staff members found.
                                    <a href="@Url.Action("Create", "HRManagement", new { area = "ClinicAdmin" })">Add staff</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="table-footer">
                    <div class="pagination-info">
                        Showing <strong>@Model.Data.Count</strong> of <strong>@Model.TotalCount</strong> staff
                        (Page @Model.PageNumber of @Model.TotalPages)
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Staff table pagination">
                            <ul class="pagination">
                                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                    <a href="?page=@(Model.PageNumber - 1)&pageSize=@Model.PageSize" class="page-link" aria-label="Previous page">
                                        <i class="fas fa-chevron-left"></i> Previous
                                    </a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                        <a href="?page=@i&pageSize=@Model.PageSize" class="page-link" aria-label="Page @i" aria-current="@(i == Model.PageNumber ? "page" : null)">@i</a>
                                    </li>
                                }

                                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                    <a href="?page=@(Model.PageNumber + 1)&pageSize=@Model.PageSize" class="page-link" aria-label="Next page">
                                        Next <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#tableSearch').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#staffTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });
    </script>
}
