@model AmbulatoryCarePortal.Application.Common.PagedResult<HrStaffDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? "HR Staff Management";
}

<div class="row">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-users"></i> Staff Management
                    <small class="ml-2 text-muted" dir="rtl">إدارة الموظفين</small>
                </h3>
                <div class="card-tools">
                    <a href="@Url.Action("Create", "HRManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus"></i> Add Staff
                    </a>
                </div>
            </div>

            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <div class="input-group">
                            <input type="text" id="tableSearch" class="form-control" placeholder="Search staff..." />
                            <div class="input-group-append">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="staffTable">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Position</th>
                                <th>Department</th>
                                <th>Documents</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Data.Any())
                            {
                                @foreach (var staff in Model.Data)
                                {
                                    <tr>
                                        <td>
                                            <strong>@staff.FullNameEn</strong>
                                            @if (!string.IsNullOrEmpty(staff.FullNameAr))
                                            {
                                                <br /><small dir="rtl">@staff.FullNameAr</small>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge badge-info">
                                                @switch (staff.StaffType)
                                                {
                                                    case StaffType.Doctor:
                                                        <i class="fas fa-user-md"></i>
                                                        break;
                                                    case StaffType.Nurse:
                                                        <i class="fas fa-notes-medical"></i>
                                                        break;
                                                    case StaffType.Admin:
                                                        <i class="fas fa-user-tie"></i>
                                                        break;
                                                    case StaffType.Pharmacist:
                                                        <i class="fas fa-pills"></i>
                                                        break;
                                                    case StaffType.Lab:
                                                        <i class="fas fa-flask"></i>
                                                        break;
                                                    case StaffType.XR:
                                                        <i class="fas fa-x-ray"></i>
                                                        break;
                                                    case StaffType.Dentist:
                                                        <i class="fas fa-tooth"></i>
                                                        break;
                                                }
                                                @staff.StaffType
                                            </span>
                                        </td>
                                        <td>@staff.DepartmentName</td>
                                        <td>
                                            <span class="badge badge-secondary">@staff.DocumentCount</span>
                                        </td>
                                        <td>
                                            @if (staff.IsActive)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "HRManagement", new { area = "ClinicAdmin", id = staff.Id })" class="btn btn-sm btn-info" title="View">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", "HRManagement", new { area = "ClinicAdmin", id = staff.Id })" class="btn btn-sm btn-warning" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Documents", "HRManagement", new { area = "ClinicAdmin", staffId = staff.Id })" class="btn btn-sm btn-primary" title="Documents">
                                                <i class="fas fa-folder-open"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        <i class="fas fa-users fa-2x mb-2 d-block"></i>
                                        No staff members found.
                                        <a href="@Url.Action("Create", "HRManagement", new { area = "ClinicAdmin" })">Add staff</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer clearfix">
                <div class="row align-items-center">
                    <div class="col-sm-6">
                        <div class="pagination-info text-muted">
                            Showing <strong>@Model.Data.Count</strong> of <strong>@Model.TotalCount</strong> staff
                            (Page @Model.PageNumber of @Model.TotalPages)
                        </div>
                    </div>
                    <div class="col-sm-6">
                        @if (Model.TotalPages > 1)
                        {
                            <ul class="pagination m-0 float-right">
                                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                    <a href="?page=@(Model.PageNumber - 1)&pageSize=@Model.PageSize" class="page-link">
                                        <i class="fas fa-chevron-left"></i> Previous
                                    </a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                        <a href="?page=@i&pageSize=@Model.PageSize" class="page-link">@i</a>
                                    </li>
                                }

                                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                    <a href="?page=@(Model.PageNumber + 1)&pageSize=@Model.PageSize" class="page-link">
                                        Next <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#tableSearch').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#staffTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });
    </script>
}
