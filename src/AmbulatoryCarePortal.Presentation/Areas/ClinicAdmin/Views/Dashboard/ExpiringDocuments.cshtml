@model List<HrDocumentDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? Localizer.T("Page.ExpiringDocuments");
}

<div class="fade-in">
    <div class="card card-warning">
        <div class="card-header">
            <h3 class="card-title">
                    <i class="fas fa-exclamation-triangle"></i> @Localizer.T("Page.ExpiringDocuments")
                <small class="ml-2 text-muted" dir="rtl">@Localizer.T("HR.ExpiringDocuments")</small>
            </h3>
            <div class="card-tools">
                <span class="badge badge-warning">@Model.Count @Localizer.T("HR.Documents")</span>
            </div>
        </div>

        <div class="card-body">
            <div class="table-container">
                <div class="table-toolbar">
                    <div class="search-box">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" class="form-control" id="tableSearch" data-table-search="expiringTable" placeholder="@Localizer.T("Doc.SearchPlaceholder")" aria-label="@Localizer.T("Doc.SearchPlaceholder")" />
                    </div>
                    <div class="btn-group" role="group" aria-label="@Localizer.T("HR.Category")">
                        <button type="button" class="btn btn-sm btn-outline-success" onclick="filterDocs('all')" aria-label="@Localizer.T("Common.All")">@Localizer.T("Common.All")</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="filterDocs('critical')" aria-label="@Localizer.T("HR.Critical")">@Localizer.T("HR.Critical")</button>
                        <button type="button" class="btn btn-sm btn-outline-warning" onclick="filterDocs('urgent')" aria-label="@Localizer.T("HR.Urgent")">@Localizer.T("HR.Urgent")</button>
                        <button type="button" class="btn btn-sm btn-outline-info" onclick="filterDocs('upcoming')" aria-label="@Localizer.T("HR.Upcoming")">@Localizer.T("HR.Upcoming")</button>
                    </div>
                </div>

                <table class="table table-hover" id="expiringTable" role="table" aria-label="@Localizer.T("Page.ExpiringDocuments")">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer.T("HR.DocumentName")</th>
                            <th scope="col">@Localizer.T("HR.DocumentType")</th>
                            <th scope="col">@Localizer.T("HR.ExpiryDate")</th>
                            <th scope="col">@Localizer.T("HR.DaysLeft")</th>
                            <th scope="col">@Localizer.T("HR.Verified")</th>
                            <th scope="col">@Localizer.T("Common.Status")</th>
                            <th scope="col">@Localizer.T("Common.Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var doc in Model.OrderBy(d => d.DaysUntilExpiry))
                            {
                                var statusClass = doc.DaysUntilExpiry <= 0 ? "critical" : doc.DaysUntilExpiry <= 7 ? "urgent" : "upcoming";
                                var statusLabel = doc.DaysUntilExpiry <= 0 ? Localizer.T("HR.Expired") : doc.DaysUntilExpiry <= 7 ? Localizer.T("HR.Critical") : doc.DaysUntilExpiry <= 14 ? Localizer.T("HR.Urgent") : Localizer.T("HR.Upcoming");

                                <tr class="doc-row" data-status="@statusClass">
                                    <td>
                                        <strong>@doc.DocumentName</strong>
                                    </td>
                                    <td>
                                        @switch (doc.DocumentType)
                                        {
                                            case HrDocumentType.ID:
                                                <span class="badge badge-secondary">@Localizer.T("HR.DocType.ID")</span>
                                                break;
                                            case HrDocumentType.CV:
                                                <span class="badge badge-info">@Localizer.T("HR.DocType.CV")</span>
                                                break;
                                            case HrDocumentType.EducationCert:
                                                <span class="badge badge-primary">@Localizer.T("HR.DocType.EducationCert")</span>
                                                break;
                                            case HrDocumentType.License:
                                                <span class="badge badge-warning">@Localizer.T("HR.DocType.License")</span>
                                                break;
                                            case HrDocumentType.Training:
                                                <span class="badge badge-success">@Localizer.T("HR.DocType.Training")</span>
                                                break;
                                            case HrDocumentType.Competency:
                                                <span class="badge badge-info">@Localizer.T("HR.DocType.Competency")</span>
                                                break;
                                            case HrDocumentType.RadiationSafety:
                                                <span class="badge badge-danger">@Localizer.T("HR.DocType.RadiationSafety")</span>
                                                break;
                                            case HrDocumentType.JobDescription:
                                                <span class="badge badge-secondary">@Localizer.T("HR.DocType.JobDescription")</span>
                                                break;
                                            case HrDocumentType.Orientation:
                                                <span class="badge badge-primary">@Localizer.T("HR.DocType.Orientation")</span>
                                                break;
                                            default:
                                                <span class="badge badge-secondary">@doc.DocumentType</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (doc.ExpiryDate.HasValue)
                                        {
                                            @doc.ExpiryDate.Value.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">@Localizer.T("HR.NA")</span>
                                        }
                                    </td>
                                    <td>
                                        <strong>@doc.DaysUntilExpiry</strong> @Localizer.T("HR.Days")
                                    </td>
                                    <td>
                                        @if (doc.IsVerified)
                                        {
                                            <span class="badge badge-success"><i class="fas fa-check"></i> @Localizer.T("HR.Verified")</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning"><i class="fas fa-times"></i> @Localizer.T("HR.Pending")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (statusClass == "critical")
                                        {
                                            <span class="badge badge-danger">@statusLabel</span>
                                        }
                                        else if (statusClass == "urgent")
                                        {
                                            <span class="badge badge-warning">@statusLabel</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-info">@statusLabel</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="actions-cell">
                                            <a href="@Url.Action("Edit", "HRManagement", new { area = "ClinicAdmin", id = doc.Id })#documents" class="btn btn-sm btn-warning" title="@Localizer.T("Common.Edit")" aria-label="@Localizer.T("Common.Edit")">
                                                <i class="fas fa-sync-alt"></i>
                                            </a>
                                            <a href="@Url.Action("Details", "HRManagement", new { area = "ClinicAdmin", id = doc.Id })" class="btn btn-sm btn-info" title="@Localizer.T("HR.View")" aria-label="@Localizer.T("HR.View")">
                                                <i class="fas fa-user"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="fas fa-check-circle fa-2x mb-2 d-block text-success"></i>
                                    @Localizer.T("Empty.NoDocuments")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="table-footer">
                    <div class="pagination-info">
                        <span class="badge badge-danger"><i class="fas fa-circle"></i> @Localizer.T("HR.CriticalDesc")</span>
                        <span class="badge badge-warning"><i class="fas fa-circle"></i> @Localizer.T("HR.UrgentDesc")</span>
                        <span class="badge badge-info"><i class="fas fa-circle"></i> @Localizer.T("HR.UpcomingDesc")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#tableSearch').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#expiringTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });

        function filterDocs(status) {
            $('.doc-row').each(function () {
                if (status === 'all') {
                    $(this).show();
                } else {
                    $(this).toggle($(this).data('status') === status);
                }
            });
        }
    </script>
}
