@model List<HrDocumentDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? Localizer.T("Page.ExpiringDocuments");
    var expiredCount = Model.Count(d => ExpiryHelper.IsExpired(d.ExpiryDate));
    var expiringSoonCount = Model.Count(d => ExpiryHelper.IsExpiringSoon(d.ExpiryDate));
}

<div class="fade-in">
    <div class="page-header mb-4">
        <div>
            <div class="page-header-title">
                <i class="fas fa-clock page-icon"></i>
                <h1>@ViewData["Title"]</h1>
            </div>
            <p class="page-header-subtitle">@Localizer.T("Clinic.ExpiringDocumentsDesc")</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-4 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-file-alt", Color = "primary", Value = Model.Count.ToString(), Label = Localizer.T("Common.Total"), Badge = Localizer.T("HR.Documents"), Link = "" }' />
        </div>
        <div class="col-lg-4 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-exclamation-triangle", Color = expiringSoonCount > 0 ? "warning" : "success", Value = expiringSoonCount.ToString(), Label = Localizer.T("Policy.ExpiringSoon"), Badge = expiringSoonCount > 0 ? Localizer.T("Common.Attention") : Localizer.T("Common.None"), Link = "" }' />
        </div>
        <div class="col-lg-4 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-clock", Color = expiredCount > 0 ? "danger" : "success", Value = expiredCount.ToString(), Label = Localizer.T("Policy.Expired"), Badge = expiredCount > 0 ? Localizer.T("Common.Overdue") : Localizer.T("Common.None"), Link = "" }' />
        </div>
    </div>

    <div class="table-container">
        <div class="table-toolbar">
            <div>
                <span class="fw-semibold"><i class="fas fa-clock me-2"></i>@Localizer.T("Page.ExpiringDocuments")</span>
                <span class="text-muted ms-2 small">@Model.Count @Localizer.T("HR.Documents")</span>
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Index", "HRManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-outline-primary"><i class="fas fa-users"></i> @Localizer.T("Nav.Staff")</a>
            </div>
        </div>

        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">@Localizer.T("HR.DocumentName")</th>
                    <th scope="col">@Localizer.T("HR.DocumentType")</th>
                    <th scope="col">@Localizer.T("Common.Expiry")</th>
                    <th scope="col">@Localizer.T("HR.Verified")</th>
                    <th scope="col">@Localizer.T("Common.Status")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var doc in Model)
                    {
                        <tr class="@(ExpiryHelper.IsExpired(doc.ExpiryDate) ? "table-danger" : ExpiryHelper.IsExpiringSoon(doc.ExpiryDate) ? "table-warning" : "")">
                            <td><strong>@doc.DocumentName</strong></td>
                            <td>@doc.DocumentType</td>
                            <td>@(doc.ExpiryDate?.ToString("dd/MM/yyyy") ?? Localizer.T("Policy.NA"))</td>
                            <td>
                                @if (doc.IsVerified) { <span class="status-pill complete">@Localizer.T("Common.Yes")</span> }
                                else { <span class="status-pill needs-review">@Localizer.T("Common.No")</span> }
                            </td>
                            <td>
                                @if (ExpiryHelper.IsExpired(doc.ExpiryDate)) { <span class="status-pill non-compliant">@Localizer.T("Policy.Expired")</span> }
                                else if (ExpiryHelper.IsExpiringSoon(doc.ExpiryDate)) { <span class="status-pill needs-review">@Localizer.T("Policy.ExpiringSoon")</span> }
                                else { <span class="status-pill complete">@Localizer.T("Common.Valid")</span> }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4">
                            <partial name="_EmptyState" model='new { Icon = "fa-clock", Title = Localizer.T("Empty.NoDocuments"), Description = Localizer.T("Empty.NoExpiringDocuments"), ActionLink = Url.Action("Index", "HRManagement", new { area = "ClinicAdmin" }), ActionText = Localizer.T("Nav.Staff") }' />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
