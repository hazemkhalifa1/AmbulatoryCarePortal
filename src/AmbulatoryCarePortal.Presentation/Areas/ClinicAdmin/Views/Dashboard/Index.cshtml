@model ClinicDetailDto

@{
    ViewData["Title"] = ViewBag.PageTitle ?? Localizer.T("Page.ClinicDashboard");
    var complianceColor = Model.ComplianceScore >= 80 ? "success" : Model.ComplianceScore >= 60 ? "warning" : "danger";
    var complianceStatus = Model.ComplianceScore >= 80 ? Localizer.T("Common.Compliant") : Model.ComplianceScore >= 60 ? Localizer.T("Common.Partial") : Localizer.T("Common.NonCompliant");
}

<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-shield-alt",
            Color = complianceColor,
            Value = Model.ComplianceScore.ToString("F1") + "%",
            Label = Localizer.T("Clinic.ComplianceScore"),
            Badge = complianceStatus,
            Link = Url.Action("Policies"),
            LinkText = Localizer.T("Common.ViewDetails")
        }' />
    </div>
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-users",
            Color = "info",
            Value = Model.UserCount.ToString(),
            Label = Localizer.T("Clinic.Staff"),
            Badge = Model.DepartmentCount + " " + Localizer.T("Clinic.Departments"),
            Link = Url.Action("Staff"),
            LinkText = Localizer.T("Common.ViewDetails")
        }' />
    </div>
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-file-alt",
            Color = "primary",
            Value = Model.PolicyDocumentCount.ToString(),
            Label = Localizer.T("Clinic.Policies"),
            Badge = Localizer.T("Clinic.TotalDocuments"),
            Link = Url.Action("Policies"),
            LinkText = Localizer.T("Common.ViewDetails")
        }' />
    </div>
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-exclamation-triangle",
            Color = Model.OpenGapCount > 0 ? "danger" : "success",
            Value = Model.OpenGapCount.ToString(),
            Label = Localizer.T("Clinic.OpenGaps"),
            Badge = Model.OpenGapCount > 0 ? Localizer.T("Common.NeedsAttention") : Localizer.T("Common.NoIssues"),
            Link = Url.Action("Policies"),
            LinkText = Localizer.T("Common.ViewDetails")
        }' />
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="form-card">
            <div class="form-card-header">
                <h3><i class="fas fa-shield-alt text-primary"></i> @Localizer.T("Clinic.ComplianceScore")</h3>
                <div class="d-flex align-items-center gap-2">
                    <span class="compliance-badge @complianceColor">
                        <span class="badge-dot"></span>
                        @complianceStatus
                    </span>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="updateComplianceScore()" aria-label="@Localizer.T("Common.Refresh")">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                </div>
            </div>
            <div class="form-card-body">
                <div class="row g-4 align-items-center">
                    <div class="col-md-5 text-center">
                        <div class="readiness-score">
                            <div class="score-ring">
                                <svg width="100" height="100" viewBox="0 0 120 120">
                                    <circle cx="60" cy="60" r="54" fill="none" stroke="var(--color-border)" stroke-width="8"/>
                                    <circle cx="60" cy="60" r="54" fill="none"
                                            stroke="var(--color-@(complianceColor))"
                                            stroke-width="8"
                                            stroke-dasharray="339.292"
                                            stroke-dashoffset="@(339.292m * (1m - Model.ComplianceScore / 100m))"
                                            stroke-linecap="round"
                                            transform="rotate(-90, 60, 60)"/>
                                </svg>
                                <div class="score-value @complianceColor">@Model.ComplianceScore.ToString("F0")%</div>
                            </div>
                            <div class="score-label">@Localizer.T("Clinic.OverallCompliance")</div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="progress-group mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="progress-text">@Localizer.T("Clinic.ComplianceScore")</span>
                                <span class="fw-bold">@Model.ComplianceScore.ToString("F1")%</span>
                            </div>
                            <div class="progress" style="height: 8px; border-radius: 4px;">
                                <div class="progress-bar bg-@complianceColor"
                                     style="width: @Model.ComplianceScore%"
                                     role="progressbar"
                                     aria-valuenow="@Model.ComplianceScore"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                </div>
                            </div>
                        </div>
                        <div class="health-info-row">
                            <span class="hi-label"><i class="fas fa-hospital"></i> @Localizer.T("Clinic.Name")</span>
                            <span class="hi-value">@Model.Name</span>
                        </div>
                        <div class="health-info-row">
                            <span class="hi-label"><i class="fas fa-map-marker-alt"></i> @Localizer.T("Clinic.City")</span>
                            <span class="hi-value">@(Model.CityEn ?? Model.CityAr)</span>
                        </div>
                        <div class="health-info-row">
                            <span class="hi-label"><i class="fas fa-id-card"></i> @Localizer.T("Clinic.LicenseNumber")</span>
                            <span class="hi-value">@Model.LicenseNumber</span>
                        </div>
                        <div class="health-info-row">
                            <span class="hi-label"><i class="fas fa-calendar-alt"></i> @Localizer.T("Clinic.LicenseExpiry")</span>
                            <span class="hi-value">
                                @if (Model.LicenseExpiry.HasValue)
                                {
                                    @Model.LicenseExpiry.Value.ToString("dd/MM/yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">@Localizer.T("HR.NA")</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 d-flex flex-column gap-3">
        <div class="form-card flex-fill">
            <div class="form-card-header">
                <h3><i class="fas fa-bolt text-warning"></i> @Localizer.T("Common.QuickActions")</h3>
            </div>
            <div class="form-card-body">
                <div class="health-actions">
                    <a href="@Url.Action("Policies")" class="health-action">
                        <div class="ha-icon" style="background: var(--color-primary-lighter); color: var(--color-primary);">
                            <i class="fas fa-file-alt"></i>
                        </div>
                        <span class="ha-label">@Localizer.T("Nav.Policies")</span>
                        <span class="ha-count">@Model.PolicyDocumentCount @Localizer.T("Clinic.Total")</span>
                    </a>
                    <a href="@Url.Action("KPIs")" class="health-action">
                        <div class="ha-icon" style="background: var(--color-accent-light); color: var(--color-accent);">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <span class="ha-label">@Localizer.T("Nav.KPIMonitoring")</span>
                    </a>
                    <a href="@Url.Action("Staff")" class="health-action">
                        <div class="ha-icon" style="background: var(--color-info-light); color: var(--color-info);">
                            <i class="fas fa-users"></i>
                        </div>
                        <span class="ha-label">@Localizer.T("Nav.Staff")</span>
                        <span class="ha-count">@Model.UserCount @Localizer.T("Clinic.Users")</span>
                    </a>
                    <a href="@Url.Action("ExpiringDocuments")" class="health-action">
                        <div class="ha-icon" style="background: var(--color-warning-light); color: var(--color-warning);">
                            <i class="fas fa-clock"></i>
                        </div>
                        <span class="ha-label">@Localizer.T("HR.ExpiringDocuments")</span>
                    </a>
                    <a href="@Url.Action("Index", "HRManagement")" class="health-action">
                        <div class="ha-icon" style="background: var(--color-success-light); color: var(--color-success);">
                            <i class="fas fa-user-md"></i>
                        </div>
                        <span class="ha-label">@Localizer.T("Nav.EmployeeManagement")</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="form-card">
            <div class="form-card-header">
                <h3><i class="fas fa-info-circle text-info"></i> @Localizer.T("Clinic.Information")</h3>
            </div>
            <div class="form-card-body p-0">
                <div class="px-3 pt-3">
                    <div class="health-info-row">
                        <span class="hi-label"><i class="fas fa-tag"></i> @Localizer.T("Common.Type")</span>
                        <span class="hi-value">@Model.ClinicType</span>
                    </div>
                    <div class="health-info-row">
                        <span class="hi-label"><i class="fas fa-check-circle"></i> @Localizer.T("Common.Status")</span>
                        <span class="hi-value">
                            @if (Model.IsActive)
                            {
                                <span class="status-pill active">@Localizer.T("Common.Active")</span>
                            }
                            else
                            {
                                <span class="status-pill inactive">@Localizer.T("Common.Inactive")</span>
                            }
                        </span>
                    </div>
                    <div class="health-info-row">
                        <span class="hi-label"><i class="fas fa-building"></i> @Localizer.T("Clinic.Departments")</span>
                        <span class="hi-value">@Model.DepartmentCount</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateComplianceScore() {
            $.post('@Url.Action("UpdateComplianceScore")', function (response) {
                if (response.success) {
                    location.reload();
                } else {
                    alert(response.message || '@Localizer.T("Alert.ErrorUpdating")');
                }
            }).fail(function () {
                alert('@Localizer.T("Alert.ErrorOccurred")');
            });
        }
    </script>
}
