@model ClinicDetailDto

@{
    ViewData["Title"] = ViewBag.PageTitle ?? Localizer.T("Page.ClinicDashboard");
    var complianceColor = Model.ComplianceScore >= 80 ? "success" : Model.ComplianceScore >= 60 ? "warning" : "danger";
    var complianceStatus = Model.ComplianceScore >= 80 ? Localizer.T("Common.Compliant") : Model.ComplianceScore >= 60 ? Localizer.T("Common.Partial") : Localizer.T("Common.NonCompliant");
    var pillVariant = complianceColor == "success" ? "complete" : complianceColor == "warning" ? "partial" : "non-compliant";
}

<div class="fade-in">
    <div class="page-header mb-4">
        <div>
            <div class="page-header-title">
                <i class="fas fa-tachometer-alt page-icon"></i>
                <h1>@ViewData["Title"]</h1>
            </div>
            <p class="page-header-subtitle">@Model.Name</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-shield-alt", Color = complianceColor, Value = Model.ComplianceScore.ToString("F1") + "%", Label = Localizer.T("Clinic.ComplianceScore"), Badge = complianceStatus, Link = Url.Action("Policies"), LinkText = Localizer.T("Common.ViewDetails") }' />
        </div>
        <div class="col-lg-3 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-users", Color = "info", Value = Model.UserCount.ToString(), Label = Localizer.T("Clinic.Staff"), Badge = Model.DepartmentCount + " " + Localizer.T("Clinic.Departments"), Link = Url.Action("Staff"), LinkText = Localizer.T("Common.ViewDetails") }' />
        </div>
        <div class="col-lg-3 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-file", Color = "primary", Value = Model.PolicyDocumentCount.ToString(), Label = Localizer.T("Nav.Documents"), Badge = Localizer.T("Clinic.TotalDocuments"), Link = Url.Action("Index", "ClinicTemplates"), LinkText = Localizer.T("Common.ViewDetails") }' />
        </div>
        <div class="col-lg-3 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-exclamation-triangle", Color = Model.OpenGapCount > 0 ? "danger" : "success", Value = Model.OpenGapCount.ToString(), Label = Localizer.T("Clinic.OpenGaps"), Badge = Model.OpenGapCount > 0 ? Localizer.T("Common.NeedsAttention") : Localizer.T("Common.NoIssues"), Link = Url.Action("Index", "ClinicTemplates"), LinkText = Localizer.T("Common.ViewDetails") }' />
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card card-primary h-100">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-shield-alt text-primary"></i> @Localizer.T("Clinic.ComplianceScore")</h3>
                    <div class="d-flex align-items-center gap-2">
                        <span class="status-pill @pillVariant">@complianceStatus</span>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="updateComplianceScore()" aria-label="@Localizer.T("Common.Refresh")">
                            <i class="fas fa-sync-alt"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-4 align-items-center">
                        <div class="col-md-5 text-center">
                            <div class="readiness-score">
                                <div class="score-ring">
                                    <svg width="100" height="100" viewBox="0 0 120 120">
                                        <circle cx="60" cy="60" r="54" fill="none" stroke="var(--gray-200)" stroke-width="8"/>
                                        <circle cx="60" cy="60" r="54" fill="none" stroke="var(--@(complianceColor))" stroke-width="8" stroke-dasharray="339.292" stroke-dashoffset="@(339.292m * (1m - Model.ComplianceScore / 100m))" stroke-linecap="round" transform="rotate(-90, 60, 60)"/>
                                    </svg>
                                    <div class="score-value @complianceColor">@Model.ComplianceScore.ToString("F0")%</div>
                                </div>
                                <div class="score-label">@Localizer.T("Clinic.OverallCompliance")</div>
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="progress-group mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="progress-text">@Localizer.T("Clinic.ComplianceScore")</span>
                                    <span class="fw-bold">@Model.ComplianceScore.ToString("F1")%</span>
                                </div>
                                <div class="progress progress-md">
                                    <div class="progress-bar bg-@complianceColor" style="width: @Model.ComplianceScore%" role="progressbar" aria-valuenow="@Model.ComplianceScore" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                            <div class="health-info-row">
                                <span class="hi-label"><i class="fas fa-hospital"></i> @Localizer.T("Clinic.Name")</span>
                                <span class="hi-value">@Model.Name</span>
                            </div>
                            <div class="health-info-row">
                                <span class="hi-label"><i class="fas fa-map-marker-alt"></i> @Localizer.T("Clinic.City")</span>
                                <span class="hi-value">@(Model.CityEn ?? Model.CityAr)</span>
                            </div>
                            <div class="health-info-row">
                                <span class="hi-label"><i class="fas fa-id-card"></i> @Localizer.T("Clinic.LicenseNumber")</span>
                                <span class="hi-value">@Model.LicenseNumber</span>
                            </div>
                            <div class="health-info-row">
                                <span class="hi-label"><i class="fas fa-calendar-alt"></i> @Localizer.T("Clinic.LicenseExpiry")</span>
                                <span class="hi-value">@if (Model.LicenseExpiry.HasValue) { @Model.LicenseExpiry.Value.ToString("dd/MM/yyyy") } else { <span class="text-muted">@Localizer.T("HR.NA")</span> }</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 d-flex flex-column gap-3">
            <div class="card card-primary flex-fill">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-bolt text-warning"></i> @Localizer.T("Common.QuickActions")</h3>
                </div>
                <div class="card-body">
                    <div class="action-grid">
                        <a href="@Url.Action("Policies")" class="action-card-btn primary">
                            <i class="fas fa-file-alt"></i>
                            <span class="action-title">@Localizer.T("Nav.Policies")</span>
                            <span class="action-desc">@Model.PolicyDocumentCount @Localizer.T("Clinic.Total")</span>
                        </a>
                        <a href="@Url.Action("KPIs")" class="action-card-btn info">
                            <i class="fas fa-chart-line"></i>
                            <span class="action-title">@Localizer.T("Nav.KPIMonitoring")</span>
                        </a>
                        <a href="@Url.Action("Staff")" class="action-card-btn info">
                            <i class="fas fa-users"></i>
                            <span class="action-title">@Localizer.T("Nav.Staff")</span>
                            <span class="action-desc">@Model.UserCount @Localizer.T("Clinic.Users")</span>
                        </a>
                        <a href="@Url.Action("ExpiringDocuments")" class="action-card-btn warning">
                            <i class="fas fa-clock"></i>
                            <span class="action-title">@Localizer.T("HR.ExpiringDocuments")</span>
                        </a>
                        <a href="@Url.Action("Index", "HRManagement")" class="action-card-btn success">
                            <i class="fas fa-user-md"></i>
                            <span class="action-title">@Localizer.T("Nav.EmployeeManagement")</span>
                        </a>
                    </div>
                </div>
            </div>

            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-info-circle text-info"></i> @Localizer.T("Clinic.Information")</h3>
                </div>
                <div class="card-body p-0">
                    <div class="px-3 pt-3">
                        <div class="health-info-row">
                            <span class="hi-label"><i class="fas fa-tag"></i> @Localizer.T("Common.Type")</span>
                            <span class="hi-value">@Model.ClinicType</span>
                        </div>
                        <div class="health-info-row">
                            <span class="hi-label"><i class="fas fa-check-circle"></i> @Localizer.T("Common.Status")</span>
                            <span class="hi-value">@if (Model.IsActive) { <span class="status-pill active">@Localizer.T("Common.Active")</span> } else { <span class="status-pill inactive">@Localizer.T("Common.Inactive")</span> }</span>
                        </div>
                        <div class="health-info-row">
                            <span class="hi-label"><i class="fas fa-building"></i> @Localizer.T("Clinic.Departments")</span>
                            <span class="hi-value">@Model.DepartmentCount</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateComplianceScore() {
            $.post('@Url.Action("UpdateComplianceScore")', function (response) {
                if (response.success) { location.reload(); }
                else { alert(response.message || '@Localizer.T("Alert.ErrorUpdating")'); }
            }).fail(function () { alert('@Localizer.T("Alert.ErrorOccurred")'); });
        }
    </script>
}