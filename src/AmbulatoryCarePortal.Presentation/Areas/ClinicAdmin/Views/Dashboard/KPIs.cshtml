@model List<KPIDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? "KPI Monitoring";
}

<div class="row">
    <div class="col-12">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-line"></i> KPI Monitoring
                    <small class="ml-2 text-muted" dir="rtl">مراقبة مؤشرات الأداء</small>
                </h3>
                <div class="card-tools">
                    <a href="@Url.Action("Create", "KPIManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-success">
                        <i class="fas fa-plus"></i> Create New KPI
                    </a>
                </div>
            </div>

            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <div class="input-group">
                            <input type="text" id="tableSearch" class="form-control" placeholder="Search KPIs..." />
                            <div class="input-group-append">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="kpisTable">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Target Value</th>
                                <th>Current Value</th>
                                <th>Achievement</th>
                                <th>Frequency</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var kpi in Model)
                                {
                                    var achievementColor = kpi.Achievement >= 80 ? "success" : kpi.Achievement >= 60 ? "warning" : "danger";
                                    <tr>
                                        <td>
                                            <strong>@kpi.Name</strong>
                                            @if (!string.IsNullOrEmpty(kpi.NameAr))
                                            {
                                                <br /><small dir="rtl">@kpi.NameAr</small>
                                            }
                                        </td>
                                        <td>@kpi.TargetValue.ToString("N2")</td>
                                        <td>@kpi.CurrentValue.ToString("N2")</td>
                                        <td>
                                            <div class="progress progress-xs mb-1">
                                                <div class="progress-bar bg-@achievementColor" style="width: @kpi.Achievement%"></div>
                                            </div>
                                            <small class="text-@achievementColor">@kpi.Achievement.ToString("F1")%</small>
                                        </td>
                                        <td>
                                            <span class="badge badge-info">
                                                @switch (kpi.Frequency)
                                                {
                                                    case KPIFrequency.Daily:
                                                        <i class="fas fa-calendar-day"></i>
                                                        break;
                                                    case KPIFrequency.Weekly:
                                                        <i class="fas fa-calendar-week"></i>
                                                        break;
                                                    case KPIFrequency.Monthly:
                                                        <i class="fas fa-calendar-alt"></i>
                                                        break;
                                                    case KPIFrequency.Quarterly:
                                                        <i class="fas fa-calendar"></i>
                                                        break;
                                                    case KPIFrequency.Annually:
                                                        <i class="fas fa-calendar-check"></i>
                                                        break;
                                                }
                                                @kpi.Frequency
                                            </span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "KPIManagement", new { area = "ClinicAdmin", id = kpi.Id })" class="btn btn-sm btn-info" title="View">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", "KPIManagement", new { area = "ClinicAdmin", id = kpi.Id })" class="btn btn-sm btn-warning" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Entries", "KPIManagement", new { area = "ClinicAdmin", kpiId = kpi.Id })" class="btn btn-sm btn-primary" title="Entries">
                                                <i class="fas fa-table"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        <i class="fas fa-chart-line fa-2x mb-2 d-block"></i>
                                        No KPIs found.
                                        <a href="@Url.Action("Create", "KPIManagement", new { area = "ClinicAdmin" })">Create your first KPI</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer">
                <div class="text-muted">
                    Showing <strong>@Model.Count</strong> KPI(s)
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#tableSearch').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#kpisTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });
    </script>
}
