@model List<KPIDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? Localizer.T("Page.KPIMonitoring");
    var totalKpis = Model.Count;
    var onTarget = Model.Count(k => k.Achievement >= 80);
    var needsImprovement = Model.Count(k => k.Achievement < 80 && k.Achievement >= 60);
    var critical = Model.Count(k => k.Achievement < 60);
}

<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-chart-line",
            Color = "primary",
            Value = totalKpis.ToString(),
            Label = Localizer.T("KPI.TotalKPIs"),
            Badge = Localizer.T("Common.Total"),
            Link = Url.Action("Create", "KPIManagement", new { area = "ClinicAdmin" }),
            LinkText = Localizer.T("KPI.CreateNew")
        }' />
    </div>
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-check-circle",
            Color = "success",
            Value = onTarget.ToString(),
            Label = Localizer.T("KPI.OnTarget"),
            Badge = onTarget > 0 ? Localizer.T("Common.Good") : Localizer.T("Common.None"),
            Link = ""
        }' />
    </div>
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-exclamation-circle",
            Color = "warning",
            Value = needsImprovement.ToString(),
            Label = Localizer.T("KPI.NeedsImprovement"),
            Badge = needsImprovement > 0 ? Localizer.T("Common.Attention") : Localizer.T("Common.None"),
            Link = ""
        }' />
    </div>
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-times-circle",
            Color = "danger",
            Value = critical.ToString(),
            Label = Localizer.T("KPI.Critical"),
            Badge = critical > 0 ? Localizer.T("Common.RequiresAction") : Localizer.T("Common.None"),
            Link = ""
        }' />
    </div>
</div>

<div class="data-table-wrapper">
    <div class="data-table-toolbar">
        <div class="toolbar-left">
            <span class="toolbar-title"><i class="fas fa-chart-line me-2"></i>@Localizer.T("Page.KPIMonitoring")</span>
            <span class="toolbar-count">@totalKpis @Localizer.T("KPI.KPIs")</span>
        </div>
        <div class="toolbar-right">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text" class="form-control" id="tableSearch" data-table-search="kpisTable" placeholder="@Localizer.T("KPI.SearchPlaceholder")" aria-label="@Localizer.T("KPI.SearchPlaceholder")" />
            </div>
            <a href="@Url.Action("Create", "KPIManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-primary">
                <i class="fas fa-plus"></i> @Localizer.T("KPI.CreateNew")
            </a>
        </div>
    </div>

    <table class="data-table" id="kpisTable" role="table" aria-label="@Localizer.T("Page.KPIMonitoring")">
        <thead>
            <tr>
                <th scope="col">@Localizer.T("Common.Name")</th>
                <th scope="col">@Localizer.T("KPI.TargetValue")</th>
                <th scope="col">@Localizer.T("KPI.CurrentValue")</th>
                <th scope="col">@Localizer.T("KPI.Achievement")</th>
                <th scope="col">@Localizer.T("Common.Frequency")</th>
                <th scope="col" class="text-end">@Localizer.T("Common.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var kpi in Model)
                {
                    var achievementColor = kpi.Achievement >= 80 ? "success" : kpi.Achievement >= 60 ? "warning" : "danger";
                    <tr>
                        <td>
                            <strong>@kpi.Name</strong>
                            @if (!string.IsNullOrEmpty(kpi.NameAr))
                            {
                                <br /><small class="text-muted" dir="rtl">@kpi.NameAr</small>
                            }
                        </td>
                        <td><span class="fw-medium">@kpi.TargetValue.ToString("N2")</span></td>
                        <td><span class="fw-medium">@kpi.CurrentValue.ToString("N2")</span></td>
                        <td style="min-width: 120px;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height: 6px; border-radius: 3px;">
                                    <div class="progress-bar bg-@achievementColor" style="width: @kpi.Achievement%" role="progressbar" aria-valuenow="@kpi.Achievement" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <small class="text-@achievementColor fw-bold">@kpi.Achievement.ToString("F1")%</small>
                            </div>
                        </td>
                        <td>
                            <span class="status-pill needs-review">
                                @switch (kpi.Frequency)
                                {
                                    case KPIFrequency.Daily:
                                        <i class="fas fa-calendar-day"></i>
                                        break;
                                    case KPIFrequency.Weekly:
                                        <i class="fas fa-calendar-week"></i>
                                        break;
                                    case KPIFrequency.Monthly:
                                        <i class="fas fa-calendar-alt"></i>
                                        break;
                                    case KPIFrequency.Quarterly:
                                        <i class="fas fa-calendar"></i>
                                        break;
                                    case KPIFrequency.Annually:
                                        <i class="fas fa-calendar-check"></i>
                                        break;
                                }
                                @kpi.Frequency
                            </span>
                        </td>
                        <td>
                            <div class="cell-actions justify-content-end">
                                <a href="@Url.Action("Details", "KPIManagement", new { area = "ClinicAdmin", id = kpi.Id })" class="btn btn-sm btn-outline-info" title="@Localizer.T("Common.View")" aria-label="@Localizer.T("Common.View")">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="@Url.Action("Edit", "KPIManagement", new { area = "ClinicAdmin", id = kpi.Id })" class="btn btn-sm btn-outline-warning" title="@Localizer.T("Common.Edit")" aria-label="@Localizer.T("Common.Edit")">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="@Url.Action("Entries", "KPIManagement", new { area = "ClinicAdmin", kpiId = kpi.Id })" class="btn btn-sm btn-outline-primary" title="@Localizer.T("KPI.Entries")" aria-label="@Localizer.T("KPI.Entries")">
                                    <i class="fas fa-table"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-4">
                        <partial name="_EmptyState" model='new {
                            Icon = "fa-chart-line",
                            Title = Localizer.T("Empty.NoKPIs"),
                            Description = Localizer.T("Empty.NoKPIsMessage"),
                            ActionLink = Url.Action("Create", "KPIManagement", new { area = "ClinicAdmin" }),
                            ActionText = Localizer.T("KPI.CreateNew")
                        }' />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.Any())
    {
        <div class="data-table-pagination">
            <div class="page-info">
                @Localizer.T("Common.Showing") <strong>@Model.Count</strong> @Localizer.T("KPI.KPIs")
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(function () {
            $('#tableSearch').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#kpisTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });
    </script>
}
