@model List<KPIDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? Localizer.T("Page.KPIMonitoring");
    var greenCount = Model.Count(k => k.Achievement >= 80);
    var yellowCount = Model.Count(k => k.Achievement >= 60 && k.Achievement < 80);
    var redCount = Model.Count(k => k.Achievement < 60);
}

<div class="fade-in">
    <div class="page-header mb-4">
        <div>
            <div class="page-header-title">
                <i class="fas fa-chart-line page-icon"></i>
                <h1>@ViewData["Title"]</h1>
            </div>
            <p class="page-header-subtitle">@Localizer.T("Clinic.KPIOverview")</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-4 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-chart-line", Color = "primary", Value = Model.Count.ToString(), Label = Localizer.T("Common.Total"), Badge = Localizer.T("Clinic.KPIs"), Link = Url.Action("Index", "KPIManagement", new { area = "ClinicAdmin" }), LinkText = Localizer.T("Common.Manage") }' />
        </div>
        <div class="col-lg-4 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-check-circle", Color = "success", Value = greenCount.ToString(), Label = Localizer.T("KPI.OnTrack"), Badge = Localizer.T("KPI.Green"), Link = "" }' />
        </div>
        <div class="col-lg-4 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-exclamation-circle", Color = redCount > 0 ? "danger" : "success", Value = redCount.ToString(), Label = Localizer.T("KPI.Critical"), Badge = redCount > 0 ? Localizer.T("KPI.Red") : Localizer.T("Common.None"), Link = "" }' />
        </div>
    </div>

    <div class="table-container">
        <div class="table-toolbar">
            <div>
                <span class="fw-semibold"><i class="fas fa-chart-line me-2"></i>@Localizer.T("Common.Total")</span>
                <span class="text-muted ms-2 small">@Model.Count @Localizer.T("Clinic.KPIs")</span>
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Index", "KPIManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-primary"><i class="fas fa-cog"></i> @Localizer.T("Common.Manage")</a>
            </div>
        </div>

        <table class="table table-hover">
            <thead>
                <tr>
                    <th scope="col">@Localizer.T("KPI.Name")</th>
                    <th scope="col">@Localizer.T("KPI.CurrentValue")</th>
                    <th scope="col">@Localizer.T("KPI.TargetValue")</th>
                    <th scope="col">@Localizer.T("KPI.Progress")</th>
                    <th scope="col">@Localizer.T("KPI.Achievement")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var kpi in Model)
                    {
                        var progress = kpi.TargetValue > 0 ? Math.Min((double)(kpi.CurrentValue) / (double)(kpi.TargetValue) * 100, 100) : 0;
                        var achColor = kpi.Achievement >= 80 ? "success" : kpi.Achievement >= 60 ? "warning" : "danger";
                        var achPill = kpi.Achievement >= 80 ? "complete" : kpi.Achievement >= 60 ? "partial" : "non-compliant";
                        <tr>
                            <td><strong>@kpi.Name</strong></td>
                            <td>@kpi.CurrentValue.ToString("N1")</td>
                            <td>@kpi.TargetValue.ToString("N1")</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress" style="width:120px;height:8px;">
                                        <div class="progress-bar bg-@achColor" style="width:@(progress)%" role="progressbar" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <span class="small">@progress.ToString("F0")%</span>
                                </div>
                            </td>
                            <td><span class="status-pill @achPill">@kpi.Achievement.ToString("F0")%</span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4">
                            <partial name="_EmptyState" model='new { Icon = "fa-chart-line", Title = Localizer.T("KPI.NoKPIsFound"), Description = Localizer.T("KPI.NoKPIsMessage"), ActionLink = Url.Action("Index", "KPIManagement", new { area = "ClinicAdmin" }), ActionText = Localizer.T("Common.Manage") }' />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
