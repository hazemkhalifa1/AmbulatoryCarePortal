@model List<KPIDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? "KPI Monitoring";
}

<div class="fade-in">
    <div class="card card-success">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-chart-line"></i> KPI Monitoring
                <small class="ml-2 text-muted" dir="rtl">مراقبة مؤشرات الأداء</small>
            </h3>
            <div class="card-tools">
                <a href="@Url.Action("Create", "KPIManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-success" aria-label="Create new KPI">
                    <i class="fas fa-plus"></i> Create New KPI
                </a>
            </div>
        </div>

        <div class="card-body">
            <div class="table-container">
                <div class="table-toolbar">
                    <div class="search-box">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" class="form-control" id="tableSearch" data-table-search="kpisTable" placeholder="Search KPIs..." aria-label="Search KPIs" />
                    </div>
                </div>

                <table class="table table-hover" id="kpisTable" role="table" aria-label="KPI metrics">
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Target Value</th>
                            <th scope="col">Current Value</th>
                            <th scope="col">Achievement</th>
                            <th scope="col">Frequency</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var kpi in Model)
                            {
                                var achievementColor = kpi.Achievement >= 80 ? "success" : kpi.Achievement >= 60 ? "warning" : "danger";
                                <tr>
                                    <td>
                                        <strong>@kpi.Name</strong>
                                        @if (!string.IsNullOrEmpty(kpi.NameAr))
                                        {
                                            <br /><small dir="rtl">@kpi.NameAr</small>
                                        }
                                    </td>
                                    <td>@kpi.TargetValue.ToString("N2")</td>
                                    <td>@kpi.CurrentValue.ToString("N2")</td>
                                    <td>
                                        <div class="progress progress-xs mb-1">
                                            <div class="progress-bar bg-@achievementColor" style="width: @kpi.Achievement%" role="progressbar" aria-valuenow="@kpi.Achievement" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <small class="text-@achievementColor">@kpi.Achievement.ToString("F1")%</small>
                                    </td>
                                    <td>
                                        <span class="badge badge-info">
                                            @switch (kpi.Frequency)
                                            {
                                                case KPIFrequency.Daily:
                                                    <i class="fas fa-calendar-day"></i>
                                                    break;
                                                case KPIFrequency.Weekly:
                                                    <i class="fas fa-calendar-week"></i>
                                                    break;
                                                case KPIFrequency.Monthly:
                                                    <i class="fas fa-calendar-alt"></i>
                                                    break;
                                                case KPIFrequency.Quarterly:
                                                    <i class="fas fa-calendar"></i>
                                                    break;
                                                case KPIFrequency.Annually:
                                                    <i class="fas fa-calendar-check"></i>
                                                    break;
                                            }
                                            @kpi.Frequency
                                        </span>
                                    </td>
                                    <td>
                                        <div class="actions-cell">
                                            <a href="@Url.Action("Details", "KPIManagement", new { area = "ClinicAdmin", id = kpi.Id })" class="btn btn-sm btn-info" title="View" aria-label="View KPI details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", "KPIManagement", new { area = "ClinicAdmin", id = kpi.Id })" class="btn btn-sm btn-warning" title="Edit" aria-label="Edit KPI">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Entries", "KPIManagement", new { area = "ClinicAdmin", kpiId = kpi.Id })" class="btn btn-sm btn-primary" title="Entries" aria-label="View KPI entries">
                                                <i class="fas fa-table"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fas fa-chart-line fa-2x mb-2 d-block"></i>
                                    No KPIs found.
                                    <a href="@Url.Action("Create", "KPIManagement", new { area = "ClinicAdmin" })">Create your first KPI</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="table-footer">
                    <div class="pagination-info">
                        Showing <strong>@Model.Count</strong> KPI(s)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#tableSearch').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#kpisTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });
    </script>
}
