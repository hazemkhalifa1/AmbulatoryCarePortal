@model AmbulatoryCarePortal.Application.Common.PagedResult<PolicyDocumentDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? "Policy Documents";
}

<div class="row">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-file-alt"></i> All Policy Documents
                    <small class="ml-2 text-muted" dir="rtl">وثائق السياسات</small>
                </h3>
                <div class="card-tools">
                    <a href="@Url.Action("Create", "PolicyManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus"></i> Add Policy
                    </a>
                </div>
            </div>

            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <div class="input-group">
                            <input type="text" id="tableSearch" class="form-control" placeholder="Search policies..." />
                            <div class="input-group-append">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="policiesTable">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Standard Code</th>
                                <th>Status</th>
                                <th>Department</th>
                                <th>Version</th>
                                <th>Expiry Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Data.Any())
                            {
                                @foreach (var doc in Model.Data)
                                {
                                    <tr>
                                        <td>
                                            <strong>@doc.Title</strong>
                                            @if (!string.IsNullOrEmpty(doc.TitleAr))
                                            {
                                                <br /><small dir="rtl">@doc.TitleAr</small>
                                            }
                                        </td>
                                        <td><code>@doc.StandardCode</code></td>
                                        <td>
                                            @switch (doc.DocumentStatus)
                                            {
                                                case DocumentStatus.Draft:
                                                    <span class="badge badge-secondary">Draft</span>
                                                    break;
                                                case DocumentStatus.NeedsReview:
                                                    <span class="badge badge-info">Needs Review</span>
                                                    break;
                                                case DocumentStatus.Pending:
                                                    <span class="badge badge-warning">Pending</span>
                                                    break;
                                                case DocumentStatus.Approved:
                                                    <span class="badge badge-success">Approved</span>
                                                    break;
                                                case DocumentStatus.Complete:
                                                    <span class="badge badge-primary">Complete</span>
                                                    break;
                                                case DocumentStatus.MissingAttachment:
                                                    <span class="badge badge-danger">Missing Attachment</span>
                                                    break;
                                                case DocumentStatus.Expired:
                                                    <span class="badge badge-dark">Expired</span>
                                                    break;
                                                default:
                                                    <span class="badge badge-secondary">@doc.DocumentStatus</span>
                                                    break;
                                            }
                                        </td>
                                        <td>@doc.DepartmentName</td>
                                        <td><span class="badge badge-info">v@(doc.VersionNumber)</span></td>
                                        <td>
                                            @if (doc.ExpiryDate.HasValue)
                                            {
                                                @doc.ExpiryDate.Value.ToString("dd/MM/yyyy")
                                                if (doc.ExpiryDate.Value <= DateTime.UtcNow)
                                                {
                                                    <br /><span class="badge badge-danger">Expired</span>
                                                }
                                                else if (doc.ExpiryDate.Value <= DateTime.UtcNow.AddDays(30))
                                                {
                                                    <br /><span class="badge badge-warning">Expiring Soon</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "PolicyManagement", new { area = "ClinicAdmin", id = doc.Id })" class="btn btn-sm btn-info" title="View">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", "PolicyManagement", new { area = "ClinicAdmin", id = doc.Id })" class="btn btn-sm btn-warning" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", "PolicyManagement", new { area = "ClinicAdmin", id = doc.Id })" class="btn btn-sm btn-danger" title="Delete"
                                               onclick="return confirm('Are you sure you want to delete this policy?')">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="fas fa-file-alt fa-2x mb-2 d-block"></i>
                                        No policy documents found.
                                        <a href="@Url.Action("Create", "PolicyManagement", new { area = "ClinicAdmin" })">Create one</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer clearfix">
                <div class="row align-items-center">
                    <div class="col-sm-6">
                        <div class="pagination-info text-muted">
                            Showing <strong>@Model.Data.Count</strong> of <strong>@Model.TotalCount</strong> policies
                            (Page @Model.PageNumber of @Model.TotalPages)
                        </div>
                    </div>
                    <div class="col-sm-6">
                        @if (Model.TotalPages > 1)
                        {
                            <ul class="pagination m-0 float-right">
                                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                    <a href="?page=@(Model.PageNumber - 1)&pageSize=@Model.PageSize" class="page-link">
                                        <i class="fas fa-chevron-left"></i> Previous
                                    </a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                        <a href="?page=@i&pageSize=@Model.PageSize" class="page-link">@i</a>
                                    </li>
                                }

                                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                    <a href="?page=@(Model.PageNumber + 1)&pageSize=@Model.PageSize" class="page-link">
                                        Next <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#tableSearch').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#policiesTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });
    </script>
}
