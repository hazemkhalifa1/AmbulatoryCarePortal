@model AmbulatoryCarePortal.Application.Common.PagedResult<PolicyDocumentDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? Localizer.T("Page.PolicyDocuments");
    var expiredCount = Model.Data.Count(d => ExpiryHelper.IsExpired(d.ExpiryDate));
    var expiringSoonCount = Model.Data.Count(d => ExpiryHelper.IsExpiringSoon(d.ExpiryDate));
    var approvedCount = Model.Data.Count(d => d.DocumentStatus == DocumentStatus.Approved || d.DocumentStatus == DocumentStatus.Complete);
}

<div class="fade-in">
    <div class="page-header mb-4">
        <div>
            <div class="page-header-title">
                <i class="fas fa-file-alt page-icon"></i>
                <h1>@ViewData["Title"]</h1>
            </div>
            <p class="page-header-subtitle">@Localizer.T("Clinic.PolicyOverview")</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-file-alt", Color = "primary", Value = Model.TotalCount.ToString(), Label = Localizer.T("Common.Total"), Badge = Localizer.T("Page.PolicyDocuments"), Link = Url.Action("Create", "PolicyManagement", new { area = "ClinicAdmin" }), LinkText = Localizer.T("Button.Create") }' />
        </div>
        <div class="col-lg-3 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-check-circle", Color = "success", Value = approvedCount.ToString(), Label = Localizer.T("Policy.Approved"), Badge = Localizer.T("Common.Compliant"), Link = "" }' />
        </div>
        <div class="col-lg-3 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-exclamation-triangle", Color = expiringSoonCount > 0 ? "warning" : "success", Value = expiringSoonCount.ToString(), Label = Localizer.T("Policy.ExpiringSoon"), Badge = expiringSoonCount > 0 ? Localizer.T("Common.Attention") : Localizer.T("Common.None"), Link = "" }' />
        </div>
        <div class="col-lg-3 col-md-6">
            <partial name="_HealthMetricCard" model='new { Icon = "fa-clock", Color = expiredCount > 0 ? "danger" : "success", Value = expiredCount.ToString(), Label = Localizer.T("Policy.Expired"), Badge = expiredCount > 0 ? Localizer.T("Common.Overdue") : Localizer.T("Common.None"), Link = "" }' />
        </div>
    </div>

    <div class="table-container">
        <div class="table-toolbar">
            <div>
                <span class="fw-semibold"><i class="fas fa-file-alt me-2"></i>@Localizer.T("Page.PolicyDocuments")</span>
                <span class="text-muted ms-2 small">@Model.TotalCount @Localizer.T("Common.Total")</span>
            </div>
            <div class="d-flex gap-2">
                <div class="search-box">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" class="form-control" id="tableSearch" data-table-search="policiesTable" placeholder="@Localizer.T("Policy.SearchPlaceholder")" aria-label="@Localizer.T("Policy.SearchPlaceholder")" />
                </div>
                <a href="@Url.Action("Create", "PolicyManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus"></i> @Localizer.T("Button.Create")
                </a>
            </div>
        </div>

        <table class="table table-hover" id="policiesTable" role="table" aria-label="@Localizer.T("Page.PolicyDocuments")">
            <thead>
                <tr>
                    <th scope="col">@Localizer.T("Common.Title")</th>
                    <th scope="col">@Localizer.T("Policy.StandardCode")</th>
                    <th scope="col">@Localizer.T("Common.Status")</th>
                    <th scope="col">@Localizer.T("HR.Department")</th>
                    <th scope="col">@Localizer.T("Common.Version")</th>
                    <th scope="col">@Localizer.T("Common.Expiry")</th>
                    <th scope="col" class="text-end">@Localizer.T("Common.Actions")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Any())
                {
                    @foreach (var doc in Model.Data)
                    {
                        <tr>
                            <td>
                                <strong>@doc.Title</strong>
                                @if (!string.IsNullOrEmpty(doc.TitleAr))
                                {
                                    <br /><small class="text-muted" dir="rtl">@doc.TitleAr</small>
                                }
                            </td>
                            <td><span class="badge bg-secondary">@doc.StandardCode</span></td>
                            <td><span class="status-pill @StatusBadgeHelper.GetDocumentStatusClass(doc.DocumentStatus)">@Localizer.T("Policy." + doc.DocumentStatus)</span></td>
                            <td>@doc.DepartmentName</td>
                            <td><span class="status-pill complete">v@(doc.VersionNumber)</span></td>
                            <td>
                                @if (doc.ExpiryDate.HasValue)
                                {
                                    <span class="@ExpiryHelper.GetExpiryStatusClass(doc.ExpiryDate)">@doc.ExpiryDate.Value.ToString("dd/MM/yyyy")</span>
                                    if (ExpiryHelper.IsExpired(doc.ExpiryDate))
                                    {
                                        <br /><span class="status-pill non-compliant mt-1 d-inline-block">@Localizer.T("Policy.Expired")</span>
                                    }
                                    else if (ExpiryHelper.IsExpiringSoon(doc.ExpiryDate))
                                    {
                                        <br /><span class="status-pill needs-review mt-1 d-inline-block">@Localizer.T("Policy.ExpiringSoon")</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">@Localizer.T("Policy.NA")</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="@Url.Action("Details", "PolicyManagement", new { area = "ClinicAdmin", id = doc.Id })" class="btn btn-sm btn-outline-info" title="@Localizer.T("Common.View")" aria-label="@Localizer.T("Common.View")"><i class="fas fa-eye"></i></a>
                                    <a href="@Url.Action("Edit", "PolicyManagement", new { area = "ClinicAdmin", id = doc.Id })" class="btn btn-sm btn-outline-warning" title="@Localizer.T("Common.Edit")" aria-label="@Localizer.T("Common.Edit")"><i class="fas fa-edit"></i></a>
                                    <form method="post" asp-area="ClinicAdmin" asp-controller="PolicyManagement" asp-action="Delete" asp-route-id="@doc.Id" style="display: inline;" onsubmit="return confirm('@Localizer.T("Alert.ConfirmDelete")')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="@Localizer.T("Common.Delete")" aria-label="@Localizer.T("Common.Delete")"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4">
                            <partial name="_EmptyState" model='new { Icon = "fa-file-alt", Title = Localizer.T("Empty.NoPolicies"), Description = Localizer.T("Empty.NoPoliciesMessage"), ActionLink = Url.Action("Create", "PolicyManagement", new { area = "ClinicAdmin" }), ActionText = Localizer.T("Button.Create") }' />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.Data.Any() && Model.TotalPages > 1)
        {
            <div class="table-footer">
                <div class="page-info">@Localizer.T("Common.Showing") <strong>@Model.Data.Count</strong> @Localizer.T("Common.Of") <strong>@Model.TotalCount</strong> (@Localizer.T("Common.Page") @Model.PageNumber @Localizer.T("Common.Of") @Model.TotalPages)</div>
                <div class="page-links">
                    <a href="?page=@(Model.PageNumber - 1)&pageSize=@Model.PageSize" class="@(Model.HasPreviousPage ? "" : "disabled")" aria-label="@Localizer.T("Common.Previous")"><i class="fas fa-chevron-left"></i></a>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.PageNumber) { <span class="active">@i</span> }
                        else { <a href="?page=@i&pageSize=@Model.PageSize" aria-label="@Localizer.T("Common.Page") @i">@i</a> }
                    }
                    <a href="?page=@(Model.PageNumber + 1)&pageSize=@Model.PageSize" class="@(Model.HasNextPage ? "" : "disabled")" aria-label="@Localizer.T("Common.Next")"><i class="fas fa-chevron-right"></i></a>
                </div>
            </div>
        }
    </div>
</div>
