@model AmbulatoryCarePortal.Application.Common.PagedResult<PolicyDocumentDto>

@{
    ViewData["Title"] = ViewBag.PageTitle ?? Localizer.T("Page.PolicyDocuments");
}

<div class="fade-in">
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">
                    <i class="fas fa-file-alt"></i> @Localizer.T("Page.PolicyDocuments")
                <small class="ml-2 text-muted" dir="rtl">@Localizer.T("Nav.Documents")</small>
            </h3>
            <div class="card-tools">
                <a href="@Url.Action("Create", "PolicyManagement", new { area = "ClinicAdmin" })" class="btn btn-sm btn-primary" aria-label="@Localizer.T("Button.Create")">
                    <i class="fas fa-plus"></i> @Localizer.T("Button.Create")
                </a>
            </div>
        </div>

        <div class="card-body">
            <div class="table-container">
                <div class="table-toolbar">
                    <div class="search-box">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" class="form-control" id="tableSearch" data-table-search="policiesTable" placeholder="@Localizer.T("Policy.SearchPlaceholder")" aria-label="@Localizer.T("Policy.SearchPlaceholder")" />
                    </div>
                </div>

                <table class="table table-hover" id="policiesTable" role="table" aria-label="@Localizer.T("Page.PolicyDocuments")">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer.T("Common.Title")</th>
                            <th scope="col">@Localizer.T("Policy.StandardCode")</th>
                            <th scope="col">@Localizer.T("Common.Status")</th>
                            <th scope="col">@Localizer.T("HR.Department")</th>
                            <th scope="col">@Localizer.T("Common.Version")</th>
                            <th scope="col">@Localizer.T("Common.Expiry")</th>
                            <th scope="col">@Localizer.T("Common.Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Data.Any())
                        {
                            @foreach (var doc in Model.Data)
                            {
                                <tr>
                                    <td>
                                        <strong>@doc.Title</strong>
                                        @if (!string.IsNullOrEmpty(doc.TitleAr))
                                        {
                                            <br /><small dir="rtl">@doc.TitleAr</small>
                                        }
                                    </td>
                                    <td><code>@doc.StandardCode</code></td>
                                    <td>
                                        @switch (doc.DocumentStatus)
                                        {
                                            case DocumentStatus.Draft:
                                                <span class="badge badge-secondary">@Localizer.T("Policy.Draft")</span>
                                                break;
                                            case DocumentStatus.NeedsReview:
                                                <span class="badge badge-info">@Localizer.T("Policy.NeedsReview")</span>
                                                break;
                                            case DocumentStatus.Pending:
                                                <span class="badge badge-warning">@Localizer.T("Policy.Pending")</span>
                                                break;
                                            case DocumentStatus.Approved:
                                                <span class="badge badge-success">@Localizer.T("Policy.Approved")</span>
                                                break;
                                            case DocumentStatus.Complete:
                                                <span class="badge badge-primary">@Localizer.T("Policy.Complete")</span>
                                                break;
                                            case DocumentStatus.MissingAttachment:
                                                <span class="badge badge-danger">@Localizer.T("Policy.MissingAttachment")</span>
                                                break;
                                            case DocumentStatus.Expired:
                                                <span class="badge badge-secondary">@Localizer.T("Policy.Expired")</span>
                                                break;
                                            default:
                                                <span class="badge badge-secondary">@doc.DocumentStatus</span>
                                                break;
                                        }
                                    </td>
                                    <td>@doc.DepartmentName</td>
                                    <td><span class="badge badge-info">v@(doc.VersionNumber)</span></td>
                                    <td>
                                        @if (doc.ExpiryDate.HasValue)
                                        {
                                            @doc.ExpiryDate.Value.ToString("dd/MM/yyyy")
                                            if (doc.ExpiryDate.Value <= DateTime.UtcNow)
                                            {
                                                <br /><span class="badge badge-danger">@Localizer.T("Policy.Expired")</span>
                                            }
                                            else if (doc.ExpiryDate.Value <= DateTime.UtcNow.AddDays(30))
                                            {
                                                <br /><span class="badge badge-warning">@Localizer.T("Policy.ExpiringSoon")</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">@Localizer.T("Policy.NA")</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="actions-cell">
                                    <a href="@Url.Action("Details", "PolicyManagement", new { area = "ClinicAdmin", id = doc.Id })" class="btn btn-sm btn-info" title="@Localizer.T("Common.View")" aria-label="@Localizer.T("Common.View")">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", "PolicyManagement", new { area = "ClinicAdmin", id = doc.Id })" class="btn btn-sm btn-warning" title="@Localizer.T("Common.Edit")" aria-label="@Localizer.T("Common.Edit")">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", "PolicyManagement", new { area = "ClinicAdmin", id = doc.Id })" class="btn btn-sm btn-danger" title="@Localizer.T("Common.Delete")" aria-label="@Localizer.T("Common.Delete")"
                                       onclick="return confirm('@Localizer.T("Alert.ConfirmDelete")')">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="fas fa-file-alt fa-2x mb-2 d-block"></i>
                                    @Localizer.T("Empty.NoPolicies")
                                    <a href="@Url.Action("Create", "PolicyManagement", new { area = "ClinicAdmin" })">@Localizer.T("Button.Create")</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="table-footer">
                    <div class="pagination-info">
                        @Localizer.T("Common.Showing") <strong>@Model.Data.Count</strong> @Localizer.T("Common.Of") <strong>@Model.TotalCount</strong> @Localizer.T("Page.PolicyDocuments")
                        (@Localizer.T("Common.Page") @Model.PageNumber @Localizer.T("Common.Of") @Model.TotalPages)
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Policies table pagination">
                            <ul class="pagination">
                                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                    <a href="?page=@(Model.PageNumber - 1)&pageSize=@Model.PageSize" class="page-link" aria-label="@Localizer.T("Common.Previous")">
                                        <i class="fas fa-chevron-left"></i> @Localizer.T("Common.Previous")
                                    </a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                        <a href="?page=@i&pageSize=@Model.PageSize" class="page-link" aria-label="@Localizer.T("Common.Page") @i" aria-current="@(i == Model.PageNumber ? "page" : null)">@i</a>
                                    </li>
                                }

                                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                    <a href="?page=@(Model.PageNumber + 1)&pageSize=@Model.PageSize" class="page-link" aria-label="@Localizer.T("Common.Next")">
                                        @Localizer.T("Common.Next") <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#tableSearch').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('#policiesTable tbody tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });
    </script>
}
