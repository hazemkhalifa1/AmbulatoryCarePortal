@model List<ClinicTemplateValueDto>
@{
    var assignment = (ClinicTemplateAssignmentDto)ViewBag.Assignment;
    ViewData["Title"] = $"{assignment.StandardCode} - {assignment.TitleEn}";
}

<div class="ds-page-header">
    <div class="ds-page-header-inner">
        <div>
            <ol class="ds-breadcrumb">
                <li><a href="/ClinicAdmin/ClinicDocumentFill">@Localizer.T("Page.DocumentFill")</a></li>
                <li class="active">@assignment.StandardCode - @assignment.TitleEn</li>
            </ol>
            <h1 class="ds-page-title"><i class="fas fa-file-pen"></i> @assignment.StandardCode - @assignment.TitleEn</h1>
            <p class="ds-page-subtitle">@Localizer.T("Clinic.AssignedTo"): @assignment.ClinicName</p>
        </div>
        <div class="ds-page-actions">
            <a asp-action="Index" class="ds-btn ds-btn-secondary">
                <i class="fas fa-arrow-left"></i> @Localizer.T("Common.Back")
            </a>
        </div>
    </div>
</div>

<div class="ds-row">
    <div class="ds-col-8">
        <div class="ds-card">
            <div class="ds-card-header">
                <h5 class="ds-card-title"><i class="fas fa-tags"></i> @Localizer.T("Template.FillVariables")</h5>
            </div>
            <div class="ds-card-body">
                @if (Model.Any())
                {
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                        @foreach (var val in Model)
                        {
                            <div class="ds-form-group">
                                <label class="ds-form-label" style="font-size:0.813rem">
                                    @val.DisplayName
                                    @if (val.IsRequired)
                                    {
                                        <span class="ds-required">*</span>
                                    }
                                    @if (val.IsImage)
                                    {
                                        <span class="ds-badge info" style="font-size:0.625rem"><i class="fas fa-image"></i> @Localizer.T("Template.Image")</span>
                                    }
                                </label>
                                @if (val.IsImage)
                                {
                                    <div>
                                        @if (!string.IsNullOrEmpty(val.ImagePath))
                                        {
                                            <img src="@val.ImagePath" alt="@val.DisplayName" style="max-width:200px;max-height:200px;border-radius:var(--ds-radius-md);border:1px solid var(--ds-border);padding:0.25rem" />
                                        }
                                        else if (!string.IsNullOrEmpty(val.Value))
                                        {
                                            <span style="font-size:0.875rem;color:var(--ds-text)">@val.Value</span>
                                        }
                                        else
                                        {
                                            <span style="font-size:0.813rem;color:var(--ds-text-muted)">@Localizer.T("HR.NA")</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div style="padding:0.5rem 0.75rem;background:var(--ds-bg);border-radius:var(--ds-radius-md);border:1px solid var(--ds-border);font-size:0.875rem;color:var(--ds-text)">
                                        @if (!string.IsNullOrEmpty(val.Value))
                                        {
                                            @val.Value
                                        }
                                        else
                                        {
                                            <span style="color:var(--ds-text-muted)">@Localizer.T("HR.NA")</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="ds-empty">
                        <div class="ds-empty-icon"><i class="fas fa-tags"></i></div>
                        <h5 class="ds-empty-title">@Localizer.T("Template.NoVariables")</h5>
                        <p class="ds-empty-desc">@Localizer.T("Template.NoVariablesHint")</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="ds-col-4">
        <div class="ds-card ds-mb-4">
            <div class="ds-card-header">
                <h5 class="ds-card-title"><i class="fas fa-info-circle"></i> @Localizer.T("Common.Information")</h5>
            </div>
            <div class="ds-card-body">
                <div class="ds-detail-list">
                    <div class="ds-detail-item">
                        <span class="ds-detail-label">@Localizer.T("Doc.StandardCode")</span>
                        <span class="ds-detail-value"><span class="ds-badge primary">@assignment.StandardCode</span></span>
                    </div>
                    <div class="ds-detail-item">
                        <span class="ds-detail-label">@Localizer.T("Clinic.Status")</span>
                        <span class="ds-detail-value"><span class="ds-badge @(assignment.AssignmentStatus == "Complete" ? "active" : "inactive")">@assignment.AssignmentStatus</span></span>
                    </div>
                    <div class="ds-detail-item">
                        <span class="ds-detail-label">@Localizer.T("Template.GeneratedDocuments")</span>
                        <span class="ds-detail-value">@assignment.GeneratedDocumentCount</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="ds-card">
            <div class="ds-card-header">
                <h5 class="ds-card-title"><i class="fas fa-file-export"></i> @Localizer.T("Template.GenerateDocument")</h5>
            </div>
            <div class="ds-card-body">
                <p style="font-size:0.813rem;color:var(--ds-text-muted);margin-bottom:0.75rem">@Localizer.T("Template.GenerateDocumentHint")</p>
                <div style="display:flex;flex-direction:column;gap:0.5rem">
                    <form method="post" asp-action="GenerateDocx" asp-route-assignmentId="@assignment.Id">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="ds-btn ds-btn-success" style="width:100%">
                            <i class="fas fa-file-word"></i> @Localizer.T("Template.GenerateDocx")
                        </button>
                    </form>
                    <form method="post" asp-action="GeneratePdf" asp-route-assignmentId="@assignment.Id">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="ds-btn ds-btn-danger" style="width:100%">
                            <i class="fas fa-file-pdf"></i> @Localizer.T("Template.GeneratePdf")
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>