@model List<ClinicTemplateAssignmentDto>
@{
    ViewData["Title"] = Localizer.T("Page.DocumentFill");
    var searchTerm = (string?)ViewBag.SearchTerm;
    var statusFilter = (string?)ViewBag.StatusFilter;
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("Page.DocumentFill"),
    Icon = "fa-file-pen",
    Subtitle = "",
    Breadcrumb = ""
}' />

<div class="data-table-wrapper">
    <div class="data-table-toolbar">
        <div class="toolbar-left">
            <span class="toolbar-title">@Localizer.T("Clinic.AssignedTemplates")</span>
            <span class="toolbar-count">@Model.Count @Localizer.T("Clinic.Templates")</span>
        </div>
        <div class="toolbar-right gap-2">
            <form method="get" asp-action="Index" id="filterForm" role="search" class="d-flex gap-2">
                <div class="search-box" style="max-width: 250px;">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" name="searchTerm" class="form-control" placeholder="@Localizer.T("Doc.SearchPlaceholder")" value="@searchTerm" />
                </div>
                <select name="statusFilter" class="form-select" style="width:auto;min-width:140px;" onchange="document.getElementById('filterForm').submit()">
                    <option value="">@Localizer.T("Doc.AllStatuses")</option>
                    <option value="Active" selected="@(statusFilter == "Active")">Active</option>
                    <option value="InProgress" selected="@(statusFilter == "InProgress")">In Progress</option>
                    <option value="Completed" selected="@(statusFilter == "Completed")">Completed</option>
                </select>
                <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search"></i></button>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-container">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>@Localizer.T("Doc.StandardCode")</th>
                        <th>@Localizer.T("Clinic.Document")</th>
                        <th class="text-center">@Localizer.T("Clinic.Status")</th>
                        <th class="text-center">@Localizer.T("Template.Values")</th>
                        <th class="text-center">@Localizer.T("Template.GeneratedDocuments")</th>
                        <th>@Localizer.T("Common.CreatedAt")</th>
                        <th class="text-center">@Localizer.T("Common.Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td><span class="badge badge-info">@a.StandardCode</span></td>
                            <td class="fw-semibold">@a.TitleEn</td>
                            <td class="text-center">
                                <span class="status-pill @(a.AssignmentStatus == "Active" ? "complete" : a.AssignmentStatus == "Completed" ? "complete" : "inactive")">
                                    @a.AssignmentStatus
                                </span>
                            </td>
                            <td class="text-center">@a.ValueCount</td>
                            <td class="text-center">@a.GeneratedDocumentCount</td>
                            <td>@a.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                <a asp-action="Fill" asp-route-id="@a.Id" class="btn btn-sm btn-primary">
                                    <i class="fas fa-pen me-1"></i>@Localizer.T("Common.Edit")
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <partial name="_EmptyState" model='new {
            Icon = "fa-file-pen",
            Title = Localizer.T("Template.NoAssignments"),
            Message = Localizer.T("Template.NoAssignmentsHint"),
            ButtonText = "",
            ButtonUrl = ""
        }' />
    }
</div>
