@model PolicyDocumentDetailViewModel

@{
    ViewData["Title"] = Model.Policy.Title;
    var statusBadge = Model.Status switch
    {
        "Draft" => "needs-review",
        "Pending" => "needs-review",
        "Approved" => "active",
        "Rejected" => "inactive",
        _ => "needs-review"
    };
}

<partial name="_PageHeader" model='new {
    Title = Model.Policy.Title,
    Icon = "fa-file-pdf",
    Breadcrumb = Localizer.T("Page.PolicyDocuments")
}' />

<div class="row g-4">
    <div class="col-lg-8">
        <div class="form-card">
            <div class="form-card-header">
                <h3><i class="fas fa-info-circle me-2"></i>@Localizer.T("Policy.Information")</h3>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Policy.Id" class="btn btn-sm btn-outline-warning">
                        <i class="fas fa-edit"></i> @Localizer.T("Common.Edit")
                    </a>
                </div>
            </div>
            <div class="form-card-body">
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Common.Title")</span>
                    <span class="detail-value">@Model.Policy.Title</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Policy.TitleAr))
                {
                    <div class="detail-row">
                        <span class="detail-label">@Localizer.T("Common.ArabicTitle")</span>
                        <span class="detail-value" dir="rtl">@Model.Policy.TitleAr</span>
                    </div>
                }
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Policy.StandardCode")</span>
                    <span class="detail-value">
                        @if (!string.IsNullOrEmpty(Model.Policy.StandardCode))
                        {
                            <span class="badge bg-secondary">@Model.Policy.StandardCode</span>
                        }
                        else
                        {
                            <span class="text-muted">&mdash;</span>
                        }
                    </span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("HR.Department")</span>
                    <span class="detail-value">@Model.Policy.DepartmentName</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Common.Status")</span>
                    <span class="detail-value">
                        <span class="status-pill @statusBadge fs-6">@Model.Status</span>
                    </span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Common.Version")</span>
                    <span class="detail-value"><span class="compliance-badge compliant">v@(Model.Policy.VersionNumber)</span></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Doc.Attachments")</span>
                    <span class="detail-value"><span class="fw-bold">@Model.Policy.AttachmentCount</span></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Common.Expiry")</span>
                    <span class="detail-value">
                        @if (Model.Policy.ExpiryDate.HasValue)
                        {
                            var isExpiring = Model.Policy.ExpiryDate.Value <= DateTime.UtcNow.AddMonths(1);
                            <span class="@(isExpiring ? "text-danger fw-bold" : "")">
                                @Model.Policy.ExpiryDate.Value.ToString("yyyy-MM-dd")
                                @if (isExpiring)
                                {
                                    <i class="fas fa-exclamation-triangle ms-1"></i>
                                }
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">&mdash;</span>
                        }
                    </span>
                </div>
                @if (Model.Evidence.Any(e => !string.IsNullOrEmpty(e.DocumentName)))
                {
                    <div class="detail-row">
                        <span class="detail-label">@Localizer.T("Doc.EvidenceFiles")</span>
                        <span class="detail-value"><span class="fw-bold">@Model.EvidenceCount @Localizer.T("Common.Files")</span></span>
                    </div>
                }
            </div>
        </div>

        <div class="form-card mt-4">
            <div class="form-card-header">
                <h3><i class="fas fa-paperclip me-2"></i>@Localizer.T("Doc.EvidenceAttachments")</h3>
                <div><span class="badge bg-secondary">@Model.EvidenceCount @Localizer.T("Doc.Attachments")</span></div>
            </div>
            <div class="form-card-body">
                @if (Model.Evidence.Any())
                {
                    <table class="data-table" id="evidenceTable" role="table" aria-label="@Localizer.T("Doc.EvidenceAttachments")">
                        <thead>
                            <tr>
                                <th scope="col">@Localizer.T("HR.DocumentName")</th>
                                <th scope="col">@Localizer.T("Common.FileType")</th>
                                <th scope="col">@Localizer.T("Common.UploadDate")</th>
                                <th scope="col">@Localizer.T("Common.Notes")</th>
                                <th scope="col" class="text-end">@Localizer.T("Common.Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ev in Model.Evidence)
                            {
                                <tr>
                                    <td>@ev.DocumentName</td>
                                    <td><span class="badge bg-secondary">@ev.FileType</span></td>
                                    <td>@ev.UploadDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(ev.Notes))
                                        {
                                            @ev.Notes
                                        }
                                        else
                                        {
                                            <span class="text-muted">&mdash;</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <span class="status-pill active"><i class="fas fa-check"></i> @Localizer.T("Common.Uploaded")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <partial name="_EmptyState" model='new {
                        Icon = "fa-paperclip",
                        Title = Localizer.T("Empty.NoDocuments"),
                        Description = Localizer.T("Doc.NoEvidenceMessage"),
                        ActionLink = "",
                        ActionText = ""
                    }' />
                }

                <hr class="my-4" />
                <h5 class="mb-3"><i class="fas fa-upload me-2"></i>@Localizer.T("Doc.UploadEvidence")</h5>
                <form method="post" asp-action="UploadEvidence" enctype="multipart/form-data" role="form" aria-label="@Localizer.T("Doc.UploadEvidence")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="policyId" value="@Model.Policy.Id" />
                    <div class="row g-3">
                        <div class="col-md-5">
                            <input type="file" name="evidenceFile" class="form-control" required aria-required="true" aria-label="@Localizer.T("Common.File")" />
                        </div>
                        <div class="col-md-4">
                            <input type="text" name="notes" class="form-control" placeholder="@Localizer.T("Common.OptionalNotes")" aria-label="@Localizer.T("Common.OptionalNotes")" />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100" aria-label="@Localizer.T("Common.Upload")">
                                <i class="fas fa-upload me-1"></i> @Localizer.T("Common.Upload")
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="form-card">
            <div class="form-card-header">
                <h3><i class="fas fa-check-circle me-2"></i>@Localizer.T("Common.Approval")</h3>
            </div>
            <div class="form-card-body text-center">
                @if (Model.Status == "Approved")
                {
                    <div class="py-3">
                        <i class="fas fa-check-circle text-success fa-4x mb-3"></i>
                        <h5 class="text-success">@Localizer.T("Common.Approved")</h5>
                        <p class="text-muted">@Localizer.T("Policy.PolicyApproved")</p>
                    </div>
                }
                else if (Model.Status == "Expired")
                {
                    <div class="py-3">
                        <i class="fas fa-calendar-times text-danger fa-4x mb-3"></i>
                        <h5 class="text-danger">@Localizer.T("Common.Expired")</h5>
                        <p class="text-muted">@Localizer.T("Policy.PolicyExpired")</p>
                    </div>
                }
                else
                {
                    <div class="py-3">
                        <i class="fas fa-hourglass-half text-warning fa-4x mb-3"></i>
                        <h5 class="text-warning">@Model.Status</h5>
                        <p class="text-muted">@Localizer.T("Policy.PolicyPending")</p>
                        @if (User.IsInRole("ClinicAdmin"))
                        {
                            <form method="post" asp-action="Approve" aria-label="@Localizer.T("Common.Approve")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Policy.Id" />
                                <button type="submit" class="btn btn-success w-100 mt-2"
                                        onclick="return confirm('@Localizer.T("Alert.ConfirmApprove")')" aria-label="@Localizer.T("Common.Approve")">
                                    <i class="fas fa-thumbs-up me-1"></i> @Localizer.T("Common.Approve")
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="form-card mt-4">
            <div class="form-card-header">
                <h3><i class="fas fa-cog me-2"></i>@Localizer.T("Common.Actions")</h3>
            </div>
            <div class="form-card-body">
                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Policy.Id" class="btn btn-outline-warning">
                        <i class="fas fa-edit me-1"></i> @Localizer.T("Common.Edit")
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i> @Localizer.T("Common.BackToList")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var autoHideAlerts = document.querySelectorAll('.alert-dismissible');
            autoHideAlerts.forEach(function (alert) {
                setTimeout(function () {
                    var bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, 5000);
            });
        });
    </script>
}
