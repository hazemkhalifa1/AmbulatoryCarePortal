@model List<PolicyDocumentDto>

@{
    ViewData["Title"] = Localizer.T("Page.PolicyDocuments");
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalCount = (int)ViewBag.TotalCount;
    var searchTerm = (string)ViewBag.SearchTerm;
    var statusFilter = (string)ViewBag.StatusFilter;
    var departmentFilter = (int?)ViewBag.DepartmentFilter;
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("Page.PolicyDocuments"),
    Icon = "fa-file-pdf",
    Breadcrumb = Localizer.T("Nav.Documents")
}' />

<div class="data-table-wrapper">
    <div class="data-table-toolbar">
        <div class="toolbar-left">
            <span class="toolbar-title">@Localizer.T("Page.PolicyDocuments")</span>
            <span class="toolbar-count">@totalCount @Localizer.T("Nav.Documents")</span>
        </div>
        <div class="toolbar-right">
            <a asp-action="Create" class="btn btn-sm btn-primary">
                <i class="fas fa-plus"></i> @Localizer.T("Button.Create")
            </a>
        </div>
    </div>

    <form method="get" asp-action="Index" id="filterForm" role="search" aria-label="@Localizer.T("Policy.FilterPolicies")">
        <div class="data-table-toolbar" style="border-top: 1px solid var(--border-color); padding-top: 1rem;">
            <div class="toolbar-left gap-2 w-100">
                <div class="search-box flex-grow-1" style="max-width: 300px;">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" name="searchTerm" class="form-control" placeholder="@Localizer.T("Policy.SearchPlaceholder")" value="@searchTerm" aria-label="@Localizer.T("Policy.SearchPlaceholder")" />
                </div>
                <select name="statusFilter" class="form-select" style="width: auto; min-width: 140px;" onchange="document.getElementById('filterForm').submit()" aria-label="@Localizer.T("Common.Filter")">
                    <option value="">@Localizer.T("Common.All")</option>
                    <option value="Draft" selected="@(statusFilter == "Draft")">@Localizer.T("Policy.Draft")</option>
                    <option value="Pending" selected="@(statusFilter == "Pending")">@Localizer.T("Policy.Pending")</option>
                    <option value="Approved" selected="@(statusFilter == "Approved")">@Localizer.T("Policy.Approved")</option>
                    <option value="Expired" selected="@(statusFilter == "Expired")">@Localizer.T("Policy.Expired")</option>
                </select>
                <button type="submit" class="btn btn-sm btn-primary" aria-label="@Localizer.T("Common.Search")">
                    <i class="fas fa-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || departmentFilter.HasValue)
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" aria-label="@Localizer.T("Common.Clear")">
                        <i class="fas fa-times"></i> @Localizer.T("Common.Clear")
                    </a>
                }
            </div>
        </div>
    </form>

    <table class="data-table" id="policiesTable" role="table" aria-label="@Localizer.T("Page.PolicyDocuments")">
        <thead>
            <tr>
                <th scope="col">@Localizer.T("Common.Title")</th>
                <th scope="col">@Localizer.T("Policy.StandardCode")</th>
                <th scope="col">@Localizer.T("Common.Status")</th>
                <th scope="col">@Localizer.T("HR.Department")</th>
                <th scope="col">@Localizer.T("Common.Version")</th>
                <th scope="col">@Localizer.T("Common.Expiry")</th>
                <th scope="col" class="text-center">@Localizer.T("Doc.Attachments")</th>
                <th scope="col" class="text-end">@Localizer.T("Common.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var policy in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@policy.Id" class="fw-bold text-decoration-none">
                                @policy.Title
                            </a>
                            @if (!string.IsNullOrEmpty(policy.TitleAr))
                            {
                                <br /><small class="text-muted" dir="rtl">@policy.TitleAr</small>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(policy.StandardCode))
                            {
                                <span class="badge bg-secondary">@policy.StandardCode</span>
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                        <td>
                            <span class="status-pill @StatusBadgeHelper.GetDocumentStatusClass(policy.DocumentStatus)">@policy.DocumentStatus</span>
                        </td>
                        <td>@policy.DepartmentName</td>
                        <td><span class="compliance-badge compliant">v@(policy.VersionNumber)</span></td>
                        <td>
                            @if (policy.ExpiryDate.HasValue)
                            {
                                <span class="@ExpiryHelper.GetExpiryStatusClass(policy.ExpiryDate)">
                                    @policy.ExpiryDate.Value.ToString("yyyy-MM-dd")
                                </span>
                                if (ExpiryHelper.IsExpiringSoon(policy.ExpiryDate, 30))
                                {
                                    <br /><span class="@ExpiryHelper.GetExpiryLabelClass(policy.ExpiryDate) mt-1 d-inline-block">@Localizer.T("Policy.ExpiringSoon")</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                        <td class="text-center"><span class="fw-bold">@policy.AttachmentCount</span></td>
                        <td>
                            <div class="cell-actions justify-content-end">
                                <a asp-action="Details" asp-route-id="@policy.Id" class="btn btn-sm btn-outline-info" title="@Localizer.T("Common.Details")" aria-label="@Localizer.T("Common.View")">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@policy.Id" class="btn btn-sm btn-outline-warning" title="@Localizer.T("Common.Edit")" aria-label="@Localizer.T("Common.Edit")">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" title="@Localizer.T("Common.Delete")" aria-label="@Localizer.T("Common.Delete")"
                                        data-bs-toggle="modal" data-bs-target="#deleteModal"
                                        data-policy-id="@policy.Id" data-policy-title="@policy.Title">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-4">
                        <partial name="_EmptyState" model='new {
                            Icon = "fa-file-pdf",
                            Title = Localizer.T("Empty.NoPolicies"),
                            Description = !string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || departmentFilter.HasValue
                                ? Localizer.T("Empty.FilterAdjust")
                                : "",
                            ActionLink = !string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || departmentFilter.HasValue ? "" : Url.Action("Create"),
                            ActionText = !string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || departmentFilter.HasValue ? "" : Localizer.T("Button.Create")
                        }' />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPages > 1)
    {
        <div class="data-table-pagination">
            <div class="page-info">@Localizer.T("Policy.PageInfo", currentPage, totalPages, totalCount)</div>
            <div class="page-links">
                <a asp-action="Index" asp-route-page="1" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter" class="@(currentPage == 1 ? "disabled" : "")" aria-label="@Localizer.T("Policy.FirstPage")">
                    <i class="fas fa-angle-double-left"></i>
                </a>
                <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter" class="@(currentPage == 1 ? "disabled" : "")" aria-label="@Localizer.T("Common.Previous")">
                    <i class="fas fa-angle-left"></i>
                </a>
                @for (var i = 1; i <= totalPages; i++)
                {
                    if (i == currentPage)
                    {
                        <span class="active">@i</span>
                    }
                    else
                    {
                        <a asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter" aria-label="@Localizer.T("Common.Page") @i">@i</a>
                    }
                }
                <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter" class="@(currentPage == totalPages ? "disabled" : "")" aria-label="@Localizer.T("Common.Next")">
                    <i class="fas fa-angle-right"></i>
                </a>
                <a asp-action="Index" asp-route-page="@totalPages" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter" class="@(currentPage == totalPages ? "disabled" : "")" aria-label="@Localizer.T("Policy.LastPage")">
                    <i class="fas fa-angle-double-right"></i>
                </a>
            </div>
        </div>
    }
</div>

<partial name="_DeleteConfirmation" model='new {
    ModalId = "deleteModal",
    Title = Localizer.T("Policy.ConfirmDelete"),
    Message = Localizer.T("Policy.DeleteConfirmMessage"),
    Warning = Localizer.T("Policy.DeleteWarning"),
    FormAction = "Delete",
    HiddenInputId = "deletePolicyId",
    DisplayTextId = "deletePolicyTitle"
}' />

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteModal = document.getElementById('deleteModal');
            if (deleteModal) {
                deleteModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    var policyId = button.getAttribute('data-policy-id');
                    var policyTitle = button.getAttribute('data-policy-title');
                    document.getElementById('deletePolicyId').value = policyId;
                    document.getElementById('deletePolicyTitle').textContent = policyTitle;
                });
            }
        });
    </script>
}
