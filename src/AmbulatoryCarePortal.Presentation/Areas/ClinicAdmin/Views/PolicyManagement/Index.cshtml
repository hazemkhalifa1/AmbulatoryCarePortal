@model List<PolicyDocumentDto>

@{
    ViewData["Title"] = "Policy Management";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalCount = (int)ViewBag.TotalCount;
    var searchTerm = (string)ViewBag.SearchTerm;
    var statusFilter = (string)ViewBag.StatusFilter;
    var departmentFilter = (int?)ViewBag.DepartmentFilter;
}

<div class="row mb-3">
    <div class="col-12">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-file-pdf me-2"></i>Policy Documents</h3>
                <div class="card-tools">
                    <a asp-action="Create" class="btn btn-success btn-sm">
                        <i class="fas fa-plus"></i> Create New Policy
                    </a>
                </div>
            </div>
            <div class="card-body">
                <form method="get" asp-action="Index" id="filterForm">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <div class="input-group">
                                <input type="text" name="searchTerm" class="form-control" placeholder="Search by title..." value="@searchTerm" />
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-search"></i>
                                </button>
                                @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || departmentFilter.HasValue)
                                {
                                    <a asp-action="Index" class="btn btn-secondary">
                                        <i class="fas fa-times"></i> Clear
                                    </a>
                                }
                            </div>
                        </div>
                        <div class="col-md-3">
                            <select name="statusFilter" class="form-select" onchange="document.getElementById('filterForm').submit()">
                                <option value="">All Statuses</option>
                                <option value="Draft" selected="@(statusFilter == "Draft")">Draft</option>
                                <option value="Pending" selected="@(statusFilter == "Pending")">Pending</option>
                                <option value="Approved" selected="@(statusFilter == "Approved")">Approved</option>
                                <option value="Expired" selected="@(statusFilter == "Expired")">Expired</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <input type="hidden" name="departmentFilter" id="departmentFilter" value="@departmentFilter" />
                        </div>
                        <div class="col-md-2 text-end">
                            <small class="text-muted">@totalCount policy document(s)</small>
                        </div>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Standard Code</th>
                                <th>Status</th>
                                <th>Department</th>
                                <th>Version</th>
                                <th>Expiry Date</th>
                                <th>Attachments</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var policy in Model)
                                {
                                    <tr>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@policy.Id" class="fw-bold text-decoration-none">
                                                @policy.Title
                                            </a>
                                            @if (!string.IsNullOrEmpty(policy.TitleAr))
                                            {
                                                <br /><small class="text-muted" dir="rtl">@policy.TitleAr</small>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(policy.StandardCode))
                                            {
                                                <span class="badge bg-info">@policy.StandardCode</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @{
                                                var statusBadge = policy.DocumentStatus switch
                                                {
                                                    DocumentStatus.Draft => "secondary",
                                                    DocumentStatus.Pending => "warning",
                                                    DocumentStatus.Approved => "success",
                                                    _ => "secondary"
                                                };
                                            }
                                            <span class="badge bg-@statusBadge">@policy.DocumentStatus</span>
                                        </td>
                                        <td>@policy.DepartmentName</td>
                                        <td><span class="badge bg-primary">v@(policy.VersionNumber)</span></td>
                                        <td>
                                            @if (policy.ExpiryDate.HasValue)
                                            {
                                                <span class="@(policy.ExpiryDate.Value <= DateTime.UtcNow.AddMonths(1) ? "text-danger fw-bold" : "")">
                                                    @policy.ExpiryDate.Value.ToString("yyyy-MM-dd")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-info">@policy.AttachmentCount</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <a asp-action="Details" asp-route-id="@policy.Id" class="btn btn-info" title="Details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@policy.Id" class="btn btn-warning" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <button type="button" class="btn btn-danger" title="Delete"
                                                        data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                        data-policy-id="@policy.Id" data-policy-title="@policy.Title">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-4">
                                        <i class="fas fa-file-pdf fa-3x mb-2"></i><br />
                                        No policy documents found.
                                        @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || departmentFilter.HasValue)
                                        {
                                            <span>Try adjusting your filters.</span>
                                        }
                                        else
                                        {
                                            <a asp-action="Create">Create the first policy</a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (totalPages > 1)
                {
                    <nav>
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter">
                                    <i class="fas fa-angle-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter">
                                    <i class="fas fa-angle-left"></i>
                                </a>
                            </li>

                            @for (var i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter">@i</a>
                                </li>
                            }

                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter">
                                    <i class="fas fa-angle-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@totalPages" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" asp-route-departmentFilter="@departmentFilter">
                                    <i class="fas fa-angle-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="Delete" id="deleteForm">
                <input type="hidden" name="id" id="deletePolicyId" value="" />
                <div class="modal-body">
                    <p>Are you sure you want to delete the policy document:</p>
                    <p class="fw-bold text-danger" id="deletePolicyTitle"></p>
                    <p class="text-muted small">This action cannot be undone. The policy will be soft-deleted.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteModal = document.getElementById('deleteModal');
            if (deleteModal) {
                deleteModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    var policyId = button.getAttribute('data-policy-id');
                    var policyTitle = button.getAttribute('data-policy-title');
                    document.getElementById('deletePolicyId').value = policyId;
                    document.getElementById('deletePolicyTitle').textContent = policyTitle;
                });
            }
        });
    </script>
}
