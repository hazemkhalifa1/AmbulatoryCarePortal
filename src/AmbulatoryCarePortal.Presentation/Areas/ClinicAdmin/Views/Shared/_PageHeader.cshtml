@model dynamic
@{
    string SafeString(object value) => value?.ToString() ?? "";
    bool HasProp(object obj, string name) => obj.GetType().GetProperty(name) != null;
    var subtitle = HasProp(Model, "Subtitle") ? SafeString(Model.Subtitle) : "";
    var hasActions = HasProp(Model, "Actions") && Model.Actions != null;
    var icon = HasProp(Model, "Icon") ? SafeString(Model.Icon) : "fa-tachometer-alt";
}
<div class="page-header mb-4">
    <div>
        <div class="page-header-title">
            <i class="fas @icon page-icon"></i>
            <h1>@Model.Title</h1>
        </div>
        @if (!string.IsNullOrEmpty(subtitle))
        {
            <p class="page-header-subtitle">@subtitle</p>
        }
    </div>
    @if (hasActions)
    {
        <div class="page-header-actions">
            @foreach (var action in Model.Actions)
            {
                <a href="@action.Link" class="btn @(!string.IsNullOrEmpty(SafeString(action.Class)) ? SafeString(action.Class) : "btn-primary")">
                    @if (HasProp(action, "Icon") && !string.IsNullOrEmpty(SafeString(action.Icon)))
                    {
                        <i class="fas @action.Icon me-1"></i>
                    }
                    @action.Text
                </a>
            }
        </div>
    }
</div>
