@model List<ClinicTemplateAssignmentDto>

@{
    ViewData["Title"] = @Localizer.T("Page.ClinicTemplates");
    var searchTerm = (string?)ViewBag.SearchTerm;
    var statusFilter = (string?)ViewBag.StatusFilter;
    var standardFilter = (string?)ViewBag.StandardFilter;
    var standards = (string[]?)ViewBag.Standards;
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("Page.ClinicTemplates"),
    Icon = "fa-file",
    Subtitle = "",
    Breadcrumb = ""
}' />

@if (standards != null && standards.Length > 0)
{
    <div class="card mb-3">
        <div class="card-body py-2">
            <ul class="nav nav-pills" id="standardsTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <a class="nav-link @(string.IsNullOrEmpty(standardFilter) ? "active" : "")" asp-action="Index" asp-route-standardFilter="" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" role="tab">@Localizer.T("Common.All")</a>
                </li>
                @foreach (var std in standards)
                {
                    <li class="nav-item" role="presentation">
                        <a class="nav-link @(standardFilter == std ? "active" : "")" asp-action="Index" asp-route-standardFilter="@std" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" role="tab">@std</a>
                    </li>
                }
            </ul>
        </div>
    </div>
}

<div class="table-container">
    <div class="table-toolbar">
        <div >
            <span class="fw-semibold">@Localizer.T("Page.ClinicTemplatesList")</span>
            <span class="text-muted ms-2 small">@Model.Count @Localizer.T("Doc.AttachmentCount")</span>
        </div>
        <div class="toolbar-right gap-2">
            <form method="get" asp-action="Index" id="filterForm" role="search" aria-label="@Localizer.T("Doc.FilterDocuments")" class="d-flex gap-2">
                <input type="hidden" name="standardFilter" value="@standardFilter" />
                <div class="search-box" style="max-width: 250px;">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" name="searchTerm" class="form-control" placeholder="@Localizer.T("Doc.SearchPlaceholder")" value="@searchTerm" aria-label="@Localizer.T("Doc.SearchDocuments")" />
                </div>
                <select name="statusFilter" class="form-select" style="width: auto; min-width: 140px;" onchange="document.getElementById('filterForm').submit()" aria-label="@Localizer.T("Doc.FilterByStatus")">
                    <option value="">@Localizer.T("Doc.AllStatuses")</option>
                    <option value="Complete" selected="@(statusFilter == "Complete")">@Localizer.T("Doc.Complete")</option>
                    <option value="NeedsReview" selected="@(statusFilter == "NeedsReview")">@Localizer.T("Doc.NeedsReview")</option>
                    <option value="MissingAttachment" selected="@(statusFilter == "MissingAttachment")">@Localizer.T("Doc.MissingAttachment")</option>
                    <option value="Expired" selected="@(statusFilter == "Expired")">@Localizer.T("Doc.Expired")</option>
                    <option value="Draft" selected="@(statusFilter == "Draft")">@Localizer.T("Doc.Draft")</option>
                </select>
                <button type="submit" class="btn btn-sm btn-primary" aria-label="@Localizer.T("Common.Search")">
                    <i class="fas fa-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(standardFilter))
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" aria-label="@Localizer.T("Doc.ClearFilters")">
                        <i class="fas fa-times"></i> @Localizer.T("Common.Clear")
                    </a>
                }
            </form>
        </div>
    </div>

    <table class="table table-hover" role="table" aria-label="@Localizer.T("Page.ClinicTemplates")">
        <thead>
            <tr>
                <th scope="col">@Localizer.T("Doc.StandardCode")</th>
                <th scope="col">@Localizer.T("Doc.DocumentHeading")</th>
                <th scope="col">@Localizer.T("Common.Status")</th>
                <th scope="col" class="text-center">@Localizer.T("Template.Values")</th>
                <th scope="col" class="text-center">@Localizer.T("Template.GeneratedDocuments")</th>
                <th scope="col">@Localizer.T("Doc.ExpiryDate")</th>
                <th scope="col" class="text-end">@Localizer.T("Common.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var doc in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@doc.StandardCode</span></td>
                        <td>
                            <span class="fw-bold">@doc.TitleEn</span>
                            @if (!string.IsNullOrEmpty(doc.TitleAr))
                            {
                                <br /><small class="text-muted" dir="rtl">@doc.TitleAr</small>
                            }
                        </td>
                        <td>
                            <span class="status-pill @StatusBadgeHelper.GetClinicDocumentStatusClass(doc.AssignmentStatus)">@doc.AssignmentStatus</span>
                        </td>
                        <td class="text-center">@doc.ValueCount</td>
                        <td class="text-center">@doc.GeneratedDocumentCount</td>
                        <td>
                            @if (doc.ExpiryDate.HasValue)
                            {
                                <span>@doc.ExpiryDate.Value.ToString("yyyy-MM-dd")</span>
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1 justify-content-end">
                                <a asp-action="Details" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-info" title="@Localizer.T("Doc.ViewDetails")" aria-label="@Localizer.T("Doc.ViewDetails")">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Download" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-success" title="@Localizer.T("Button.Download")" aria-label="@Localizer.T("Doc.DownloadTitle")">
                                    <i class="fas fa-download"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-4">
                        <partial name="_EmptyState" model='new {
                            Icon = "fa-file",
                            Title = Localizer.T("Empty.NoDocuments"),
                            Description = !string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(standardFilter) ? Localizer.T("Empty.NoDocumentsMessage") : "",
                            ActionLink = "",
                            ActionText = ""
                        }' />
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
