@model List<AmbulatoryCarePortal.Application.DTOs.FormVersionDto>

@{
    var form = ViewBag.Form as AmbulatoryCarePortal.Application.DTOs.FormDto;
    ViewData["Title"] = $"{Localizer.T("Common.Versions")} - {form?.Title}";
    var canUpload = User.IsInRole("ClinicAdmin");
}

<partial name="_PageHeader" model='new {
    Title = form?.Title ?? Localizer.T("Common.Versions"),
    Icon = "fa-history",
    Subtitle = Localizer.T("Common.Versions"),
    Breadcrumb = ""
}' />

<div class="row">
    <div class="col-12">
        @if (canUpload)
        {
            <div class="card card-primary mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0"><i class="fas fa-upload me-2"></i>@Localizer.T("Common.Upload")</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="UploadVersion" enctype="multipart/form-data">
                        <input type="hidden" name="formId" value="@form?.Id" />
                        <div class="row align-items-end">
                            <div class="col-md-5">
                                <div class="form-group">
                                    <label class="form-label">@Localizer.T("Common.File") <span class="required">*</span></label>
                                    <input type="file" name="file" class="form-control" required accept=".pdf,.doc,.docx,.xlsx,.xls" />
                                    <small class="text-muted">@Localizer.T("Form.AllowedFileTypes")</small>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="form-group">
                                    <label class="form-label">@Localizer.T("Common.VersionNotes")</label>
                                    <input type="text" name="notes" class="form-control" placeholder="@Localizer.T("Common.OptionalNotes")" />
                                </div>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-upload me-1"></i>@Localizer.T("Common.Upload")
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }

        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title mb-0"><i class="fas fa-history me-2"></i>@Localizer.T("Common.VersionHistory")</h3>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <div class="table-container">
                        <table class="table table-hover" id="versionsTable">
                            <thead>
                                <tr>
                                    <th>@Localizer.T("Common.Version")</th>
                                    <th>@Localizer.T("Common.UploadedAt")</th>
                                    <th>@Localizer.T("Common.Notes")</th>
                                    <th>@Localizer.T("Common.Actions")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var version in Model)
                                {
                                    <tr>
                                        <td><strong>v@(version.VersionNumber)</strong></td>
                                        <td>@version.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@(version.Notes ?? "-")</td>
                                        <td>
                                            <div class="actions-cell">
                                                @if (!string.IsNullOrEmpty(version.FilePath))
                                                {
                                                    <a href="@version.FilePath" target="_blank" class="btn btn-sm btn-outline-info" aria-label="@Localizer.T("Common.View")">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="@version.FilePath" download class="btn btn-sm btn-outline-success" aria-label="@Localizer.T("Common.Download")">
                                                        <i class="fas fa-download"></i>
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <partial name="_EmptyState" model='new {
                            Icon = "fa-file-alt",
                            Title = Localizer.T("Empty.NoData"),
                            Description = Localizer.T("Form.NoVersionsMessage"),
                            ActionLink = "",
                            ActionText = ""
                        }' />
                    </div>
                }
            </div>
        </div>
    </div>
</div>
