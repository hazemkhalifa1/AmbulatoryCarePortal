@model List<AmbulatoryCarePortal.Application.DTOs.FormVersionDto>

@{
    var form = ViewBag.Form as AmbulatoryCarePortal.Application.DTOs.FormDto;
    ViewData["Title"] = $"Versions - {form?.Title}";
    var canUpload = User.IsInRole("ClinicAdmin") || User.IsInRole("HospitalAdmin") || User.IsInRole("DepartmentUser");
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    @form?.Title
                    @if (!string.IsNullOrEmpty(form?.TitleAr))
                    {
                        <small class="text-muted ml-2">@form.TitleAr</small>
                    }
                </h3>
                <div class="card-tools">
                    <a href="/ClinicAdmin/Forms" class="btn btn-sm btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Forms
                    </a>
                </div>
            </div>
            <div class="card-body">
                @if (canUpload)
                {
                    <div class="mb-4 p-3 bg-light rounded">
                        <h5><i class="fas fa-upload"></i> Upload New Version</h5>
                        <form method="post" action="/ClinicAdmin/Forms/UploadVersion" enctype="multipart/form-data">
                            <input type="hidden" name="formId" value="@form?.Id" />
                            <div class="row">
                                <div class="col-md-5">
                                    <div class="form-group">
                                        <input type="file" name="file" class="form-control-file" required accept=".pdf,.doc,.docx,.xlsx,.xls" />
                                        <small class="text-muted">Allowed: PDF, Word, Excel (max 20MB)</small>
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="form-group">
                                        <input type="text" name="notes" class="form-control" placeholder="Version notes (optional)" />
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-primary btn-block">
                                        <i class="fas fa-upload"></i> Upload
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                }

                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Version</th>
                                    <th>Uploaded At</th>
                                    <th>Notes</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var version in Model)
                                {
                                    <tr>
                                        <td><strong>v@(version.VersionNumber)</strong></td>
                                        <td>@version.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@(version.Notes ?? "-")</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(version.FilePath))
                                            {
                                                <a href="@version.FilePath" target="_blank" class="btn btn-sm btn-primary">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="@version.FilePath" download class="btn btn-sm btn-success">
                                                    <i class="fas fa-download"></i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center mb-0">No version history available.</p>
                }
            </div>
        </div>
    </div>
</div>
