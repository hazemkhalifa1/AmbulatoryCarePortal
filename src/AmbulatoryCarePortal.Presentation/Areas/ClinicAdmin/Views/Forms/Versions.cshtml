@model List<AmbulatoryCarePortal.Application.DTOs.FormVersionDto>

@{
    var form = ViewBag.Form as AmbulatoryCarePortal.Application.DTOs.FormDto;
    ViewData["Title"] = $"Versions - {form?.Title}";
    var canUpload = User.IsInRole("ClinicAdmin");
}

<div class="fade-in">
    <div class="row">
        <div class="col-12">
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-history"></i>
                        @form?.Title
                        @if (!string.IsNullOrEmpty(form?.TitleAr))
                        {
                            <small class="text-muted ml-2">@form.TitleAr</small>
                        }
                    </h3>
                    <div class="card-tools">
                        <a href="/ClinicAdmin/Forms" class="btn btn-sm btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Forms
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (canUpload)
                    {
                        <div class="card card-info mb-4">
                            <div class="card-header">
                                <h5 class="card-title"><i class="fas fa-upload"></i> Upload New Version</h5>
                            </div>
                            <div class="card-body">
                                <form method="post" action="/ClinicAdmin/Forms/UploadVersion" enctype="multipart/form-data">
                                    <input type="hidden" name="formId" value="@form?.Id" />
                                    <div class="row align-items-end">
                                        <div class="col-md-5">
                                            <div class="form-group">
                                                <label class="form-label">File <span class="required">*</span></label>
                                                <input type="file" name="file" class="form-control" required accept=".pdf,.doc,.docx,.xlsx,.xls" />
                                                <small class="text-muted">Allowed: PDF, Word, Excel (max 20MB)</small>
                                            </div>
                                        </div>
                                        <div class="col-md-5">
                                            <div class="form-group">
                                                <label class="form-label">Version Notes</label>
                                                <input type="text" name="notes" class="form-control" placeholder="Version notes (optional)" />
                                            </div>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="submit" class="btn btn-primary btn-block">
                                                <i class="fas fa-upload"></i> Upload
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }

                    @if (Model.Any())
                    {
                        <div class="table-container">
                            <table class="table table-hover" id="versionsTable">
                                <thead>
                                    <tr>
                                        <th>Version</th>
                                        <th>Uploaded At</th>
                                        <th>Notes</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var version in Model)
                                    {
                                        <tr>
                                            <td><strong>v@(version.VersionNumber)</strong></td>
                                            <td>@version.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>@(version.Notes ?? "-")</td>
                                            <td>
                                                <div class="actions-cell">
                                                    @if (!string.IsNullOrEmpty(version.FilePath))
                                                    {
                                                        <a href="@version.FilePath" target="_blank" class="btn btn-sm btn-info" aria-label="View version">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <a href="@version.FilePath" download class="btn btn-sm btn-success" aria-label="Download version">
                                                            <i class="fas fa-download"></i>
                                                        </a>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-file-alt empty-icon"></i>
                            <h4>No Version History</h4>
                            <p>This form does not have any versions yet. Upload the first version to get started.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>