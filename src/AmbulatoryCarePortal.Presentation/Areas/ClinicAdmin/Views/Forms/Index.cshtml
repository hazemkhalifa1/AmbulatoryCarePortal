@model List<AmbulatoryCarePortal.Application.DTOs.FormDto>

@{
    ViewData["Title"] = Localizer.T("Page.FormsLibrary");
    var searchTerm = ViewBag.SearchTerm as string ?? "";
    var canManage = User.IsInRole("ClinicAdmin");
}

<div class="fade-in">
    <div class="row mb-4">
        <div class="col-md-8">
            <form method="get" class="form-inline">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" name="searchTerm" class="form-control" placeholder="@Localizer.T("Form.SearchPlaceholder")" value="@searchTerm">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> @Localizer.T("Common.Search")</button>
                </div>
            </form>
        </div>
        @if (canManage)
        {
            <div class="col-md-4 text-end">
                <a href="/ClinicAdmin/Forms/Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> @Localizer.T("Button.Add")
                </a>
            </div>
        }
    </div>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var form in Model)
            {
                <div class="col-md-4 col-sm-6 mb-4">
                    <div class="card card-primary h-100">
                        <div class="card-header">
                            <h5 class="card-title">@form.Title</h5>
                            @if (!string.IsNullOrEmpty(form.TitleAr))
                            {
                                <small class="float-end text-muted">@form.TitleAr</small>
                            }
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <span class="badge badge-info">v@(form.VersionNumber)</span>
                                @if (!string.IsNullOrEmpty(form.Category))
                                {
                                    <span class="badge badge-secondary">@form.Category</span>
                                }
                                @if (form.IsActive)
                                {
                                    <span class="badge badge-success">@Localizer.T("Form.Active")</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">@Localizer.T("Form.Inactive")</span>
                                }
                            </div>
                            @if (form.PublishedAt.HasValue)
                            {
                                <small class="text-muted">@Localizer.T("Form.Published"): @form.PublishedAt.Value.ToString("dd/MM/yyyy")</small>
                            }
                        </div>
                        <div class="card-footer">
                            <div class="btn-group">
                                <a href="/ClinicAdmin/Forms/Versions/@form.Id" class="btn btn-sm btn-info">
                                    <i class="fas fa-history"></i> @Localizer.T("Common.Versions")
                                </a>
                                @if (!string.IsNullOrEmpty(form.FilePath))
                                {
                                    <a href="@form.FilePath" target="_blank" class="btn btn-sm btn-primary">
                                        <i class="fas fa-eye"></i> @Localizer.T("Common.View")
                                    </a>
                                    <a href="@form.FilePath" download class="btn btn-sm btn-success">
                                        <i class="fas fa-download"></i> @Localizer.T("Common.Download")
                                    </a>
                                }
                                @if (canManage)
                                {
                                    <form method="post" action="/ClinicAdmin/Forms/Delete/@form.Id" style="display:inline" onsubmit="return confirm('@Localizer.T("Alert.ConfirmDeleteForm")');">
                                        <button type="submit" class="btn btn-sm btn-danger" aria-label="@Localizer.T("Common.Delete")">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card card-primary">
            <div class="card-body">
                <div class="empty-state">
                    <i class="fas fa-file-alt empty-icon"></i>
                    <h4>@Localizer.T("Empty.NoForms")</h4>
                    <p>@(canManage ? @Localizer.T("Form.CreatePrompt") : @Localizer.T("Form.NoFormsMessage"))</p>
                    @if (canManage)
                    {
                        <a href="/ClinicAdmin/Forms/Create" class="btn btn-primary">
                            <i class="fas fa-plus"></i> @Localizer.T("Form.CreateForm")
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>