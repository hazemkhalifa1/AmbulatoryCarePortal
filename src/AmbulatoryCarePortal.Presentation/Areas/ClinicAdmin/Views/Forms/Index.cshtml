@model List<AmbulatoryCarePortal.Application.DTOs.FormDto>

@{
    ViewData["Title"] = Localizer.T("Page.FormsLibrary");
    var searchTerm = ViewBag.SearchTerm as string ?? "";
    var canManage = User.IsInRole("ClinicAdmin");
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("Page.FormsLibrary"),
    Icon = "fa-file-alt",
    Breadcrumb = ""
}' />

<div class="data-table-toolbar mb-4">
    <div class="toolbar-left gap-2 w-100">
        <form method="get" class="d-flex gap-2 flex-grow-1" style="max-width: 400px;">
            <div class="search-box flex-grow-1">
                <i class="fas fa-search search-icon"></i>
                <input type="text" name="searchTerm" class="form-control" placeholder="@Localizer.T("Form.SearchPlaceholder")" value="@searchTerm">
            </div>
            <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search"></i> @Localizer.T("Common.Search")</button>
        </form>
        @if (canManage)
        {
            <a href="/ClinicAdmin/Forms/Create" class="btn btn-sm btn-primary ms-auto">
                <i class="fas fa-plus"></i> @Localizer.T("Button.Add")
            </a>
        }
    </div>
</div>

@if (Model.Any())
{
    <div class="row g-4">
        @foreach (var form in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="form-card h-100">
                    <div class="form-card-header">
                        <h5 class="mb-0">@form.Title</h5>
                        @if (!string.IsNullOrEmpty(form.TitleAr))
                        {
                            <small class="text-muted" dir="rtl">@form.TitleAr</small>
                        }
                    </div>
                    <div class="form-card-body">
                        <div class="mb-3">
                            <span class="compliance-badge compliant me-1">v@(form.VersionNumber)</span>
                            @if (!string.IsNullOrEmpty(form.Category))
                            {
                                <span class="status-pill needs-review">@form.Category</span>
                            }
                            @if (form.IsActive)
                            {
                                <span class="status-pill active">@Localizer.T("Form.Active")</span>
                            }
                            else
                            {
                                <span class="status-pill inactive">@Localizer.T("Form.Inactive")</span>
                            }
                        </div>
                        @if (form.PublishedAt.HasValue)
                        {
                            <small class="text-muted">@Localizer.T("Form.Published"): @form.PublishedAt.Value.ToString("dd/MM/yyyy")</small>
                        }
                    </div>
                    <div class="form-card-footer">
                        <div class="d-flex gap-2 flex-wrap">
                            <a href="/ClinicAdmin/Forms/Versions/@form.Id" class="btn btn-sm btn-outline-info">
                                <i class="fas fa-history"></i> @Localizer.T("Common.Versions")
                            </a>
                            @if (!string.IsNullOrEmpty(form.FilePath))
                            {
                                <a href="@form.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i> @Localizer.T("Common.View")
                                </a>
                                <a href="@form.FilePath" download class="btn btn-sm btn-outline-success">
                                    <i class="fas fa-download"></i> @Localizer.T("Common.Download")
                                </a>
                            }
                            @if (canManage)
                            {
                                <form method="post" action="/ClinicAdmin/Forms/Delete/@form.Id" style="display:inline" onsubmit="return confirm('@Localizer.T("Alert.ConfirmDeleteForm")');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="@Localizer.T("Common.Delete")">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="form-card">
        <div class="form-card-body">
            <partial name="_EmptyState" model='new {
                Icon = "fa-file-alt",
                Title = Localizer.T("Empty.NoForms"),
                Message = canManage ? Localizer.T("Form.CreatePrompt") : Localizer.T("Form.NoFormsMessage"),
                ActionLink = canManage ? "/ClinicAdmin/Forms/Create" : "",
                ActionText = canManage ? Localizer.T("Form.CreateForm") : ""
            }' />
        </div>
    </div>
}
