@model List<PolicyDocumentListItem>
@using System.Globalization

@{
    ViewData["Title"] = Localizer.T("Nav.PoliciesDocuments");
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    var searchTerm = (string?)ViewBag.SearchTerm;
    var statusFilter = (string?)ViewBag.StatusFilter;
    var standardFilter = (string?)ViewBag.StandardFilter;
    var standards = (string[]?)ViewBag.Standards;
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("Nav.PoliciesDocuments"),
    Icon = "fa-file-alt",
    Breadcrumb = ""
}' />

@if (standards != null && standards.Length > 0)
{
    <div class="card mb-3">
        <div class="card-body py-2">
            <ul class="nav nav-pills" id="standardsTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <a class="nav-link @(string.IsNullOrEmpty(standardFilter) ? "active" : "")" asp-action="Index" asp-route-standardFilter="" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" role="tab">@Localizer.T("Common.All")</a>
                </li>
                @foreach (var std in standards)
                {
                    <li class="nav-item" role="presentation">
                        <a class="nav-link @(standardFilter == std ? "active" : "")" asp-action="Index" asp-route-standardFilter="@std" asp-route-searchTerm="@searchTerm" asp-route-statusFilter="@statusFilter" role="tab">@std</a>
                    </li>
                }
            </ul>
        </div>
    </div>
}

<div class="data-table-wrapper">
    <div class="data-table-toolbar">
        <div class="toolbar-left">
            <span class="toolbar-title">@Localizer.T("Nav.PoliciesDocuments")</span>
            <span class="toolbar-count">@Model.Count @Localizer.T("Doc.AttachmentCount")</span>
        </div>
        <div class="toolbar-right gap-2">
            <a asp-action="Index" asp-controller="PolicyManagement" asp-area="ClinicAdmin" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-file-pdf"></i> @Localizer.T("Doc.CustomPolicy")
            </a>
            <a asp-action="Index" asp-controller="ClinicDocuments" asp-area="ClinicAdmin" class="btn btn-sm btn-outline-info">
                <i class="fas fa-file"></i> @Localizer.T("Doc.CBAHIStandard")
            </a>
        </div>
    </div>

    <form method="get" asp-action="Index" id="filterForm" role="search" aria-label="@Localizer.T("Doc.FilterDocuments")">
        <div class="data-table-toolbar" style="border-top: 1px solid var(--border-color); padding-top: 1rem;">
            <div class="toolbar-left gap-2 w-100 flex-wrap">
                <input type="hidden" name="standardFilter" value="@standardFilter" />
                <div class="search-box" style="max-width: 250px;">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" name="searchTerm" class="form-control" placeholder="@Localizer.T("Doc.SearchPlaceholder")" value="@searchTerm" aria-label="@Localizer.T("Doc.SearchDocuments")" />
                </div>
                <select name="statusFilter" class="form-select" style="width: auto; min-width: 140px;" onchange="document.getElementById('filterForm').submit()" aria-label="@Localizer.T("Doc.FilterByStatus")">
                    <option value="">@Localizer.T("Doc.AllStatuses")</option>
                    <option value="Approved" selected="@(statusFilter == "Approved")">@Localizer.T("Policy.Approved")</option>
                    <option value="NeedsReview" selected="@(statusFilter == "NeedsReview")">@Localizer.T("Doc.NeedsReview")</option>
                    <option value="Draft" selected="@(statusFilter == "Draft")">@Localizer.T("Doc.Draft")</option>
                    <option value="Expired" selected="@(statusFilter == "Expired")">@Localizer.T("Doc.Expired")</option>
                </select>
                <button type="submit" class="btn btn-sm btn-primary" aria-label="@Localizer.T("Common.Search")">
                    <i class="fas fa-search"></i>
                </button>
                @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(standardFilter))
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" aria-label="@Localizer.T("Doc.ClearFilters")">
                        <i class="fas fa-times"></i> @Localizer.T("Common.Clear")
                    </a>
                }
            </div>
        </div>
    </form>

    <table class="data-table" role="table" aria-label="@Localizer.T("Nav.PoliciesDocuments")">
        <thead>
            <tr>
                <th scope="col">@Localizer.T("Doc.Type")</th>
                <th scope="col">@Localizer.T("Common.Title")</th>
                <th scope="col">@Localizer.T("Doc.StandardCode")</th>
                <th scope="col">@Localizer.T("HR.Department")</th>
                <th scope="col">@Localizer.T("Common.Status")</th>
                <th scope="col">@Localizer.T("Common.Version")</th>
                <th scope="col">@Localizer.T("Common.Expiry")</th>
                <th scope="col" class="text-center">@Localizer.T("Doc.Attachments")</th>
                <th scope="col" class="text-end">@Localizer.T("Common.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (item.Type == "Policy")
                            {
                                <span class="badge bg-primary">@Localizer.T("Doc.CustomPolicy")</span>
                            }
                            else
                            {
                                <span class="badge bg-info">@Localizer.T("Doc.CBAHIStandard")</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" asp-route-type="@item.Type" class="fw-bold text-decoration-none">
                                @item.Title
                            </a>
                            @if (!string.IsNullOrEmpty(item.TitleAr))
                            {
                                <br /><small class="text-muted" dir="rtl">@item.TitleAr</small>
                            }
                        </td>
                        <td>@item.StandardCode</td>
                        <td>@item.DepartmentName</td>
                        <td>
                            @if (item.DocumentStatus == "Approved" || item.DocumentStatus == "Complete")
                            {
                                <span class="status-pill active"><i class="fas fa-check-circle"></i> @Localizer.T("Common.Compliant")</span>
                            }
                            else
                            {
                                <span class="status-pill @StatusBadgeHelper.GetDocumentStatusClass(item.DocumentStatus)">@item.DocumentStatus</span>
                            }
                        </td>
                        <td>@item.VersionNumber</td>
                        <td>
                            @if (item.ExpiryDate.HasValue)
                            {
                                <small>@item.ExpiryDate.Value.ToString("dd/MM/yyyy")</small>
                            }
                            else
                            {
                                <small class="text-muted">-</small>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.AttachmentCount > 0)
                            {
                                <span class="badge bg-secondary">@item.AttachmentCount</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            <div class="cell-actions justify-content-end">
                                <a asp-action="Details" asp-route-id="@item.Id" asp-route-type="@item.Type" class="btn btn-sm btn-outline-info" title="@Localizer.T("Common.View")" aria-label="@Localizer.T("Common.View")">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center py-4">
                        <partial name="_EmptyState" model='new {
                            Icon = "fa-file-alt",
                            Title = Localizer.T("Doc.NoDocumentsFound"),
                            Description = Localizer.T("Doc.NoDocumentsFoundMessage"),
                            ActionLink = "",
                            ActionText = ""
                        }' />
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
