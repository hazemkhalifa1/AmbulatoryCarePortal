@model List<NotificationDto>
@using AmbulatoryCarePortal.Application.DTOs

@{
    ViewData["Title"] = Localizer.T("Page.Notifications");
    var unreadCount = ViewBag.UnreadCount as int? ?? 0;
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("Page.Notifications"),
    Icon = "fa-bell",
    Breadcrumb = ""
}' />

<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-bell",
            Color = "primary",
            Value = Model.Count.ToString(),
            Label = Localizer.T("Common.Total"),
            Badge = Localizer.T("Page.Notifications"),
            Link = ""
        }' />
    </div>
    <div class="col-lg-3 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-envelope",
            Color = unreadCount > 0 ? "warning" : "success",
            Value = unreadCount.ToString(),
            Label = Localizer.T("Common.Unread"),
            Badge = unreadCount > 0 ? Localizer.T("Common.Attention") : Localizer.T("Common.None"),
            Link = ""
        }' />
    </div>
</div>

<div class="form-card">
    <div class="form-card-header">
        <h3><i class="fas fa-bell"></i> @Localizer.T("Page.Notifications")</h3>
        @if (unreadCount > 0)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="status-pill needs-review">@unreadCount @Localizer.T("Common.Unread")</span>
                <form method="post" action="/ClinicAdmin/Notifications/MarkAllRead" style="display:inline">
                    <button type="submit" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-check-double"></i> @Localizer.T("Button.MarkAllRead")
                    </button>
                </form>
            </div>
        }
    </div>
    <div class="form-card-body p-0">
        @if (Model.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var notification in Model)
                {
                    var notifType = notification.NotificationType.ToString();
                    var iconClass = notifType switch
                    {
                        "DocumentExpiry" => "fas fa-calendar-exclamation text-warning",
                        "DocumentMissing" => "fas fa-file-excel text-danger",
                        "OpenGap" => "fas fa-exclamation-triangle text-danger",
                        "ComplianceAlert" => "fas fa-chart-line text-warning",
                        "PolicyUpdate" => "fas fa-file-pdf text-info",
                        _ => "fas fa-bell text-secondary"
                    };

                    <div class="list-group-item list-group-item-action @(notification.IsRead ? "" : "list-group-item-info")" role="alert" aria-live="polite">
                        <div class="row align-items-center g-3">
                            <div class="col-auto">
                                <i class="@iconClass fa-lg"></i>
                            </div>
                            <div class="col">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1 @(notification.IsRead ? "" : "fw-bold")">@notification.Title</h6>
                                    <small class="text-muted">@notification.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                <p class="mb-1">@notification.Message</p>
                            </div>
                            <div class="col-auto">
                                @if (!notification.IsRead)
                                {
                                    <form method="post" action="/ClinicAdmin/Notifications/MarkRead/@notification.Id" style="display:inline">
                                        <button type="submit" class="btn btn-sm btn-outline-primary mark-read-btn" aria-label="@Localizer.T("Common.MarkAsRead")">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="p-4">
                <partial name="_EmptyState" model='new {
                    Icon = "fa-bell-slash",
                    Title = Localizer.T("Empty.NoNotifications"),
                    Description = Localizer.T("Empty.NoNotificationsMessage"),
                    ActionLink = "",
                    ActionText = ""
                }' />
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.mark-read-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                var form = this.closest('form');
                fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                }).then(r => r.json()).then(data => {
                    if (data.success) {
                        var item = this.closest('.list-group-item');
                        item.classList.remove('list-group-item-info');
                        location.reload();
                    }
                });
            });
        });
    </script>
}
