@model HRStaffDetailsViewModel
@using AmbulatoryCarePortal.Domain.Enums

@{
    ViewData["Title"] = Model.Staff.FullNameEn;
    var docTypes = Enum.GetValues<HrDocumentType>();
}

<div class="fade-in">
    <div class="row">
        <div class="col-md-4">
            <div class="card card-primary">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <div style="width:100px;height:100px;background:var(--color-bg-secondary);display:inline-flex;align-items:center;justify-content:center;border-radius:50%;font-size:2.5rem;color:var(--color-text-secondary);">
                            <i class="fas fa-user-circle"></i>
                        </div>
                    </div>

                    <h3>@Model.Staff.FullNameEn</h3>
                    @if (!string.IsNullOrEmpty(Model.Staff.FullNameAr))
                    {
                        <p class="text-muted" dir="rtl">@Model.Staff.FullNameAr</p>
                    }

                    <hr />

                    <div class="detail-row">
                        <span class="detail-label"><i class="fas fa-building"></i> @Localizer.T("HR.Department")</span>
                        <span class="detail-value">@Model.Staff.DepartmentName</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="fas fa-tag"></i> @Localizer.T("Common.Type")</span>
                        <span class="detail-value"><span class="badge badge-info">@Model.Staff.StaffType</span></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="fas fa-check-circle"></i> @Localizer.T("Common.Status")</span>
                        <span class="detail-value">
                            @if (Model.Staff.IsActive)
                            {
                                <span class="badge badge-success">@Localizer.T("HR.Active")</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">@Localizer.T("HR.Inactive")</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="fas fa-file"></i> @Localizer.T("HR.Documents")</span>
                        <span class="detail-value">@Model.DocumentCount</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label"><i class="fas fa-check-circle"></i> @Localizer.T("HR.Compliance")</span>
                        <span class="detail-value">
                            @if (Model.ComplianceStatus == "Compliant")
                            {
                                <span class="badge badge-success"><i class="fas fa-check"></i> @Localizer.T("HR.Compliant")</span>
                            }
                            else
                            {
                                <span class="badge badge-danger"><i class="fas fa-times"></i> @Localizer.T("HR.NonCompliant")</span>
                            }
                        </span>
                    </div>

                    <hr />

                    <a asp-action="Index" class="btn btn-secondary btn-block">
                        <i class="fas fa-arrow-left"></i> @Localizer.T("HR.BackToList")
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="row mb-4">
                <div class="col-lg-4 col-6">
                    <div class="small-box bg-info">
                        <h3>@Model.DocumentCount</h3>
                        <p>@Localizer.T("HR.TotalDocuments")</p>
                        <div class="icon"><i class="fas fa-file"></i></div>
                    </div>
                </div>
                <div class="col-lg-4 col-6">
                    <div class="small-box bg-warning">
                        <h3>@Model.ExpiringCount</h3>
                        <p>@Localizer.T("HR.ExpiringSoon")</p>
                        <div class="icon"><i class="fas fa-clock"></i></div>
                    </div>
                </div>
                <div class="col-lg-4 col-6">
                    <div class="small-box bg-danger">
                        <h3>@Model.ExpiredCount</h3>
                        <p>@Localizer.T("HR.Expired")</p>
                        <div class="icon"><i class="fas fa-calendar-times"></i></div>
                    </div>
                </div>
            </div>

            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-file-alt"></i>
                        @Localizer.T("HR.Documents")
                    </h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#uploadSection" aria-expanded="@((ViewBag.ShowUpload == true ? "true" : "false"))">
                            <i class="fas fa-upload"></i> @Localizer.T("HR.Upload")
                        </button>
                    </div>
                </div>

                <div class="collapse @(ViewBag.ShowUpload == true ? "show" : "")" id="uploadSection">
                    <div class="card-body bg-light">
                        <form method="post" asp-action="UploadDocument" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="staffId" value="@Model.Staff.Id" />

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">@Localizer.T("HR.DocumentName") <span class="required">*</span></label>
                                        <input name="DocumentName" class="form-control" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label">@Localizer.T("HR.DocumentNameAr")</label>
                                        <input name="DocumentNameAr" class="form-control" dir="rtl" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="form-label">@Localizer.T("HR.DocumentType") <span class="required">*</span></label>
                                        <select name="DocumentType" class="form-control">
                                            <option value="">-- @Localizer.T("HR.Select") --</option>
                                            @foreach (var dt in docTypes)
                                            {
                                                <option value="@dt">@dt</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="form-label">@Localizer.T("HR.IssueDate")</label>
                                        <input name="IssueDate" class="form-control" type="date" />
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label class="form-label">@Localizer.T("HR.ExpiryDate")</label>
                                        <input name="ExpiryDate" class="form-control" type="date" />
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label class="form-label">@Localizer.T("HR.File") <span class="required">*</span></label>
                                        <input name="documentFile" class="form-control" type="file" required />
                                    </div>
                                </div>
                                <div class="col-md-4 d-flex align-items-end">
                                    <div class="form-group w-100">
                                        <button type="submit" class="btn btn-success btn-block">
                                            <i class="fas fa-upload"></i> @Localizer.T("HR.Upload")
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-container">
                        <table class="table table-hover" id="documentsTable">
                            <thead>
                                <tr>
                                    <th>@Localizer.T("HR.DocumentName")</th>
                                    <th>@Localizer.T("HR.DocumentType")</th>
                                    <th>@Localizer.T("HR.ExpiryDate")</th>
                                    <th>@Localizer.T("HR.DaysLeft")</th>
                                    <th>@Localizer.T("HR.Verified")</th>
                                    <th>@Localizer.T("HR.Actions")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Documents.Any())
                                {
                                    @foreach (var doc in Model.Documents)
                                    {
                                        var daysLeft = doc.ExpiryDate.HasValue ? doc.DaysUntilExpiry : (int?)null;
                                        <tr class="@(daysLeft < 0 ? "table-danger" : daysLeft <= 30 ? "table-warning" : "")">
                                            <td>@doc.DocumentName</td>
                                            <td><span class="badge badge-secondary">@doc.DocumentType</span></td>
                                            <td>
                                                @if (doc.ExpiryDate.HasValue)
                                                {
                                                    @doc.ExpiryDate.Value.ToString("dd/MM/yyyy")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">@Localizer.T("HR.NA")</span>
                                                }
                                            </td>
                                            <td>
                                                @if (daysLeft.HasValue)
                                                {
                                                    if (daysLeft < 0)
                                                    {
                                                        <span class="badge badge-danger">@(Math.Abs(daysLeft.Value)) @Localizer.T("HR.DaysOverdue")</span>
                                                    }
                                                    else if (daysLeft <= 7)
                                                    {
                                                        <span class="badge badge-warning">@daysLeft @Localizer.T("HR.Days")</span>
                                                    }
                                                    else if (daysLeft <= 30)
                                                    {
                                                        <span class="badge badge-info">@daysLeft @Localizer.T("HR.Days")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-success">@daysLeft @Localizer.T("HR.Days")</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (doc.IsVerified)
                                                {
                                                    <span class="badge badge-success"><i class="fas fa-check"></i></span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-warning"><i class="fas fa-clock"></i> @Localizer.T("HR.Pending")</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="actions-cell">
                                                    @if (!doc.IsVerified)
                                                    {
                                                        <form method="post" asp-action="VerifyDocument" style="display:inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="documentId" value="@doc.Id" />
                                                            <button type="submit" class="btn btn-sm btn-success" title="Verify" aria-label="Verify document">
                                                                <i class="fas fa-check-circle"></i>
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6">
                                            <div class="empty-state">
                                                <i class="fas fa-file empty-icon"></i>
                                                <h4>@Localizer.T("HR.NoDocuments")</h4>
                                                <p>@Localizer.T("HR.NoDocumentsMessage")</p>
                                                <button type="button" class="btn btn-primary" data-bs-toggle="collapse" data-bs-target="#uploadSection">
                            <i class="fas fa-upload"></i> @Localizer.T("HR.Upload")
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>