@model HRStaffDetailsViewModel
@using AmbulatoryCarePortal.Domain.Enums

@{
    ViewData["Title"] = Model.Staff.FullNameEn;
    var docTypes = Enum.GetValues<HrDocumentType>();
}

<partial name="_PageHeader" model='new {
    Title = Model.Staff.FullNameEn,
    Icon = "fa-user-circle",
    Breadcrumb = Localizer.T("Page.StaffManagement")
}' />

<div class="row g-4">
    <div class="col-lg-4">
        <div class="form-card">
            <div class="form-card-body text-center">
                <div class="mb-3">
                    <div style="width:100px;height:100px;background:var(--color-bg-secondary);display:inline-flex;align-items:center;justify-content:center;border-radius:50%;font-size:2.5rem;color:var(--color-text-secondary);">
                        <i class="fas fa-user-circle"></i>
                    </div>
                </div>

                <h3>@Model.Staff.FullNameEn</h3>
                @if (!string.IsNullOrEmpty(Model.Staff.FullNameAr))
                {
                    <p class="text-muted" dir="rtl">@Model.Staff.FullNameAr</p>
                }

                <hr />

                <div class="detail-row">
                    <span class="detail-label"><i class="fas fa-building"></i> @Localizer.T("HR.Department")</span>
                    <span class="detail-value">@Model.Staff.DepartmentName</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label"><i class="fas fa-tag"></i> @Localizer.T("Common.Type")</span>
                    <span class="detail-value"><span class="status-pill needs-review">@Model.Staff.StaffType</span></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label"><i class="fas fa-check-circle"></i> @Localizer.T("Common.Status")</span>
                    <span class="detail-value">
                        @if (Model.Staff.IsActive)
                        {
                            <span class="status-pill active">@Localizer.T("HR.Active")</span>
                        }
                        else
                        {
                            <span class="status-pill inactive">@Localizer.T("HR.Inactive")</span>
                        }
                    </span>
                </div>
                <div class="detail-row">
                    <span class="detail-label"><i class="fas fa-file"></i> @Localizer.T("HR.Documents")</span>
                    <span class="detail-value"><span class="fw-bold">@Model.DocumentCount</span></span>
                </div>
                <div class="detail-row">
                    <span class="detail-label"><i class="fas fa-check-circle"></i> @Localizer.T("HR.Compliance")</span>
                    <span class="detail-value">
                        @if (Model.ComplianceStatus == "Compliant")
                        {
                            <span class="status-pill active"><i class="fas fa-check"></i> @Localizer.T("HR.Compliant")</span>
                        }
                        else
                        {
                            <span class="status-pill inactive"><i class="fas fa-times"></i> @Localizer.T("HR.NonCompliant")</span>
                        }
                    </span>
                </div>

                <hr />

                <a asp-action="Edit" asp-route-id="@Model.Staff.Id" class="btn btn-primary w-100 mb-2">
                    <i class="fas fa-edit"></i> @Localizer.T("Common.Edit")
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="fas fa-arrow-left"></i> @Localizer.T("HR.BackToList")
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="row g-3 mb-4">
            <div class="col-lg-4 col-6">
                <partial name="_HealthMetricCard" model='new {
                    Icon = "fa-file",
                    Color = "info",
                    Value = Model.DocumentCount.ToString(),
                    Label = Localizer.T("HR.TotalDocuments"),
                    Badge = Localizer.T("Common.Total"),
                    Link = ""
                }' />
            </div>
            <div class="col-lg-4 col-6">
                <partial name="_HealthMetricCard" model='new {
                    Icon = "fa-clock",
                    Color = Model.ExpiringCount > 0 ? "warning" : "success",
                    Value = Model.ExpiringCount.ToString(),
                    Label = Localizer.T("HR.ExpiringSoon"),
                    Badge = Model.ExpiringCount > 0 ? Localizer.T("Common.Attention") : Localizer.T("Common.None"),
                    Link = ""
                }' />
            </div>
            <div class="col-lg-4 col-6">
                <partial name="_HealthMetricCard" model='new {
                    Icon = "fa-calendar-times",
                    Color = Model.ExpiredCount > 0 ? "danger" : "success",
                    Value = Model.ExpiredCount.ToString(),
                    Label = Localizer.T("HR.Expired"),
                    Badge = Model.ExpiredCount > 0 ? Localizer.T("Common.Overdue") : Localizer.T("Common.None"),
                    Link = ""
                }' />
            </div>
        </div>

        <div class="form-card">
            <div class="form-card-header">
                <h3><i class="fas fa-file-alt"></i> @Localizer.T("HR.Documents")</h3>
                <div>
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#uploadSection" aria-expanded="@((ViewBag.ShowUpload == true ? "true" : "false"))">
                        <i class="fas fa-upload"></i> @Localizer.T("HR.Upload")
                    </button>
                </div>
            </div>

            <div class="collapse @(ViewBag.ShowUpload == true ? "show" : "")" id="uploadSection">
                <div class="form-card-body" style="background: var(--color-bg-secondary);">
                    <form method="post" asp-action="UploadDocument" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="staffId" value="@Model.Staff.Id" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="form-label">@Localizer.T("HR.DocumentName") <span class="text-danger">*</span></label>
                                    <input name="DocumentName" class="form-control" required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="form-label">@Localizer.T("HR.DocumentNameAr")</label>
                                    <input name="DocumentNameAr" class="form-control" dir="rtl" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="form-label">@Localizer.T("HR.DocumentType") <span class="text-danger">*</span></label>
                                    <select name="DocumentType" class="form-select">
                                        <option value="">-- @Localizer.T("HR.Select") --</option>
                                        @foreach (var dt in docTypes)
                                        {
                                            <option value="@dt">@dt</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="form-label">@Localizer.T("HR.IssueDate")</label>
                                    <input name="IssueDate" class="form-control" type="date" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="form-label">@Localizer.T("HR.ExpiryDate")</label>
                                    <input name="ExpiryDate" class="form-control" type="date" />
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="form-group">
                                    <label class="form-label">@Localizer.T("HR.File") <span class="text-danger">*</span></label>
                                    <input name="documentFile" class="form-control" type="file" required />
                                </div>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-group w-100">
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="fas fa-upload"></i> @Localizer.T("HR.Upload")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="form-card-body p-0">
                <table class="data-table" id="documentsTable">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer.T("HR.DocumentName")</th>
                            <th scope="col">@Localizer.T("HR.DocumentType")</th>
                            <th scope="col">@Localizer.T("HR.ExpiryDate")</th>
                            <th scope="col">@Localizer.T("HR.DaysLeft")</th>
                            <th scope="col">@Localizer.T("HR.Verified")</th>
                            <th scope="col" class="text-end">@Localizer.T("HR.Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Documents.Any())
                        {
                            @foreach (var doc in Model.Documents)
                            {
                                var daysLeft = doc.ExpiryDate.HasValue ? doc.DaysUntilExpiry : (int?)null;
                                <tr class="@(daysLeft < 0 ? "table-danger" : daysLeft <= 30 ? "table-warning" : "")">
                                    <td>@doc.DocumentName</td>
                                    <td><span class="badge bg-secondary">@doc.DocumentType</span></td>
                                    <td>
                                        @if (doc.ExpiryDate.HasValue)
                                        {
                                            @doc.ExpiryDate.Value.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">@Localizer.T("HR.NA")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (daysLeft.HasValue)
                                        {
                                            if (daysLeft < 0)
                                            {
                                                <span class="compliance-badge non-compliant">@(Math.Abs(daysLeft.Value)) @Localizer.T("HR.DaysOverdue")</span>
                                            }
                                            else if (daysLeft <= 7)
                                            {
                                                <span class="compliance-badge needs-attention">@daysLeft @Localizer.T("HR.Days")</span>
                                            }
                                            else if (daysLeft <= 30)
                                            {
                                                <span class="compliance-badge needs-attention">@daysLeft @Localizer.T("HR.Days")</span>
                                            }
                                            else
                                            {
                                                <span class="compliance-badge compliant">@daysLeft @Localizer.T("HR.Days")</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (doc.IsVerified)
                                        {
                                            <span class="status-pill active"><i class="fas fa-check"></i></span>
                                        }
                                        else
                                        {
                                            <span class="status-pill needs-review"><i class="fas fa-clock"></i> @Localizer.T("HR.Pending")</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="cell-actions justify-content-end">
                                            @if (!doc.IsVerified)
                                            {
                                                <form method="post" asp-action="VerifyDocument" style="display:inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="documentId" value="@doc.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success" title="@Localizer.T("HR.Verify")" aria-label="@Localizer.T("HR.VerifyDocument")">
                                                        <i class="fas fa-check-circle"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4">
                                    <partial name="_EmptyState" model='new {
                                        Icon = "fa-file",
                                        Title = Localizer.T("HR.NoDocuments"),
                                        Description = Localizer.T("HR.NoDocumentsMessage"),
                                        ActionLink = "",
                                        ActionText = ""
                                    }' />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
