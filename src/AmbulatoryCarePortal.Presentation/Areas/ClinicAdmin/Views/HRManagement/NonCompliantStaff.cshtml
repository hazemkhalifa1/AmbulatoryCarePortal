@model List<HRStaffNonCompliantViewModel>
@{
    ViewData["Title"] = Localizer.T("Page.NonCompliantStaff");
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("HR.NonCompliantStaff"),
    Icon = "fa-times-circle",
    Subtitle = "",
    Breadcrumb = ""
}' />

<div class="row g-3">
    @if (Model.Any())
    {
        @foreach (var item in Model)
        {
            <div class="col-12">
                <div class="card card-primary border-danger">
                    <div class="card-header bg-danger text-white">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-user me-2"></i>
                            <a asp-action="Details" asp-route-id="@item.Staff.Id" class="text-white">
                                @item.Staff.FullNameEn
                            </a>
                            @if (!string.IsNullOrEmpty(item.Staff.FullNameAr))
                            {
                                <small dir="rtl"> (@item.Staff.FullNameAr)</small>
                            }
                        </h5>
                        <div class="card-tools d-flex gap-2 align-items-center">
                            <span class="status-pill inactive">
                                <i class="fas fa-calendar-times me-1"></i>@item.ExpiredDocumentCount @Localizer.T("HR.DocumentsExpired")
                            </span>
                            <span class="status-pill needs-review">
                                <i class="fas fa-hourglass-end me-1"></i>@item.DaysOverdue @Localizer.T("HR.DaysOverdue")
                            </span>
                            <a asp-action="Details" asp-route-id="@item.Staff.Id" class="btn btn-sm btn-light">
                                <i class="fas fa-eye me-1"></i>@Localizer.T("HR.View")
                            </a>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-container">
                            <table class="table table-hover" id="nonCompliantTable_@item.Staff.Id">
                                <thead>
                                    <tr>
                                        <th>@Localizer.T("HR.DocumentName")</th>
                                        <th>@Localizer.T("Common.Type")</th>
                                        <th>@Localizer.T("HR.ExpiryDate")</th>
                                        <th>@Localizer.T("HR.OverdueBy")</th>
                                        <th>@Localizer.T("Common.Status")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in item.ExpiredDocuments)
                                    {
                                        var overdueDays = doc.ExpiryDate.HasValue ? (DateTime.UtcNow - doc.ExpiryDate.Value).Days : 0;
                                        <tr class="table-danger">
                                            <td>@doc.DocumentName</td>
                                            <td><span class="status-pill info">@doc.DocumentType</span></td>
                                            <td>@doc.ExpiryDate?.ToString("dd/MM/yyyy")</td>
                                            <td><strong>@overdueDays</strong> @Localizer.T("HR.Days")</td>
                                            <td>
                                                <span class="status-pill inactive">
                                                    <i class="fas fa-times-circle me-1"></i>@Localizer.T("HR.Expired")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <partial name="_EmptyState" model='new {
                Icon = "fa-check-circle",
                Title = Localizer.T("HR.AllStaffCompliant"),
                Description = Localizer.T("HR.AllStaffCompliantMessage"),
                ActionLink = Url.Action("Index"),
                ActionText = Localizer.T("HR.BackToStaffList")
            }' />
        </div>
    }
</div>
