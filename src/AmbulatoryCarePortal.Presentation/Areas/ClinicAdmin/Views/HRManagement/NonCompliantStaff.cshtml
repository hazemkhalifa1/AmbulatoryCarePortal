@model List<HRStaffNonCompliantViewModel>
@{
    ViewData["Title"] = Localizer.T("Page.NonCompliantStaff");
}

<div class="fade-in">
    <div class="row">
        <div class="col-12">
            <div class="card card-danger">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-times-circle"></i>
                        @Localizer.T("HR.NonCompliantStaff")
                    </h3>
                    <div class="card-tools">
                        <span class="badge badge-danger">@Model.Count @Localizer.T("HR.StaffCount")</span>
                        <a asp-action="Index" class="btn btn-sm btn-secondary ml-2">
                            <i class="fas fa-arrow-left"></i> @Localizer.T("HR.Back")
                        </a>
                    </div>
                </div>

                <div class="card-body p-0">
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <div class="card card-danger m-3">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-user"></i>
                                        <a asp-action="Details" asp-route-id="@item.Staff.Id">
                                            @item.Staff.FullNameEn
                                        </a>
                                        @if (!string.IsNullOrEmpty(item.Staff.FullNameAr))
                                        {
                                            <small class="text-muted" dir="rtl"> (@item.Staff.FullNameAr)</small>
                                        }
                                    </h5>
                                    <div class="card-tools">
                                        <span class="badge badge-danger">
                                            <i class="fas fa-calendar-times"></i>
                                            @item.ExpiredDocumentCount @Localizer.T("HR.DocumentsExpired")
                                        </span>
                                        <span class="badge badge-warning">
                                            <i class="fas fa-hourglass-end"></i>
                                            @item.DaysOverdue @Localizer.T("HR.DaysOverdue")
                                        </span>
                                        <a asp-action="Details" asp-route-id="@item.Staff.Id" class="btn btn-sm btn-info ml-2">
                                            <i class="fas fa-eye"></i> @Localizer.T("HR.View")
                                        </a>
                                    </div>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-container">
                                        <table class="table table-hover" id="nonCompliantTable_@item.Staff.Id">
                                            <thead>
                                                <tr>
                                                    <th>@Localizer.T("HR.DocumentName")</th>
                                                    <th>@Localizer.T("Common.Type")</th>
                                                    <th>@Localizer.T("HR.ExpiryDate")</th>
                                                    <th>@Localizer.T("HR.OverdueBy")</th>
                                                    <th>@Localizer.T("Common.Status")</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var doc in item.ExpiredDocuments)
                                                {
                                                    var overdueDays = doc.ExpiryDate.HasValue ? (DateTime.UtcNow - doc.ExpiryDate.Value).Days : 0;
                                                    <tr class="table-danger">
                                                        <td>@doc.DocumentName</td>
                                                        <td><span class="badge badge-secondary">@doc.DocumentType</span></td>
                                                        <td>@doc.ExpiryDate?.ToString("dd/MM/yyyy")</td>
                                                        <td><strong>@overdueDays</strong> @Localizer.T("HR.Days")</td>
                                                        <td>
                                                            <span class="badge badge-danger">
                                                                <i class="fas fa-times-circle"></i> @Localizer.T("HR.Expired")
                                                            </span>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-check-circle empty-icon" style="color:var(--color-success)"></i>
                            <h4>@Localizer.T("HR.AllStaffCompliant")</h4>
                            <p>@Localizer.T("HR.AllStaffCompliantMessage")</p>
                            <a asp-action="Index" class="btn btn-success">
                                <i class="fas fa-arrow-left"></i> @Localizer.T("HR.BackToStaffList")
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>