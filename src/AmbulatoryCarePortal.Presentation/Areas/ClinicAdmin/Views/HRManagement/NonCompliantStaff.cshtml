@model List<HRStaffNonCompliantViewModel>
@using System.Globalization

@{
    ViewData["Title"] = "Non-Compliant Staff";
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
}

<div class="fade-in">
    <div class="row">
        <div class="col-12">
            <div class="card card-danger">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-times-circle"></i>
                        @(isArabic ? "الموظفون غير الملتزمين" : "Non-Compliant Staff")
                    </h3>
                    <div class="card-tools">
                        <span class="badge badge-danger">@Model.Count @(isArabic ? "موظف" : "staff")</span>
                        <a asp-action="Index" class="btn btn-sm btn-secondary ml-2">
                            <i class="fas fa-arrow-left"></i> @(isArabic ? "عودة" : "Back")
                        </a>
                    </div>
                </div>

                <div class="card-body p-0">
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <div class="card card-danger m-3">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-user"></i>
                                        <a asp-action="Details" asp-route-id="@item.Staff.Id">
                                            @item.Staff.FullNameEn
                                        </a>
                                        @if (!string.IsNullOrEmpty(item.Staff.FullNameAr))
                                        {
                                            <small class="text-muted" dir="rtl"> (@item.Staff.FullNameAr)</small>
                                        }
                                    </h5>
                                    <div class="card-tools">
                                        <span class="badge badge-danger">
                                            <i class="fas fa-calendar-times"></i>
                                            @item.ExpiredDocumentCount @(isArabic ? "وثيقة منتهية" : "expired documents")
                                        </span>
                                        <span class="badge badge-warning">
                                            <i class="fas fa-hourglass-end"></i>
                                            @item.DaysOverdue @(isArabic ? "يوم متجاوز" : "days overdue")
                                        </span>
                                        <a asp-action="Details" asp-route-id="@item.Staff.Id" class="btn btn-sm btn-info ml-2">
                                            <i class="fas fa-eye"></i> @(isArabic ? "عرض" : "View")
                                        </a>
                                    </div>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-container">
                                        <table class="table table-hover" id="nonCompliantTable_@item.Staff.Id">
                                            <thead>
                                                <tr>
                                                    <th>@(isArabic ? "اسم الوثيقة" : "Document Name")</th>
                                                    <th>@(isArabic ? "النوع" : "Type")</th>
                                                    <th>@(isArabic ? "تاريخ الانتهاء" : "Expiry Date")</th>
                                                    <th>@(isArabic ? "تاريخ التجاوز" : "Overdue By")</th>
                                                    <th>@(isArabic ? "الحالة" : "Status")</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var doc in item.ExpiredDocuments)
                                                {
                                                    var overdueDays = doc.ExpiryDate.HasValue ? (DateTime.UtcNow - doc.ExpiryDate.Value).Days : 0;
                                                    <tr class="table-danger">
                                                        <td>@doc.DocumentName</td>
                                                        <td><span class="badge badge-secondary">@doc.DocumentType</span></td>
                                                        <td>@doc.ExpiryDate?.ToString("dd/MM/yyyy")</td>
                                                        <td><strong>@overdueDays</strong> @(isArabic ? "يوم" : "days")</td>
                                                        <td>
                                                            <span class="badge badge-danger">
                                                                <i class="fas fa-times-circle"></i> @(isArabic ? "منتهية" : "Expired")
                                                            </span>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-check-circle empty-icon" style="color:var(--color-success)"></i>
                            <h4>@(isArabic ? "جميع الموظفين ملتزمون" : "All Staff Are Compliant")</h4>
                            <p>@(isArabic ? "لا توجد وثائق منتهية لأي موظف." : "No expired documents for any staff member.")</p>
                            <a asp-action="Index" class="btn btn-success">
                                <i class="fas fa-arrow-left"></i> @(isArabic ? "العودة إلى القائمة" : "Back to Staff List")
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>