@model List<HRStaffDetailViewModel>
@using System.Globalization

@{
    ViewData["Title"] = "Staff Management";
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    var totalCount = ViewBag.TotalCount ?? 0;
    var currentPage = ViewBag.CurrentPage ?? 1;
    var pageSize = 10;
    var totalPages = totalCount > 0 ? (int)Math.Ceiling((double)totalCount / pageSize) : 1;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-users mr-2"></i>
                    @(isArabic ? "إدارة الموظفين" : "Staff Management")
                </h3>
                <div class="card-tools">
                    <a asp-action="Create" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus"></i> @(isArabic ? "إضافة موظف" : "Add Staff")
                    </a>
                    <a asp-action="ExpiringDocuments" class="btn btn-sm btn-warning">
                        <i class="fas fa-exclamation-triangle"></i> @(isArabic ? "الوثائق المنتهية" : "Expiring Documents")
                    </a>
                    <a asp-action="NonCompliantStaff" class="btn btn-sm btn-danger">
                        <i class="fas fa-times-circle"></i> @(isArabic ? "غير الملتزمين" : "Non-Compliant Staff")
                    </a>
                </div>
            </div>

            <div class="card-body">
                <form method="get" asp-action="Index" class="mb-3">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <div class="input-group">
                                <input type="text" name="searchTerm" class="form-control"
                                       placeholder="@(isArabic ? "بحث بالاسم أو البريد..." : "Search by name or email...")"
                                       value="@ViewBag.SearchTerm" />
                                <button type="submit" class="btn btn-info">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <select name="complianceFilter" class="form-select" onchange="this.form.submit()">
                                <option value="">@(isArabic ? "جميع حالات الامتثال" : "All Compliance")</option>
                                <option value="Compliant" selected="@(ViewBag.ComplianceFilter == "Compliant")">
                                    @(isArabic ? "ممتثل" : "Compliant")
                                </option>
                                <option value="Non-Compliant" selected="@(ViewBag.ComplianceFilter == "Non-Compliant")">
                                    @(isArabic ? "غير ممتثل" : "Non-Compliant")
                                </option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select name="departmentFilter" class="form-select" onchange="this.form.submit()">
                                <option value="">@(isArabic ? "جميع الأقسام" : "All Departments")</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <a asp-action="Index" class="btn btn-secondary w-100">
                                <i class="fas fa-redo"></i> @(isArabic ? "إعادة" : "Reset")
                            </a>
                        </div>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>@(isArabic ? "الاسم" : "Name")</th>
                                <th>@(isArabic ? "الاسم" : "Name")</th>
                                <th>@(isArabic ? "النوع" : "Staff Type")</th>
                                <th>@(isArabic ? "القسم" : "Department")</th>
                                <th>@(isArabic ? "الحالة" : "Status")</th>
                                <th>@(isArabic ? "الوثائق" : "Documents")</th>
                                <th>@(isArabic ? "حالة الامتثال" : "Compliance")</th>
                                <th>@(isArabic ? "آخر تحديث" : "Last Update")</th>
                                <th>@(isArabic ? "الإجراءات" : "Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.Staff.FullNameEn</strong>
                                            @if (!string.IsNullOrEmpty(item.Staff.FullNameAr))
                                            {
                                                <br /><small class="text-muted" dir="rtl">@item.Staff.FullNameAr</small>
                                            }
                                        </td>
                                        <td><span class="badge bg-info">@item.Staff.StaffType</span></td>
                                        <td>@item.Staff.DepartmentName</td>
                                        <td>
                                            @if (item.Staff.IsActive)
                                            {
                                                <span class="badge bg-success">@(isArabic ? "نشط" : "Active")</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">@(isArabic ? "غير نشط" : "Inactive")</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-info" title="Total">@item.TotalDocuments</span>
                                            <span class="badge bg-success" title="Valid">@item.ValidDocuments</span>
                                            @if (item.ExpiringDocuments > 0)
                                            {
                                                <span class="badge bg-warning" title="Expiring">@item.ExpiringDocuments</span>
                                            }
                                            @if (item.ExpiredDocuments > 0)
                                            {
                                                <span class="badge bg-danger" title="Expired">@item.ExpiredDocuments</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.ComplianceStatus == "Compliant")
                                            {
                                                <span class="badge badge-success">
                                                    <i class="fas fa-check-circle"></i> @(isArabic ? "ممتثل" : "Compliant")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">
                                                    <i class="fas fa-times-circle"></i> @(isArabic ? "غير ممتثل" : "Non-Compliant")
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.LastDocumentUpdate > DateTime.MinValue)
                                            {
                                                <small>@item.LastDocumentUpdate.ToString("dd/MM/yyyy")</small>
                                            }
                                            else
                                            {
                                                <small class="text-muted">-</small>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@item.Staff.Id" class="btn btn-sm btn-info" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        <i class="fas fa-users fa-2x d-block mb-2"></i>
                                        @(isArabic ? "لا يوجد موظفون" : "No staff found.")
                                        <a asp-action="Create">@(isArabic ? "إضافة موظف جديد" : "Add a new staff member")</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer clearfix">
                <div class="float-start">
                    <small class="text-muted">
                        @(isArabic ? "عرض" : "Showing") @Model.Count @(isArabic ? "من" : "of") @totalCount
                    </small>
                </div>
                @if (totalPages > 1)
                {
                    <nav class="float-end">
                        <ul class="pagination pagination-sm m-0">
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" href="?page=@(currentPage - 1)&searchTerm=@ViewBag.SearchTerm&complianceFilter=@ViewBag.ComplianceFilter&departmentFilter=@ViewBag.DepartmentFilter">
                                    &laquo;
                                </a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="?page=@i&searchTerm=@ViewBag.SearchTerm&complianceFilter=@ViewBag.ComplianceFilter&departmentFilter=@ViewBag.DepartmentFilter">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link" href="?page=@(currentPage + 1)&searchTerm=@ViewBag.SearchTerm&complianceFilter=@ViewBag.ComplianceFilter&departmentFilter=@ViewBag.DepartmentFilter">
                                    &raquo;
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>
