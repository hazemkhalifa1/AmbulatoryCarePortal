@model List<HRStaffDetailViewModel>
@using System.Globalization
@using AmbulatoryCarePortal.Domain.Entities

@{
    ViewData["Title"] = Localizer.T("Page.StaffManagement");
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    var departments = ViewBag.Departments as IEnumerable<Department> ?? Enumerable.Empty<Department>();
    var totalCount = ViewBag.TotalCount ?? 0;
    var currentPage = ViewBag.CurrentPage ?? 1;
    var pageSize = 10;
    var totalPages = totalCount > 0 ? (int)Math.Ceiling((double)totalCount / pageSize) : 1;
}

<div class="row g-3 mb-4">
    <div class="col-lg-4 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-users",
            Color = "primary",
            Value = totalCount.ToString(),
            Label = Localizer.T("HR.TotalStaff"),
            Badge = Localizer.T("Common.Total"),
            Link = Url.Action("Create"),
            LinkText = Localizer.T("HR.AddStaff")
        }' />
    </div>
    <div class="col-lg-4 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-check-circle",
            Color = "success",
            Value = ViewBag.CompliantCount?.ToString() ?? "0",
            Label = Localizer.T("HR.Compliant"),
            Badge = Localizer.T("Common.Compliant"),
            Link = ""
        }' />
    </div>
    <div class="col-lg-4 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-times-circle",
            Color = "danger",
            Value = ViewBag.NonCompliantCount?.ToString() ?? "0",
            Label = Localizer.T("HR.NonCompliant"),
            Badge = Localizer.T("Common.NonCompliant"),
            Link = ""
        }' />
    </div>
</div>

<div class="data-table-wrapper">
    <div class="data-table-toolbar">
        <div class="toolbar-left">
            <span class="toolbar-title"><i class="fas fa-users me-2"></i>@Localizer.T("Page.StaffManagement")</span>
            <span class="toolbar-count">@totalCount @Localizer.T("HR.StaffCount")</span>
        </div>
        <div class="toolbar-right gap-2">
            <a asp-action="ExpiringDocuments" class="btn btn-sm btn-outline-warning">
                <i class="fas fa-exclamation-triangle"></i> @Localizer.T("HR.ExpiringDocuments")
            </a>
            <a asp-action="NonCompliantStaff" class="btn btn-sm btn-outline-danger">
                <i class="fas fa-times-circle"></i> @Localizer.T("HR.NonCompliantStaff")
            </a>
            <a asp-action="Create" class="btn btn-sm btn-primary">
                <i class="fas fa-plus"></i> @Localizer.T("HR.AddStaff")
            </a>
        </div>
    </div>

    <form method="get" asp-action="Index" role="search">
        <div class="data-table-toolbar" style="border-top: 1px solid var(--border-color); padding-top: 1rem;">
            <div class="toolbar-left gap-2 w-100 flex-wrap">
                <div class="search-box" style="max-width: 250px;">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" name="searchTerm" class="form-control" placeholder="@Localizer.T("HR.SearchPlaceholder")" value="@ViewBag.SearchTerm" />
                </div>
                <select name="complianceFilter" class="form-select" style="width: auto; min-width: 140px;" onchange="this.form.submit()">
                    <option value="">@Localizer.T("HR.AllCompliance")</option>
                    <option value="Compliant" selected="@(ViewBag.ComplianceFilter == "Compliant")">@Localizer.T("HR.Compliant")</option>
                    <option value="Non-Compliant" selected="@(ViewBag.ComplianceFilter == "Non-Compliant")">@Localizer.T("HR.NonCompliant")</option>
                </select>
                <select name="departmentFilter" class="form-select" style="width: auto; min-width: 140px;" onchange="this.form.submit()">
                    <option value="">@Localizer.T("HR.AllDepartments")</option>
                    @foreach (var dept in departments)
                    {
                        <option value="@dept.Id" selected="@(ViewBag.DepartmentFilter?.ToString() == dept.Id.ToString())">@dept.NameEn</option>
                    }
                </select>
                <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search"></i></button>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="fas fa-redo"></i> @Localizer.T("Common.Reset")</a>
            </div>
        </div>
    </form>

    <table class="data-table" id="staffTable">
        <thead>
            <tr>
                <th scope="col">@Localizer.T("HR.Name")</th>
                <th scope="col">@Localizer.T("HR.StaffType")</th>
                <th scope="col">@Localizer.T("HR.Department")</th>
                <th scope="col">@Localizer.T("HR.Status")</th>
                <th scope="col" class="text-center">@Localizer.T("HR.Documents")</th>
                <th scope="col">@Localizer.T("HR.ComplianceStatus")</th>
                <th scope="col">@Localizer.T("HR.LastUpdate")</th>
                <th scope="col" class="text-end">@Localizer.T("HR.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.Staff.FullNameEn</strong>
                            @if (!string.IsNullOrEmpty(item.Staff.FullNameAr))
                            {
                                <br /><small class="text-muted" dir="rtl">@item.Staff.FullNameAr</small>
                            }
                        </td>
                        <td><span class="status-pill needs-review">@item.Staff.StaffType</span></td>
                        <td>@item.Staff.DepartmentName</td>
                        <td>
                            @if (item.Staff.IsActive)
                            {
                                <span class="status-pill active">@Localizer.T("HR.Active")</span>
                            }
                            else
                            {
                                <span class="status-pill inactive">@Localizer.T("HR.Inactive")</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="fw-bold" title="@Localizer.T("HR.TotalDocuments")">@item.TotalDocuments</span>
                            <span class="compliance-badge compliant ms-1" title="@Localizer.T("HR.Verified")">@item.ValidDocuments</span>
                            @if (item.ExpiringDocuments > 0)
                            {
                                <span class="compliance-badge needs-attention ms-1" title="@Localizer.T("HR.ExpiringSoon")">@item.ExpiringDocuments</span>
                            }
                            @if (item.ExpiredDocuments > 0)
                            {
                                <span class="compliance-badge non-compliant ms-1" title="@Localizer.T("Common.Expired")">@item.ExpiredDocuments</span>
                            }
                        </td>
                        <td>
                            @if (item.ComplianceStatus == "Compliant")
                            {
                                <span class="status-pill active"><i class="fas fa-check-circle"></i> @Localizer.T("HR.Compliant")</span>
                            }
                            else
                            {
                                <span class="status-pill inactive"><i class="fas fa-times-circle"></i> @Localizer.T("HR.NonCompliant")</span>
                            }
                        </td>
                        <td>
                            @if (item.LastDocumentUpdate > DateTime.MinValue)
                            {
                                <small>@item.LastDocumentUpdate.ToString("dd/MM/yyyy")</small>
                            }
                            else
                            {
                                <small class="text-muted">-</small>
                            }
                        </td>
                        <td>
                            <div class="cell-actions justify-content-end">
                                <a asp-action="Edit" asp-route-id="@item.Staff.Id" class="btn btn-sm btn-outline-primary" title="@Localizer.T("Common.Edit")" aria-label="@Localizer.T("Common.Edit")">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Staff.Id" class="btn btn-sm btn-outline-info" title="@Localizer.T("Common.View")" aria-label="@Localizer.T("Common.View")">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-4">
                        <partial name="_EmptyState" model='new {
                            Icon = "fa-users",
                            Title = Localizer.T("HR.NoStaffFound"),
                            Message = Localizer.T("HR.NoStaffFoundMessage"),
                            ActionLink = Url.Action("Create"),
                            ActionText = Localizer.T("HR.AddNewStaffMember")
                        }' />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPages > 1)
    {
        <div class="data-table-pagination">
            <div class="page-info">
                @Localizer.T("HR.Showing") @Model.Count @Localizer.T("HR.Of") @totalCount
            </div>
            <div class="page-links">
                <a href="?page=@(currentPage - 1)&searchTerm=@ViewBag.SearchTerm&complianceFilter=@ViewBag.ComplianceFilter&departmentFilter=@ViewBag.DepartmentFilter" class="@(currentPage <= 1 ? "disabled" : "")" aria-label="@Localizer.T("Common.Previous")">
                    <i class="fas fa-chevron-left"></i>
                </a>
                @for (int i = 1; i <= totalPages; i++)
                {
                    if (i == currentPage)
                    {
                        <span class="active">@i</span>
                    }
                    else
                    {
                        <a href="?page=@i&searchTerm=@ViewBag.SearchTerm&complianceFilter=@ViewBag.ComplianceFilter&departmentFilter=@ViewBag.DepartmentFilter">@i</a>
                    }
                }
                <a href="?page=@(currentPage + 1)&searchTerm=@ViewBag.SearchTerm&complianceFilter=@ViewBag.ComplianceFilter&departmentFilter=@ViewBag.DepartmentFilter" class="@(currentPage >= totalPages ? "disabled" : "")" aria-label="@Localizer.T("Common.Next")">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
