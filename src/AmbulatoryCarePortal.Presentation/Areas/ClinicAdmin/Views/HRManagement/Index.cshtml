@model List<HRStaffDetailViewModel>
@using System.Globalization

@{
    ViewData["Title"] = Localizer.T("Page.StaffManagement");
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    var totalCount = ViewBag.TotalCount ?? 0;
    var currentPage = ViewBag.CurrentPage ?? 1;
    var pageSize = 10;
    var totalPages = totalCount > 0 ? (int)Math.Ceiling((double)totalCount / pageSize) : 1;
}

<div class="fade-in">
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="kpi-card">
                <div class="kpi-icon primary"><i class="fas fa-users"></i></div>
                <div class="kpi-label">@Localizer.T("HR.TotalStaff")</div>
                <div class="kpi-value">@totalCount</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="kpi-card">
                <div class="kpi-icon success"><i class="fas fa-check-circle"></i></div>
                <div class="kpi-label">@Localizer.T("HR.Compliant")</div>
                <div class="kpi-value">@ViewBag.CompliantCount</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="kpi-card">
                <div class="kpi-icon danger"><i class="fas fa-times-circle"></i></div>
                <div class="kpi-label">@Localizer.T("HR.NonCompliant")</div>
                <div class="kpi-value">@ViewBag.NonCompliantCount</div>
            </div>
        </div>
    </div>

    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-users"></i>
                @Localizer.T("Page.StaffManagement")
            </h3>
            <div class="card-tools">
                <div class="btn-group">
                    <a asp-action="Create" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus"></i> @Localizer.T("HR.AddStaff")
                    </a>
                    <a asp-action="ExpiringDocuments" class="btn btn-sm btn-warning">
                        <i class="fas fa-exclamation-triangle"></i> @Localizer.T("HR.ExpiringDocuments")
                    </a>
                    <a asp-action="NonCompliantStaff" class="btn btn-sm btn-danger">
                        <i class="fas fa-times-circle"></i> @Localizer.T("HR.NonCompliantStaff")
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            <form method="get" asp-action="Index" class="mb-4">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">@Localizer.T("Common.Search")</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-search"></i></span>
                            <input type="text" name="searchTerm" class="form-control"
                                   placeholder="@Localizer.T("HR.SearchPlaceholder")"
                                   value="@ViewBag.SearchTerm" />
                            <button type="submit" class="btn btn-info">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@Localizer.T("HR.ComplianceStatus")</label>
                        <select name="complianceFilter" class="form-control" onchange="this.form.submit()">
                            <option value="">@Localizer.T("HR.AllCompliance")</option>
                            <option value="Compliant" selected="@(ViewBag.ComplianceFilter == "Compliant")">
                                @Localizer.T("HR.Compliant")
                            </option>
                            <option value="Non-Compliant" selected="@(ViewBag.ComplianceFilter == "Non-Compliant")">
                                @Localizer.T("HR.NonCompliant")
                            </option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">@Localizer.T("HR.Department")</label>
                        <select name="departmentFilter" class="form-control" onchange="this.form.submit()">
                            <option value="">@Localizer.T("HR.AllDepartments")</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <a asp-action="Index" class="btn btn-secondary w-100">
                            <i class="fas fa-redo"></i> @Localizer.T("Common.Reset")
                        </a>
                    </div>
                </div>
            </form>

            <div class="table-container">
                <table class="table table-hover" id="staffTable">
                    <thead>
                        <tr>
                            <th>@Localizer.T("HR.Name")</th>
                            <th>@Localizer.T("HR.StaffType")</th>
                            <th>@Localizer.T("HR.Department")</th>
                            <th>@Localizer.T("HR.Status")</th>
                            <th>@Localizer.T("HR.Documents")</th>
                            <th>@Localizer.T("HR.ComplianceStatus")</th>
                            <th>@Localizer.T("HR.LastUpdate")</th>
                            <th>@Localizer.T("HR.Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.Staff.FullNameEn</strong>
                                        @if (!string.IsNullOrEmpty(item.Staff.FullNameAr))
                                        {
                                            <br /><small class="text-muted" dir="rtl">@item.Staff.FullNameAr</small>
                                        }
                                    </td>
                                    <td><span class="badge badge-info">@item.Staff.StaffType</span></td>
                                    <td>@item.Staff.DepartmentName</td>
                                    <td>
                                        @if (item.Staff.IsActive)
                                        {
                                            <span class="badge badge-success">@Localizer.T("HR.Active")</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">@Localizer.T("HR.Inactive")</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge badge-info" title="@Localizer.T("HR.TotalDocuments")">@item.TotalDocuments</span>
                                        <span class="badge badge-success" title="@Localizer.T("HR.Verified")">@item.ValidDocuments</span>
                                        @if (item.ExpiringDocuments > 0)
                                        {
                                            <span class="badge badge-warning" title="@Localizer.T("HR.ExpiringSoon")">@item.ExpiringDocuments</span>
                                        }
                                        @if (item.ExpiredDocuments > 0)
                                        {
                                            <span class="badge badge-danger" title="@Localizer.T("Common.Expired")">@item.ExpiredDocuments</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.ComplianceStatus == "Compliant")
                                        {
                                            <span class="badge badge-success">
                                                <i class="fas fa-check-circle"></i> @Localizer.T("HR.Compliant")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">
                                                <i class="fas fa-times-circle"></i> @Localizer.T("HR.NonCompliant")
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.LastDocumentUpdate > DateTime.MinValue)
                                        {
                                            <small>@item.LastDocumentUpdate.ToString("dd/MM/yyyy")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">-</small>
                                        }
                                    </td>
                                    <td>
                                        <div class="actions-cell">
                                            <a asp-action="Details" asp-route-id="@item.Staff.Id" class="btn btn-sm btn-info" title="@Localizer.T("Common.View")" aria-label="@Localizer.T("Common.View")">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8">
                                    <div class="empty-state">
                                        <i class="fas fa-users empty-icon"></i>
                                        <h4>@Localizer.T("HR.NoStaffFound")</h4>
                                        <p>@Localizer.T("HR.NoStaffFoundMessage")</p>
                                        <a asp-action="Create" class="btn btn-primary">@Localizer.T("HR.AddNewStaffMember")</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-footer">
                <div class="pagination-info">
                    @Localizer.T("HR.Showing") @Model.Count @Localizer.T("HR.Of") @totalCount
                </div>
                @if (totalPages > 1)
                {
                    <ul class="pagination">
                        <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" href="?page=@(currentPage - 1)&searchTerm=@ViewBag.SearchTerm&complianceFilter=@ViewBag.ComplianceFilter&departmentFilter=@ViewBag.DepartmentFilter" aria-label="@Localizer.T("Common.Previous")">
                                &laquo;
                            </a>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" href="?page=@i&searchTerm=@ViewBag.SearchTerm&complianceFilter=@ViewBag.ComplianceFilter&departmentFilter=@ViewBag.DepartmentFilter">@i</a>
                            </li>
                        }
                        <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                            <a class="page-link" href="?page=@(currentPage + 1)&searchTerm=@ViewBag.SearchTerm&complianceFilter=@ViewBag.ComplianceFilter&departmentFilter=@ViewBag.DepartmentFilter" aria-label="@Localizer.T("Common.Next")">
                                &raquo;
                            </a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </div>
</div>