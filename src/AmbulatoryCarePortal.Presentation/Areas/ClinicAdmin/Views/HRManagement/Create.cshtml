@model CreateHRStaffViewModel
@using System.Globalization

@{
    ViewData["Title"] = Localizer.T("Page.AddStaff");
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("HR.AddNewStaffMember"),
    Icon = "fa-user-plus",
    Breadcrumb = Localizer.T("Page.StaffManagement")
}' />

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="form-card">
            <div class="form-card-header">
                <h3><i class="fas fa-user-plus"></i> @Localizer.T("HR.AddNewStaffMember")</h3>
            </div>

            <form method="post" asp-action="Create">
                @Html.AntiForgeryToken()

                <div class="form-card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="fas fa-exclamation-circle"></i>
                            @Localizer.T("Alert.CorrectErrors")
                            <div asp-validation-summary="All" class="mt-2"></div>
                        </div>
                    }

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FirstName" class="form-label">
                                    @Localizer.T("HR.FirstName") <span class="text-danger">*</span>
                                </label>
                                <input asp-for="FirstName" class="form-control" placeholder="@Localizer.T("HR.FirstName")" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="LastName" class="form-label">
                                    @Localizer.T("HR.LastName") <span class="text-danger">*</span>
                                </label>
                                <input asp-for="LastName" class="form-control" placeholder="@Localizer.T("HR.LastName")" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="NationalId" class="form-label">@Localizer.T("HR.NationalID")</label>
                                <input asp-for="NationalId" class="form-control" placeholder="@Localizer.T("HR.NationalID")" />
                                <span asp-validation-for="NationalId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="StaffType" class="form-label">
                                    @Localizer.T("HR.StaffType") <span class="text-danger">*</span>
                                </label>
                                <select asp-for="StaffType" class="form-select">
                                    <option value="">-- @Localizer.T("HR.Select") --</option>
                                    @foreach (var type in Model.StaffTypes)
                                    {
                                        <option value="@type">@type</option>
                                    }
                                </select>
                                <span asp-validation-for="StaffType" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Email" class="form-label">
                                    @Localizer.T("HR.Email") <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                    <input asp-for="Email" class="form-control" type="email" placeholder="@Localizer.T("HR.EmailPlaceholder")" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PhoneNumber" class="form-label">@Localizer.T("HR.PhoneNumber")</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="@Localizer.T("HR.PhonePlaceholder")" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PositionTitle" class="form-label">
                                    @Localizer.T("HR.PositionTitle") <span class="text-danger">*</span>
                                </label>
                                <input asp-for="PositionTitle" class="form-control" placeholder="@Localizer.T("HR.PositionTitlePlaceholder")" />
                                <span asp-validation-for="PositionTitle" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DepartmentId" class="form-label">
                                    @Localizer.T("HR.Department") <span class="text-danger">*</span>
                                </label>
                                <select asp-for="DepartmentId" class="form-select">
                                    <option value="">-- @Localizer.T("HR.SelectDepartment") --</option>
                                    @foreach (var dept in Model.AvailableDepartments)
                                    {
                                        <option value="@dept.Id">@dept.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="JoinDate" class="form-label">
                                    @Localizer.T("HR.JoinDate") <span class="text-danger">*</span>
                                </label>
                                <input asp-for="JoinDate" class="form-control" type="date"
                                       value="@Model.JoinDate.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="JoinDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-card-footer">
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-times"></i> @Localizer.T("HR.Cancel")
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> @Localizer.T("HR.Save")
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
