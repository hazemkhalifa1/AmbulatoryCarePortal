@model List<ExpiringDocumentViewModel>
@{
    ViewData["Title"] = Localizer.T("Page.ExpiringDocuments");
}

<div class="fade-in">
    <div class="row">
        <div class="col-12">
            <div class="card card-warning">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-exclamation-triangle"></i>
                        @Localizer.T("HR.ExpiringDocuments")
                    </h3>
                    <div class="card-tools">
                        <a asp-action="Index" class="btn btn-sm btn-secondary">
                            <i class="fas fa-arrow-left"></i> @Localizer.T("HR.Back")
                        </a>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-container">
                        <table class="table table-hover" id="expiringTable">
                            <thead>
                                <tr>
                                    <th>@Localizer.T("HR.DocumentName")</th>
                                    <th>@Localizer.T("HR.StaffName")</th>
                                    <th>@Localizer.T("HR.Department")</th>
                                    <th>@Localizer.T("HR.ExpiryDate")</th>
                                    <th>@Localizer.T("HR.DaysLeft")</th>
                                    <th>@Localizer.T("HR.Category")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        var rowClass = item.Category == "Critical" ? "table-danger" :
                                                       item.Category == "Urgent" ? "table-warning" : "";
                                        <tr class="@rowClass">
                                            <td><strong>@item.Document.DocumentName</strong></td>
                                            <td>@item.StaffName</td>
                                            <td>@item.DepartmentName</td>
                                            <td>
                                                @item.Document.ExpiryDate?.ToString("dd/MM/yyyy")
                                            </td>
                                            <td>
                                                <strong>@item.DaysUntilExpiry</strong>
                                                @Localizer.T("HR.Days")
                                            </td>
                                            <td>
                                                @if (item.Category == "Critical")
                                                {
                                                    <span class="badge badge-danger">
                                                        <i class="fas fa-bolt"></i> @Localizer.T("HR.Critical")
                                                    </span>
                                                }
                                                else if (item.Category == "Urgent")
                                                {
                                                    <span class="badge badge-warning">
                                                        <i class="fas fa-exclamation"></i> @Localizer.T("HR.Urgent")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-info">
                                                        <i class="fas fa-info-circle"></i> @Localizer.T("HR.Upcoming")
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6">
                                            <div class="empty-state">
                                                <i class="fas fa-check-circle empty-icon" style="color:var(--color-success)"></i>
                                                <h4>@Localizer.T("Empty.NoDocuments")</h4>
                                                <p>@Localizer.T("HR.NoDocumentsMessage")</p>
                                                <a asp-action="Index" class="btn btn-primary">
                                                    <i class="fas fa-arrow-left"></i> @Localizer.T("HR.BackToStaff")
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @if (Model.Any())
                {
                    <div class="card-footer">
                        <div class="row">
                            <div class="col-md-4">
                                <span class="badge badge-danger"><i class="fas fa-bolt"></i> @Localizer.T("HR.CriticalDesc")</span>
                            </div>
                            <div class="col-md-4">
                                <span class="badge badge-warning"><i class="fas fa-exclamation"></i> @Localizer.T("HR.UrgentDesc")</span>
                            </div>
                            <div class="col-md-4">
                                <span class="badge badge-info"><i class="fas fa-info-circle"></i> @Localizer.T("HR.UpcomingDesc")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>