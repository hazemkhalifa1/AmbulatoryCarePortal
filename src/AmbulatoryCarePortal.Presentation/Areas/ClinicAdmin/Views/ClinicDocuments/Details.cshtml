@model ClinicDocumentDetailDto

@{
    ViewData["Title"] = $"{Model.StandardCode} - {Model.TitleEn}";
    var statusBadge = Model.DocumentStatus switch
    {
        ClinicDocumentStatus.Complete => "success",
        ClinicDocumentStatus.NeedsReview => "warning",
        ClinicDocumentStatus.MissingAttachment => "danger",
        ClinicDocumentStatus.Expired => "secondary",
        ClinicDocumentStatus.Draft => "info",
        _ => "secondary"
    };
    var statusLabel = Model.DocumentStatus switch
    {
        ClinicDocumentStatus.Complete => "Complete",
        ClinicDocumentStatus.NeedsReview => "Needs Review",
        ClinicDocumentStatus.MissingAttachment => "Missing Attachment",
        ClinicDocumentStatus.Expired => "Expired",
        ClinicDocumentStatus.Draft => "Draft",
        _ => Model.DocumentStatus.ToString()
    };
    var canEdit = User.IsInRole("ClinicAdmin");
}

<div class="fade-in">
    <div class="row">
        <div class="col-md-8">
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-file me-2"></i>@Localizer.T("Doc.DocumentInformation")</h3>
                    <div class="card-tools">
                        <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success btn-sm" aria-label="@Localizer.T("Doc.DownloadTitle")">
                            <i class="fas fa-download"></i> @Localizer.T("Button.Download")
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="detail-row">
                        <span class="detail-label">@Localizer.T("Doc.StandardCode")</span>
                        <span class="detail-value"><span class="badge badge-info">@Model.StandardCode</span></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Localizer.T("Doc.TitleEn")</span>
                        <span class="detail-value">@Model.TitleEn</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.TitleAr))
                    {
                        <div class="detail-row">
                            <span class="detail-label">@Localizer.T("Doc.TitleAr")</span>
                            <span class="detail-value" dir="rtl">@Model.TitleAr</span>
                        </div>
                    }
                    <div class="detail-row">
                        <span class="detail-label">@Localizer.T("Doc.DepartmentCategory")</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrEmpty(Model.DepartmentCategory))
                            {
                                @Model.DepartmentCategory
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Localizer.T("Common.Status")</span>
                        <span class="detail-value">
                            <span class="badge badge-@statusBadge fs-6">@statusLabel</span>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Localizer.T("Doc.ExpiryDate")</span>
                        <span class="detail-value">
                            @if (Model.ExpiryDate.HasValue)
                            {
                                <span>@Model.ExpiryDate.Value.ToString("yyyy-MM-dd")</span>
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="detail-row">
                            <span class="detail-label">@Localizer.T("Doc.Notes")</span>
                            <span class="detail-value">@Model.Notes</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-paperclip me-2"></i>@Localizer.T("Doc.Attachments")</h3>
                    <div class="card-tools">
                        <span class="badge badge-info">@Model.Attachments.Count @Localizer.T("Doc.AttachmentCount")</span>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.Attachments.Any())
                    {
                        <div class="table-container">
                            <table class="table table-hover" role="table" aria-label="@Localizer.T("Doc.Attachments")">
                                <thead>
                                    <tr>
                                        <th scope="col">@Localizer.T("Doc.FileName")</th>
                                        <th scope="col">@Localizer.T("Doc.FileType")</th>
                                        <th scope="col">@Localizer.T("Doc.UploadedAt")</th>
                                        <th scope="col">@Localizer.T("Doc.Notes")</th>
                                        <th scope="col" class="text-center">@Localizer.T("Common.Actions")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var attachment in Model.Attachments)
                                    {
                                        <tr>
                                            <td>@attachment.FileName</td>
                                            <td><span class="badge badge-secondary">@attachment.FileType</span></td>
                                            <td>@attachment.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(attachment.Notes))
                                                {
                                                    @attachment.Notes
                                                }
                                                else
                                                {
                                                    <span class="text-muted">&mdash;</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (canEdit)
                                                {
                                                    <button type="button" class="btn btn-sm btn-danger" title="@Localizer.T("Common.Delete")" aria-label="@Localizer.T("Common.Delete")"
                                                            data-bs-toggle="modal" data-bs-target="#deleteAttachmentModal"
                                                            data-attachment-id="@attachment.Id" data-attachment-name="@attachment.FileName">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-success"><i class="fas fa-check"></i> @Localizer.T("Doc.Uploaded")</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-paperclip empty-icon"></i>
                            <h4>@Localizer.T("Doc.NoAttachments")</h4>
                            <p>@Localizer.T("Empty.NoAttachments")</p>
                        </div>
                    }

                    @if (canEdit)
                    {
                        <hr />
                        <h5 class="mb-3"><i class="fas fa-upload me-2"></i>@Localizer.T("Doc.UploadAttachment")</h5>
                        <form method="post" asp-action="UploadEvidence" enctype="multipart/form-data" role="form" aria-label="@Localizer.T("Doc.UploadAttachmentForm")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="clinicDocumentId" value="@Model.Id" />
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <input type="file" name="evidenceFile" class="form-control" required aria-required="true" aria-label="@Localizer.T("Doc.AttachmentFile")" />
                                </div>
                                <div class="col-md-4">
                                    <input type="text" name="notes" class="form-control" placeholder="@Localizer.T("Doc.NotesPlaceholder")" aria-label="@Localizer.T("Doc.NotesPlaceholder")" />
                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-success w-100" aria-label="@Localizer.T("Doc.UploadAttachmentAction")">
                                        <i class="fas fa-upload me-1"></i> @Localizer.T("Button.Upload")
                                    </button>
                                </div>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-@(Model.DocumentStatus == ClinicDocumentStatus.Complete ? "success" : "warning")">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-check-circle me-2"></i>@Localizer.T("Common.Status")</h3>
                </div>
                <div class="card-body text-center">
                    <div class="py-3">
                        <i class="fas @(Model.DocumentStatus == ClinicDocumentStatus.Complete ? "fa-check-circle text-success" : Model.DocumentStatus == ClinicDocumentStatus.Expired ? "fa-calendar-times text-danger" : "fa-hourglass-half text-warning") fa-4x mb-3"></i>
                        <h5 class="@(Model.DocumentStatus == ClinicDocumentStatus.Complete ? "text-success" : Model.DocumentStatus == ClinicDocumentStatus.Expired ? "text-danger" : "text-warning")">@statusLabel</h5>
                        <p class="text-muted">@Localizer.T("Doc.DocumentStatus")</p>
                    </div>

                    @if (canEdit && Model.DocumentStatus != ClinicDocumentStatus.Complete)
                    {
                        <form method="post" asp-action="UpdateStatus" aria-label="@Localizer.T("Doc.UpdateStatusForm")" class="mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="d-grid gap-2">
                                <button type="submit" name="status" value="Complete" class="btn btn-success"
                                        onclick="return confirm('@Localizer.T("Doc.ConfirmMarkComplete")')">
                                    <i class="fas fa-check me-1"></i> @Localizer.T("Doc.MarkComplete")
                                </button>
                                <button type="submit" name="status" value="NeedsReview" class="btn btn-warning"
                                        onclick="return confirm('@Localizer.T("Doc.ConfirmMarkNeedsReview")')">
                                    <i class="fas fa-redo me-1"></i> @Localizer.T("Doc.MarkNeedsReview")
                                </button>
                                <button type="submit" name="status" value="MissingAttachment" class="btn btn-danger"
                                        onclick="return confirm('@Localizer.T("Doc.ConfirmMarkMissingAttachment")')">
                                    <i class="fas fa-paperclip me-1"></i> @Localizer.T("Doc.MarkMissingAttachment")
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>

            <div class="card card-secondary">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-cog me-2"></i>@Localizer.T("Common.Actions")</h3>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success" aria-label="@Localizer.T("Doc.DownloadFilled")">
                            <i class="fas fa-download me-1"></i> @Localizer.T("Doc.DownloadDocument")
                        </a>
                        <a asp-action="Index" class="btn btn-secondary" aria-label="@Localizer.T("Doc.BackToDocumentList")">
                            <i class="fas fa-arrow-left me-1"></i> @Localizer.T("Doc.BackToList")
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Attachment Modal -->
<div class="modal fade" id="deleteAttachmentModal" tabindex="-1" role="dialog" aria-labelledby="deleteAttachmentModalTitle" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteAttachmentModalTitle"><i class="fas fa-exclamation-triangle me-2"></i>@Localizer.T("Doc.ConfirmDelete")</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="@Localizer.T("Common.Close")"></button>
            </div>
            <form method="post" asp-action="DeleteAttachment" id="deleteAttachmentForm">
                <input type="hidden" name="attachmentId" id="deleteAttachmentId" value="" />
                <div class="modal-body">
                    <p>@Localizer.T("Doc.DeleteConfirmMessage")</p>
                    <p class="fw-bold text-danger" id="deleteAttachmentName"></p>
                    <p class="text-muted small">@Localizer.T("Doc.DeleteWarning")</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer.T("Common.Cancel")</button>
                    <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>@Localizer.T("Common.Delete")</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteModal = document.getElementById('deleteAttachmentModal');
            if (deleteModal) {
                deleteModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    document.getElementById('deleteAttachmentId').value = button.getAttribute('data-attachment-id');
                    document.getElementById('deleteAttachmentName').textContent = button.getAttribute('data-attachment-name');
                });
            }
        });
    </script>
}
