@model ClinicDocumentDetailDto

@{
    ViewData["Title"] = $"{Model.StandardCode} - {Model.TitleEn}";
    var statusBadge = Model.DocumentStatus switch
    {
        ClinicDocumentStatus.Complete => "success",
        ClinicDocumentStatus.NeedsReview => "warning",
        ClinicDocumentStatus.MissingAttachment => "danger",
        ClinicDocumentStatus.Expired => "secondary",
        ClinicDocumentStatus.Draft => "info",
        _ => "secondary"
    };
    var statusLabel = Model.DocumentStatus switch
    {
        ClinicDocumentStatus.Complete => "Complete",
        ClinicDocumentStatus.NeedsReview => "Needs Review",
        ClinicDocumentStatus.MissingAttachment => "Missing Attachment",
        ClinicDocumentStatus.Expired => "Expired",
        ClinicDocumentStatus.Draft => "Draft",
        _ => Model.DocumentStatus.ToString()
    };
    var canEdit = User.IsInRole("ClinicAdmin");
}

<div class="fade-in">
    <div class="row">
        <div class="col-md-8">
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-file me-2"></i>Document Information</h3>
                    <div class="card-tools">
                        <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success btn-sm" aria-label="Download document">
                            <i class="fas fa-download"></i> Download
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="detail-row">
                        <span class="detail-label">Standard Code</span>
                        <span class="detail-value"><span class="badge badge-info">@Model.StandardCode</span></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Title (EN)</span>
                        <span class="detail-value">@Model.TitleEn</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.TitleAr))
                    {
                        <div class="detail-row">
                            <span class="detail-label">Title (AR)</span>
                            <span class="detail-value" dir="rtl">@Model.TitleAr</span>
                        </div>
                    }
                    <div class="detail-row">
                        <span class="detail-label">Department Category</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrEmpty(Model.DepartmentCategory))
                            {
                                @Model.DepartmentCategory
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Status</span>
                        <span class="detail-value">
                            <span class="badge badge-@statusBadge fs-6">@statusLabel</span>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Expiry Date</span>
                        <span class="detail-value">
                            @if (Model.ExpiryDate.HasValue)
                            {
                                <span>@Model.ExpiryDate.Value.ToString("yyyy-MM-dd")</span>
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="detail-row">
                            <span class="detail-label">Notes</span>
                            <span class="detail-value">@Model.Notes</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card card-info">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-paperclip me-2"></i>Attachments</h3>
                    <div class="card-tools">
                        <span class="badge badge-info">@Model.Attachments.Count attachment(s)</span>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.Attachments.Any())
                    {
                        <div class="table-container">
                            <table class="table table-hover" role="table" aria-label="Attachments">
                                <thead>
                                    <tr>
                                        <th scope="col">File Name</th>
                                        <th scope="col">File Type</th>
                                        <th scope="col">Uploaded At</th>
                                        <th scope="col">Notes</th>
                                        <th scope="col" class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var attachment in Model.Attachments)
                                    {
                                        <tr>
                                            <td>@attachment.FileName</td>
                                            <td><span class="badge badge-secondary">@attachment.FileType</span></td>
                                            <td>@attachment.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(attachment.Notes))
                                                {
                                                    @attachment.Notes
                                                }
                                                else
                                                {
                                                    <span class="text-muted">&mdash;</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (canEdit)
                                                {
                                                    <button type="button" class="btn btn-sm btn-danger" title="Delete" aria-label="Delete attachment"
                                                            data-bs-toggle="modal" data-bs-target="#deleteAttachmentModal"
                                                            data-attachment-id="@attachment.Id" data-attachment-name="@attachment.FileName">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-success"><i class="fas fa-check"></i> Uploaded</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-paperclip empty-icon"></i>
                            <h4>No Attachments</h4>
                            <p>No attachments yet. Upload supporting documents below.</p>
                        </div>
                    }

                    @if (canEdit)
                    {
                        <hr />
                        <h5 class="mb-3"><i class="fas fa-upload me-2"></i>Upload Attachment</h5>
                        <form method="post" asp-action="UploadEvidence" enctype="multipart/form-data" role="form" aria-label="Upload attachment form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="clinicDocumentId" value="@Model.Id" />
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <input type="file" name="evidenceFile" class="form-control" required aria-required="true" aria-label="Attachment file" />
                                </div>
                                <div class="col-md-4">
                                    <input type="text" name="notes" class="form-control" placeholder="Optional notes..." aria-label="Optional notes" />
                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-success w-100" aria-label="Upload attachment">
                                        <i class="fas fa-upload me-1"></i> Upload
                                    </button>
                                </div>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card card-@(Model.DocumentStatus == ClinicDocumentStatus.Complete ? "success" : "warning")">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-check-circle me-2"></i>Status</h3>
                </div>
                <div class="card-body text-center">
                    <div class="py-3">
                        <i class="fas @(Model.DocumentStatus == ClinicDocumentStatus.Complete ? "fa-check-circle text-success" : Model.DocumentStatus == ClinicDocumentStatus.Expired ? "fa-calendar-times text-danger" : "fa-hourglass-half text-warning") fa-4x mb-3"></i>
                        <h5 class="@(Model.DocumentStatus == ClinicDocumentStatus.Complete ? "text-success" : Model.DocumentStatus == ClinicDocumentStatus.Expired ? "text-danger" : "text-warning")">@statusLabel</h5>
                        <p class="text-muted">Document status</p>
                    </div>

                    @if (canEdit && Model.DocumentStatus != ClinicDocumentStatus.Complete)
                    {
                        <form method="post" asp-action="UpdateStatus" aria-label="Update status form" class="mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="d-grid gap-2">
                                <button type="submit" name="status" value="Complete" class="btn btn-success"
                                        onclick="return confirm('Mark this document as Complete?')">
                                    <i class="fas fa-check me-1"></i> Mark as Complete
                                </button>
                                <button type="submit" name="status" value="NeedsReview" class="btn btn-warning"
                                        onclick="return confirm('Mark this document as Needs Review?')">
                                    <i class="fas fa-redo me-1"></i> Needs Review
                                </button>
                                <button type="submit" name="status" value="MissingAttachment" class="btn btn-danger"
                                        onclick="return confirm('Mark this document as Missing Attachment?')">
                                    <i class="fas fa-paperclip me-1"></i> Missing Attachment
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>

            <div class="card card-secondary">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-cog me-2"></i>Actions</h3>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success" aria-label="Download filled document">
                            <i class="fas fa-download me-1"></i> Download Document
                        </a>
                        <a asp-action="Index" class="btn btn-secondary" aria-label="Back to document list">
                            <i class="fas fa-arrow-left me-1"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Attachment Modal -->
<div class="modal fade" id="deleteAttachmentModal" tabindex="-1" role="dialog" aria-labelledby="deleteAttachmentModalTitle" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteAttachmentModalTitle"><i class="fas fa-exclamation-triangle me-2"></i>Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="DeleteAttachment" id="deleteAttachmentForm">
                <input type="hidden" name="attachmentId" id="deleteAttachmentId" value="" />
                <div class="modal-body">
                    <p>Are you sure you want to delete this attachment?</p>
                    <p class="fw-bold text-danger" id="deleteAttachmentName"></p>
                    <p class="text-muted small">This action cannot be undone. The attachment will be soft-deleted.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteModal = document.getElementById('deleteAttachmentModal');
            if (deleteModal) {
                deleteModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    document.getElementById('deleteAttachmentId').value = button.getAttribute('data-attachment-id');
                    document.getElementById('deleteAttachmentName').textContent = button.getAttribute('data-attachment-name');
                });
            }
        });
    </script>
}
