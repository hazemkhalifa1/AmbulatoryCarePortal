@model ClinicTemplateAssignmentDto
@{
    ViewData["Title"] = $"{Model.StandardCode} - {Model.TitleEn}";
    var variableValues = (List<ClinicTemplateValueDto>?)ViewBag.VariableValues ?? new();
    var activeTab = Context.Request.Query["tab"].FirstOrDefault() ?? "info";

    var statusBadge = Model.AssignmentStatus switch
    {
        "Complete" => "success",
        "NeedsReview" => "warning",
        "MissingAttachment" => "danger",
        "Expired" => "secondary",
        "Draft" => "info",
        _ => "secondary"
    };
    var canEdit = User.IsInRole("ClinicAdmin");
}

<div class="fade-in">
    <div class="template-hero mb-4">
        <div class="template-hero-content">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <h1 class="template-hero-title mb-0"><i class="fas fa-file-alt me-2"></i>@Model.StandardCode - @Model.TitleEn</h1>
                        <span class="status-pill @statusBadge">@Model.AssignmentStatus</span>
                    </div>
                    <p class="template-hero-subtitle mb-0">
                        @variableValues.Count @Localizer.T("Template.Variables")
                    </p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success">
                        <i class="fas fa-download me-1"></i>@Localizer.T("Button.Download")
                    </a>
                    <a asp-action="Index" class="btn btn-light">
                        <i class="fas fa-arrow-left me-1"></i>@Localizer.T("Common.Back")
                    </a>
                </div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs detail-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "info" ? "active" : "")" id="info-tab" data-bs-toggle="tab" data-bs-target="#info" type="button" role="tab">
                <i class="fas fa-info-circle me-1"></i>@Localizer.T("Common.Information")
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "variables" ? "active" : "")" id="variables-tab" data-bs-toggle="tab" data-bs-target="#variables" type="button" role="tab">
                <i class="fas fa-tags me-1"></i>@Localizer.T("Template.Variables") <span class="badge bg-secondary ms-1">@variableValues.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade @(activeTab == "info" ? "show active" : "")" id="info" role="tabpanel">
            <div class="row">
                <div class="col-lg-8 mb-4">
                    <div class="card detail-card h-100">
                        <div class="card-header"><h3 class="card-title"><i class="fas fa-info-circle me-2"></i>@Localizer.T("Doc.DocumentInformation")</h3></div>
                        <div class="card-body">
                            <div class="detail-list">
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Doc.StandardCode")</span>
                                    <span class="detail-value"><span class="badge badge-info">@Model.StandardCode</span></span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Doc.TitleEn")</span>
                                    <span class="detail-value">@Model.TitleEn</span>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.TitleAr))
                                {
                                    <div class="detail-item">
                                        <span class="detail-label">@Localizer.T("Doc.TitleAr")</span>
                                        <span class="detail-value" dir="rtl">@Model.TitleAr</span>
                                    </div>
                                }
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Doc.ExpiryDate")</span>
                                    <span class="detail-value">@(Model.ExpiryDate?.ToString("yyyy-MM-dd") ?? "&mdash;")</span>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.Notes))
                                {
                                    <div class="detail-item">
                                        <span class="detail-label">@Localizer.T("Doc.Notes")</span>
                                        <span class="detail-value">@Model.Notes</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 mb-4">
                    <div class="card action-card mb-4">
                        <div class="card-header"><h3 class="card-title"><i class="fas fa-check-circle me-2"></i>@Localizer.T("Common.Status")</h3></div>
                        <div class="card-body text-center">
                            <div class="py-2">
                                <i class="fas @(Model.AssignmentStatus == "Complete" ? "fa-check-circle text-success" : Model.AssignmentStatus == "Expired" ? "fa-calendar-times text-danger" : "fa-hourglass-half text-warning") fa-4x mb-2"></i>
                                <h4 class="mb-1">@Model.AssignmentStatus</h4>
                                <p class="text-muted small">@Localizer.T("Doc.DocumentStatus")</p>
                            </div>
                            @if (canEdit && Model.AssignmentStatus != "Complete")
                            {
                                <form method="post" asp-action="UpdateStatus" class="mt-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <div class="d-grid gap-2">
                                        <button type="submit" name="status" value="Complete" class="btn btn-success btn-sm"
                                                onclick="return confirm('@Localizer.T("Doc.ConfirmMarkComplete")')">
                                            <i class="fas fa-check me-1"></i> @Localizer.T("Doc.MarkComplete")
                                        </button>
                                        <button type="submit" name="status" value="NeedsReview" class="btn btn-warning btn-sm"
                                                onclick="return confirm('@Localizer.T("Doc.ConfirmMarkNeedsReview")')">
                                            <i class="fas fa-redo me-1"></i> @Localizer.T("Doc.MarkNeedsReview")
                                        </button>
                                        <button type="submit" name="status" value="MissingAttachment" class="btn btn-danger btn-sm"
                                                onclick="return confirm('@Localizer.T("Doc.ConfirmMarkMissingAttachment")')">
                                            <i class="fas fa-paperclip me-1"></i> @Localizer.T("Doc.MarkMissingAttachment")
                                        </button>
                                    </div>
                                </form>
                            }
                        </div>
                    </div>
                    <div class="card action-card">
                        <div class="card-header"><h3 class="card-title"><i class="fas fa-bolt me-2"></i>@Localizer.T("Dashboard.QuickActions")</h3></div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success">
                                    <i class="fas fa-download me-1"></i> @Localizer.T("Doc.DownloadDocument")
                                </a>
                                <a asp-action="Index" class="btn btn-light">
                                    <i class="fas fa-arrow-left me-1"></i> @Localizer.T("Doc.BackToList")
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade @(activeTab == "variables" ? "show active" : "")" id="variables" role="tabpanel">
            <div class="card detail-card">
                <div class="card-header">
                    <h3 class="card-title mb-0"><i class="fas fa-tags me-2"></i>@Localizer.T("Template.Variables")</h3>
                </div>
                <div class="card-body">
                    @if (variableValues.Any())
                    {
                        <div class="table-container">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>@Localizer.T("Template.VariableName")</th>
                                        <th>@Localizer.T("Template.Value")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in variableValues.Select((x, i) => new { x, i }))
                                    {
                                        <tr>
                                            <td>@(v.i + 1)</td>
                                            <td>@v.x.DisplayName</td>
                                            <td>
                                                @if (v.x.IsImage)
                                                {
                                                    if (!string.IsNullOrEmpty(v.x.ImagePath))
                                                    {
                                                        <img src="@v.x.ImagePath" alt="@v.x.DisplayName" style="max-width:150px;max-height:150px;" class="img-thumbnail" />
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">&mdash;</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span>@(!string.IsNullOrEmpty(v.x.Value) ? v.x.Value : "&mdash;")</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-tags fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">@Localizer.T("Template.NoVariables")</h5>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
