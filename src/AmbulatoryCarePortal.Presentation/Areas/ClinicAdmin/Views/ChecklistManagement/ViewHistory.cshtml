@using AmbulatoryCarePortal.Domain.Enums
@model List<ChecklistHistoryViewModel>

@{
    ViewData["Title"] = "Checklist History";
    var templateName = ViewBag.TemplateName as string ?? "Checklist";
    var templateId = ViewBag.TemplateId as int? ?? 0;
}

<div class="row fade-in">
    <div class="col-sm-6">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Back to List
        </a>
    </div>
    <div class="col-sm-6 text-sm-end">
        <a asp-action="Execute" asp-route-templateId="@templateId" class="btn btn-success">
            <i class="fas fa-play me-1"></i> Execute Now
        </a>
    </div>
</div>

<div class="card card-info">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-history"></i> Execution History: <strong>@templateName</strong></h3>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-container">
                <table class="table table-hover" id="historyTable">
                    <thead>
                        <tr>
                            <th>Executed Date</th>
                            <th>Executed By</th>
                            <th class="text-center">Total Items</th>
                            <th class="text-center">Yes Count</th>
                            <th class="text-center">Completion %</th>
                            <th class="text-center">Completion</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="text-nowrap">@item.Round.ExecutedAt.ToString("yyyy-MM-dd")</span>
                                    <br><small class="text-muted">@item.Round.ExecutedAt.ToString("HH:mm")</small>
                                </td>
                                <td>@item.Round.ExecutedBy</td>
                                <td class="text-center">@item.TotalItems</td>
                                <td class="text-center">@item.CompletedItems</td>
                                <td style="min-width: 120px;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height: 8px;">
                                            <div class="progress-bar @(item.CompletionRate >= 80 ? "bg-success" : item.CompletionRate >= 50 ? "bg-warning" : "bg-danger")"
                                                 style="width: @item.CompletionRate%" role="progressbar"
                                                 aria-valuenow="@item.CompletionRate" aria-valuemin="0" aria-valuemax="100" aria-label="Completion @item.CompletionRate%"></div>
                                        </div>
                                        <small class="text-nowrap">@item.CompletionRate%</small>
                                    </div>
                                </td>
                                <td style="min-width: 120px;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height: 8px;">
                                            <div class="progress-bar @(item.CompletionRate >= 80 ? "bg-success" : item.CompletionRate >= 50 ? "bg-warning" : "bg-danger")"
                                                 style="width: @item.CompletionRate%" role="progressbar"
                                                 aria-valuenow="@item.CompletionRate" aria-valuemin="0" aria-valuemax="100" aria-label="Completion @item.CompletionRate%"></div>
                                        </div>
                                        <small class="text-nowrap">@item.CompletionRate%</small>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <form asp-action="Approve" asp-route-roundId="@item.Round.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Approve this checklist execution?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success" title="Approve" aria-label="Approve checklist execution">
                                            <i class="fas fa-check-double me-1"></i> Approve
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body">
                <div class="empty-state">
                    <i class="fas fa-history empty-icon"></i>
                    <h4>No History Found</h4>
                    <p>No execution history found for this checklist.</p>
                    <a asp-action="Execute" asp-route-templateId="@templateId" class="btn btn-success">
                        <i class="fas fa-play me-1"></i> Execute Now
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- Notes Modal -->
<div class="modal fade" id="notesModal" tabindex="-1" aria-hidden="true" aria-labelledby="notesModalLabel">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="notesModalLabel"><i class="fas fa-sticky-note"></i> Execution Notes</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="notesBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showNotes(notes) {
            $('#notesBody').text(notes);
            $('#notesModal').modal('show');
        }
    </script>
}
