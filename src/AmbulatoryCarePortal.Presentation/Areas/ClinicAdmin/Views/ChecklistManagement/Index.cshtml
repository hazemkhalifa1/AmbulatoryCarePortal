@model List<ChecklistDetailViewModel>

@{
    ViewData["Title"] = Localizer.T("Page.ChecklistManagement");
    var totalCount = ViewBag.TotalCount ?? 0;
}

<partial name="_PageHeader" model='new {
    Title = Localizer.T("Page.ChecklistManagement"),
    Icon = "fa-clipboard-list",
    Breadcrumb = ""
}' />

<div class="row g-3 mb-4">
    <div class="col-lg-4 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-clipboard-list",
            Color = "primary",
            Value = totalCount.ToString(),
            Label = Localizer.T("Checklist.AllChecklists"),
            Badge = Localizer.T("Common.Total"),
            Link = Url.Action("Create"),
            LinkText = Localizer.T("Checklist.CreateChecklist")
        }' />
    </div>
    <div class="col-lg-4 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-check-circle",
            Color = "success",
            Value = Model.Count(m => m.CompletionRate >= 80).ToString(),
            Label = Localizer.T("Checklist.CompletedRounds"),
            Badge = Localizer.T("Common.Compliant"),
            Link = ""
        }' />
    </div>
    <div class="col-lg-4 col-md-6">
        <partial name="_HealthMetricCard" model='new {
            Icon = "fa-sync-alt",
            Color = "info",
            Value = Model.Count(m => m.LastExecutedDate == DateTime.MinValue).ToString(),
            Label = Localizer.T("Checklist.NotStarted"),
            Badge = Localizer.T("Common.Attention"),
            Link = ""
        }' />
    </div>
</div>

<div class="data-table-wrapper">
    <div class="data-table-toolbar">
        <div class="toolbar-left">
            <span class="toolbar-title"><i class="fas fa-clipboard-list me-2"></i>@Localizer.T("Checklist.AllChecklists")</span>
            <span class="toolbar-count">@totalCount @Localizer.T("Checklist.TotalChecklists")</span>
        </div>
        <div class="toolbar-right gap-2">
            <div class="search-box">
                <i class="fas fa-search search-icon"></i>
                <input type="text" class="form-control" id="searchInput" placeholder="@Localizer.T("Checklist.SearchPlaceholder")" value="@ViewBag.SearchTerm" aria-label="@Localizer.T("Checklist.SearchPlaceholder")">
            </div>
            <select id="frequencyFilter" class="form-select" style="width: auto; min-width: 120px;" onchange="applyFilters()" aria-label="@Localizer.T("Checklist.Frequency")">
                <option value="">@Localizer.T("Common.All")</option>
                <option value="Daily" selected="@(ViewBag.FrequencyFilter == "Daily")">@Localizer.T("Checklist.Daily")</option>
                <option value="Weekly" selected="@(ViewBag.FrequencyFilter == "Weekly")">@Localizer.T("Checklist.Weekly")</option>
                <option value="Monthly" selected="@(ViewBag.FrequencyFilter == "Monthly")">@Localizer.T("Checklist.Monthly")</option>
            </select>
            <select id="statusFilter" class="form-select" style="width: auto; min-width: 120px;" onchange="applyFilters()" aria-label="@Localizer.T("Common.Status")">
                <option value="">@Localizer.T("Common.All")</option>
                <option value="active" selected="@(ViewBag.StatusFilter == "active")">@Localizer.T("Common.Active")</option>
                <option value="inactive" selected="@(ViewBag.StatusFilter == "inactive")">@Localizer.T("Common.Inactive")</option>
            </select>
            <a asp-action="Create" class="btn btn-sm btn-primary">
                <i class="fas fa-plus me-1"></i> @Localizer.T("Checklist.CreateChecklist")
            </a>
        </div>
    </div>

    <table class="data-table" id="checklistTable">
        <thead>
            <tr>
                <th scope="col">@Localizer.T("Checklist.TemplateName")</th>
                <th scope="col">@Localizer.T("Checklist.Frequency")</th>
                <th scope="col" class="text-center">@Localizer.T("Checklist.TotalRounds")</th>
                <th scope="col" class="text-center">@Localizer.T("Checklist.CompletedRounds")</th>
                <th scope="col">@Localizer.T("Checklist.CompletionPct")</th>
                <th scope="col">@Localizer.T("Checklist.LastExecuted")</th>
                <th scope="col" class="text-end">@Localizer.T("Common.Actions")</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.Template.Name</strong>
                            @if (!string.IsNullOrEmpty(item.Template.NameAr))
                            {
                                <br><small class="text-muted" dir="rtl">@item.Template.NameAr</small>
                            }
                        </td>
                        <td>
                            <span class="status-pill needs-review">@item.Template.Frequency</span>
                        </td>
                        <td class="text-center fw-bold">@item.TotalRounds</td>
                        <td class="text-center fw-bold">@item.CompletedRounds</td>
                        <td>
                            <div class="d-flex align-items-center gap-2" style="min-width: 120px;">
                                <div class="progress flex-grow-1" style="height: 8px;">
                                    <div class="progress-bar @(item.CompletionRate >= 80 ? "bg-success" : item.CompletionRate >= 50 ? "bg-warning" : "bg-danger")"
                                         style="width: @item.CompletionRate%" role="progressbar"
                                         aria-valuenow="@item.CompletionRate" aria-valuemin="0" aria-valuemax="100" aria-label="@Localizer.T("Checklist.Completion") @item.CompletionRate%"></div>
                                </div>
                                <small class="text-nowrap fw-bold">@item.CompletionRate%</small>
                            </div>
                        </td>
                        <td>
                            @if (item.LastExecutedDate == DateTime.MinValue)
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                <span>@item.LastExecutedDate.ToString("yyyy-MM-dd")</span>
                            }
                        </td>
                        <td>
                            <div class="cell-actions justify-content-end">
                                <a asp-action="Execute" asp-route-templateId="@item.Template.Id"
                                   class="btn btn-sm btn-outline-success" title="@Localizer.T("Checklist.Execute")" aria-label="@Localizer.T("Checklist.Execute")">
                                    <i class="fas fa-play"></i>
                                </a>
                                <a asp-action="ViewHistory" asp-route-templateId="@item.Template.Id"
                                   class="btn btn-sm btn-outline-info" title="@Localizer.T("Checklist.ViewHistory")" aria-label="@Localizer.T("Checklist.ViewHistory")">
                                    <i class="fas fa-history"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-warning" title="@Localizer.T("Checklist.Analytics")"
                                        aria-label="@Localizer.T("Checklist.Analytics")"
                                        onclick="showAnalytics(@item.Template.Id)">
                                    <i class="fas fa-chart-bar"></i>
                                </button>
                                <a asp-action="Export" asp-route-templateId="@item.Template.Id" asp-route-format="excel"
                                   class="btn btn-sm btn-outline-secondary" title="@Localizer.T("Common.Export")" aria-label="@Localizer.T("Common.Export")">
                                    <i class="fas fa-download"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-4">
                        <partial name="_EmptyState" model='new {
                            Icon = "fa-clipboard-list",
                            Title = Localizer.T("Empty.NoChecklists"),
                            Description = Localizer.T("Checklist.NoChecklistsMessage"),
                            ActionLink = Url.Action("Create"),
                            ActionText = Localizer.T("Checklist.CreateChecklist")
                        }' />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="data-table-pagination">
            <div class="page-info">
                @Localizer.T("Common.Showing") @Model.Count @Localizer.T("Common.Of") @totalCount @Localizer.T("Checklist.TotalChecklists")
            </div>
            <div class="page-links">
                @for (int p = 1; p <= ViewBag.TotalPages; p++)
                {
                    if (p == ViewBag.CurrentPage)
                    {
                        <span class="active">@p</span>
                    }
                    else
                    {
                        <a href="javascript:void(0)" onclick="goToPage(@p)">@p</a>
                    }
                }
            </div>
        </div>
    }
</div>

<div class="modal fade" id="analyticsModal" tabindex="-1" aria-hidden="true" aria-labelledby="analyticsModalLabel">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="analyticsModalLabel"><i class="fas fa-chart-bar"></i> @Localizer.T("Checklist.Analytics")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@Localizer.T("Common.Close")"></button>
            </div>
            <div class="modal-body" id="analyticsBody">
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin fa-2x"></i>
                    <p class="mt-2">@Localizer.T("Common.Loading")</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer.T("Common.Close")</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function applyFilters() {
            const search = $('#searchInput').val();
            const frequency = $('#frequencyFilter').val();
            const status = $('#statusFilter').val();
            const params = new URLSearchParams({ searchTerm: search, frequencyFilter: frequency, statusFilter: status });
            window.location.href = '@Url.Action("Index")?' + params.toString();
        }

        function goToPage(page) {
            const search = $('#searchInput').val();
            const frequency = $('#frequencyFilter').val();
            const status = $('#statusFilter').val();
            const params = new URLSearchParams({ page, pageSize: 10, searchTerm: search, frequencyFilter: frequency, statusFilter: status });
            window.location.href = '@Url.Action("Index")?' + params.toString();
        }

        function showAnalytics(templateId) {
            $('#analyticsModal').modal('show');
            $('#analyticsBody').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x"></i><p class="mt-2">@Localizer.T("Common.Loading")</p></div>');
            $.getJSON('/api/checklist/analytics?templateId=' + templateId)
                .done(function(data) {
                    const html = `
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="health-metric-card">
                                    <div class="metric-icon info"><i class="fas fa-clipboard-list"></i></div>
                                    <div class="metric-content"><span class="metric-value">${data.totalRounds}</span><span class="metric-label">@Localizer.T("Checklist.TotalRounds")</span></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="health-metric-card">
                                    <div class="metric-icon success"><i class="fas fa-check-circle"></i></div>
                                    <div class="metric-content"><span class="metric-value">${data.completedRounds}</span><span class="metric-label">@Localizer.T("Checklist.CompletedRounds")</span></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="health-metric-card">
                                    <div class="metric-icon warning"><i class="fas fa-check-double"></i></div>
                                    <div class="metric-content"><span class="metric-value">${data.approvedRounds}</span><span class="metric-label">@Localizer.T("Checklist.ApprovedRounds")</span></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="health-metric-card">
                                    <div class="metric-icon danger"><i class="fas fa-calendar"></i></div>
                                    <div class="metric-content"><span class="metric-value">${data.lastExecutedDate ? new Date(data.lastExecutedDate).toLocaleDateString() : '@Localizer.T("HR.NA")'}</span><span class="metric-label">@Localizer.T("Checklist.LastExecuted")</span></div>
                                </div>
                            </div>
                        </div>
                        <div class="row g-3 mt-3">
                            <div class="col-md-6">
                                <h6>@Localizer.T("Checklist.Completion")</h6>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-success" style="width: ${data.completionRate}%">${data.completionRate}%</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h6>@Localizer.T("Checklist.Approve") Rate</h6>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-info" style="width: ${data.approvalRate}%">${data.approvalRate}%</div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-3"><strong>@Localizer.T("Checklist.TemplateLabel"):</strong> ${data.templateName}</div>
                    `;
                    $('#analyticsBody').html(html);
                })
                .fail(function() {
                    $('#analyticsBody').html('<div class="alert alert-danger">@Localizer.T("Checklist.FailedToLoadAnalytics")</div>');
                });
        }

        $('#searchInput').on('keypress', function(e) {
            if (e.key === 'Enter') applyFilters();
        });
    </script>
}
