@model List<ChecklistDetailViewModel>

@{
    ViewData["Title"] = "Checklist Management";
}

<div class="row fade-in">
    <div class="col-sm-6">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Create New Checklist
        </a>
    </div>
    <div class="col-sm-6 text-sm-end">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-sync-alt me-1"></i> Refresh
        </a>
    </div>
</div>

<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-clipboard-list"></i> All Checklists</h3>
        <div class="card-tools">
            <div class="table-toolbar">
                <div class="search-box">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" class="form-control" data-table-search="checklistTable" id="searchInput" placeholder="Search..." value="@ViewBag.SearchTerm" aria-label="Search checklists">
                </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="form-group">
                    <label class="form-label small">Frequency</label>
                    <select id="frequencyFilter" class="form-select" onchange="applyFilters()" aria-label="Filter by frequency">
                        <option value="">All Frequencies</option>
                        <option value="Daily" selected="@(ViewBag.FrequencyFilter == "Daily")">Daily</option>
                        <option value="Weekly" selected="@(ViewBag.FrequencyFilter == "Weekly")">Weekly</option>
                        <option value="Monthly" selected="@(ViewBag.FrequencyFilter == "Monthly")">Monthly</option>
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label class="form-label small">Status</label>
                    <select id="statusFilter" class="form-select" onchange="applyFilters()" aria-label="Filter by status">
                        <option value="">All Status</option>
                        <option value="active" selected="@(ViewBag.StatusFilter == "active")">Active</option>
                        <option value="inactive" selected="@(ViewBag.StatusFilter == "inactive")">Inactive</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="table-container">
            <table class="table table-hover" id="checklistTable">
                <thead>
                    <tr>
                        <th>Template Name</th>
                        <th>Frequency</th>
                        <th class="text-center">Total Rounds</th>
                        <th class="text-center">Completed Rounds</th>
                        <th class="text-center">Completion %</th>
                        <th>Last Executed</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var idx = 0;
                        foreach (var item in Model)
                        {
                            idx++;
                            <tr>
                                <td>
                                    <strong>@item.Template.Name</strong>
                                    @if (!string.IsNullOrEmpty(item.Template.NameAr))
                                    {
                                        <br><small class="text-muted" dir="rtl">@item.Template.NameAr</small>
                                    }
                                </td>
                                <td>
                                    @if (item.Template.Frequency.ToString() == "Daily")
                                    {
                                        <span class="badge badge-info">@item.Template.Frequency</span>
                                    }
                                    else if (item.Template.Frequency.ToString() == "Weekly")
                                    {
                                        <span class="badge badge-warning">@item.Template.Frequency</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">@item.Template.Frequency</span>
                                    }
                                </td>
                                <td class="text-center">@item.TotalRounds</td>
                                <td class="text-center">@item.CompletedRounds</td>
                                <td style="min-width: 120px;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height: 8px;">
                                            <div class="progress-bar @(item.CompletionRate >= 80 ? "bg-success" : item.CompletionRate >= 50 ? "bg-warning" : "bg-danger")"
                                                 style="width: @item.CompletionRate%" role="progressbar"
                                                 aria-valuenow="@item.CompletionRate" aria-valuemin="0" aria-valuemax="100" aria-label="Completion @item.CompletionRate%"></div>
                                        </div>
                                        <small class="text-nowrap">@item.CompletionRate%</small>
                                    </div>
                                </td>
                                <td>
                                    @if (item.LastExecutedDate == DateTime.MinValue)
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                    else
                                    {
                                        <span>@item.LastExecutedDate.ToString("yyyy-MM-dd")</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="actions-cell">
                                        <a asp-action="Execute" asp-route-templateId="@item.Template.Id"
                                           class="btn btn-sm btn-success" title="Execute" aria-label="Execute @item.Template.Name">
                                            <i class="fas fa-play"></i>
                                        </a>
                                        <a asp-action="ViewHistory" asp-route-templateId="@item.Template.Id"
                                           class="btn btn-sm btn-info" title="View History" aria-label="View history for @item.Template.Name">
                                            <i class="fas fa-history"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-warning" title="Analytics"
                                                aria-label="Show analytics for @item.Template.Name"
                                                onclick="showAnalytics(@item.Template.Id)">
                                            <i class="fas fa-chart-bar"></i>
                                        </button>
                                        <a asp-action="Export" asp-route-templateId="@item.Template.Id" asp-route-format="excel"
                                           class="btn btn-sm btn-secondary" title="Export" aria-label="Export @item.Template.Name">
                                            <i class="fas fa-download"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <i class="fas fa-clipboard-list empty-icon"></i>
                                    <h4>No Checklists Found</h4>
                                    <p>No checklists found. Click "Create New Checklist" to get started.</p>
                                    <a asp-action="Create" class="btn btn-primary">Create New Checklist</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="table-footer">
                <div class="pagination-info">Showing @Model.Count of @ViewBag.TotalCount total checklists</div>
                <ul class="pagination">
                    @for (int p = 1; p <= ViewBag.TotalPages; p++)
                    {
                        <li class="page-item @(p == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="javascript:void(0)" onclick="goToPage(@p)" aria-label="Page @p">@p</a>
                        </li>
                    }
                </ul>
            </div>
        }
        else
        {
            <div class="text-muted small mt-3">
                Showing @Model.Count of @ViewBag.TotalCount total checklists
            </div>
        }
    </div>
</div>

<!-- Analytics Modal -->
<div class="modal fade" id="analyticsModal" tabindex="-1" aria-hidden="true" aria-labelledby="analyticsModalLabel">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="analyticsModalLabel"><i class="fas fa-chart-bar"></i> Checklist Analytics</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="analyticsBody">
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin fa-2x"></i>
                    <p class="mt-2">Loading analytics...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function applyFilters() {
            const search = $('#searchInput').val();
            const frequency = $('#frequencyFilter').val();
            const status = $('#statusFilter').val();
            const params = new URLSearchParams({ searchTerm: search, frequencyFilter: frequency, statusFilter: status });
            window.location.href = '@Url.Action("Index")?' + params.toString();
        }

        function goToPage(page) {
            const search = $('#searchInput').val();
            const frequency = $('#frequencyFilter').val();
            const status = $('#statusFilter').val();
            const params = new URLSearchParams({ page, pageSize: 10, searchTerm: search, frequencyFilter: frequency, statusFilter: status });
            window.location.href = '@Url.Action("Index")?' + params.toString();
        }

        function showAnalytics(templateId) {
            $('#analyticsModal').modal('show');
            $('#analyticsBody').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x"></i><p class="mt-2">Loading analytics...</p></div>');
            $.getJSON('/api/checklist/analytics?templateId=' + templateId)
                .done(function(data) {
                    const html = `
                        <div class="row">
                            <div class="col-md-6">
                                <div class="small-box bg-info">
                                    <div class="inner">
                                        <h3>${data.totalRounds}</h3>
                                        <p>Total Rounds</p>
                                    </div>
                                    <div class="icon"><i class="fas fa-clipboard-list"></i></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="small-box bg-success">
                                    <div class="inner">
                                        <h3>${data.completedRounds}</h3>
                                        <p>Completed Rounds</p>
                                    </div>
                                    <div class="icon"><i class="fas fa-check-circle"></i></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="small-box bg-warning">
                                    <div class="inner">
                                        <h3>${data.approvedRounds}</h3>
                                        <p>Approved Rounds</p>
                                    </div>
                                    <div class="icon"><i class="fas fa-check-double"></i></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="small-box bg-danger">
                                    <div class="inner">
                                        <h3>${data.lastExecutedDate ? new Date(data.lastExecutedDate).toLocaleDateString() : 'N/A'}</h3>
                                        <p>Last Executed</p>
                                    </div>
                                    <div class="icon"><i class="fas fa-calendar"></i></div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <h6>Completion Rate</h6>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-success" style="width: ${data.completionRate}%" role="progressbar" aria-valuenow="${data.completionRate}" aria-valuemin="0" aria-valuemax="100">
                                        ${data.completionRate}%
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h6>Approval Rate</h6>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-info" style="width: ${data.approvalRate}%" role="progressbar" aria-valuenow="${data.approvalRate}" aria-valuemin="0" aria-valuemax="100">
                                        ${data.approvalRate}%
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-3">
                            <strong>Template:</strong> ${data.templateName}
                        </div>
                    `;
                    $('#analyticsBody').html(html);
                })
                .fail(function() {
                    $('#analyticsBody').html('<div class="alert alert-danger">Failed to load analytics.</div>');
                });
        }

        $('#searchInput').on('keypress', function(e) {
            if (e.key === 'Enter') applyFilters();
        });
    </script>
}
