@model List<ChecklistDetailViewModel>

@{
    ViewData["Title"] = "Checklist Management";
}

<div class="row mb-3">
    <div class="col-sm-6">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Create New Checklist
        </a>
    </div>
    <div class="col-sm-6 text-sm-end">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-sync-alt"></i> Refresh
        </a>
    </div>
</div>

<div class="card card-primary card-outline">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-clipboard-list"></i> All Checklists
        </h3>
        <div class="card-tools">
            <div class="input-group input-group-sm" style="width: 200px;">
                <input type="text" id="searchInput" class="form-control" placeholder="Search..." value="@ViewBag.SearchTerm">
                <div class="input-group-append">
                    <button type="button" class="btn btn-default" onclick="applyFilters()">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label small text-muted">Frequency</label>
                <select id="frequencyFilter" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">All Frequencies</option>
                    <option value="Daily" selected="@(ViewBag.FrequencyFilter == "Daily")">Daily</option>
                    <option value="Weekly" selected="@(ViewBag.FrequencyFilter == "Weekly")">Weekly</option>
                    <option value="Monthly" selected="@(ViewBag.FrequencyFilter == "Monthly")">Monthly</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small text-muted">Status</label>
                <select id="statusFilter" class="form-select form-select-sm" onchange="applyFilters()">
                    <option value="">All Status</option>
                    <option value="active" selected="@(ViewBag.StatusFilter == "active")">Active</option>
                    <option value="inactive" selected="@(ViewBag.StatusFilter == "inactive")">Inactive</option>
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th>Template Name</th>
                        <th>Frequency</th>
                        <th>Total Rounds</th>
                        <th>Completed Rounds</th>
                        <th>Completion %</th>
                        <th>Last Executed</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        var idx = 0;
                        foreach (var item in Model)
                        {
                            idx++;
                            <tr>
                                <td>
                                    <strong>@item.Template.Name</strong>
                                    @if (!string.IsNullOrEmpty(item.Template.NameAr))
                                    {
                                        <br><small class="text-muted" dir="rtl">@item.Template.NameAr</small>
                                    }
                                </td>
                                <td>
                                    @if (item.Template.Frequency.ToString() == "Daily")
                                    {
                                        <span class="badge bg-info">@item.Template.Frequency</span>
                                    }
                                    else if (item.Template.Frequency.ToString() == "Weekly")
                                    {
                                        <span class="badge bg-warning">@item.Template.Frequency</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Template.Frequency</span>
                                    }
                                </td>
                                <td class="text-center">@item.TotalRounds</td>
                                <td class="text-center">@item.CompletedRounds</td>
                                <td style="min-width: 120px;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress progress-xs flex-grow-1" style="height: 8px;">
                                            <div class="progress-bar @(item.CompletionRate >= 80 ? "bg-success" : item.CompletionRate >= 50 ? "bg-warning" : "bg-danger")"
                                                 style="width: @item.CompletionRate%"></div>
                                        </div>
                                        <small class="text-nowrap">@item.CompletionRate%</small>
                                    </div>
                                </td>
                                <td>
                                    @if (item.LastExecutedDate == DateTime.MinValue)
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                    else
                                    {
                                        <span>@item.LastExecutedDate.ToString("yyyy-MM-dd")</span>
                                    }
                                </td>
                                <td class="text-nowrap">
                                    <a asp-action="Execute" asp-route-templateId="@item.Template.Id"
                                       class="btn btn-sm btn-success" title="Execute">
                                        <i class="fas fa-play"></i>
                                    </a>
                                    <a asp-action="ViewHistory" asp-route-templateId="@item.Template.Id"
                                       class="btn btn-sm btn-info" title="View History">
                                        <i class="fas fa-history"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-warning" title="Analytics"
                                            onclick="showAnalytics(@item.Template.Id)">
                                        <i class="fas fa-chart-bar"></i>
                                    </button>
                                    <a asp-action="Export" asp-route-templateId="@item.Template.Id" asp-route-format="excel"
                                       class="btn btn-sm btn-secondary" title="Export">
                                        <i class="fas fa-download"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="fas fa-clipboard-list fa-2x mb-2 d-block"></i>
                                No checklists found. Click "Create New Checklist" to get started.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <nav>
                <ul class="pagination pagination-sm justify-content-center">
                    @for (int p = 1; p <= ViewBag.TotalPages; p++)
                    {
                        <li class="page-item @(p == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="javascript:void(0)" onclick="goToPage(@p)">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        }

        <div class="text-muted small">
            Showing @Model.Count of @ViewBag.TotalCount total checklists
        </div>
    </div>
</div>

<!-- Analytics Modal -->
<div class="modal fade" id="analyticsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-chart-bar"></i> Checklist Analytics</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="analyticsBody">
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin fa-2x"></i>
                    <p class="mt-2">Loading analytics...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function applyFilters() {
            const search = $('#searchInput').val();
            const frequency = $('#frequencyFilter').val();
            const status = $('#statusFilter').val();
            const params = new URLSearchParams({ searchTerm: search, frequencyFilter: frequency, statusFilter: status });
            window.location.href = '@Url.Action("Index")?' + params.toString();
        }

        function goToPage(page) {
            const search = $('#searchInput').val();
            const frequency = $('#frequencyFilter').val();
            const status = $('#statusFilter').val();
            const params = new URLSearchParams({ page, pageSize: 10, searchTerm: search, frequencyFilter: frequency, statusFilter: status });
            window.location.href = '@Url.Action("Index")?' + params.toString();
        }

        function showAnalytics(templateId) {
            $('#analyticsModal').modal('show');
            $('#analyticsBody').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x"></i><p class="mt-2">Loading analytics...</p></div>');
            $.getJSON('/api/checklist/analytics?templateId=' + templateId)
                .done(function(data) {
                    const html = `
                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-box bg-info">
                                    <span class="info-box-icon"><i class="fas fa-clipboard-list"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Total Rounds</span>
                                        <span class="info-box-number">${data.totalRounds}</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-box bg-success">
                                    <span class="info-box-icon"><i class="fas fa-check-circle"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Completed Rounds</span>
                                        <span class="info-box-number">${data.completedRounds}</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-box bg-warning">
                                    <span class="info-box-icon"><i class="fas fa-check-double"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Approved Rounds</span>
                                        <span class="info-box-number">${data.approvedRounds}</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-box bg-danger">
                                    <span class="info-box-icon"><i class="fas fa-calendar"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Last Executed</span>
                                        <span class="info-box-number">${data.lastExecutedDate ? new Date(data.lastExecutedDate).toLocaleDateString() : 'N/A'}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <h6>Completion Rate</h6>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-success" style="width: ${data.completionRate}%">
                                        ${data.completionRate}%
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h6>Approval Rate</h6>
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-info" style="width: ${data.approvalRate}%">
                                        ${data.approvalRate}%
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-3">
                            <strong>Template:</strong> ${data.templateName}
                        </div>
                    `;
                    $('#analyticsBody').html(html);
                })
                .fail(function() {
                    $('#analyticsBody').html('<div class="alert alert-danger">Failed to load analytics.</div>');
                });
        }

        $('#searchInput').on('keypress', function(e) {
            if (e.key === 'Enter') applyFilters();
        });
    </script>
}
