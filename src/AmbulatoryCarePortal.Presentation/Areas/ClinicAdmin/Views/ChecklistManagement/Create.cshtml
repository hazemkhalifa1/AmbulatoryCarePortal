@model CreateChecklistViewModel

@{
    ViewData["Title"] = Localizer.T("Page.CreateChecklist");
}

<div class="row fade-in">
    <div class="col-sm-6">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> @Localizer.T("HR.BackToList")
        </a>
    </div>
</div>

<form asp-action="Create" method="post" id="checklistForm">
    <div class="row">
        <div class="col-md-12">
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-clipboard-list"></i> @Localizer.T("Checklist.TemplateLabel")</h3>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Name" class="form-label">@Localizer.T("Common.Name") <span class="required">*</span></label>
                                <input asp-for="Name" class="form-control" placeholder="@Localizer.T("Checklist.NamePlaceholder")" required>
                                <span asp-validation-for="Name" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="NameAr" class="form-label">@Localizer.T("Checklist.NameAr") <span dir="rtl">الاسم</span></label>
                                <input asp-for="NameAr" class="form-control" placeholder="أدخل اسم القائمة" dir="rtl">
                                <span asp-validation-for="NameAr" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Frequency" class="form-label">@Localizer.T("Common.Frequency") <span class="required">*</span></label>
                                <select asp-for="Frequency" class="form-select">
                                    <option value="">@Localizer.T("Checklist.SelectFrequency")</option>
                                    @if (Model.Frequencies.Any())
                                    {
                                        @foreach (var freq in Model.Frequencies)
                                        {
                                            <option value="@freq">@freq</option>
                                        }
                                    }
                                    else
                                    {
                                        <option value="Daily">@Localizer.T("Checklist.Daily")</option>
                                        <option value="Weekly">@Localizer.T("Checklist.Weekly")</option>
                                        <option value="Monthly">@Localizer.T("Checklist.Monthly")</option>
                                    }
                                </select>
                                <span asp-validation-for="Frequency" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DepartmentId" class="form-label">@Localizer.T("HR.Department")</label>
                                <select asp-for="DepartmentId" class="form-select">
                                    <option value="">@Localizer.T("Common.All")</option>
                                    @if (Model.AvailableDepartments.Any())
                                    {
                                        @foreach (var dept in Model.AvailableDepartments)
                                        {
                                            <option value="@dept.Id">@dept.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="DepartmentId" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="form-label">@Localizer.T("Common.Description")</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="@Localizer.T("Checklist.DescriptionPlaceholder")"></textarea>
                        <span asp-validation-for="Description" class="invalid-feedback"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title"><i class="fas fa-list"></i> @Localizer.T("Checklist.Items")</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-primary btn-sm" onclick="addItem()">
                    <i class="fas fa-plus"></i> @Localizer.T("Checklist.AddItem")
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-container">
                <table class="table table-hover" id="itemsTable">
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>@Localizer.T("Checklist.QuestionText") <span class="required">*</span></th>
                            <th>@Localizer.T("Checklist.QuestionTextAr")</th>
                            <th style="width: 80px;">@Localizer.T("Checklist.Order")</th>
                            <th style="width: 80px;">@Localizer.T("Checklist.Weight")</th>
                            <th style="width: 50px;"></th>
                        </tr>
                    </thead>
                    <tbody id="itemsContainer">
                        <tr id="noItemsRow">
                            <td colspan="6">
                                <div class="empty-state">
                                    <i class="fas fa-plus-circle empty-icon"></i>
                                    <h4>@Localizer.T("Checklist.NoItems")</h4>
                                    <p>@Localizer.T("Checklist.NoItemsMessage")</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i> @Localizer.T("Checklist.CreateChecklist")
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">@Localizer.T("Common.Cancel")</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let itemIndex = 0;

        function addItem() {
            $('#noItemsRow').hide();

            const html = `
                <tr class="item-row" data-index="${itemIndex}">
                    <td class="item-counter text-center align-middle">${itemIndex + 1}</td>
                    <td>
                        <input type="text" name="Items[${itemIndex}].QuestionText" class="form-control form-control-sm" placeholder="@Localizer.T("Checklist.QuestionPlaceholder")" required>
                    </td>
                    <td>
                        <input type="text" name="Items[${itemIndex}].QuestionTextAr" class="form-control form-control-sm" placeholder="أدخل السؤال" dir="rtl">
                    </td>
                    <td>
                        <input type="number" name="Items[${itemIndex}].ItemOrder" class="form-control form-control-sm" value="${itemIndex + 1}" min="1">
                    </td>
                    <td>
                        <input type="number" name="Items[${itemIndex}].Weight" class="form-control form-control-sm" value="1" min="1" max="100">
                    </td>
                    <td class="text-center align-middle">
                        <button type="button" class="btn btn-danger btn-sm" onclick="removeItem(this)" aria-label="@Localizer.T("Checklist.RemoveItem")">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            `;

            $('#itemsContainer').append(html);
            itemIndex++;
        }

        function removeItem(btn) {
            $(btn).closest('tr').remove();
            recalcCounters();
            if ($('.item-row').length === 0) {
                $('#noItemsRow').show();
            }
        }

        function recalcCounters() {
            $('.item-row').each(function(i) {
                $(this).find('.item-counter').text(i + 1);
                $(this).find('input[name$=".ItemOrder"]').val(i + 1);
                $(this).find('input').each(function() {
                    const name = $(this).attr('name');
                    if (name) {
                        $(this).attr('name', name.replace(/Items\[\d+\]/, `Items[${i}]`));
                    }
                });
            });
            itemIndex = $('.item-row').length;
        }

        $('#checklistForm').on('submit', function(e) {
            const rows = $('.item-row').length;
            if (rows === 0) {
                e.preventDefault();
                alert('@Localizer.T("Checklist.AddItemRequired")');
                return false;
            }
        });
    </script>
}
