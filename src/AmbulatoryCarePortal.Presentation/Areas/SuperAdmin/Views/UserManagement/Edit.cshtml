@model AmbulatoryCarePortal.Presentation.ViewModels.UserRoleManagementViewModel

@{
    ViewData["Title"] = Localizer.T("Page.EditUser");
}

<div class="row fade-in">
    <div class="col-md-8 offset-md-2">
        <div class="card card-warning">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-user-edit"></i> @Localizer.T("Page.EditUser") - @Model.Email</h3>
            </div>
            <form method="post" asp-action="Edit" asp-route-id="@Model.UserId" aria-label="Edit user form">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="UserId" />

                    <div class="form-group">
                        <label asp-for="Email" class="form-label">@Localizer.T("User.Email") <span class="required">*</span></label>
                        <div class="input-group">
                            <div class="input-group-text"><i class="fas fa-envelope"></i></div>
                            <input asp-for="Email" class="form-control" type="email" required aria-required="true" />
                        </div>
                        <span asp-validation-for="Email" class="invalid-feedback"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="FullName" class="form-label">@Localizer.T("User.FullName") <span class="required">*</span></label>
                        <div class="input-group">
                            <div class="input-group-text"><i class="fas fa-user"></i></div>
                            <input asp-for="FullName" class="form-control" required aria-required="true" />
                        </div>
                        <span asp-validation-for="FullName" class="invalid-feedback"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PhoneNumber" class="form-label">@Localizer.T("User.Phone")</label>
                        <div class="input-group">
                            <div class="input-group-text"><i class="fas fa-phone"></i></div>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="SelectedRole" class="form-label">@Localizer.T("User.Role") <span class="required">*</span></label>
                        <select asp-for="SelectedRole" class="form-control" required aria-required="true">
                            <option value="">@Localizer.T("User.SelectRole")</option>
                            @if (Model.AvailableRoles != null)
                            {
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    <option value="@role.RoleName" selected="@(role.RoleName == Model.SelectedRole)">@role.RoleName</option>
                                }
                            }
                        </select>
                    </div>

                    @if (Model.AvailableClinics != null && Model.AvailableClinics.Any())
                    {
                        <div class="form-group">
                            <label asp-for="ClinicId" class="form-label">@Localizer.T("User.Clinic")</label>
                            <select asp-for="ClinicId" class="form-control">
                                <option value="">@Localizer.T("User.SelectClinic")</option>
                                @foreach (var clinic in Model.AvailableClinics)
                                {
                                    <option value="@clinic.Id" selected="@(clinic.Id == Model.ClinicId)">@clinic.Name</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">@Localizer.T("Common.Active")</label>
                        </div>
                    </div>

                    <hr />
                    <h5><i class="fas fa-key"></i> @Localizer.T("User.PasswordManagement")</h5>
                    <div class="form-group">
                        <label class="form-label">@Localizer.T("User.NewPassword")</label>
                        <div class="input-group">
                            <div class="input-group-text"><i class="fas fa-lock"></i></div>
                            <input id="newPassword" type="password" class="form-control" aria-label="@Localizer.T("User.NewPassword")" />
                        </div>
                        <button type="button" class="btn btn-sm btn-info mt-2" onclick="resetPassword()" aria-label="@Localizer.T("User.ResetPassword")">
                            <i class="fas fa-key"></i> @Localizer.T("User.ResetPassword")
                        </button>
                    </div>

                    <div class="form-group">
                        <label class="form-label">@Localizer.T("User.Created")</label>
                        <p class="form-control-static">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    @if (Model.LastLoginAt.HasValue)
                    {
                        <div class="form-group">
                            <label class="form-label">@Localizer.T("User.LastLogin")</label>
                            <p class="form-control-static">@Model.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-warning"><i class="fas fa-save"></i> @Localizer.T("Button.Save")</button>
                    <a href="/SuperAdmin/UserManagement" class="btn btn-secondary">@Localizer.T("Button.Cancel")</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function resetPassword() {
            var newPassword = document.getElementById('newPassword').value;
            if (!newPassword || newPassword.length < 8) {
                alert('@Localizer.T("Validation.PasswordMinLength")');
                return;
            }
            if (confirm('@Localizer.T("User.ConfirmPasswordReset") @Model.Email?')) {
                var form = document.createElement('form');
                form.method = 'post';
                form.action = '/SuperAdmin/UserManagement/ResetPassword/@Model.UserId';
                var input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'newPassword';
                input.value = newPassword;
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}
