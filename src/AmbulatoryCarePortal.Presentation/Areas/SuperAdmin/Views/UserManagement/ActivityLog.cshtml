@model List<AmbulatoryCarePortal.Presentation.ViewModels.AuditLogViewModel>

@{
    ViewData["Title"] = Localizer.T("Page.AuditLog");
}

<div class="row fade-in">
    <div class="col-12">
        <div class="card card-info">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-history"></i> @Localizer.T("Page.AuditLog")</h3>
                <div class="card-tools">
                    <a href="/SuperAdmin/UserManagement" class="btn btn-sm btn-secondary" aria-label="@Localizer.T("Common.Back")">
                        <i class="fas fa-arrow-left"></i> @Localizer.T("Common.Back")
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <div class="table-container">
                        <div class="table-toolbar">
                            <div class="search-box">
                                <i class="fas fa-search search-icon"></i>
                                <input type="text" class="form-control" data-table-search="activityLogTable" placeholder="@Localizer.T("Search.Activity")" aria-label="@Localizer.T("Search.Activity")">
                            </div>
                        </div>
                        <table class="table table-hover" id="activityLogTable">
                            <thead>
                                <tr>
                                    <th>@Localizer.T("Common.Date")</th>
                                    <th>Action</th>
                                    <th>Target</th>
                                    <th>IP Address</th>
                                    <th>@Localizer.T("Common.Details")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model)
                                {
                                    <tr>
                                        <td>@log.ActionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@log.Action</td>
                                        <td>@log.TargetType</td>
                                        <td>@log.IpAddress</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#logModal@(log.Id)" aria-label="@Localizer.T("Common.View")">
                                                <i class="fas fa-eye"></i> @Localizer.T("Common.View")
                                            </button>
                                            <div class="modal fade" id="logModal@(log.Id)" tabindex="-1" aria-hidden="true">
                                                <div class="modal-dialog modal-lg">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">@Localizer.T("Common.Details")</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@Localizer.T("Common.Close")"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <div class="detail-row">
                                                                <span class="detail-label">Action</span>
                                                                <span class="detail-value">@log.Action</span>
                                                            </div>
                                                            <div class="detail-row">
                                                                <span class="detail-label">User</span>
                                                                <span class="detail-value">@log.User</span>
                                                            </div>
                                                            <div class="detail-row">
                                                                <span class="detail-label">Date</span>
                                                                <span class="detail-value">@log.ActionDate.ToString("dd/MM/yyyy HH:mm")</span>
                                                            </div>
                                                            <div class="detail-row">
                                                                <span class="detail-label">IP Address</span>
                                                                <span class="detail-value">@log.IpAddress</span>
                                                            </div>
                                                            @if (!string.IsNullOrEmpty(log.OldValues))
                                                            {
                                                                <p><strong>Old Values:</strong></p>
                                                                <pre class="bg-light p-2">@log.OldValues</pre>
                                                            }
                                                            @if (!string.IsNullOrEmpty(log.NewValues))
                                                            {
                                                                <p><strong>New Values:</strong></p>
                                                                <pre class="bg-light p-2">@log.NewValues</pre>
                                                            }
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer.T("Common.Close")</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-history empty-icon"></i>
                        <h4>@Localizer.T("Empty.NoActivity")</h4>
                        <p>@Localizer.T("Empty.NoAuditLogsMessage")</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
