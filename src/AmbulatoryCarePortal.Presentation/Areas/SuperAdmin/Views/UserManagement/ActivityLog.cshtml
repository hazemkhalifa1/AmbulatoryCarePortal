@model List<AmbulatoryCarePortal.Presentation.ViewModels.AuditLogViewModel>

@{
    ViewData["Title"] = "Activity Log";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">User Activity</h3>
                <div class="card-tools">
                    <a href="/SuperAdmin/UserManagement" class="btn btn-sm btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Users
                    </a>
                </div>
            </div>
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Action</th>
                                    <th>Target</th>
                                    <th>IP Address</th>
                                    <th>Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model)
                                {
                                    <tr>
                                        <td>@log.ActionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@log.Action</td>
                                        <td>@log.TargetType</td>
                                        <td>@log.IpAddress</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-info" data-bs-toggle="modal" data-bs-target="#logModal@(log.Id)">
                                                <i class="fas fa-eye"></i> View
                                            </button>
                                            <div class="modal fade" id="logModal@(log.Id)" tabindex="-1">
                                                <div class="modal-dialog modal-lg">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Action Details</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <p><strong>Action:</strong> @log.Action</p>
                                                            <p><strong>User:</strong> @log.User</p>
                                                            <p><strong>Date:</strong> @log.ActionDate.ToString("dd/MM/yyyy HH:mm")</p>
                                                            <p><strong>IP Address:</strong> @log.IpAddress</p>
                                                            @if (!string.IsNullOrEmpty(log.OldValues))
                                                            {
                                                                <p><strong>Old Values:</strong></p>
                                                                <pre class="bg-light p-2">@log.OldValues</pre>
                                                            }
                                                            @if (!string.IsNullOrEmpty(log.NewValues))
                                                            {
                                                                <p><strong>New Values:</strong></p>
                                                                <pre class="bg-light p-2">@log.NewValues</pre>
                                                            }
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center mb-0">No activity log entries found.</p>
                }
            </div>
        </div>
    </div>
</div>
