@model AmbulatoryCarePortal.Presentation.ViewModels.UserRoleManagementViewModel

@{
    ViewData["Title"] = Localizer.T("Page.CreateUser");
}

<div class="row fade-in">
    <div class="col-md-8 offset-md-2">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-user-plus"></i> @Localizer.T("Page.CreateUser")</h3>
            </div>
            <form method="post" asp-action="Create" asp-route-password="" aria-label="Create user form">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="Email" class="form-label">Email <span class="required">*</span></label>
                        <div class="input-group">
                            <div class="input-group-text"><i class="fas fa-envelope"></i></div>
                            <input asp-for="Email" class="form-control" type="email" required aria-required="true" />
                        </div>
                        <span asp-validation-for="Email" class="invalid-feedback"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Password <span class="required">*</span></label>
                        <div class="input-group">
                            <div class="input-group-text"><i class="fas fa-lock"></i></div>
                            <input name="password" type="password" class="form-control" required minlength="8" aria-required="true" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="FullName" class="form-label">Full Name <span class="required">*</span></label>
                        <div class="input-group">
                            <div class="input-group-text"><i class="fas fa-user"></i></div>
                            <input asp-for="FullName" class="form-control" required aria-required="true" />
                        </div>
                        <span asp-validation-for="FullName" class="invalid-feedback"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <div class="input-group">
                            <div class="input-group-text"><i class="fas fa-phone"></i></div>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="SelectedRole" class="form-label">Role <span class="required">*</span></label>
                        <select asp-for="SelectedRole" class="form-control" required aria-required="true">
                            <option value="">-- Select Role --</option>
                            @if (Model.AvailableRoles != null)
                            {
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    <option value="@role.RoleName" title="@role.Description">@role.RoleName</option>
                                }
                            }
                        </select>
                    </div>

                    @if (Model.AvailableClinics != null && Model.AvailableClinics.Any())
                    {
                        <div class="form-group">
                            <label asp-for="ClinicId" class="form-label">Clinic</label>
                            <select asp-for="ClinicId" class="form-control">
                                <option value="">-- Select Clinic --</option>
                                @foreach (var clinic in Model.AvailableClinics)
                                {
                                    <option value="@clinic.Id">@clinic.Name (@clinic.CityEn)</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">@Localizer.T("Common.Active")</label>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> @Localizer.T("Button.Create")</button>
                    <a href="/SuperAdmin/UserManagement" class="btn btn-secondary">@Localizer.T("Button.Cancel")</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
