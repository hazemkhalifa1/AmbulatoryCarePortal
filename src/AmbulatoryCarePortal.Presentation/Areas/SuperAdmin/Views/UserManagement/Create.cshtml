@model AmbulatoryCarePortal.Presentation.ViewModels.UserRoleManagementViewModel

@{
    ViewData["Title"] = "Create User";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">New User</h3>
            </div>
            <form method="post" asp-action="Create" asp-route-password="">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email" class="form-control" type="email" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <input name="password" type="password" class="form-control" required minlength="8" />
                    </div>

                    <div class="form-group">
                        <label asp-for="FullName">Full Name</label>
                        <input asp-for="FullName" class="form-control" required />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PhoneNumber">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label asp-for="SelectedRole">Role</label>
                        <select asp-for="SelectedRole" class="form-control" required>
                            <option value="">-- Select Role --</option>
                            @if (Model.AvailableRoles != null)
                            {
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    <option value="@role.RoleName" title="@role.Description">@role.RoleName</option>
                                }
                            }
                        </select>
                    </div>

                    @if (Model.AvailableClinics != null && Model.AvailableClinics.Any())
                    {
                        <div class="form-group">
                            <label asp-for="ClinicId">Clinic</label>
                            <select asp-for="ClinicId" class="form-control">
                                <option value="">-- Select Clinic --</option>
                                @foreach (var clinic in Model.AvailableClinics)
                                {
                                    <option value="@clinic.Id">@clinic.Name (@clinic.CityEn)</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create User</button>
                    <a href="/SuperAdmin/UserManagement" class="btn btn-secondary float-right">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
