@model List<AmbulatoryCarePortal.Presentation.ViewModels.UserRoleManagementViewModel>

@{
    ViewData["Title"] = "User Management";
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">All Users (@totalCount)</h3>
                <div class="card-tools">
                    <a href="/SuperAdmin/UserManagement/Create" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus"></i> Add User
                    </a>
                </div>
            </div>
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Full Name</th>
                                    <th>Phone</th>
                                    <th>Role</th>
                                    <th>Active</th>
                                    <th>Created</th>
                                    <th>Last Login</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td>@user.Email</td>
                                        <td>@user.FullName</td>
                                        <td>@user.PhoneNumber</td>
                                        <td><span class="badge badge-info">@user.SelectedRole</span></td>
                                        <td>
                                            @if (user.IsActive)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">Inactive</span>
                                            }
                                        </td>
                                        <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        <td>@(user.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "Never")</td>
                                        <td>
                                            <a href="/SuperAdmin/UserManagement/Edit/@user.UserId" class="btn btn-sm btn-warning" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="/SuperAdmin/UserManagement/ActivityLog?userId=@user.UserId" class="btn btn-sm btn-info" title="Activity Log">
                                                <i class="fas fa-history"></i>
                                            </a>
                                            <form method="post" action="/SuperAdmin/UserManagement/Delete/@user.UserId" style="display:inline" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                                <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center mb-0">No users found. <a href="/SuperAdmin/UserManagement/Create">Create one</a></p>
                }
            </div>
            @if (totalCount > 10)
            {
                <div class="card-footer clearfix">
                    <div class="pagination-info float-left">Total: @totalCount</div>
                    <ul class="pagination pagination-sm m-0 float-right">
                        @if (currentPage > 1)
                        {
                            <li class="page-item"><a href="?page=@(currentPage - 1)" class="page-link">Previous</a></li>
                        }
                        @for (int i = 1; i <= Math.Ceiling((double)totalCount / 10); i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a href="?page=@i" class="page-link">@i</a>
                            </li>
                        }
                        @if (currentPage < Math.Ceiling((double)totalCount / 10))
                        {
                            <li class="page-item"><a href="?page=@(currentPage + 1)" class="page-link">Next</a></li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
</div>
