@model List<AmbulatoryCarePortal.Presentation.ViewModels.UserRoleManagementViewModel>

@{
    ViewData["Title"] = "User Management";
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
}

<div class="row fade-in">
    <div class="col-12">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-users"></i> All Users (@totalCount)</h3>
                <div class="card-tools">
                    <a href="/SuperAdmin/UserManagement/Create" class="btn btn-sm btn-primary" aria-label="Add new user">
                        <i class="fas fa-plus"></i> Add User
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <div class="table-container">
                        <div class="table-toolbar">
                            <div class="search-box">
                                <i class="fas fa-search search-icon"></i>
                                <input type="text" class="form-control" data-table-search="userTable" placeholder="Search users..." aria-label="Search users">
                            </div>
                        </div>
                        <table class="table table-hover" id="userTable">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Full Name</th>
                                    <th>Phone</th>
                                    <th>Role</th>
                                    <th>Active</th>
                                    <th>Created</th>
                                    <th>Last Login</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td>@user.Email</td>
                                        <td><strong>@user.FullName</strong></td>
                                        <td>@user.PhoneNumber</td>
                                        <td><span class="badge badge-info">@user.SelectedRole</span></td>
                                        <td>
                                            @if (user.IsActive)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">Inactive</span>
                                            }
                                        </td>
                                        <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        <td>@(user.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "Never")</td>
                                        <td>
                                            <div class="actions-cell">
                                                <a href="/SuperAdmin/UserManagement/Edit/@user.UserId" class="btn btn-sm btn-warning" title="Edit" aria-label="Edit user">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a href="/SuperAdmin/UserManagement/ActivityLog?userId=@user.UserId" class="btn btn-sm btn-info" title="Activity Log" aria-label="View user activity log">
                                                    <i class="fas fa-history"></i>
                                                </a>
                                                <form method="post" action="/SuperAdmin/UserManagement/Delete/@user.UserId" style="display:inline" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                                    <button type="submit" class="btn btn-sm btn-danger" title="Delete" aria-label="Delete user">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-users empty-icon"></i>
                        <h4>No Users Found</h4>
                        <p>Get started by creating your first user.</p>
                        <a href="/SuperAdmin/UserManagement/Create" class="btn btn-primary">Create User</a>
                    </div>
                }
            </div>
            @if (totalCount > 10)
            {
                <div class="card-footer">
                    <div class="table-footer">
                        <div class="pagination-info">Total: @totalCount users</div>
                        <ul class="pagination">
                            @if (currentPage > 1)
                            {
                                <li class="page-item"><a href="?page=@(currentPage - 1)" class="page-link" aria-label="Previous page">Previous</a></li>
                            }
                            @for (int i = 1; i <= Math.Ceiling((double)totalCount / 10); i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a href="?page=@i" class="page-link" aria-label="Page @i">@i</a>
                                </li>
                            }
                            @if (currentPage < Math.Ceiling((double)totalCount / 10))
                            {
                                <li class="page-item"><a href="?page=@(currentPage + 1)" class="page-link" aria-label="Next page">Next</a></li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
