@model CreateClinicViewModel

@{
    ViewData["Title"] = Localizer.T("Page.CreateClinic");
}

<!-- Hero Banner -->
<div class="create-clinic-hero mb-4">
    <div class="hero-content">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="hero-title"><i class="fas fa-plus-circle me-2"></i>@Localizer.T("Clinic.CreateHeading")</h1>
                <p class="hero-subtitle mb-0">@Localizer.T("Clinic.CreateSubtitle")</p>
            </div>
            <a href="/SuperAdmin/Dashboard/Clinics" class="btn btn-light btn-lg">
                <i class="fas fa-arrow-left me-2"></i>@Localizer.T("Common.Back")
            </a>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card form-card">
            <div class="card-body">
                <form method="post" asp-action="CreateClinic" aria-label="Create clinic form">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <!-- Section: Basic Information -->
                    <div class="form-section">
                        <div class="form-section-header">
                            <i class="fas fa-info-circle me-2"></i>
                            <span>Basic Information</span>
                        </div>
                        <div class="form-section-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Name" class="form-label">Name (English) <span class="text-danger">*</span></label>
                                    <input asp-for="Name" class="form-control" placeholder="@Localizer.T("Clinic.NameEnPlaceholder")" required aria-required="true" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="NameAr" class="form-label">Name (Arabic)</label>
                                    <input asp-for="NameAr" class="form-control" placeholder="@Localizer.T("Clinic.NameArPlaceholder")" dir="rtl" />
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CityEn" class="form-label">City (English)</label>
                                    <input asp-for="CityEn" class="form-control" placeholder="@Localizer.T("Clinic.CityEnPlaceholder")" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="CityAr" class="form-label">City (Arabic)</label>
                                    <input asp-for="CityAr" class="form-control" placeholder="@Localizer.T("Clinic.CityArPlaceholder")" dir="rtl" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Section: Classification -->
                    <div class="form-section">
                        <div class="form-section-header">
                            <i class="fas fa-tag me-2"></i>
                            <span>Classification</span>
                        </div>
                        <div class="form-section-body">
                            <div class="mb-3">
                                <label asp-for="ClinicType" class="form-label">Clinic Type <span class="text-danger">*</span></label>
                                <select asp-for="ClinicType" class="form-select" asp-items="Html.GetEnumSelectList<ClinicType>()" required aria-required="true">
                                    <option value="">-- Select Clinic Type --</option>
                                </select>
                                <span asp-validation-for="ClinicType" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Section: License Information -->
                    <div class="form-section">
                        <div class="form-section-header">
                            <i class="fas fa-certificate me-2"></i>
                            <span>License Information</span>
                        </div>
                        <div class="form-section-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="LicenseNumber" class="form-label">License Number</label>
                                    <input asp-for="LicenseNumber" class="form-control" placeholder="@Localizer.T("Clinic.LicensePlaceholder")" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="LicenseExpiry" class="form-label">License Expiry Date</label>
                                    <input asp-for="LicenseExpiry" type="date" class="form-control" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                            <i class="fas fa-save me-2"></i>@Localizer.T("Clinic.CreateButton")
                        </button>
                        <a href="/SuperAdmin/Dashboard/Clinics" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times me-2"></i>@Localizer.T("Button.Cancel")
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
