@model AmbulatoryCarePortal.Application.Common.PagedResult<AmbulatoryCarePortal.Application.DTOs.Clinic.ClinicDto>

@{
    ViewData["Title"] = "Manage Clinics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">All Clinics</h3>
                <div class="card-tools">
                    <a href="/SuperAdmin/Dashboard/CreateClinic" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus"></i> Add Clinic
                    </a>
                </div>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>City</th>
                                <th>License</th>
                                <th>Compliance</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Data.Any())
                            {
                                @foreach (var clinic in Model.Data)
                                {
                                    <tr>
                                        <td>
                                            <strong>@clinic.Name</strong><br>
                                            <small>@clinic.NameAr</small>
                                        </td>
                                        <td>@clinic.ClinicType</td>
                                        <td>@clinic.CityEn</td>
                                        <td>
                                            @clinic.LicenseNumber<br>
                                            @if (clinic.LicenseExpiry.HasValue)
                                            {
                                                <small>Exp: @clinic.LicenseExpiry.Value.ToString("dd/MM/yyyy")</small>
                                            }
                                        </td>
                                        <td>
                                            <div class="progress progress-xs">
                                                <div class="progress-bar @(clinic.ComplianceScore >= 80 ? "bg-success" : clinic.ComplianceScore >= 60 ? "bg-warning" : "bg-danger")" 
                                                     style="width: @clinic.ComplianceScore%">
                                                </div>
                                            </div>
                                            <small>@clinic.ComplianceScore%</small>
                                        </td>
                                        <td>
                                            @if (clinic.IsActive)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="/SuperAdmin/Dashboard/ClinicDetail/@clinic.Id" class="btn btn-sm btn-info" title="View">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a href="#" class="btn btn-sm btn-warning" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="#" class="btn btn-sm btn-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">
                                        No clinics found. <a href="/SuperAdmin/Dashboard/CreateClinic">Create one</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer clearfix">
                <div class="pagination-info">
                    Showing @(Model.Data.Count) of @Model.TotalCount
                </div>

                @if (Model.TotalPages > 1)
                {
                    <ul class="pagination m-0 float-right">
                        @if (Model.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a href="?page=@(Model.PageNumber - 1)" class="page-link">Previous</a>
                            </li>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a href="?page=@i" class="page-link">@i</a>
                            </li>
                        }

                        @if (Model.HasNextPage)
                        {
                            <li class="page-item">
                                <a href="?page=@(Model.PageNumber + 1)" class="page-link">Next</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
