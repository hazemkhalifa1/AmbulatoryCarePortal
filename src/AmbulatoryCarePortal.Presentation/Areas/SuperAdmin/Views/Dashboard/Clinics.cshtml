@model PagedResult<ClinicDto>

@{
    ViewData["Title"] = Localizer.T("Page.ManageClinics");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-title">
        <span class="page-icon"><i class="fas fa-hospital"></i></span>
        <div>
            <h1>@Localizer.T("Page.ManageClinics")</h1>
            <p class="page-header-subtitle">@Localizer.T("Clinics.Subtitle")</p>
        </div>
    </div>
    <div class="page-header-actions">
        <a href="/SuperAdmin/Clinic/CreateClinic" class="btn btn-primary">
            <i class="fas fa-plus"></i> @Localizer.T("Button.Add")
        </a>
        <a href="/SuperAdmin/Dashboard" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> @Localizer.T("Common.Back")
        </a>
    </div>
</div>

<!-- Metric Cards -->
<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon primary"><i class="fas fa-hospital"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Dashboard.TotalClinics")</div>
            <div class="metric-value">@Model.TotalCount</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon success"><i class="fas fa-check-circle"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Clinics.Active")</div>
            <div class="metric-value">@Model.Data.Count(c => c.IsActive)</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon warning"><i class="fas fa-chart-pie"></i></div>
                <span class="metric-badge neutral">@Localizer.T("Clinics.Average")</span>
            </div>
            <div class="metric-label">@Localizer.T("Dashboard.AvgCompliance")</div>
            <div class="metric-value">
                @(Model.Data.Any() ? Model.Data.Average(c => c.ComplianceScore).ToString("F0") : "0")<span class="text-lg font-medium text-muted">%</span>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon danger"><i class="fas fa-exclamation-triangle"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Clinics.LowCompliance")</div>
            <div class="metric-value">@Model.Data.Count(c => c.ComplianceScore < 60)</div>
        </div>
    </div>
</div>

<!-- Search & Filter -->
<div class="filter-bar">
    <div class="search-input">
        <i class="fas fa-search"></i>
        <input type="text" class="form-control" data-table-search="clinicsTable" placeholder="@Localizer.T("Common.Search")" />
    </div>
    <div class="d-flex gap-2">
        <select class="form-control" style="width: auto; min-width: 140px;">
            <option value="">@Localizer.T("Clinics.AllStatus")</option>
            <option value="active">@Localizer.T("Common.Active")</option>
            <option value="inactive">@Localizer.T("Common.Inactive")</option>
        </select>
        <button class="btn btn-secondary btn-icon"><i class="fas fa-filter"></i></button>
    </div>
</div>

<!-- Clinics Table -->
<div class="card">
    <div class="card-body p-0">
        @if (Model.Data.Any())
        {
            <div class="table-container border-0">
                <table class="table" id="clinicsTable">
                    <thead>
                        <tr>
                            <th>@Localizer.T("Common.Name")</th>
                            <th>@Localizer.T("Common.City")</th>
                            <th>@Localizer.T("Dashboard.Compliance")</th>
                            <th>@Localizer.T("Common.Status")</th>
                            <th class="text-center">@Localizer.T("Common.Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var clinic in Model.Data)
                        {
                            <tr>
                                <td>
                                    <span class="cell-title">@clinic.Name</span>
                                    <span class="cell-sub">@clinic.NameAr</span>
                                </td>
                                <td>@clinic.CityEn</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="max-width: 100px;">
                                            <div class="progress-bar @(clinic.ComplianceScore >= 80 ? "bg-success" : clinic.ComplianceScore >= 60 ? "bg-warning" : "bg-danger")"
                                                 style="width: @clinic.ComplianceScore%"></div>
                                        </div>
                                        <span class="text-sm font-medium @(clinic.ComplianceScore >= 80 ? "text-success" : clinic.ComplianceScore >= 60 ? "text-warning" : "text-danger")">
                                            @clinic.ComplianceScore%
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    @if (clinic.IsActive)
                                    {
                                        <span class="badge badge-success">@Localizer.T("Common.Active")</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">@Localizer.T("Common.Inactive")</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        <a href="/SuperAdmin/Clinic/ClinicDetail/@clinic.Id" class="btn btn-sm btn-secondary btn-icon" data-bs-toggle="tooltip" title="@Localizer.T("Common.View")">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="/SuperAdmin/Clinic/Edit/@clinic.Id" class="btn btn-sm btn-secondary btn-icon" data-bs-toggle="tooltip" title="@Localizer.T("Common.Edit")">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="/SuperAdmin/Clinic/Delete/@clinic.Id" class="d-inline" onsubmit="return confirm('@Localizer.T("Clinic.ConfirmDelete"): @clinic.Name?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-secondary btn-icon" data-bs-toggle="tooltip" title="@Localizer.T("Common.Delete")">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="card-footer d-flex align-items-center justify-content-between">
                <span class="text-sm text-muted">
                    @Localizer.T("Common.Showing") @Model.Data.Count @Localizer.T("Common.Of") @Model.TotalCount
                </span>
                @if (Model.TotalPages > 1)
                {
                    <nav>
                        <ul class="pagination mb-0">
                            <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                <a class="page-link" href="?page=@(Model.PageNumber - 1)&pageSize=@Model.PageSize"><i class="fas fa-chevron-left"></i></a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" href="?page=@i&pageSize=@Model.PageSize">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="?page=@(Model.PageNumber + 1)&pageSize=@Model.PageSize"><i class="fas fa-chevron-right"></i></a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-hospital"></i>
                <h4>@Localizer.T("Empty.NoClinics")</h4>
                <p>@Localizer.T("Empty.NoClinicsMessage")</p>
            </div>
        }
    </div>
</div>
