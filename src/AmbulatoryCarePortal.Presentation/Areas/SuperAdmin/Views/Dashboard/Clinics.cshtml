@model AmbulatoryCarePortal.Application.Common.PagedResult<AmbulatoryCarePortal.Application.DTOs.Clinic.ClinicDto>

@{
    ViewData["Title"] = "Manage Clinics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row fade-in">
    <div class="col-12">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-hospital"></i> All Clinics</h3>
                <div class="card-tools">
                    <a href="/SuperAdmin/Dashboard/CreateClinic" class="btn btn-sm btn-primary" aria-label="Add new clinic">
                        <i class="fas fa-plus"></i> Add Clinic
                    </a>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-container">
                    <div class="table-toolbar">
                        <div class="search-box">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text" class="form-control" data-table-search="clinicsTable" placeholder="Search clinics..." aria-label="Search clinics">
                        </div>
                    </div>
                    <table class="table table-hover" id="clinicsTable">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>City</th>
                                <th>License</th>
                                <th>Compliance</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Data.Any())
                            {
                                @foreach (var clinic in Model.Data)
                                {
                                    <tr>
                                        <td>
                                            <strong>@clinic.Name</strong><br>
                                            <small class="text-muted">@clinic.NameAr</small>
                                        </td>
                                        <td>@clinic.ClinicType</td>
                                        <td>@clinic.CityEn</td>
                                        <td>
                                            @clinic.LicenseNumber<br>
                                            @if (clinic.LicenseExpiry.HasValue)
                                            {
                                                <small class="text-muted">Exp: @clinic.LicenseExpiry.Value.ToString("dd/MM/yyyy")</small>
                                            }
                                        </td>
                                        <td>
                                            <div class="progress progress-xs">
                                                <div class="progress-bar @(clinic.ComplianceScore >= 80 ? "bg-success" : clinic.ComplianceScore >= 60 ? "bg-warning" : "bg-danger")" 
                                                     style="width: @clinic.ComplianceScore%">
                                                </div>
                                            </div>
                                            <small>@clinic.ComplianceScore%</small>
                                        </td>
                                        <td>
                                            @if (clinic.IsActive)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="actions-cell">
                                                <a href="/SuperAdmin/Dashboard/ClinicDetail/@clinic.Id" class="btn btn-sm btn-info" title="View" aria-label="View clinic details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="#" class="btn btn-sm btn-warning" title="Edit" aria-label="Edit clinic">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a href="#" class="btn btn-sm btn-danger" title="Delete" aria-label="Delete clinic">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7">
                                        <div class="empty-state">
                                            <i class="fas fa-hospital empty-icon"></i>
                                            <h4>No Clinics Found</h4>
                                            <p>Get started by creating your first clinic.</p>
                                            <a href="/SuperAdmin/Dashboard/CreateClinic" class="btn btn-primary">Create Clinic</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer">
                <div class="table-footer">
                    <div class="pagination-info">
                        Showing @(Model.Data.Count) of @Model.TotalCount clinics
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <ul class="pagination">
                            @if (Model.HasPreviousPage)
                            {
                                <li class="page-item">
                                    <a href="?page=@(Model.PageNumber - 1)" class="page-link" aria-label="Previous page">Previous</a>
                                </li>
                            }

                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a href="?page=@i" class="page-link" aria-label="Page @i">@i</a>
                                </li>
                            }

                            @if (Model.HasNextPage)
                            {
                                <li class="page-item">
                                    <a href="?page=@(Model.PageNumber + 1)" class="page-link" aria-label="Next page">Next</a>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
