@model ClinicDetailDto

@{
    ViewData["Title"] = Model.Name;
}

<!-- Hero Banner -->
<div class="clinic-detail-hero mb-4">
    <div class="hero-content">
        <div class="d-flex justify-content-between align-items-start">
            <div class="d-flex align-items-center gap-4">
                @if (!string.IsNullOrEmpty(Model.LogoPath))
                {
                    <div class="clinic-logo-wrapper">
                        <img src="@Model.LogoPath" alt="@Model.Name logo" class="clinic-hero-logo" />
                    </div>
                }
                <div>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <h1 class="hero-title mb-0"><i class="fas fa-clinic-medical me-2"></i>@Model.Name</h1>
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-lg bg-success">@Localizer.T("Common.Active")</span>
                        }
                        else
                        {
                            <span class="badge badge-lg bg-danger">@Localizer.T("Common.Inactive")</span>
                        }
                    </div>
                    <p class="hero-subtitle mb-0">@Model.NameAr</p>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a href="/SuperAdmin/Dashboard/Edit/@Model.Id" class="btn btn-primary">
                    <i class="fas fa-edit me-1"></i>@Localizer.T("Common.Edit")
                </a>
                <a href="/SuperAdmin/Dashboard/Clinics" class="btn btn-light">
                    <i class="fas fa-arrow-left me-1"></i>@Localizer.T("Common.Back")
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card stat-card-info">
            <div class="stat-card-body">
                <div class="stat-card-icon"><i class="fas fa-users"></i></div>
                <div class="stat-card-content">
                    <h3>@Model.UserCount</h3>
                    <p>@Localizer.T("Clinic.Users")</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card stat-card-success">
            <div class="stat-card-body">
                <div class="stat-card-icon"><i class="fas fa-building"></i></div>
                <div class="stat-card-content">
                    <h3>@Model.DepartmentCount</h3>
                    <p>@Localizer.T("Clinic.Departments")</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card stat-card-warning">
            <div class="stat-card-body">
                <div class="stat-card-icon"><i class="fas fa-file-pdf"></i></div>
                <div class="stat-card-content">
                    <h3>@Model.PolicyDocumentCount</h3>
                    <p>@Localizer.T("Clinic.Policies")</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card stat-card-danger">
            <div class="stat-card-body">
                <div class="stat-card-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="stat-card-content">
                    <h3>@Model.OpenGapCount</h3>
                    <p>@Localizer.T("Clinic.OpenGaps")</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Details Card -->
    <div class="col-lg-5 mb-4">
        <div class="card detail-card h-100">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-info-circle me-2"></i>@Localizer.T("Page.ClinicDetail")</h3>
            </div>
            <div class="card-body">
                <div class="detail-list">
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Common.Type")</span>
                        <span class="detail-value">@Model.ClinicType</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Common.City")</span>
                        <span class="detail-value">@(Model.CityEn ?? Model.CityAr)</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Clinic.LicenseNumber")</span>
                        <span class="detail-value">@Model.LicenseNumber</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Clinic.LicenseExpiry")</span>
                        <span class="detail-value">@(Model.LicenseExpiry?.ToString("dd/MM/yyyy") ?? Localizer.T("HR.NA"))</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Clinic.ComplianceScore")</span>
                        <span class="detail-value">
                            <div class="progress compliance-progress">
                                <div class="progress-bar @(Model.ComplianceScore >= 80 ? "bg-success" : Model.ComplianceScore >= 60 ? "bg-warning" : "bg-danger")"
                                     style="width: @Model.ComplianceScore%">
                                </div>
                            </div>
                            <small class="@(Model.ComplianceScore >= 80 ? "text-success" : Model.ComplianceScore >= 60 ? "text-warning" : "text-danger")">
                                @Model.ComplianceScore%
                            </small>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-lg-7 mb-4">
        <div class="card action-card h-100">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-bolt me-2"></i>@Localizer.T("Dashboard.QuickActions")</h3>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <a href="/SuperAdmin/Dashboard/AuditLog?clinicId=@Model.Id" class="action-btn action-btn-warning">
                            <i class="fas fa-history"></i>
                            <span>@Localizer.T("Common.View") @Localizer.T("Page.AuditLog")</span>
                            <small>@Localizer.T("Dashboard.Action.ReviewAllActivities")</small>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="/SuperAdmin/UserManagement/Create?clinicId=@Model.Id" class="action-btn action-btn-info">
                            <i class="fas fa-user-plus"></i>
                            <span>@Localizer.T("Button.Add")</span>
                            <small>@Localizer.T("Dashboard.Action.AssignPersonnel")</small>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <form method="post" asp-area="SuperAdmin" asp-controller="DocumentTemplates" asp-action="AssignToAllClinics" asp-route-id="@Model.Id" style="margin: 0; padding: 0;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="action-btn action-btn-primary" style="width: 100%; cursor: pointer; font-family: inherit; font-size: inherit; line-height: inherit; text-align: inherit;">
                                <i class="fas fa-file-upload"></i>
                                <span>@Localizer.T("Clinic.AssignTemplates")</span>
                                <small>@Localizer.T("Dashboard.Action.LinkTemplates")</small>
                            </button>
                        </form>
                    </div>
                    <div class="col-md-6">
                        <form method="post" action="/SuperAdmin/Dashboard/Delete/@Model.Id" style="margin: 0; padding: 0;" onsubmit="return confirm('@Localizer.T("Clinic.ConfirmDelete"): @Model.Name?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="action-btn action-btn-danger" style="width: 100%; cursor: pointer; font-family: inherit; font-size: inherit; line-height: inherit; text-align: inherit;">
                                <i class="fas fa-trash"></i>
                                <span>@Localizer.T("Common.Delete") @Localizer.T("Page.Clinic")</span>
                                <small>@Localizer.T("Dashboard.Action.DeleteClinicWarning")</small>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Global Document Values Section -->
<div class="card mt-4">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-globe me-2"></i>@Localizer.T("Template.GlobalValues")</h3>
    </div>
    <div class="card-body">
        @if (Model.GlobalTemplateValues.Any())
        {
            <form method="post" asp-action="SaveGlobalValues" asp-route-clinicId="@Model.Id">
                @Html.AntiForgeryToken()

                @for (int g = 0; g < Model.GlobalTemplateValues.Count; g++)
                {
                    var gv = Model.GlobalTemplateValues[g];
                    <input type="hidden" name="values[@g].VariableName" value="@gv.VariableName" />

                    <div class="mb-3">
                        <label class="form-label">
                            @gv.DisplayName (@gv.VariableName)
                            @if (gv.IsImage)
                            {
                                <span class="badge bg-info text-white ms-2"><i class="fas fa-image me-1"></i>@Localizer.T("Template.Image")</span>
                            }
                            @if (gv.IsAutoPopulated)
                            {
                                <span class="badge bg-secondary ms-2"><i class="fas fa-cloud me-1"></i>@Localizer.T("Template.AutoPopulated")</span>
                            }
                        </label>

                        @if (gv.IsAutoPopulated)
                        {
                            @if (gv.IsImage)
                            {
                                <div>
                                    @if (!string.IsNullOrEmpty(gv.ImagePath))
                                    {
                                        <div class="mb-2">
                                            <img src="@gv.ImagePath" alt="@gv.DisplayName" style="max-width:200px;max-height:200px;" class="img-thumbnail" />
                                        </div>
                                    }
                                    <input type="text" class="form-control" value="@gv.ImagePath" readonly />
                                </div>
                            }
                            else
                            {
                                <input type="text" class="form-control" value="@gv.Value" readonly />
                            }
                        }
                        else
                        {
                            @if (gv.IsImage)
                            {
                                <div>
                                    @if (!string.IsNullOrEmpty(gv.ImagePath))
                                    {
                                        <div class="mb-2">
                                            <img src="@gv.ImagePath" alt="@gv.DisplayName" style="max-width:200px;max-height:200px;" class="img-thumbnail" />
                                        </div>
                                    }
                                    <input type="text" name="values[@g].Value" class="form-control" value="@gv.ImagePath" placeholder="@Localizer.T("Template.ImagePathPlaceholder")" />
                                </div>
                            }
                            else
                            {
                                <input type="text" name="values[@g].Value" class="form-control" value="@gv.Value" placeholder="@gv.DisplayName" />
                            }
                        }
                    </div>
                }

                @if (Model.GlobalTemplateValues.Any(g => !g.IsAutoPopulated))
                {
                    <button type="submit" class="btn btn-info"><i class="fas fa-save me-1"></i>@Localizer.T("Common.Save")</button>
                }
            </form>
        }
        else
        {
            <p class="text-muted mb-0">@Localizer.T("Template.NoGlobalValues")</p>
        }
    </div>
</div>

<!-- Document Values Section -->
<div class="card mt-4">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-file-pen me-2"></i>@Localizer.T("Template.DocumentValues")</h3>
    </div>
    <div class="card-body">
        @if (Model.DocumentAssignments.Any())
        {
            <div class="accordion" id="documentValuesAccordion">
                @for (int a = 0; a < Model.DocumentAssignments.Count; a++)
                {
                    var assignment = Model.DocumentAssignments[a];
                    var collapseId = $"collapse_{a}";

                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                <span class="badge bg-primary me-2">@assignment.StandardCode</span>
                                <span>@assignment.TitleEn</span>
                                <span class="ms-2 text-muted small">(@assignment.TitleAr)</span>
                                <span class="ms-auto me-2"><span class="status-pill complete">@assignment.AssignmentStatus</span></span>
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#documentValuesAccordion">
                            <div class="accordion-body">
                                @if (assignment.VariableValues.Any())
                                {
                                    <form method="post" asp-action="SaveDocumentValues" asp-route-clinicId="@Model.Id" asp-route-assignmentId="@assignment.AssignmentId">
                                        @Html.AntiForgeryToken()

                                        @for (int v = 0; v < assignment.VariableValues.Count; v++)
                                        {
                                            var val = assignment.VariableValues[v];
                                            <input type="hidden" name="values[@v].TemplateVariableId" value="@val.TemplateVariableId" />

                                            <div class="mb-3">
                                                <label class="form-label">
                                                    @val.DisplayName (@val.VariableName)
                                                    @if (val.IsRequired)
                                                    {
                                                        <span class="text-danger">*</span>
                                                    }
                                                    @if (val.IsImage)
                                                    {
                                                        <span class="badge bg-info text-white ms-2"><i class="fas fa-image me-1"></i>@Localizer.T("Template.Image")</span>
                                                    }
                                                </label>

                                                @if (val.IsImage)
                                                {
                                                    <div>
                                                        @if (!string.IsNullOrEmpty(val.ImagePath))
                                                        {
                                                            <div class="mb-2">
                                                                <img src="@val.ImagePath" alt="@val.DisplayName" style="max-width:200px;max-height:200px;" class="img-thumbnail" />
                                                            </div>
                                                        }
                                                        <input type="text" name="values[@v].Value" class="form-control" value="@val.ImagePath" placeholder="@Localizer.T("Template.ImagePathPlaceholder")" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <input type="text" name="values[@v].Value" class="form-control" value="@val.Value" placeholder="@val.DisplayName" @(val.IsRequired ? "required" : "") />
                                                }
                                            </div>
                                        }

                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>@Localizer.T("Common.Save")</button>
                                            <a asp-action="PreviewDocument" asp-route-assignmentId="@assignment.AssignmentId" target="_blank" class="btn btn-info text-white preview-btn">
                                                <i class="fas fa-eye me-1"></i>@Localizer.T("Common.Preview")
                                            </a>
                                            <a asp-action="DownloadDocumentWord" asp-route-assignmentId="@assignment.AssignmentId" class="btn btn-success text-white">
                                                <i class="fas fa-file-word me-1"></i>Word
                                            </a>
                                        </div>
                                    </form>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-between">
                                        <p class="text-muted mb-0">@Localizer.T("Template.NoVariables")</p>
                                        <div class="d-flex gap-2">
                                            <a asp-action="PreviewDocument" asp-route-assignmentId="@assignment.AssignmentId" target="_blank" class="btn btn-info text-white btn-sm">
                                                <i class="fas fa-eye me-1"></i>@Localizer.T("Common.Preview")
                                            </a>
                                            <a asp-action="DownloadDocumentWord" asp-route-assignmentId="@assignment.AssignmentId" class="btn btn-success text-white btn-sm">
                                                <i class="fas fa-file-word me-1"></i>Word
                                            </a>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <i class="fas fa-file-pen fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">@Localizer.T("Template.NoAssignments")</h5>
                <p class="text-muted small">@Localizer.T("Template.NoAssignmentsHint")</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        .preview-btn .spinner-border {
            width: 1rem;
            height: 1rem;
            border-width: 2px;
            display: none;
        }
        .preview-btn.loading .spinner-border {
            display: inline-block;
        }
        .preview-btn.loading .btn-text {
            display: none;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.preview-btn').forEach(function (btn) {
                var spinner = document.createElement('span');
                spinner.className = 'spinner-border spinner-border-sm me-1';
                spinner.setAttribute('role', 'status');
                var btnText = document.createElement('span');
                btnText.className = 'btn-text';
                btnText.innerHTML = btn.innerHTML;
                btn.innerHTML = '';
                btn.appendChild(spinner);
                btn.appendChild(btnText);

                btn.addEventListener('click', function (e) {
                    var form = this.closest('form');
                    if (!form) return;

                    e.preventDefault();
                    var previewUrl = this.href;
                    var submitBtn = form.querySelector('button[type="submit"]');
                    this.classList.add('loading');

                    fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(function (response) {
                        if (response.ok) {
                            window.open(previewUrl, '_blank');
                        } else {
                            alert('@Localizer.T("Alert.Error.ValuesSaveFailed")');
                        }
                    })
                    .catch(function () {
                        alert('@Localizer.T("Alert.Error.ValuesSaveFailed")');
                    })
                    .finally(function () {
                        btn.classList.remove('loading');
                    });
                });
            });
        });
    </script>
}