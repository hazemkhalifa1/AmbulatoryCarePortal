@model AmbulatoryCarePortal.Application.DTOs.Clinic.ClinicDetailDto

@{
    ViewData["Title"] = Model.Name;
}

<div class="row fade-in">
    <div class="col-md-4">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-clinic-medical"></i> @Model.Name</h3>
            </div>
            <div class="card-body">
                <p class="text-muted text-center mb-4">@Model.NameAr</p>
                <div class="detail-row">
                    <span class="detail-label">Type</span>
                    <span class="detail-value">@Model.ClinicType</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">City</span>
                    <span class="detail-value">@(Model.CityEn ?? Model.CityAr)</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">License</span>
                    <span class="detail-value">@Model.LicenseNumber</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">License Expiry</span>
                    <span class="detail-value">@(Model.LicenseExpiry?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Status</span>
                    <span class="detail-value">
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">Inactive</span>
                        }
                    </span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Compliance Score</span>
                    <span class="detail-value">
                        <div class="progress progress-xs" style="width: 100px; display: inline-block;">
                            <div class="progress-bar @(Model.ComplianceScore >= 80 ? "bg-success" : Model.ComplianceScore >= 60 ? "bg-warning" : "bg-danger")" style="width: @Model.ComplianceScore%"></div>
                        </div>
                        @Model.ComplianceScore%
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="row">
            <div class="col-lg-3 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@Model.UserCount</h3>
                        <p>Users</p>
                    </div>
                    <div class="icon"><i class="fas fa-users"></i></div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>@Model.DepartmentCount</h3>
                        <p>Departments</p>
                    </div>
                    <div class="icon"><i class="fas fa-building"></i></div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@Model.PolicyDocumentCount</h3>
                        <p>Policies</p>
                    </div>
                    <div class="icon"><i class="fas fa-file-pdf"></i></div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@Model.OpenGapCount</h3>
                        <p>Open Gaps</p>
                    </div>
                    <div class="icon"><i class="fas fa-exclamation-triangle"></i></div>
                </div>
            </div>
        </div>

        <div class="card card-info">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-tasks"></i> Quick Actions</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-2">
                        <a href="/SuperAdmin/Dashboard/AuditLog?clinicId=@Model.Id" class="btn btn-warning btn-block" aria-label="View audit log for this clinic">
                            <i class="fas fa-history"></i> View Audit Log
                        </a>
                    </div>
                    <div class="col-md-4 mb-2">
                        <a href="/SuperAdmin/UserManagement/Create?clinicId=@Model.Id" class="btn btn-info btn-block" aria-label="Add user to this clinic">
                            <i class="fas fa-user-plus"></i> Add User
                        </a>
                    </div>
                    <div class="col-md-4 mb-2">
                        <a href="/SuperAdmin/Dashboard/Clinics" class="btn btn-secondary btn-block" aria-label="Back to clinics list">
                            <i class="fas fa-arrow-left"></i> Back to Clinics
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
