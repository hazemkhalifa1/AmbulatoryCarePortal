@model AmbulatoryCarePortal.Application.DTOs.Clinic.ClinicDetailDto

@{
    ViewData["Title"] = Model.Name;
}

<div class="row">
    <div class="col-md-4">
        <div class="card card-primary card-outline">
            <div class="card-body box-profile">
                <h3 class="profile-username text-center">@Model.Name</h3>
                <p class="text-muted text-center">@Model.NameAr</p>
                <ul class="list-group list-group-unbordered mb-3">
                    <li class="list-group-item">
                        <b>Type</b> <span class="float-right">@Model.ClinicType</span>
                    </li>
                    <li class="list-group-item">
                        <b>City</b> <span class="float-right">@(Model.CityEn ?? Model.CityAr)</span>
                    </li>
                    <li class="list-group-item">
                        <b>License</b> <span class="float-right">@Model.LicenseNumber</span>
                    </li>
                    <li class="list-group-item">
                        <b>License Expiry</b> <span class="float-right">@(Model.LicenseExpiry?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                    </li>
                    <li class="list-group-item">
                        <b>Status</b>
                        <span class="float-right">
                            @if (Model.IsActive)
                            {
                                <span class="badge badge-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactive</span>
                            }
                        </span>
                    </li>
                    <li class="list-group-item">
                        <b>Compliance Score</b>
                        <span class="float-right">
                            <div class="progress progress-xs" style="width: 100px; display: inline-block;">
                                <div class="progress-bar @(Model.ComplianceScore >= 80 ? "bg-success" : Model.ComplianceScore >= 60 ? "bg-warning" : "bg-danger")" style="width: @Model.ComplianceScore%"></div>
                            </div>
                            @Model.ComplianceScore%
                        </span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="row">
            <div class="col-lg-3 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@Model.UserCount</h3>
                        <p>Users</p>
                    </div>
                    <div class="icon"><i class="fas fa-users"></i></div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>@Model.DepartmentCount</h3>
                        <p>Departments</p>
                    </div>
                    <div class="icon"><i class="fas fa-building"></i></div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@Model.PolicyDocumentCount</h3>
                        <p>Policies</p>
                    </div>
                    <div class="icon"><i class="fas fa-file-pdf"></i></div>
                </div>
            </div>
            <div class="col-lg-3 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@Model.OpenGapCount</h3>
                        <p>Open Gaps</p>
                    </div>
                    <div class="icon"><i class="fas fa-exclamation-triangle"></i></div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Quick Actions</h3>
            </div>
            <div class="card-body">
                <a href="/SuperAdmin/Dashboard/AuditLog?clinicId=@Model.Id" class="btn btn-warning">
                    <i class="fas fa-history"></i> View Audit Log
                </a>
                <a href="/SuperAdmin/UserManagement/Create?clinicId=@Model.Id" class="btn btn-info">
                    <i class="fas fa-user-plus"></i> Add User
                </a>
                <a href="/SuperAdmin/Dashboard/Clinics" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Clinics
                </a>
            </div>
        </div>
    </div>
</div>
