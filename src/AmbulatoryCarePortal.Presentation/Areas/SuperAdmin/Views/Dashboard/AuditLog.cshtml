@model PagedResult<AuditTrailDto>
@inject ITranslationService Localizer

@{
    ViewData["Title"] = Localizer.T("Page.AuditLog");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-title">
        <span class="page-icon"><i class="fas fa-history"></i></span>
        <div>
            <h1>@Localizer.T("Page.AuditLog")</h1>
            <p class="page-header-subtitle">@Localizer.T("AuditLog.Subtitle")</p>
        </div>
    </div>
    <div class="page-header-actions">
        <a href="/SuperAdmin/Dashboard" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> @Localizer.T("Common.Back")
        </a>
    </div>
</div>

<!-- Metric Cards -->
<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon primary"><i class="fas fa-list"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("AuditLog.Total")</div>
            <div class="metric-value">@Model.TotalCount</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon success"><i class="fas fa-plus-circle"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("AuditLog.Creates")</div>
            <div class="metric-value">@Model.Data.Count(l => l.ActionType == AuditActionType.Create)</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon warning"><i class="fas fa-pen"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("AuditLog.Updates")</div>
            <div class="metric-value">@Model.Data.Count(l => l.ActionType == AuditActionType.Update)</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon danger"><i class="fas fa-trash"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("AuditLog.Deletions")</div>
            <div class="metric-value">@Model.Data.Count(l => l.ActionType == AuditActionType.Delete)</div>
        </div>
    </div>
</div>

<!-- Audit Log Table -->
<div class="card">
    <div class="card-body p-0">
        @if (Model.Data.Any())
        {
            <div class="table-container border-0">
                <table class="table" id="auditTable">
                    <thead>
                        <tr>
                            <th>@Localizer.T("AuditLog.Timestamp")</th>
                            <th>@Localizer.T("AuditLog.User")</th>
                            <th>@Localizer.T("AuditLog.Action")</th>
                            <th>@Localizer.T("AuditLog.Entity")</th>
                            <th>@Localizer.T("Common.Details")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.Data)
                        {
                            var badgeClass = log.ActionType == AuditActionType.Create ? "badge-success"
                                : log.ActionType == AuditActionType.Update ? "badge-warning"
                                : log.ActionType == AuditActionType.Delete ? "badge-danger"
                                : "badge-neutral";
                            <tr>
                                <td><span class="text-sm font-medium">@log.ActionDate.ToString("yyyy-MM-dd HH:mm")</span></td>
                                <td>@log.UserName</td>
                                <td><span class="badge @badgeClass">@log.ActionType</span></td>
                                <td>@log.TargetObjectType <span class="text-muted text-xs">(#@log.TargetObjectId)</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.Description))
                                    {
                                        <span class="text-sm text-muted cell-sub">@log.Description</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="card-footer d-flex align-items-center justify-content-between">
                <span class="text-sm text-muted">
                    @Localizer.T("Common.Showing") @Model.Data.Count @Localizer.T("Common.Of") @Model.TotalCount
                </span>
                @if (Model.TotalPages > 1)
                {
                    <nav>
                        <ul class="pagination mb-0">
                            <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                <a class="page-link" href="?page=@(Model.PageNumber - 1)&pageSize=@Model.PageSize"><i class="fas fa-chevron-left"></i></a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" href="?page=@i&pageSize=@Model.PageSize">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="?page=@(Model.PageNumber + 1)&pageSize=@Model.PageSize"><i class="fas fa-chevron-right"></i></a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-history"></i>
                <h4>@Localizer.T("Empty.NoAuditLogs")</h4>
                <p>@Localizer.T("Empty.NoAuditLogsMessage")</p>
            </div>
        }
    </div>
</div>
