@model SuperAdminDashboardViewModel

@{
    ViewData["Title"] = Localizer.T("Page.ExecutiveDashboard");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <div class="page-header-title">
            <span class="page-icon"><i class="fas fa-tachometer-alt"></i></span>
            <div>
                <h1>@Localizer.T("Page.ExecutiveDashboard")</h1>
                <p class="page-header-subtitle">@Localizer.T("Executive.Subtitle")</p>
            </div>
        </div>
    </div>
    <div class="page-header-actions">
        <a href="/SuperAdmin/Dashboard/CreateClinic" class="btn btn-primary">
            <i class="fas fa-plus"></i> @Localizer.T("Button.Add")
        </a>
    </div>
</div>

<!-- Metric Cards -->
<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon primary"><i class="fas fa-hospital"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Dashboard.TotalClinics")</div>
            <div class="metric-value">@Model.Metrics.TotalClinics</div>
            <div class="metric-footer">
                <a href="/SuperAdmin/Dashboard/Clinics">@Localizer.T("Button.ViewDetails") <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon success"><i class="fas fa-chart-pie"></i></div>
                <span class="metric-badge up"><i class="fas fa-arrow-up"></i> 2%</span>
            </div>
            <div class="metric-label">@Localizer.T("Dashboard.AvgCompliance")</div>
            <div class="metric-value">@Model.Metrics.AverageCompliance.ToString("F0")<span class="text-lg font-medium text-muted">%</span></div>
            <div class="metric-footer">
                <a href="/SuperAdmin/Dashboard/Clinics">@Localizer.T("Button.ViewDetails") <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon warning"><i class="fas fa-exclamation-triangle"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Dashboard.PendingReviews")</div>
            <div class="metric-value">@Model.Metrics.PendingApprovals</div>
            <div class="metric-footer">
                <a href="/SuperAdmin/Dashboard/Clinics">@Localizer.T("Button.ViewDetails") <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon danger"><i class="fas fa-calendar-times"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Dashboard.OverdueItems")</div>
            <div class="metric-value">@Model.Metrics.OverdueItems</div>
            <div class="metric-footer">
                <a href="/SuperAdmin/Dashboard/Clinics">@Localizer.T("Button.ViewDetails") <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Recent Clinics -->
    <div class="col-md-7 mb-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-clock"></i> @Localizer.T("Dashboard.RecentClinics")</h3>
                <div class="d-flex gap-2">
                    <a href="/SuperAdmin/Dashboard/Clinics" class="btn btn-sm btn-secondary">
                        @Localizer.T("Common.ViewAll") <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentClinics.Any())
                {
                    <div class="table-container border-0">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>@Localizer.T("Common.Name")</th>
                                    <th>@Localizer.T("Common.City")</th>
                                    <th>@Localizer.T("Dashboard.Compliance")</th>
                                    <th class="text-center">@Localizer.T("Common.Actions")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var clinic in Model.RecentClinics.Take(5))
                                {
                                    <tr>
                                        <td>
                                            <span class="cell-title">@clinic.Name</span>
                                            <span class="cell-sub">@clinic.NameAr</span>
                                        </td>
                                        <td>@clinic.CityEn</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="max-width: 100px;">
                                                    <div class="progress-bar @(clinic.ComplianceScore >= 80 ? "bg-success" : clinic.ComplianceScore >= 60 ? "bg-warning" : "bg-danger")"
                                                         style="width: @clinic.ComplianceScore%"></div>
                                                </div>
                                                <span class="text-sm font-medium @(clinic.ComplianceScore >= 80 ? "text-success" : clinic.ComplianceScore >= 60 ? "text-warning" : "text-danger")">
                                                    @clinic.ComplianceScore%
                                                </span>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <a href="/SuperAdmin/Dashboard/ClinicDetail/@clinic.Id" class="btn btn-sm btn-secondary btn-icon">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-hospital"></i>
                        <h4>@Localizer.T("Empty.NoClinics")</h4>
                        <p>@Localizer.T("Empty.NoClinicsMessage")</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-md-5 mb-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-bolt"></i> @Localizer.T("Dashboard.QuickActions")</h3>
            </div>
            <div class="card-body">
                <div class="action-grid">
                    <a href="/SuperAdmin/Dashboard/CreateClinic" class="action-card-btn primary">
                        <i class="fas fa-plus"></i>
                        <span class="action-title">@Localizer.T("Button.Add")</span>
                        <span class="action-desc">@Localizer.T("Dashboard.Action.RegisterFacility")</span>
                    </a>
                    <a href="/SuperAdmin/Dashboard/Clinics" class="action-card-btn info">
                        <i class="fas fa-list"></i>
                        <span class="action-title">@Localizer.T("Common.ViewAll")</span>
                        <span class="action-desc">@Localizer.T("Dashboard.Action.BrowseFacilities")</span>
                    </a>
                    <a href="/SuperAdmin/Dashboard/AuditLog?clinicId=1" class="action-card-btn warning">
                        <i class="fas fa-history"></i>
                        <span class="action-title">@Localizer.T("Page.AuditLog")</span>
                        <span class="action-desc">@Localizer.T("Dashboard.Action.ReviewActivities")</span>
                    </a>
                    <a href="/SuperAdmin/UserManagement" class="action-card-btn success">
                        <i class="fas fa-users"></i>
                        <span class="action-title">@Localizer.T("Page.UserManagement")</span>
                        <span class="action-desc">@Localizer.T("Dashboard.Action.UserAdministration")</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
