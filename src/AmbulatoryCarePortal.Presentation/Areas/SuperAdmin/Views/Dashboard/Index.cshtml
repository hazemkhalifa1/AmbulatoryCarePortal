@model List<AmbulatoryCarePortal.Application.DTOs.Clinic.ClinicDto>

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-lg-3 col-6">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>@ViewBag.TotalClinics</h3>
                <p>Total Clinics</p>
            </div>
            <div class="icon">
                <i class="fas fa-hospital"></i>
            </div>
            <a href="/SuperAdmin/Dashboard/Clinics" class="small-box-footer">More info <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>85<sup style="font-size: 20px">%</sup></h3>
                <p>Average Compliance</p>
            </div>
            <div class="icon">
                <i class="fas fa-chart-pie"></i>
            </div>
            <a href="#" class="small-box-footer">More info <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>12</h3>
                <p>Pending Reviews</p>
            </div>
            <div class="icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <a href="#" class="small-box-footer">More info <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-danger">
            <div class="inner">
                <h3>5</h3>
                <p>Overdue Items</p>
            </div>
            <div class="icon">
                <i class="fas fa-calendar-times"></i>
            </div>
            <a href="#" class="small-box-footer">More info <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card card-primary">
            <div class="card-header with-border">
                <h3 class="card-title">Recent Clinics</h3>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Clinic Name</th>
                                <th>City</th>
                                <th>Compliance</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var clinic in Model.Take(5))
                                {
                                    <tr>
                                        <td>@clinic.Name</td>
                                        <td>@clinic.CityEn</td>
                                        <td>
                                            <div class="progress progress-xs">
                                                <div class="progress-bar bg-success" style="width: @clinic.ComplianceScore%"></div>
                                            </div>
                                            <small>@clinic.ComplianceScore%</small>
                                        </td>
                                        <td>
                                            <a href="/SuperAdmin/Dashboard/ClinicDetail/@clinic.Id" class="btn btn-sm btn-info">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">No clinics found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card card-warning">
            <div class="card-header with-border">
                <h3 class="card-title">Quick Actions</h3>
            </div>
            <div class="card-body">
                <a href="/SuperAdmin/Dashboard/CreateClinic" class="btn btn-primary btn-block mb-2">
                    <i class="fas fa-plus"></i> Add New Clinic
                </a>
                <a href="/SuperAdmin/Dashboard/Clinics" class="btn btn-info btn-block mb-2">
                    <i class="fas fa-list"></i> View All Clinics
                </a>
                <a href="/SuperAdmin/Dashboard/AuditLog" class="btn btn-warning btn-block">
                    <i class="fas fa-history"></i> View Audit Log
                </a>
            </div>
        </div>
    </div>
</div>
