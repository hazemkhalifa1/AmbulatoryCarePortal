@model List<ClinicDto>

@{
    ViewData["Title"] = Localizer.T("Page.Dashboard");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Banner -->
<div class="dashboard-hero mb-4">
    <div class="hero-content">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="hero-title"><i class="fas fa-tachometer-alt me-2"></i>@Localizer.T("Page.ExecutiveDashboard")</h1>
                <p class="hero-subtitle mb-0">@Localizer.T("Executive.Subtitle")</p>
            </div>
            <a href="/SuperAdmin/Dashboard/CreateClinic" class="btn btn-light btn-lg">
                <i class="fas fa-plus me-2"></i>@Localizer.T("Button.Add")
            </a>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card stat-card-info">
            <div class="stat-card-body">
                <div class="stat-card-icon"><i class="fas fa-hospital"></i></div>
                <div class="stat-card-content">
                    <h3>@ViewBag.TotalClinics</h3>
                    <p>@Localizer.T("Dashboard.TotalClinics")</p>
                </div>
            </div>
            <a href="/SuperAdmin/Dashboard/Clinics" class="stat-card-footer">
                @Localizer.T("Button.ViewDetails") <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card stat-card-success">
            <div class="stat-card-body">
                <div class="stat-card-icon"><i class="fas fa-chart-pie"></i></div>
                <div class="stat-card-content">
                    <h3>85<sup style="font-size: 16px">%</sup></h3>
                    <p>@Localizer.T("Dashboard.AvgCompliance")</p>
                </div>
            </div>
            <a href="#" class="stat-card-footer">
                @Localizer.T("Button.ViewDetails") <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card stat-card-warning">
            <div class="stat-card-body">
                <div class="stat-card-icon"><i class="fas fa-exclamation-triangle"></i></div>
                <div class="stat-card-content">
                    <h3>12</h3>
                    <p>@Localizer.T("Dashboard.PendingReviews")</p>
                </div>
            </div>
            <a href="#" class="stat-card-footer">
                @Localizer.T("Button.ViewDetails") <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="stat-card stat-card-danger">
            <div class="stat-card-body">
                <div class="stat-card-icon"><i class="fas fa-calendar-times"></i></div>
                <div class="stat-card-content">
                    <h3>5</h3>
                    <p>@Localizer.T("Dashboard.OverdueItems")</p>
                </div>
            </div>
            <a href="#" class="stat-card-footer">
                @Localizer.T("Button.ViewDetails") <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
    </div>
</div>

<div class="row">
    <!-- Recent Clinics -->
    <div class="col-md-7 mb-4">
        <div class="card recent-clinics-card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-clock me-2"></i>@Localizer.T("Dashboard.RecentClinics")</h3>
                <div class="card-tools">
                    <a href="/SuperAdmin/Dashboard/Clinics" class="btn btn-sm btn-outline-primary">
                        @Localizer.T("Common.ViewAll") <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>@Localizer.T("Common.Name")</th>
                                    <th>@Localizer.T("Common.City")</th>
                                    <th>@Localizer.T("Dashboard.Compliance")</th>
                                    <th class="text-center">@Localizer.T("Common.Actions")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var clinic in Model.Take(5))
                                {
                                    <tr>
                                        <td>
                                            <strong>@clinic.Name</strong>
                                            <small class="text-muted d-block">@clinic.NameAr</small>
                                        </td>
                                        <td>@clinic.CityEn</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress compliance-progress flex-grow-1" style="max-width: 100px;">
                                                    <div class="progress-bar bg-success" style="width: @clinic.ComplianceScore%"></div>
                                                </div>
                                                <small class="text-muted">@clinic.ComplianceScore%</small>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <a href="/SuperAdmin/Dashboard/ClinicDetail/@clinic.Id" class="btn btn-sm btn-outline-info">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-hospital empty-icon"></i>
                        <h4>@Localizer.T("Empty.NoClinics")</h4>
                        <p>@Localizer.T("Empty.NoClinicsMessage")</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-md-5 mb-4">
        <div class="card quick-actions-card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-bolt me-2"></i>@Localizer.T("Dashboard.QuickActions")</h3>
            </div>
            <div class="card-body">
                <div class="d-grid gap-3">
                    <a href="/SuperAdmin/Dashboard/CreateClinic" class="action-btn action-btn-primary">
                        <i class="fas fa-plus"></i>
                        <span>@Localizer.T("Button.Add")</span>
                        <small>@Localizer.T("Dashboard.Action.RegisterFacility")</small>
                    </a>
                    <a href="/SuperAdmin/Dashboard/Clinics" class="action-btn action-btn-info">
                        <i class="fas fa-list"></i>
                        <span>@Localizer.T("Common.ViewAll")</span>
                        <small>@Localizer.T("Dashboard.Action.BrowseFacilities")</small>
                    </a>
                    <a href="/SuperAdmin/Dashboard/AuditLog?clinicId=1" class="action-btn action-btn-warning">
                        <i class="fas fa-history"></i>
                        <span>@Localizer.T("Common.View") @Localizer.T("Page.AuditLog")</span>
                        <small>@Localizer.T("Dashboard.Action.ReviewActivities")</small>
                    </a>
                    <a href="/SuperAdmin/UserManagement" class="action-btn action-btn-success">
                        <i class="fas fa-users"></i>
                        <span>@Localizer.T("Page.UserManagement")</span>
                        <small>@Localizer.T("Dashboard.Action.UserAdministration")</small>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
