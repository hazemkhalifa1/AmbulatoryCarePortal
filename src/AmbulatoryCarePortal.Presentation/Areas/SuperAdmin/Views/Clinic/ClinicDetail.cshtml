@model ClinicDetailDto

@{
    ViewData["Title"] = Model.Name;
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-title">
        @if (!string.IsNullOrEmpty(Model.LogoPath))
        {
            <img src="@Model.LogoPath" alt="@Model.Name logo" class="clinic-logo" />
        }
        else
        {
            <div class="clinic-logo-placeholder"><i class="fas fa-clinic-medical"></i></div>
        }
        <div>
            <div class="d-flex align-items-center gap-2">
                <h1>@Model.Name</h1>
                @if (Model.IsActive)
                {
                    <span class="badge badge-success badge-lg">@Localizer.T("Common.Active")</span>
                }
                else
                {
                    <span class="badge badge-danger badge-lg">@Localizer.T("Common.Inactive")</span>
                }
            </div>
            <p class="page-header-subtitle">@Model.NameAr</p>
        </div>
    </div>
    <div class="page-header-actions">
        <a href="/SuperAdmin/Clinic/Edit/@Model.Id" class="btn btn-primary">
            <i class="fas fa-edit"></i> @Localizer.T("Common.Edit")
        </a>
        <a href="/SuperAdmin/Dashboard/Clinics" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> @Localizer.T("Common.Back")
        </a>
    </div>
</div>

<!-- Metric Cards -->
<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon primary"><i class="fas fa-users"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Clinic.Users")</div>
            <div class="metric-value">@Model.UserCount</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon success"><i class="fas fa-building"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Clinic.Departments")</div>
            <div class="metric-value">@Model.DepartmentCount</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon warning"><i class="fas fa-file-pdf"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Clinic.Policies")</div>
            <div class="metric-value">@Model.PolicyDocumentCount</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="metric-card">
            <div class="metric-top">
                <div class="metric-icon danger"><i class="fas fa-exclamation-triangle"></i></div>
            </div>
            <div class="metric-label">@Localizer.T("Clinic.OpenGaps")</div>
            <div class="metric-value">@Model.OpenGapCount</div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Details -->
    <div class="col-lg-5 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-info-circle"></i> @Localizer.T("Page.ClinicDetail")</h3>
            </div>
            <div class="card-body">
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Common.Type")</span>
                        <span class="detail-value">@Model.ClinicType</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Common.City")</span>
                        <span class="detail-value">@(Model.CityEn ?? Model.CityAr)</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Clinic.LicenseNumber")</span>
                        <span class="detail-value">@Model.LicenseNumber</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Clinic.LicenseExpiry")</span>
                        <span class="detail-value">@(Model.LicenseExpiry?.ToString("dd/MM/yyyy") ?? Localizer.T("HR.NA"))</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">@Localizer.T("Clinic.ComplianceScore")</span>
                        <span class="detail-value">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="max-width: 120px;">
                                    <div class="progress-bar @(Model.ComplianceScore >= 80 ? "bg-success" : Model.ComplianceScore >= 60 ? "bg-warning" : "bg-danger")"
                                         style="width: @Model.ComplianceScore%"></div>
                                </div>
                                <span class="font-semibold @(Model.ComplianceScore >= 80 ? "text-success" : Model.ComplianceScore >= 60 ? "text-warning" : "text-danger")">
                                    @Model.ComplianceScore%
                                </span>
                            </div>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-lg-7 mb-4">
        <div class="card h-100">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-bolt"></i> @Localizer.T("Dashboard.QuickActions")</h3>
            </div>
            <div class="card-body">
                <div class="action-grid">
                    <a href="/SuperAdmin/Dashboard/AuditLog?clinicId=@Model.Id" class="action-card-btn warning">
                        <i class="fas fa-history"></i>
                        <span class="action-title">@Localizer.T("Page.AuditLog")</span>
                        <span class="action-desc">@Localizer.T("Dashboard.Action.ReviewAllActivities")</span>
                    </a>
                    <a href="/SuperAdmin/UserManagement/Create?clinicId=@Model.Id" class="action-card-btn info">
                        <i class="fas fa-user-plus"></i>
                        <span class="action-title">@Localizer.T("Button.Add")</span>
                        <span class="action-desc">@Localizer.T("Dashboard.Action.AssignPersonnel")</span>
                    </a>
                    <form method="post" asp-area="SuperAdmin" asp-controller="DocumentTemplates" asp-action="AssignToAllClinics" asp-route-id="@Model.Id" class="h-100 m-0 p-0" style="display: contents;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="action-card-btn primary" style="cursor: pointer; font-family: inherit;">
                            <i class="fas fa-file-upload"></i>
                            <span class="action-title">@Localizer.T("Clinic.AssignTemplates")</span>
                            <span class="action-desc">@Localizer.T("Dashboard.Action.LinkTemplates")</span>
                        </button>
                    </form>
                    <form method="post" action="/SuperAdmin/Clinic/Delete/@Model.Id" class="h-100 m-0 p-0" style="display: contents;" onsubmit="return confirm('@Localizer.T("Clinic.ConfirmDelete"): @Model.Name?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="action-card-btn danger" style="cursor: pointer; font-family: inherit;">
                            <i class="fas fa-trash"></i>
                            <span class="action-title">@Localizer.T("Common.Delete")</span>
                            <span class="action-desc">@Localizer.T("Dashboard.Action.DeleteClinicWarning")</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Global Document Values -->
<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-globe"></i> @Localizer.T("Template.GlobalValues")</h3>
    </div>
    <div class="card-body">
        @if (Model.GlobalTemplateValues.Any())
        {
            <form method="post" asp-action="SaveGlobalValues" asp-route-clinicId="@Model.Id">
                @Html.AntiForgeryToken()

                <div class="row">
                    @for (int g = 0; g < Model.GlobalTemplateValues.Count; g++)
                    {
                        var gv = Model.GlobalTemplateValues[g];
                        <div class="col-md-6 mb-3">
                            <input type="hidden" name="values[@g].VariableName" value="@gv.VariableName" />
                            <label class="form-label">
                                @gv.DisplayName
                                <span class="text-muted font-medium text-xs">(@gv.VariableName)</span>
                                @if (gv.IsImage)
                                {
                                    <span class="badge badge-info badge-sm ms-1"><i class="fas fa-image"></i> @Localizer.T("Template.Image")</span>
                                }
                                @if (gv.IsAutoPopulated)
                                {
                                    <span class="badge badge-neutral badge-sm ms-1"><i class="fas fa-cloud"></i> @Localizer.T("Template.AutoPopulated")</span>
                                }
                            </label>

                            @if (gv.IsAutoPopulated)
                            {
                                if (gv.IsImage)
                                {
                                    <div>
                                        @if (!string.IsNullOrEmpty(gv.ImagePath))
                                        {
                                            <div class="mb-2">
                                                <img src="@gv.ImagePath" alt="@gv.DisplayName" style="max-width:160px; max-height:120px;" class="rounded-md border" />
                                            </div>
                                        }
                                        <input type="text" class="form-control" value="@gv.ImagePath" readonly />
                                    </div>
                                }
                                else
                                {
                                    <input type="text" class="form-control" value="@gv.Value" readonly />
                                }
                            }
                            else
                            {
                                if (gv.IsImage)
                                {
                                    <div>
                                        @if (!string.IsNullOrEmpty(gv.ImagePath))
                                        {
                                            <div class="mb-2">
                                                <img src="@gv.ImagePath" alt="@gv.DisplayName" style="max-width:160px; max-height:120px;" class="rounded-md border" />
                                            </div>
                                        }
                                        <input type="text" name="values[@g].Value" class="form-control" value="@gv.ImagePath" placeholder="@Localizer.T("Template.ImagePathPlaceholder")" />
                                    </div>
                                }
                                else
                                {
                                    <input type="text" name="values[@g].Value" class="form-control" value="@gv.Value" placeholder="@gv.DisplayName" />
                                }
                            }
                        </div>
                    }
                </div>

                @if (Model.GlobalTemplateValues.Any(g => !g.IsAutoPopulated))
                {
                    <div class="mt-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> @Localizer.T("Common.Save")</button>
                    </div>
                }
            </form>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-globe"></i>
                <h4>@Localizer.T("Template.NoGlobalValues")</h4>
            </div>
        }
    </div>
</div>

<!-- Document Values -->
<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-file-pen"></i> @Localizer.T("Template.DocumentValues")</h3>
    </div>
    <div class="card-body">
        @if (Model.DocumentAssignments.Any())
        {
            <div class="accordion" id="documentValuesAccordion">
                @for (int a = 0; a < Model.DocumentAssignments.Count; a++)
                {
                    var assignment = Model.DocumentAssignments[a];
                    var collapseId = $"collapse_{a}";

                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-btn" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                                <span class="badge badge-primary">@assignment.StandardCode</span>
                                <span>@assignment.TitleEn</span>
                                <span class="text-muted text-sm">(@assignment.TitleAr)</span>
                                <span class="ms-auto d-flex align-items-center gap-2">
                                    @if (assignment.HasTemplateFile)
                                    {
                                        <span class="badge badge-success badge-sm"><i class="fas fa-file"></i> @Localizer.T("Common.TemplateAttached")</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-warning badge-sm"><i class="fas fa-exclamation-triangle"></i> @Localizer.T("Common.NoFile")</span>
                                    }
                                    <span class="status-pill @(assignment.AssignmentStatus == "Complete" ? "complete" : "pending")">@assignment.AssignmentStatus</span>
                                </span>
                                <i class="accordion-chevron fas fa-chevron-down"></i>
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#documentValuesAccordion">
                            <div class="accordion-body">
                                @if (assignment.VariableValues.Any())
                                {
                                    <form method="post" asp-action="SaveDocumentValues" asp-route-clinicId="@Model.Id" asp-route-assignmentId="@assignment.AssignmentId">
                                        @Html.AntiForgeryToken()

                                        <div class="row">
                                            @for (int v = 0; v < assignment.VariableValues.Count; v++)
                                            {
                                                var val = assignment.VariableValues[v];
                                                <div class="col-md-6 mb-3">
                                                    <input type="hidden" name="values[@v].TemplateVariableId" value="@val.TemplateVariableId" />
                                                    <label class="form-label">
                                                        @val.DisplayName
                                                        <span class="text-muted font-medium text-xs">(@val.VariableName)</span>
                                                        @if (val.IsRequired)
                                                        {
                                                            <span class="required">*</span>
                                                        }
                                                        @if (val.IsImage)
                                                        {
                                                            <span class="badge badge-info badge-sm ms-1"><i class="fas fa-image"></i> @Localizer.T("Template.Image")</span>
                                                        }
                                                    </label>

                                                    @if (val.IsImage)
                                                    {
                                                        <div>
                                                            @if (!string.IsNullOrEmpty(val.ImagePath))
                                                            {
                                                                <div class="mb-2">
                                                                    <img src="@val.ImagePath" alt="@val.DisplayName" style="max-width:160px; max-height:120px;" class="rounded-md border" />
                                                                </div>
                                                            }
                                                            <input type="text" name="values[@v].Value" class="form-control" value="@val.ImagePath" placeholder="@Localizer.T("Template.ImagePathPlaceholder")" />
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <input type="text" name="values[@v].Value" class="form-control" value="@val.Value" placeholder="@val.DisplayName" @(val.IsRequired ? "required" : "") />
                                                    }
                                                </div>
                                            }
                                        </div>

                                        <div class="d-flex gap-2 mt-2">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="fas fa-save"></i> @Localizer.T("Common.Save")
                                            </button>
                                            <a asp-action="PreviewDocument" asp-route-assignmentId="@assignment.AssignmentId" target="_blank" class="btn btn-info preview-btn">
                                                <i class="fas fa-eye"></i> @Localizer.T("Common.Preview")
                                            </a>
                                            <a asp-action="DownloadDocumentWord" asp-route-assignmentId="@assignment.AssignmentId" class="btn btn-secondary">
                                                <i class="fas fa-file-word"></i> Word
                                            </a>
                                            <a asp-area="SuperAdmin" asp-controller="DocumentTemplates" asp-action="Edit" asp-route-id="@assignment.DocumentTemplateId" class="btn btn-outline-primary">
                                                <i class="fas fa-upload"></i> @Localizer.T("Common.TemplateFile")
                                            </a>
                                        </div>
                                    </form>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-between">
                                        <p class="text-muted mb-0">@Localizer.T("Template.NoVariables")</p>
                                        <div class="d-flex gap-2">
                                            <a asp-action="PreviewDocument" asp-route-assignmentId="@assignment.AssignmentId" target="_blank" class="btn btn-sm btn-info">
                                                <i class="fas fa-eye"></i> @Localizer.T("Common.Preview")
                                            </a>
                                            <a asp-action="DownloadDocumentWord" asp-route-assignmentId="@assignment.AssignmentId" class="btn btn-sm btn-secondary">
                                                <i class="fas fa-file-word"></i> Word
                                            </a>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-file-pen"></i>
                <h4>@Localizer.T("Template.NoAssignments")</h4>
                <p>@Localizer.T("Template.NoAssignmentsHint")</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.preview-btn').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    var form = this.closest('form');
                    if (!form) return;

                    e.preventDefault();
                    var previewUrl = this.href;

                    this.classList.add('loading');

                    fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(function (response) {
                        if (response.ok) {
                            window.open(previewUrl, '_blank');
                        } else {
                            showAlert('@Localizer.T("Alert.Error.ValuesSaveFailed")', 'danger');
                        }
                    })
                    .catch(function () {
                        showAlert('@Localizer.T("Alert.Error.ValuesSaveFailed")', 'danger');
                    })
                    .finally(function () {
                        btn.classList.remove('loading');
                    });
                });
            });
        });
    </script>
}
