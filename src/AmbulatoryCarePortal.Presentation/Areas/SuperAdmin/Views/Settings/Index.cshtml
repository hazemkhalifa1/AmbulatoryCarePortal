@{
    ViewData["Title"] = Localizer.T("Page.SystemSettings");
    Layout = "~/Views/Shared/_Layout.cshtml";
    var activeTab = ViewBag.ActiveTab as string ?? "mail";

    var navItems = new[]
    {
        new { Id = "mail", Icon = "fa-envelope", Label = Localizer.T("Settings.Mail.Tab"), Desc = "SMTP and email delivery configuration" },
        new { Id = "documenttemplate", Icon = "fa-file-alt", Label = Localizer.T("Settings.DocumentTemplate.Tab"), Desc = "Upload rules, expiry warnings, and file limits" },
        new { Id = "branding", Icon = "fa-palette", Label = Localizer.T("Settings.Branding.Tab"), Desc = "Site identity, colors, and contact info" },
        new { Id = "notifications", Icon = "fa-bell", Label = Localizer.T("Settings.Notifications.Tab"), Desc = "Alert preferences and daily digest settings" },
        new { Id = "localization", Icon = "fa-globe", Label = Localizer.T("Settings.Localization.Tab"), Desc = "Language, region, and locale preferences" },
        new { Id = "general", Icon = "fa-wrench", Label = Localizer.T("Settings.General.Tab"), Desc = "System-wide preferences and maintenance" }
    };

    var partialMap = new Dictionary<string, string>
    {
        { "mail", "_MailSettingsPartial" },
        { "documenttemplate", "_DocumentTemplateSettingsPartial" },
        { "branding", "_BrandingSettingsPartial" },
        { "notifications", "_NotificationsSettingsPartial" },
        { "localization", "_LocalizationSettingsPartial" },
        { "general", "_GeneralSettingsPartial" }
    };
}

<div class="settings-page-wrapper">
    <div class="settings-header">
        <div class="settings-header-icon">
            <i class="fas fa-cog"></i>
        </div>
        <div>
            <h1 class="settings-header-title">@Localizer.T("Page.SystemSettings")</h1>
            <p class="settings-header-desc">@Localizer.T("Settings.Subtitle")</p>
        </div>
    </div>

    <button class="settings-sidebar-toggle" id="settingsSidebarToggle" type="button" aria-expanded="false" aria-controls="settingsNav">
        <span><i class="fas fa-bars me-2" aria-hidden="true"></i>@Localizer.T("Settings.SidebarTitle")</span>
        <i class="fas fa-chevron-down"></i>
    </button>

    <div class="settings-pills" id="settingsPills" role="tablist">
        @foreach (var item in navItems)
        {
            <button type="button" class="pill @(activeTab == item.Id ? "active" : "")"
                    id="pill-@item.Id" data-target="@item.Id" role="tab"
                    aria-selected="@(activeTab == item.Id ? "true" : "false")"
                    aria-controls="section-@item.Id">
                <i class="fas @item.Icon" aria-hidden="true"></i>
                <span>@item.Label</span>
            </button>
        }
    </div>

    <div class="settings-layout">
        <aside class="settings-sidebar" id="settingsSidebar">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-layer-group me-1" aria-hidden="true"></i> @Localizer.T("Settings.SidebarTitle")
                </div>
                <div class="list-group" id="settingsNav" role="tablist">
                    @foreach (var item in navItems)
                    {
                        <button type="button" class="list-group-item list-group-item-action @(activeTab == item.Id ? "active" : "")"
                                id="nav-@item.Id" data-target="@item.Id" role="tab"
                                aria-selected="@(activeTab == item.Id ? "true" : "false")"
                                aria-controls="section-@item.Id">
                            <i class="fas @item.Icon" aria-hidden="true"></i>
                            <span class="nav-label">@item.Label</span>
                            <span class="nav-desc">@item.Desc</span>
                        </button>
                    }
                </div>
            </div>
        </aside>

        <main class="settings-content" id="settingsContent">
            <div id="settingsSections">
                @foreach (var item in navItems)
                {
                    var isActive = activeTab == item.Id;
                    <div class="settings-section" id="section-@item.Id" role="tabpanel"
                         aria-labelledby="nav-@item.Id"
                         data-active="@(isActive ? "true" : "false")"
                         style="display: @(isActive ? "block" : "none")">
                        @await Html.PartialAsync(partialMap[item.Id])
                    </div>
                }
            </div>

            <div class="settings-action-bar">
                <button type="button" class="btn btn-outline-secondary" id="resetDefaultsBtn">
                    <i class="fas fa-undo" aria-hidden="true"></i> @Localizer.T("Settings.ResetToDefault")
                </button>
                <button type="button" class="btn btn-primary" id="saveAllSettingsBtn">
                    <i class="fas fa-save" aria-hidden="true"></i> @Localizer.T("Settings.SaveAll")
                </button>
            </div>
        </main>
    </div>
</div>

<div class="settings-toast-container" id="toastContainer" aria-live="polite" aria-atomic="true"></div>

<div class="settings-loading" id="settingsLoading">
    <div class="spinner-border" role="status">
        <span class="visually-hidden">@Localizer.T("Common.Loading")</span>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var activeSection = '@activeTab';
            var validSections = ['mail', 'documenttemplate', 'branding', 'notifications', 'localization', 'general'];
            var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            function showToast(message, type) {
                type = type || 'success';
                var container = document.getElementById('toastContainer');
                var toast = document.createElement('div');
                toast.className = 'settings-toast toast-' + type;
                if (prefersReducedMotion) {
                    toast.style.animation = 'none';
                }
                var iconMap = { success: 'fa-check-circle', error: 'fa-exclamation-circle', info: 'fa-info-circle', warning: 'fa-exclamation-triangle' };
                var icon = iconMap[type] || 'fa-info-circle';
                toast.innerHTML =
                    '<i class="fas ' + icon + '" aria-hidden="true"></i>' +
                    '<span>' + message + '</span>' +
                    '<button type="button" class="toast-close" aria-label="Close">&times;</button>';
                toast.querySelector('.toast-close').addEventListener('click', function() {
                    toast.remove();
                });
                container.appendChild(toast);
                setTimeout(function() {
                    if (toast.parentNode) toast.remove();
                }, 4000);
            }

            function setActiveNav(sectionId) {
                document.querySelectorAll('#settingsNav .list-group-item').forEach(function(el) {
                    el.classList.remove('active');
                    el.setAttribute('aria-selected', 'false');
                });
                var navBtn = document.getElementById('nav-' + sectionId);
                if (navBtn) {
                    navBtn.classList.add('active');
                    navBtn.setAttribute('aria-selected', 'true');
                }
                document.querySelectorAll('#settingsPills .pill').forEach(function(el) {
                    el.classList.remove('active');
                    el.setAttribute('aria-selected', 'false');
                });
                var pill = document.getElementById('pill-' + sectionId);
                if (pill) {
                    pill.classList.add('active');
                    pill.setAttribute('aria-selected', 'true');
                    pill.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
                }
            }

            function switchSection(sectionId) {
                document.querySelectorAll('.settings-section').forEach(function(el) {
                    el.style.display = 'none';
                    el.classList.remove('active');
                    el.setAttribute('data-active', 'false');
                });
                var target = document.getElementById('section-' + sectionId);
                if (target) {
                    target.style.display = 'block';
                    target.classList.add('active');
                    target.setAttribute('data-active', 'true');
                }
                setActiveNav(sectionId);
                activeSection = sectionId;
                if (window.location.hash !== '#' + sectionId) {
                    history.replaceState(null, '', '#' + sectionId);
                }
                var toggle = document.getElementById('settingsSidebarToggle');
                if (toggle) {
                    toggle.setAttribute('aria-expanded', 'false');
                    var icon = toggle.querySelector('.fa-chevron-down, .fa-chevron-up');
                    if (icon) icon.className = 'fas fa-chevron-down';
                }
                var listGroup = document.querySelector('#settingsSidebar .list-group');
                if (listGroup) listGroup.classList.remove('show');
            }

            document.querySelectorAll('#settingsNav .list-group-item, #settingsPills .pill').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var target = this.getAttribute('data-target');
                    if (target) switchSection(target);
                });
            });

            document.getElementById('settingsSidebarToggle')?.addEventListener('click', function() {
                var listGroup = document.querySelector('#settingsSidebar .list-group');
                var isExpanded = this.getAttribute('aria-expanded') === 'true';
                if (listGroup) listGroup.classList.toggle('show');
                this.setAttribute('aria-expanded', !isExpanded);
                var icon = this.querySelector('.fa-chevron-down, .fa-chevron-up');
                if (icon) {
                    icon.className = isExpanded
                        ? 'fas fa-chevron-down'
                        : 'fas fa-chevron-up';
                }
            });

            var hash = window.location.hash.replace('#', '');
            if (hash && validSections.indexOf(hash) >= 0) {
                switchSection(hash);
            }

            document.getElementById('saveAllSettingsBtn')?.addEventListener('click', function() {
                var btn = this;
                btn.disabled = true;
                var originalHtml = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> @Localizer.T("Settings.Saving")';
                var loading = document.getElementById('settingsLoading');
                if (loading) loading.classList.add('active');

                var activeForm = document.querySelector('.settings-section[data-active="true"] form');
                if (activeForm) {
                    var formData = new FormData(activeForm);
                    fetch(activeForm.action, {
                        method: 'POST',
                        body: new URLSearchParams(formData),
                        headers: {
                            'RequestVerificationToken': activeForm.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        }
                    })
                    .then(function(r) {
                        if (r.redirected) {
                            if (r.url.indexOf('tab=') > -1 || r.url.indexOf('Settings') > -1) {
                                showToast('@Localizer.T("Settings.SavedToast")', 'success');
                            }
                            window.location.href = r.url;
                            return null;
                        }
                        return r.text();
                    })
                    .then(function() {
                        showToast('@Localizer.T("Settings.SavedToast")', 'success');
                    })
                    .catch(function() {
                        showToast('@Localizer.T("Alert.Error.General")', 'error');
                    })
                    .finally(function() {
                        btn.disabled = false;
                        btn.innerHTML = originalHtml;
                        if (loading) loading.classList.remove('active');
                    });
                }
            });

            document.getElementById('resetDefaultsBtn')?.addEventListener('click', function() {
                if (confirm('@Localizer.T("Common.Confirm")')) {
                    showToast('@Localizer.T("Settings.SavedToast")', 'info');
                }
            });

            var testBtn = document.getElementById('sendTestEmailBtn');
            if (testBtn) {
                testBtn.addEventListener('click', function() {
                    var btn = this;
                    btn.disabled = true;
                    var originalHtml = btn.innerHTML;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> @Localizer.T("Common.Loading")';

                    fetch('/SuperAdmin/Settings/SendTestEmail', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        }
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        showToast(data.message, data.success ? 'success' : 'error');
                    })
                    .catch(function() {
                        showToast('@Localizer.T("Settings.TestEmailFailed")', 'error');
                    })
                    .finally(function() {
                        btn.disabled = false;
                        btn.innerHTML = originalHtml;
                    });
                });
            }

            document.querySelectorAll('.toggle-password').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var targetName = this.getAttribute('data-target');
                    var input = document.querySelector('input[name="' + targetName + '"]');
                    if (input) {
                        var isPassword = input.type === 'password';
                        input.type = isPassword ? 'text' : 'password';
                        var icon = this.querySelector('i');
                        if (icon) {
                            icon.className = isPassword ? 'fas fa-eye-slash' : 'fas fa-eye';
                        }
                        this.setAttribute('aria-label', isPassword
                            ? 'Hide password'
                            : 'Show password');
                    }
                });
            });

            document.querySelectorAll('.settings-card form').forEach(function(form) {
                form.addEventListener('submit', function(e) {
                    var submitBtn = this.querySelector('.settings-card-footer .btn-primary');
                    if (submitBtn && !submitBtn.disabled) {
                        submitBtn.disabled = true;
                        var originalHtml = submitBtn.innerHTML;
                        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> @Localizer.T("Settings.Saving")';
                        setTimeout(function() {
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = originalHtml;
                        }, 10000);
                    }
                });
            });
        })();
    </script>
}
