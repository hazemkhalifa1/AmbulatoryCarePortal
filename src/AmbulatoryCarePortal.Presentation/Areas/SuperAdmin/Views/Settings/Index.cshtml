@{
    ViewData["Title"] = Localizer.T("Page.SystemSettings");
    Layout = "~/Views/Shared/_Layout.cshtml";
    var activeTab = ViewBag.ActiveTab as string ?? "mail";

    var navItems = new[]
    {
        new { Id = "mail", Icon = "fa-envelope", Label = (string)Localizer.T("Settings.Mail.Tab"), Desc = (string)Localizer.T("Settings.Mail.Desc") },
        new { Id = "documenttemplate", Icon = "fa-file-alt", Label = (string)Localizer.T("Settings.DocumentTemplate.Tab"), Desc = (string)Localizer.T("Settings.DocumentTemplate.Desc") },
        new { Id = "branding", Icon = "fa-palette", Label = (string)Localizer.T("Settings.Branding.Tab"), Desc = (string)Localizer.T("Settings.Branding.Desc") },
        new { Id = "notifications", Icon = "fa-bell", Label = (string)Localizer.T("Settings.Notifications.Tab"), Desc = (string)Localizer.T("Settings.Notifications.Desc") },
        new { Id = "localization", Icon = "fa-globe", Label = (string)Localizer.T("Settings.Localization.Tab"), Desc = (string)Localizer.T("Settings.Localization.Desc") },
        new { Id = "general", Icon = "fa-wrench", Label = (string)Localizer.T("Settings.General.Tab"), Desc = (string)Localizer.T("Settings.General.Desc") }
    };

    var partialMap = new Dictionary<string, string>
    {
        { "mail", "_MailSettingsPartial" },
        { "documenttemplate", "_DocumentTemplateSettingsPartial" },
        { "branding", "_BrandingSettingsPartial" },
        { "notifications", "_NotificationsSettingsPartial" },
        { "localization", "_LocalizationSettingsPartial" },
        { "general", "_GeneralSettingsPartial" }
    };
}

<link rel="stylesheet" href="~/css/_settings_new.css" asp-append-version="true" />

<div class="settings-page-wrapper">
    <div class="settings-hero">
        <div class="settings-hero-icon"><i class="fas fa-cog" aria-hidden="true"></i></div>
        <div class="settings-hero-body">
            <h1 class="settings-hero-title">@Localizer.T("Page.SystemSettings")</h1>
            <p class="settings-hero-desc">@Localizer.T("Settings.Subtitle")</p>
        </div>
        <span class="settings-hero-badge">@Localizer.T("Settings.SidebarTitle")</span>
    </div>

    <button class="settings-sidebar-toggle" id="settingsSidebarToggle" type="button" aria-expanded="false" aria-controls="settingsNavList">
        <span><i class="fas fa-bars me-2" aria-hidden="true"></i>@Localizer.T("Settings.SidebarTitle")</span>
        <i class="fas fa-chevron-down"></i>
    </button>

    <div class="settings-pills" id="settingsPills" role="tablist">
        @foreach (var item in navItems)
        {
            <button type="button" class="pill @(activeTab == item.Id ? "active" : "")"
                    id="pill-@item.Id" data-target="@item.Id" role="tab"
                    aria-selected="@(activeTab == item.Id ? "true" : "false")"
                    aria-controls="section-@item.Id">
                <i class="fas @item.Icon" aria-hidden="true"></i>
                <span>@item.Label</span>
            </button>
        }
    </div>

    <div class="settings-layout">
        <aside class="settings-sidebar" id="settingsSidebar">
            <nav class="settings-nav" aria-label="@Localizer.T("Settings.SidebarTitle")">
                <div class="settings-nav-header">
                    <i class="fas fa-layer-group" aria-hidden="true"></i> @Localizer.T("Settings.SidebarTitle")
                </div>
                <div class="settings-nav-list" id="settingsNavList" role="tablist">
                    @foreach (var item in navItems)
                    {
                        <button type="button" class="settings-nav-item @(activeTab == item.Id ? "active" : "")"
                                id="nav-@item.Id" data-target="@item.Id" role="tab"
                                aria-selected="@(activeTab == item.Id ? "true" : "false")"
                                aria-controls="section-@item.Id">
                            <span class="settings-nav-label">
                                <i class="fas @item.Icon" aria-hidden="true"></i>
                                <span>@item.Label</span>
                            </span>
                            <span class="settings-nav-desc">@item.Desc</span>
                        </button>
                    }
                </div>
            </nav>
        </aside>

        <main class="settings-content" id="settingsContent">
            <div class="settings-skeleton" id="settingsSkeleton" aria-hidden="true">
                <div class="skeleton-card">
                    <div class="skeleton-card-header">
                        <div class="skeleton-card-icon skeleton-pulse"></div>
                        <div style="flex:1">
                            <div class="skeleton-line skeleton-pulse" style="width:160px;height:14px;margin-bottom:6px"></div>
                            <div class="skeleton-line skeleton-pulse" style="width:220px;height:10px"></div>
                        </div>
                    </div>
                    <div class="skeleton-card-body">
                        <div class="row g-3">
                            <div class="col-md-5"><div class="skeleton-line skeleton-pulse" style="width:100%;height:40px"></div></div>
                            <div class="col-md-2"><div class="skeleton-line skeleton-pulse" style="width:100%;height:40px"></div></div>
                            <div class="col-md-5"><div class="skeleton-line skeleton-pulse" style="width:100%;height:40px"></div></div>
                        </div>
                        <div style="margin-top:1rem">
                            <div class="row g-3">
                                <div class="col-md-6"><div class="skeleton-line skeleton-pulse" style="width:100%;height:40px"></div></div>
                                <div class="col-md-6"><div class="skeleton-line skeleton-pulse" style="width:100%;height:40px"></div></div>
                            </div>
                        </div>
                    </div>
                    <div class="skeleton-card-footer">
                        <div class="skeleton-line skeleton-pulse" style="width:90px;height:36px"></div>
                    </div>
                </div>
            </div>

            <div id="settingsSections" style="display:none">
                @foreach (var item in navItems)
                {
                    var isActive = activeTab == item.Id;
                    <div class="settings-section" id="section-@item.Id" role="tabpanel"
                         aria-labelledby="nav-@item.Id"
                         data-active="@(isActive ? "true" : "false")"
                         style="display: @(isActive ? "block" : "none")">
                        @await Html.PartialAsync(partialMap[item.Id])
                    </div>
                }
            </div>

            <div class="settings-action-bar" id="settingsActionBar" style="display:none">
                <button type="button" class="btn btn-secondary" id="resetDefaultsBtn">
                    <i class="fas fa-undo" aria-hidden="true"></i> @Localizer.T("Settings.ResetToDefault")
                </button>
                <button type="button" class="btn btn-primary" id="saveAllSettingsBtn">
                    <i class="fas fa-save" aria-hidden="true"></i> @Localizer.T("Settings.SaveAll")
                </button>
            </div>
        </main>
    </div>
</div>

<div class="settings-toast-container" id="toastContainer" aria-live="polite" aria-atomic="true"></div>

<div class="settings-loading" id="settingsLoading" aria-hidden="true">
    <div class="spinner-border" role="status">
        <span class="visually-hidden">@Localizer.T("Common.Loading")</span>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var activeSection = '@activeTab';
            var validSections = ['mail', 'documenttemplate', 'branding', 'notifications', 'localization', 'general'];
            var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            var transitionMs = prefersReducedMotion ? 0 : 300;

            function showToast(message, type) {
                type = type || 'success';
                var container = document.getElementById('toastContainer');
                var toast = document.createElement('div');
                toast.className = 'settings-toast toast-' + type;
                if (prefersReducedMotion) toast.style.animation = 'none';
                var iconMap = { success: 'fa-check-circle', error: 'fa-exclamation-circle', info: 'fa-info-circle', warning: 'fa-exclamation-triangle' };
                var icon = iconMap[type] || 'fa-info-circle';
                toast.innerHTML =
                    '<i class="fas ' + icon + '" aria-hidden="true"></i>' +
                    '<span>' + message + '</span>' +
                    '<button type="button" class="toast-close" aria-label="Close">&times;</button>';
                toast.querySelector('.toast-close').addEventListener('click', function() { toast.remove(); });
                container.appendChild(toast);
                setTimeout(function() { if (toast.parentNode) toast.remove(); }, 4000);
            }

            function setActiveNav(sectionId) {
                var nav = document.getElementById('settingsNavList');
                if (nav) {
                    Array.from(nav.children).forEach(function(el) {
                        el.classList.remove('active');
                        el.setAttribute('aria-selected', 'false');
                    });
                    var navBtn = document.getElementById('nav-' + sectionId);
                    if (navBtn) { navBtn.classList.add('active'); navBtn.setAttribute('aria-selected', 'true'); }
                }
                var pills = document.getElementById('settingsPills');
                if (pills) {
                    Array.from(pills.children).forEach(function(el) {
                        el.classList.remove('active');
                        el.setAttribute('aria-selected', 'false');
                    });
                    var pill = document.getElementById('pill-' + sectionId);
                    if (pill) {
                        pill.classList.add('active');
                        pill.setAttribute('aria-selected', 'true');
                        if (!prefersReducedMotion) {
                            pill.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
                        }
                    }
                }
            }

            function switchSection(sectionId) {
                var prevSection = document.querySelector('.settings-section[data-active="true"]');
                var nextSection = document.getElementById('section-' + sectionId);

                if (prevSection) {
                    prevSection.style.opacity = '0';
                    prevSection.style.transform = 'translateY(10px)';
                    setTimeout(function() {
                        prevSection.style.display = 'none';
                        prevSection.setAttribute('data-active', 'false');
                        prevSection.classList.remove('active');
                        if (nextSection) {
                            nextSection.style.display = 'block';
                            nextSection.classList.add('active');
                            nextSection.setAttribute('data-active', 'true');
                            setTimeout(function() {
                                nextSection.style.opacity = '1';
                                nextSection.style.transform = 'translateY(0)';
                            }, 10);
                        }
                    }, transitionMs);
                } else if (nextSection) {
                    nextSection.style.display = 'block';
                    nextSection.classList.add('active');
                    nextSection.setAttribute('data-active', 'true');
                    setTimeout(function() {
                        nextSection.style.opacity = '1';
                        nextSection.style.transform = 'translateY(0)';
                    }, 10);
                }

                setActiveNav(sectionId);
                activeSection = sectionId;
                if (window.location.hash !== '#' + sectionId) {
                    history.replaceState(null, '', '#' + sectionId);
                }
                var toggle = document.getElementById('settingsSidebarToggle');
                if (toggle) {
                    toggle.setAttribute('aria-expanded', 'false');
                    var icon = toggle.querySelector('.fa-chevron-down, .fa-chevron-up');
                    if (icon) icon.className = 'fas fa-chevron-down';
                }
                var navList = document.getElementById('settingsNavList');
                if (navList) navList.classList.remove('show');
            }

            // Navigation clicks
            document.querySelectorAll('#settingsNavList .settings-nav-item, #settingsPills .pill').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var target = this.getAttribute('data-target');
                    if (target) switchSection(target);
                });
            });

            // Mobile toggle
            document.getElementById('settingsSidebarToggle')?.addEventListener('click', function() {
                var navList = document.getElementById('settingsNavList');
                var isExpanded = this.getAttribute('aria-expanded') === 'true';
                if (navList) navList.classList.toggle('show');
                this.setAttribute('aria-expanded', !isExpanded);
                var icon = this.querySelector('.fa-chevron-down, .fa-chevron-up');
                if (icon) icon.className = isExpanded ? 'fas fa-chevron-down' : 'fas fa-chevron-up';
            });

            // Hash-based navigation
            var hash = window.location.hash.replace('#', '');
            if (hash && validSections.indexOf(hash) >= 0) switchSection(hash);

            // Show content, hide skeleton
            var skeleton = document.getElementById('settingsSkeleton');
            var sections = document.getElementById('settingsSections');
            var actionBar = document.getElementById('settingsActionBar');
            if (skeleton) setTimeout(function() { skeleton.style.opacity = '0'; }, 150);
            setTimeout(function() {
                if (skeleton) skeleton.style.display = 'none';
                if (sections) sections.style.display = 'block';
                if (actionBar) actionBar.style.display = 'flex';
            }, 350);

            // Save All
            document.getElementById('saveAllSettingsBtn')?.addEventListener('click', function() {
                var btn = this;
                btn.disabled = true;
                var originalHtml = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> @Localizer.T("Settings.Saving")';
                var loading = document.getElementById('settingsLoading');
                if (loading) loading.classList.add('active');

                var activeForm = document.querySelector('.settings-section[data-active="true"] form');
                if (activeForm) {
                    var formData = new FormData(activeForm);
                    fetch(activeForm.action, {
                        method: 'POST',
                        body: new URLSearchParams(formData),
                        headers: { 'RequestVerificationToken': activeForm.querySelector('input[name="__RequestVerificationToken"]')?.value || '' }
                    })
                    .then(function(r) {
                        if (r.redirected) {
                            if (r.url.indexOf('tab=') > -1 || r.url.indexOf('Settings') > -1) showToast('@Localizer.T("Settings.SavedToast")', 'success');
                            window.location.href = r.url;
                            return null;
                        }
                        return r.text();
                    })
                    .then(function() { showToast('@Localizer.T("Settings.SavedToast")', 'success'); })
                    .catch(function() { showToast('@Localizer.T("Alert.Error.General")', 'error'); })
                    .finally(function() {
                        btn.disabled = false;
                        btn.innerHTML = originalHtml;
                        if (loading) loading.classList.remove('active');
                    });
                } else { btn.disabled = false; btn.innerHTML = originalHtml; }
            });

            // Reset defaults
            document.getElementById('resetDefaultsBtn')?.addEventListener('click', function() {
                if (confirm('@Localizer.T("Common.Confirm")')) showToast('@Localizer.T("Settings.SavedToast")', 'info');
            });

            // Send test email
            var testBtn = document.getElementById('sendTestEmailBtn');
            if (testBtn) {
                testBtn.addEventListener('click', function() {
                    var btn = this;
                    btn.disabled = true;
                    var originalHtml = btn.innerHTML;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> @Localizer.T("Common.Loading")';
                    fetch('/SuperAdmin/Settings/SendTestEmail', {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' }
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) { showToast(data.message, data.success ? 'success' : 'error'); })
                    .catch(function() { showToast('@Localizer.T("Settings.TestEmailFailed")', 'error'); })
                    .finally(function() { btn.disabled = false; btn.innerHTML = originalHtml; });
                });
            }

            // Password toggle
            document.querySelectorAll('.toggle-password').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var targetName = this.getAttribute('data-target');
                    var input = document.getElementById(targetName);
                    if (input) {
                        var isPassword = input.type === 'password';
                        input.type = isPassword ? 'text' : 'password';
                        var icon = this.querySelector('i');
                        if (icon) icon.className = isPassword ? 'fas fa-eye-slash' : 'fas fa-eye';
                        this.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
                    }
                });
            });

            // Live branding preview
            var siteNameInput = document.querySelector('input[name="Branding_SiteName"]');
            var siteNameArInput = document.querySelector('input[name="Branding_SiteNameAr"]');
            var colorInput = document.querySelector('input[name="Branding_PrimaryColor"]');
            var previewName = document.getElementById('previewSiteName');
            var previewMark = document.getElementById('previewBrandMark');
            var previewBox = document.getElementById('previewBrandBox');

            if (colorInput && previewMark) {
                function updateBrandPreview() {
                    var color = colorInput.value || '#1A3A6B';
                    var name = siteNameInput ? siteNameInput.value || 'CBAHI Portal' : 'CBAHI Portal';
                    if (previewMark) {
                        previewMark.style.background = color;
                        previewMark.textContent = name.charAt(0).toUpperCase();
                    }
                    if (previewBox) {
                        previewBox.style.borderColor = color;
                        previewBox.style.boxShadow = '0 0 0 1px ' + color + '20';
                    }
                    if (previewName) previewName.textContent = name;
                }
                colorInput.addEventListener('input', updateBrandPreview);
                if (siteNameInput) siteNameInput.addEventListener('input', updateBrandPreview);
                updateBrandPreview();
            }

            // Form submit spinner
            document.querySelectorAll('.settings-card form').forEach(function(form) {
                form.addEventListener('submit', function(e) {
                    var submitBtn = this.querySelector('.settings-card-footer .btn-primary');
                    if (submitBtn && !submitBtn.disabled) {
                        submitBtn.disabled = true;
                        var originalHtml = submitBtn.innerHTML;
                        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> @Localizer.T("Settings.Saving")';
                        setTimeout(function() { submitBtn.disabled = false; submitBtn.innerHTML = originalHtml; }, 10000);
                    }
                });
            });
        })();
    </script>
}
