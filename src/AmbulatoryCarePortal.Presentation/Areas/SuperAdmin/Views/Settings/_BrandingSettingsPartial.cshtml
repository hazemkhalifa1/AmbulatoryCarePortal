@{
    SystemSettingDto? GetSetting(string key)
    {
        var settings = ViewBag.Settings as Dictionary<SettingCategory, List<SystemSettingDto>> ?? new();
        foreach (var kv in settings)
        {
            var found = kv.Value.FirstOrDefault(s => s.Key == key);
            if (found != null) return found;
        }
        return null;
    }

    string SettingValue(string key) => GetSetting(key)?.Value ?? "";
}

<form method="post" asp-action="UpdateBranding" aria-label="@Localizer.T("Settings.Branding.Tab")" novalidate>
    @Html.AntiForgeryToken()
    <div class="settings-card">
        <div class="settings-card-header">
            <div class="settings-card-icon brand-icon"><i class="fas fa-palette" aria-hidden="true"></i></div>
            <div class="settings-card-heading">
                <h3>@Localizer.T("Settings.Branding.Title")</h3>
                <p class="card-subtitle">@Localizer.T("Settings.Branding.Subtitle")</p>
            </div>
        </div>
        <div class="settings-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="settings-label" for="Branding_SiteName">@Localizer.T("Settings.Branding.SiteName")</label>
                    <input name="Branding_SiteName" id="Branding_SiteName" class="settings-input" value="@SettingValue("Branding.SiteName")" placeholder="CBAHI Ambulatory Care Portal" />
                </div>
                <div class="col-md-6">
                    <label class="settings-label" for="Branding_SiteNameAr">@Localizer.T("Settings.Branding.SiteNameAr")</label>
                    <input name="Branding_SiteNameAr" id="Branding_SiteNameAr" class="settings-input" value="@SettingValue("Branding.SiteNameAr")" dir="rtl" placeholder="بوابة ساباهي للرعاية الخارجية" />
                </div>
            </div>
            <div class="settings-field-group">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="settings-label" for="Branding_PrimaryColor">@Localizer.T("Settings.Branding.PrimaryColor")</label>
                        <div class="settings-color-wrap">
                            <input name="Branding_PrimaryColor" id="Branding_PrimaryColor" class="settings-color-input" value="@(SettingValue("Branding.PrimaryColor") ?? "#1A3A6B")" type="color" />
                            <span class="settings-color-hex" id="colorValueDisplay">@(SettingValue("Branding.PrimaryColor") ?? "#1A3A6B")</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="settings-label" for="Branding_SupportPhone">@Localizer.T("Settings.Branding.SupportPhone")</label>
                        <input name="Branding_SupportPhone" id="Branding_SupportPhone" class="settings-input" value="@SettingValue("Branding.SupportPhone")" placeholder="+966 5X XXX XXXX" autocomplete="tel" />
                    </div>
                    <div class="col-md-5">
                        <label class="settings-label" for="Branding_SupportEmail">@Localizer.T("Settings.Branding.SupportEmail")</label>
                        <input name="Branding_SupportEmail" id="Branding_SupportEmail" class="settings-input" value="@SettingValue("Branding.SupportEmail")" type="email" placeholder="support@cbahi-portal.com" autocomplete="email" />
                    </div>
                </div>
            </div>
            <div class="branding-preview">
                <div class="branding-preview-label">@Localizer.T("Settings.Branding.Preview")</div>
                <div class="branding-preview-box preview-light" id="previewBrandBox">
                    <div class="branding-preview-mark" id="previewBrandMark" style="background: @(SettingValue("Branding.PrimaryColor") ?? "#1A3A6B")">
                        @(string.IsNullOrEmpty(SettingValue("Branding.SiteName")) ? "C" : SettingValue("Branding.SiteName").Trim().Substring(0, 1).ToUpper())
                    </div>
                    <div>
                        <div class="branding-preview-name">
                            <span id="previewSiteName">@(string.IsNullOrEmpty(SettingValue("Branding.SiteName")) ? "CBAHI Portal" : SettingValue("Branding.SiteName"))</span>
                            <span class="brand-secondary">| Ambulatory Care</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="settings-card-footer">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save" aria-hidden="true"></i> @Localizer.T("Common.Save")
            </button>
        </div>
    </div>
</form>

<script>
    (function() {
        var colorInput = document.querySelector('input[name="Branding_PrimaryColor"]');
        var colorDisplay = document.getElementById('colorValueDisplay');
        if (colorInput && colorDisplay) {
            colorInput.addEventListener('input', function() { colorDisplay.textContent = this.value; });
        }
    })();
</script>
