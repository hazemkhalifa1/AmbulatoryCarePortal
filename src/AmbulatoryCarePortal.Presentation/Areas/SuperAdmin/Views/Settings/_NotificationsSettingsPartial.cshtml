@{
    SystemSettingDto? GetSetting(string key)
    {
        var settings = ViewBag.Settings as Dictionary<SettingCategory, List<SystemSettingDto>> ?? new();
        foreach (var kv in settings)
        {
            var found = kv.Value.FirstOrDefault(s => s.Key == key);
            if (found != null) return found;
        }
        return null;
    }

    string SettingValue(string key) => GetSetting(key)?.Value ?? "";
    bool SettingBool(string key) => bool.TryParse(GetSetting(key)?.Value, out var b) && b;
}

<form method="post" asp-action="UpdateNotifications" aria-label="@Localizer.T("Settings.Notifications.Tab")">
    @Html.AntiForgeryToken()
    <div class="settings-card">
        <div class="settings-card-header">
            <div class="header-icon icon-bell"><i class="fas fa-bell"></i></div>
            <h3>@Localizer.T("Settings.Notifications.Title")</h3>
            <span class="header-badge">@Localizer.T("Settings.Notifications.Tab")</span>
        </div>
        <div class="settings-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">@Localizer.T("Settings.Notifications.PolicyExpiryWarningDays")</label>
                    <input name="Notifications_PolicyExpiryWarningDays" class="form-control" value="@SettingValue("Notifications.PolicyExpiryWarningDays")" type="number" min="1" placeholder="30" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">@Localizer.T("Settings.Notifications.HRDocumentExpiryWarningDays")</label>
                    <input name="Notifications_HRDocumentExpiryWarningDays" class="form-control" value="@SettingValue("Notifications.HRDocumentExpiryWarningDays")" type="number" min="1" placeholder="30" />
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    @await Html.PartialAsync("_SettingsToggle", new { Name = "Notifications_EnableEmailNotifications", Label = Localizer.T("Settings.Notifications.EnableEmail"), Checked = SettingBool("Notifications.EnableEmailNotifications") })
                </div>
                <div class="col-md-4">
                    @await Html.PartialAsync("_SettingsToggle", new { Name = "Notifications_DailyDigestEnabled", Label = Localizer.T("Settings.Notifications.DailyDigest"), Checked = SettingBool("Notifications.DailyDigestEnabled") })
                </div>
                <div class="col-md-4">
                    <label class="form-label">@Localizer.T("Settings.Notifications.DigestSendTime")</label>
                    <input name="Notifications_DigestSendTime" class="form-control" value="@SettingValue("Notifications.DigestSendTime")" type="time" />
                </div>
            </div>
        </div>
    </div>
</form>
