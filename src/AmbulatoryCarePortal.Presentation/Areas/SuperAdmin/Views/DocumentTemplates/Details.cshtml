@model TemplateDetailsDto
@{
    ViewData["Title"] = $"{Model.StandardCode} - {Model.TitleEn}";
    var activeTab = Context.Request.Query["tab"].FirstOrDefault() ?? "info";
}

@section Styles {
    <link rel="stylesheet" href="~/css/document-templates.css" asp-append-version="true" />
}

<div class="fade-in">
    <!-- Page Header -->
    <div class="template-page-header">
        <div class="template-page-header-left">
            <div class="template-page-header-icon">
                <i class="fas fa-file-alt"></i>
            </div>
            <div>
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <h1 class="mb-0">@Model.StandardCode — @Model.TitleEn</h1>
                    <span class="status-pill @(Model.IsActive ? "active" : "inactive")">@Localizer.T(Model.IsActive ? "Common.Active" : "Common.Inactive")</span>
                </div>
                <p class="template-page-header-sub">
                    @Model.ClinicType
                    <span class="mx-2 text-muted">|</span>
                    v@(Model.CurrentVersion)
                    <span class="mx-2 text-muted">|</span>
                    @Model.Variables.Count @Localizer.T("Template.Variables").ToLower()
                    <span class="mx-2 text-muted">|</span>
                    @Model.Assignments.Count @Localizer.T("Clinic.Assignments").ToLower()
                </p>
            </div>
        </div>
        <div class="template-page-header-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="fas fa-edit me-1"></i>@Localizer.T("Common.Edit")
            </a>
            <a asp-action="Preview" asp-route-id="@Model.Id" class="btn btn-info text-white">
                <i class="fas fa-eye me-1"></i>@Localizer.T("Common.Preview")
            </a>
            <a asp-action="Index" class="back-link">
                <i class="fas fa-arrow-left"></i>
                @Localizer.T("Common.Back")
            </a>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav detail-tabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "info" ? "active" : "")" id="info-tab" data-bs-toggle="tab" data-bs-target="#info" type="button" role="tab">
                <i class="fas fa-info-circle me-1"></i>@Localizer.T("Common.Information")
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "variables" ? "active" : "")" id="variables-tab" data-bs-toggle="tab" data-bs-target="#variables" type="button" role="tab">
                <i class="fas fa-tags me-1"></i>@Localizer.T("Template.Variables")
                <span class="tab-count">@Model.Variables.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "versions" ? "active" : "")" id="versions-tab" data-bs-toggle="tab" data-bs-target="#versions" type="button" role="tab">
                <i class="fas fa-history me-1"></i>@Localizer.T("Template.Versions")
                <span class="tab-count">@Model.Versions.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "assignments" ? "active" : "")" id="assignments-tab" data-bs-toggle="tab" data-bs-target="#assignments" type="button" role="tab">
                <i class="fas fa-hospital me-1"></i>@Localizer.T("Clinic.Assignments")
                <span class="tab-count">@Model.Assignments.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == "generated" ? "active" : "")" id="generated-tab" data-bs-toggle="tab" data-bs-target="#generated" type="button" role="tab">
                <i class="fas fa-file-export me-1"></i>@Localizer.T("Template.GeneratedDocuments")
                <span class="tab-count">@Model.GeneratedDocuments.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- Info Tab -->
        <div class="tab-pane fade @(activeTab == "info" ? "show active" : "")" id="info" role="tabpanel">
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="card card-primary h-100">
                        <div class="card-header">
                            <h3 class="card-title"><i class="fas fa-info-circle"></i>@Localizer.T("Common.Information")</h3>
                        </div>
                        <div class="card-body">
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Common.Id")</span>
                                    <span class="detail-value">@Model.Id</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Doc.StandardCode")</span>
                                    <span class="detail-value"><span class="standard-code-badge">@Model.StandardCode</span></span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Doc.TitleEn")</span>
                                    <span class="detail-value">@Model.TitleEn</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Doc.TitleAr")</span>
                                    <span class="detail-value">@(Model.TitleAr ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Doc.ClinicType")</span>
                                    <span class="detail-value">@Model.ClinicType</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Template.DepartmentCategory")</span>
                                    <span class="detail-value">@(Model.DepartmentCategory ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Template.CurrentVersion")</span>
                                    <span class="detail-value">v@(Model.CurrentVersion)</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-label">@Localizer.T("Common.CreatedAt")</span>
                                    <span class="detail-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card h-100">
                        <div class="card-header">
                            <h3 class="card-title"><i class="fas fa-bolt"></i>@Localizer.T("Dashboard.QuickActions")</h3>
                        </div>
                        <div class="card-body">
                            <div class="action-grid">
                                <form method="post" asp-action="ExtractVariables" asp-route-id="@Model.Id">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="action-card-btn info" style="width:100%;cursor:pointer;font-family:inherit;border:none;">
                                        <i class="fas fa-magic"></i>
                                        <span class="action-title">@Localizer.T("Template.ExtractVariables")</span>
                                        <span class="action-desc">Parse DOCX placeholders</span>
                                    </button>
                                </form>
                                <form method="post" asp-action="AssignToAllClinics" asp-route-id="@Model.Id">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="action-card-btn primary" style="width:100%;cursor:pointer;font-family:inherit;border:none;">
                                        <i class="fas fa-hospital"></i>
                                        <span class="action-title">@Localizer.T("Clinic.AssignToAll")</span>
                                        <span class="action-desc">Assign to all active clinics</span>
                                    </button>
                                </form>
                                @if (!string.IsNullOrEmpty(Model.TemplateFilePath))
                                {
                                    <a href="@Model.TemplateFilePath" target="_blank" class="action-card-btn success">
                                        <i class="fas fa-file-word"></i>
                                        <span class="action-title">@Localizer.T("Common.View") @Localizer.T("Common.File")</span>
                                        <span class="action-desc">Open current DOCX template</span>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card mt-4">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fas fa-align-left"></i>@Localizer.T("Common.Description")</h3>
                    </div>
                    <div class="card-body">
                        <p class="mb-0" style="font-size:var(--font-size-base);color:var(--gray-600);line-height:1.7;">@Model.Description</p>
                    </div>
                </div>
            }
        </div>

        <!-- Variables Tab -->
        <div class="tab-pane fade @(activeTab == "variables" ? "show active" : "")" id="variables" role="tabpanel">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-tags"></i>@Localizer.T("Template.Variables")</h3>
                    <form method="post" asp-action="ExtractVariables" asp-route-id="@Model.Id" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-info text-white">
                            <i class="fas fa-magic me-1"></i>@Localizer.T("Template.ExtractVariables")
                        </button>
                    </form>
                </div>
                <div class="card-body">
                    @if (Model.Variables.Any())
                    {
                        <div class="table-responsive">
                            <table class="table template-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>@Localizer.T("Template.VariableName")</th>
                                        <th>@Localizer.T("Template.DisplayName")</th>
                                        <th class="text-center">@Localizer.T("Template.IsImage")</th>
                                        <th class="text-center">@Localizer.T("Template.IsRequired")</th>
                                        <th>@Localizer.T("Template.DefaultValue")</th>
                                        <th class="text-center">@Localizer.T("Common.Actions")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in Model.Variables.Select((v, i) => new { v, i }))
                                    {
                                        <tr>
                                            <td>@(v.i + 1)</td>
                                            <td><code>{{@v.v.Name}}</code></td>
                                            <td>
                                                <div class="inline-edit" id="inline-@v.v.Id">
                                                    <div class="inline-edit-display" onclick="activateEdit(@v.v.Id)">
                                                        <span id="display-@v.v.Id">@v.v.DisplayName</span>
                                                        <i class="fas fa-pen text-muted" style="font-size:0.6rem;opacity:0.4;"></i>
                                                    </div>
                                                    <div class="inline-edit-input">
                                                        <input id="edit-@v.v.Id" class="form-control" value="@v.v.DisplayName" />
                                                        <button type="button" class="btn btn-sm btn-primary" onclick="saveEdit(@v.v.Id)">
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-ghost" onclick="cancelEdit(@v.v.Id)">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="status-pill @(v.v.IsImage ? "active" : "inactive")">@(v.v.IsImage ? "Yes" : "No")</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="status-pill @(v.v.IsRequired ? "active" : "inactive")">@(v.v.IsRequired ? "Yes" : "No")</span>
                                            </td>
                                            <td>@(v.v.DefaultValue ?? "—")</td>
                                            <td class="text-center">
                                                <div class="cell-actions justify-content-center">
                                                    <form method="post" asp-action="DeleteVariable" asp-route-id="@v.v.Id" class="d-inline" onsubmit="return confirm('Delete this variable?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn-action delete" title="Delete">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-tags"></i>
                            <h4>@Localizer.T("Template.NoVariables")</h4>
                            <p class="mb-0">@Localizer.T("Template.ExtractVariablesHint")</p>
                            <form method="post" asp-action="ExtractVariables" asp-route-id="@Model.Id" class="mt-3">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-info text-white"><i class="fas fa-magic me-1"></i>@Localizer.T("Template.ExtractVariables")</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Versions Tab -->
        <div class="tab-pane fade @(activeTab == "versions" ? "show active" : "")" id="versions" role="tabpanel">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-history"></i>@Localizer.T("Template.Versions")</h3>
                </div>
                <div class="card-body">
                    @if (Model.Versions.Any())
                    {
                        <div class="version-timeline">
                            @foreach (var ver in Model.Versions.OrderByDescending(v => v.VersionNumber))
                            {
                                <div class="version-item">
                                    <div class="version-dot @(ver.VersionNumber == Model.CurrentVersion ? "current" : "previous")"></div>
                                    <div class="version-content">
                                        <div class="version-header">
                                            <div class="d-flex align-items-center gap-3">
                                                <span class="version-number">
                                                    <span class="standard-code-badge">v@(ver.VersionNumber)</span>
                                                </span>
                                                @if (ver.VersionNumber == Model.CurrentVersion)
                                                {
                                                    <span class="badge badge-success">@Localizer.T("Common.Active")</span>
                                                }
                                            </div>
                                            <div class="version-meta">
                                                <span>@ver.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                                @if (!string.IsNullOrEmpty(ver.FilePath))
                                                {
                                                    <a href="@ver.FilePath" target="_blank" class="btn btn-sm btn-ghost">
                                                        <i class="fas fa-download me-1"></i>@Localizer.T("Common.Download")
                                                    </a>
                                                }
                                                @if (ver.VersionNumber != Model.CurrentVersion)
                                                {
                                                    <form method="post" asp-action="RestoreVersion" asp-route-templateId="@Model.Id" asp-route-versionId="@ver.Id" class="d-inline" onsubmit="return confirm('Restore version v@(ver.VersionNumber)?');">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                                            <i class="fas fa-undo me-1"></i>@Localizer.T("Template.Restore")
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(ver.ChangeLog))
                                        {
                                            <div class="version-changelog">
                                                <i class="fas fa-quote-left me-1 text-muted" style="font-size:0.7rem;"></i>
                                                @ver.ChangeLog
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-history"></i>
                            <h4 class="mb-0">@Localizer.T("Template.NoVersions")</h4>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Assignments Tab -->
        <div class="tab-pane fade @(activeTab == "assignments" ? "show active" : "")" id="assignments" role="tabpanel">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-hospital"></i>@Localizer.T("Clinic.Assignments")</h3>
                    <form method="post" asp-action="AssignToAllClinics" asp-route-id="@Model.Id" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-plus me-1"></i>@Localizer.T("Clinic.AssignToAll")</button>
                    </form>
                </div>
                <div class="card-body">
                    @if (Model.Assignments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table template-table">
                                <thead>
                                    <tr>
                                        <th>@Localizer.T("Clinic.Name")</th>
                                        <th>@Localizer.T("Clinic.Status")</th>
                                        <th class="text-center">@Localizer.T("Template.Values")</th>
                                        <th class="text-center">@Localizer.T("Template.GeneratedDocuments")</th>
                                        <th>@Localizer.T("Common.CreatedAt")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in Model.Assignments)
                                    {
                                        <tr>
                                            <td class="assignment-clinic-name">@a.ClinicName</td>
                                            <td><span class="status-pill @(a.AssignmentStatus == "Active" ? "active" : "inactive")">@a.AssignmentStatus</span></td>
                                            <td class="text-center">@a.ValueCount</td>
                                            <td class="text-center">@a.GeneratedDocumentCount</td>
                                            <td>@a.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-hospital"></i>
                            <h4>@Localizer.T("Template.NoAssignments")</h4>
                            <form method="post" asp-action="AssignToAllClinics" asp-route-id="@Model.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-primary mt-2"><i class="fas fa-plus me-1"></i>@Localizer.T("Clinic.AssignToAll")</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Generated Documents Tab -->
        <div class="tab-pane fade @(activeTab == "generated" ? "show active" : "")" id="generated" role="tabpanel">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-file-export"></i>@Localizer.T("Template.GeneratedDocuments")</h3>
                </div>
                <div class="card-body">
                    @if (Model.GeneratedDocuments.Any())
                    {
                        <div class="table-responsive">
                            <table class="table template-table">
                                <thead>
                                    <tr>
                                        <th>@Localizer.T("Common.FileName")</th>
                                        <th>@Localizer.T("Common.Type")</th>
                                        <th>@Localizer.T("Common.Size")</th>
                                        <th>@Localizer.T("Common.CreatedAt")</th>
                                        <th class="text-center">@Localizer.T("Common.Actions")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var g in Model.GeneratedDocuments.OrderByDescending(g => g.CreatedAt))
                                    {
                                        <tr>
                                            <td class="template-title">@g.FileName</td>
                                            <td><span class="badge badge-info">@g.FileType.ToUpper()</span></td>
                                            <td>@(g.FileSizeBytes / 1024) KB</td>
                                            <td>@g.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-center">
                                                <a href="@g.FilePath" target="_blank" class="btn-action" title="Download">
                                                    <i class="fas fa-download" style="color:var(--info);"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-file-export"></i>
                            <h4 class="mb-0">@Localizer.T("Template.NoGeneratedDocuments")</h4>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function activateEdit(id) {
            var container = document.getElementById('inline-' + id);
            container.classList.add('active');
            var input = document.getElementById('edit-' + id);
            input.focus();
            input.select();
        }

        function saveEdit(id) {
            var container = document.getElementById('inline-' + id);
            var input = document.getElementById('edit-' + id);
            var display = document.getElementById('display-' + id);
            var newValue = input.value;

            $.post('@Url.Action("UpdateVariable", "DocumentTemplates", new { area = "SuperAdmin" })', {
                id: id,
                displayName: newValue,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            }).done(function () {
                display.textContent = newValue;
                container.classList.remove('active');
            }).fail(function () {
                container.classList.remove('active');
            });
        }

        function cancelEdit(id) {
            var container = document.getElementById('inline-' + id);
            container.classList.remove('active');
        }

        document.querySelectorAll('.inline-edit-input .form-control').forEach(function(input) {
            input.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    var id = this.id.replace('edit-', '');
                    saveEdit(id);
                }
                if (e.key === 'Escape') {
                    var id = this.id.replace('edit-', '');
                    cancelEdit(id);
                }
            });
        });
    </script>
}
