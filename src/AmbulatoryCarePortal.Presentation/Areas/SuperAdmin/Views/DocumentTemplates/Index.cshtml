@model PagedResult<DocumentTemplateDto>

@{
    ViewData["Title"] = Localizer.T("Page.DocumentTemplates");
    var selectedClinicType = (string?)ViewBag.SelectedClinicType;
    var selectedStandard = (string?)ViewBag.SelectedStandard;
    var standards = (string[]?)ViewBag.Standards;
    var documentCounts = (Dictionary<string, int>?)ViewBag.DocumentCounts;
    var searchTerm = (string?)ViewBag.SearchTerm;
    var currentPage = Model.PageNumber;
    var totalPages = Model.TotalPages;
    var totalCount = Model.TotalCount;

    var standardNames = new Dictionary<string, string>
    {
        {"LD", "Leadership"},
        {"PC", "Provision of Care"},
        {"FMS", "Facility Management & Safety"},
        {"LB", "Laboratory"},
        {"RD", "Radiology"},
        {"DN", "Dental/Nursing"},
        {"MM", "Medication Management"},
        {"MOI", "Management of Information"},
        {"IPC", "Infection Prevention & Control"},
        {"DPU", "DPU"},
        {"DA", "DA"},
        {"DL", "Dental Lab"}
    };

    var standardIcons = new Dictionary<string, string>
    {
        {"LD", "fa-users-cog"},
        {"PC", "fa-stethoscope"},
        {"FMS", "fa-building"},
        {"LB", "fa-flask"},
        {"RD", "fa-x-ray"},
        {"DN", "fa-tooth"},
        {"MM", "fa-pills"},
        {"MOI", "fa-database"},
        {"IPC", "fa-shield-virus"},
        {"DPU", "fa-tint"},
        {"DA", "fa-syringe"},
        {"DL", "fa-tooth"}
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/document-templates.css" asp-append-version="true" />
}

<div class="fade-in">

    @if (!string.IsNullOrEmpty(selectedClinicType))
    {
        <!-- Standards Section -->
        @if (standards != null && standards.Any())
        {
            <div class="card mb-4">
                <div class="card-body" style="padding-bottom: 0.75rem;">
                    <div class="standards-header">
                        <div class="standards-header-left">
                            <div class="template-stat-icon primary">
                                <i class="fas fa-award"></i>
                            </div>
                            <div>
                                <div class="standards-title">CBAHI Standards</div>
                                <p class="standards-subtitle">@Localizer.T("Doc.FilterDocuments")</p>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(selectedStandard))
                        {
                            <a href="@Url.Action("Index", new { clinicType = selectedClinicType })" class="btn btn-sm btn-ghost">
                                <i class="fas fa-times me-1"></i>@Localizer.T("Doc.ClearFilters")
                            </a>
                        }
                    </div>
                    <div class="d-flex flex-nowrap gap-3 overflow-auto py-1 standards-row">
                        @foreach (var std in standards)
                        {
                            var count = documentCounts != null && documentCounts.ContainsKey(std) ? documentCounts[std] : 0;
                            var isSelected = std == selectedStandard;
                            var stdName = standardNames.ContainsKey(std) ? standardNames[std] : std;
                            var icon = standardIcons.ContainsKey(std) ? standardIcons[std] : "fa-file";
                            <div class="flex-shrink-0 standards-col">
                                <a href="@Url.Action("Index", new { clinicType = selectedClinicType, standard = std })"
                                   class="standard-link">
                                    <div class="standard-card @(isSelected ? "selected" : "")">
                                        <div class="standard-icon-wrap">
                                            <i class="fas @icon"></i>
                                        </div>
                                        <span class="standard-badge">@std</span>
                                        <div class="standard-name">@stdName</div>
                                        <span class="standard-count">
                                            <span class="standard-count-num">@count</span>
                                            <span>@Localizer.T("Clinic.Documents")</span>
                                        </span>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Stats row -->
        <div class="template-stats">
            <div class="template-stat">
                <div class="template-stat-icon primary">
                    <i class="fas fa-file-alt"></i>
                </div>
                <div class="template-stat-content">
                    <span class="template-stat-value">@totalCount</span>
                    <span class="template-stat-label">@Localizer.T("Clinic.Documents")</span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(selectedStandard))
            {
                <div class="template-stat">
                    <div class="template-stat-icon info">
                        <i class="fas fa-filter"></i>
                    </div>
                    <div class="template-stat-content">
                        <span class="template-stat-value">@selectedStandard</span>
                        <span class="template-stat-label">@Localizer.T("Common.Filtered")</span>
                    </div>
                </div>
            }
        </div>

        <!-- Table -->
        <div class="table-container">
            <div class="table-toolbar">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <h5 class="mb-0 font-semibold" style="font-size:var(--font-size-base);">
                        @if (!string.IsNullOrEmpty(selectedStandard))
                        {
                            @Localizer.T("Page.DocumentTemplates")
                        }
                        else
                        {
                            <span>@Localizer.T("Clinic.AllDocuments")</span>
                        }
                    </h5>
                    @if (!string.IsNullOrEmpty(selectedStandard))
                    {
                        <span class="badge badge-primary">@selectedStandard</span>
                    }
                    else
                    {
                        <span class="badge badge-neutral">@selectedClinicType</span>
                    }
                    <span class="page-info">@totalCount @Localizer.T("Clinic.Documents")</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <form method="get" action="@Url.Action("Index")" class="d-flex align-items-center gap-2" role="search">
                        <input type="hidden" name="clinicType" value="@selectedClinicType" />
                        @if (!string.IsNullOrEmpty(selectedStandard))
                        {
                            <input type="hidden" name="standard" value="@selectedStandard" />
                        }
                        <div class="search-box">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text" name="searchTerm" class="form-control" placeholder="@Localizer.T("Search.Templates")" value="@searchTerm" style="height:34px;font-size:var(--font-size-sm);padding-inline-start:2.1rem;" />
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search"></i></button>
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <a href="@Url.Action("Index", new { clinicType = selectedClinicType, standard = selectedStandard })" class="btn btn-sm btn-ghost"><i class="fas fa-times"></i></a>
                        }
                    </form>
                    <a asp-action="Create" asp-route-clinicType="@selectedClinicType" asp-route-standard="@selectedStandard" class="btn btn-sm btn-primary">
                        <i class="fas fa-plus"></i> @Localizer.T("Button.Add")
                    </a>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table template-table" role="table">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer.T("Common.Id")</th>
                            <th scope="col">@Localizer.T("Clinic.Document")</th>
                            <th scope="col">@Localizer.T("Clinic.Department")</th>
                            <th scope="col" class="text-center">@Localizer.T("Common.View")</th>
                            <th scope="col" class="text-center">@Localizer.T("Common.Active")</th>
                            <th scope="col" class="text-center">@Localizer.T("Common.Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Data.Any())
                        {
                            @foreach (var template in Model.Data)
                            {
                                <tr>
                                    <td><span class="template-code">@template.StandardCode</span></td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@template.Id" class="template-title text-decoration-none">
                                            @template.TitleEn
                                        </a>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(template.DepartmentCategory))
                                        {
                                            @template.DepartmentCategory
                                        }
                                        else
                                        {
                                            <span class="text-muted">&mdash;</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(template.TemplateFilePath))
                                        {
                                            <a href="@template.TemplateFilePath" target="_blank" class="btn-action" title="@Localizer.T("Common.View")">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">&mdash;</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="status-pill @(template.IsActive ? "active" : "inactive")">@Localizer.T(template.IsActive ? "Common.Active" : "Common.Inactive")</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="cell-actions">
                                            <a asp-action="Edit" asp-route-id="@template.Id" class="btn-action edit" title="@Localizer.T("Common.Edit")">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button type="button" class="btn-action assign"
                                                    data-bs-toggle="modal" data-bs-target="#assignModal"
                                                    data-template-id="@template.Id" data-template-code="@template.StandardCode"
                                                    title="@Localizer.T("Clinic.AssignTemplates")">
                                                <i class="fas fa-hospital"></i>
                                            </button>
                                            <button type="button" class="btn-action delete"
                                                    data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                    data-template-id="@template.Id" data-template-code="@template.StandardCode"
                                                    title="@Localizer.T("Common.Delete")">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6">
                                    <div class="empty-state">
                                        <i class="fas fa-file-alt"></i>
                                        <h4>@Localizer.T("Empty.NoTemplates")</h4>
                                        <p>
                                            @if (!string.IsNullOrEmpty(searchTerm))
                                            {
                                                @Localizer.T("Common.NoData")
                                            }
                                            else
                                            {
                                                <a asp-action="Create" class="btn btn-sm btn-primary mt-2">
                                                    <i class="fas fa-plus"></i>@Localizer.T("Button.Create")
                                                </a>
                                            }
                                        </p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="table-footer">
                    <span class="page-info">
                        @Localizer.T("Common.Page") @currentPage @Localizer.T("Common.Of") @totalPages
                    </span>
                    <nav aria-label="Template table pagination">
                        <ul class="pagination">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { clinicType = selectedClinicType, standard = selectedStandard, page = 1, searchTerm })" aria-label="First">
                                    <i class="fas fa-angle-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { clinicType = selectedClinicType, standard = selectedStandard, page = currentPage - 1, searchTerm })" aria-label="Previous">
                                    <i class="fas fa-angle-left"></i>
                                </a>
                            </li>
                            @for (var i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { clinicType = selectedClinicType, standard = selectedStandard, page = i, searchTerm })">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { clinicType = selectedClinicType, standard = selectedStandard, page = currentPage + 1, searchTerm })" aria-label="Next">
                                    <i class="fas fa-angle-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { clinicType = selectedClinicType, standard = selectedStandard, page = totalPages, searchTerm })" aria-label="Last">
                                    <i class="fas fa-angle-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Clinic Type Selection -->
        <div class="template-page-header">
            <div class="template-page-header-left">
                <div class="template-page-header-icon">
                    <i class="fas fa-file-alt"></i>
                </div>
                <div>
                    <h1>@Localizer.T("Page.DocumentTemplates")</h1>
                    <p class="template-page-header-sub">@Localizer.T("Document.SelectClinicTypeHint")</p>
                </div>
            </div>
        </div>

        <div class="clinic-type-grid">
            <a href="@Url.Action("Index", new { clinicType = "AMB" })" class="clinic-type-card">
                <div class="clinic-type-icon">
                    <i class="fas fa-hospital"></i>
                </div>
                <span class="clinic-type-label">AMB CBAHI</span>
                <span class="clinic-type-desc">@Localizer.T("Document.AMBDescription", "Ambulatory Care CBAHI standards")</span>
            </a>
            <a href="@Url.Action("Index", new { clinicType = "Dental" })" class="clinic-type-card">
                <div class="clinic-type-icon">
                    <i class="fas fa-tooth"></i>
                </div>
                <span class="clinic-type-label">Dental CBAHI</span>
                <span class="clinic-type-desc">@Localizer.T("Document.DentalDescription", "Dental Care CBAHI standards")</span>
            </a>
        </div>
    }
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalTitle">
                    <i class="fas fa-exclamation-triangle text-danger me-2"></i>@Localizer.T("Common.Confirm")
                </h5>
                <button type="button" class="modal-close" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form method="post" asp-action="Delete" id="deleteForm">
                <input type="hidden" name="id" id="deleteTemplateId" value="" />
                <div class="modal-body">
                    <p>@Localizer.T("Template.DeleteConfirmMessage")</p>
                    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 mb-0">
                        <i class="fas fa-info-circle"></i>
                        <span><strong id="deleteTemplateCode"></strong> &mdash; @Localizer.T("Template.DeleteWarning")</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer.T("Button.Cancel")</button>
                    <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>@Localizer.T("Common.Delete")</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Assign to All Clinics Modal -->
<div class="modal fade" id="assignModal" tabindex="-1" role="dialog" aria-labelledby="assignModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="assignModalTitle">
                    <i class="fas fa-hospital text-info me-2"></i>@Localizer.T("Clinic.AssignToAll")
                </h5>
                <button type="button" class="modal-close" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form method="post" asp-action="AssignToAllClinics" id="assignForm">
                <input type="hidden" name="id" id="assignTemplateId" value="" />
                <div class="modal-body">
                    <p>@Localizer.T("Template.AssignConfirmMessage", "Assign this template to all active clinics?")</p>
                    <div class="d-flex align-items-center gap-2 p-3 bg-gray-50 rounded-md mb-3">
                        <i class="fas fa-file-alt text-info"></i>
                        <span class="font-semibold" id="assignTemplateCode"></span>
                    </div>
                    <p class="text-sm text-muted mb-0">
                        <i class="fas fa-info-circle me-1"></i>@Localizer.T("Template.AssignHint", "Existing assignments will not be duplicated.")
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer.T("Button.Cancel")</button>
                    <button type="submit" class="btn btn-info"><i class="fas fa-check me-1"></i>@Localizer.T("Common.Submit")</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteModal = document.getElementById('deleteModal');
            if (deleteModal) {
                deleteModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    document.getElementById('deleteTemplateId').value = button.getAttribute('data-template-id');
                    document.getElementById('deleteTemplateCode').textContent = button.getAttribute('data-template-code');
                });
            }

            var assignModal = document.getElementById('assignModal');
            if (assignModal) {
                assignModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    document.getElementById('assignTemplateId').value = button.getAttribute('data-template-id');
                    document.getElementById('assignTemplateCode').textContent = button.getAttribute('data-template-code');
                });
            }
        });
    </script>
}
