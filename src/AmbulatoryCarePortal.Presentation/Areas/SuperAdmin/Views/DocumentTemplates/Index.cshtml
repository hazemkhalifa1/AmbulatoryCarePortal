@model PagedResult<DocumentTemplateDto>

@{
    ViewData["Title"] = Localizer.T("Page.DocumentTemplates");
    var selectedClinicType = (string?)ViewBag.SelectedClinicType;
    var selectedStandard = (string?)ViewBag.SelectedStandard;
    var standards = (string[]?)ViewBag.Standards;
    var documentCounts = (Dictionary<string, int>?)ViewBag.DocumentCounts;
    var searchTerm = (string?)ViewBag.SearchTerm;
    var currentPage = Model.PageNumber;
    var totalPages = Model.TotalPages;
    var totalCount = Model.TotalCount;

    var standardNames = new Dictionary<string, string>
    {
        {"LD", "Leadership"},
        {"PC", "Provision of Care"},
        {"FMS", "Facility Management & Safety"},
        {"LB", "Laboratory"},
        {"RD", "Radiology"},
        {"DN", "Dental/Nursing"},
        {"MM", "Medication Management"},
        {"MOI", "Management of Information"},
        {"IPC", "Infection Prevention & Control"},
        {"DPU", "DPU"},
        {"DA", "DA"},
        {"DL", "Dental Lab"}
    };

    var standardIcons = new Dictionary<string, string>
    {
        {"LD", "fa-users-cog"},
        {"PC", "fa-stethoscope"},
        {"FMS", "fa-building"},
        {"LB", "fa-flask"},
        {"RD", "fa-x-ray"},
        {"DN", "fa-tooth"},
        {"MM", "fa-pills"},
        {"MOI", "fa-database"},
        {"IPC", "fa-shield-virus"},
        {"DPU", "fa-tint"},
        {"DA", "fa-syringe"},
        {"DL", "fa-tooth"}
    };
}

<div class="fade-in">

    @if (!string.IsNullOrEmpty(selectedClinicType))
    {
        <!-- Standards Cards Row -->
        @if (standards != null && standards.Any())
        {
            <div class="row g-2 mb-3">
                @foreach (var std in standards)
                {
                    var count = documentCounts != null && documentCounts.ContainsKey(std) ? documentCounts[std] : 0;
                    var isSelected = std == selectedStandard;
                    var stdName = standardNames.ContainsKey(std) ? standardNames[std] : std;
                    var icon = standardIcons.ContainsKey(std) ? standardIcons[std] : "fa-file";
                    <div class="col-lg-2 col-md-3 col-sm-4 col-6">
                        <a href="/SuperAdmin/DocumentTemplates?clinicType=@selectedClinicType&standard=@std"
                           class="text-decoration-none">
                            <div class="standard-card @(isSelected ? "standard-card-selected" : "")">
                                <div class="standard-card-icon"><i class="fas @icon"></i></div>
                                <div class="standard-card-name">@stdName</div>
                                <div class="standard-card-count">@count @Localizer.T("Clinic.Documents")</div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }

        <!-- Toolbar -->
        <div class="table-toolbar">
            <div class="d-flex align-items-center gap-3">
                <h5 class="mb-0 fw-bold">
                    @if (!string.IsNullOrEmpty(selectedStandard))
                    {
                        @Localizer.T("Page.DocumentTemplates")
                    }
                    else
                    {
                        <span>@Localizer.T("Clinic.AllDocuments")</span>
                    }
                </h5>
                @if (!string.IsNullOrEmpty(selectedStandard))
                {
                    <span class="badge badge-primary">@selectedStandard</span>
                }
                else
                {
                    <span class="badge badge-secondary">@selectedClinicType</span>
                }
                <small class="text-muted">(@totalCount @Localizer.T("Clinic.Documents"))</small>
            </div>
            <div class="d-flex align-items-center gap-2">
                <form method="get" action="/SuperAdmin/DocumentTemplates" class="d-flex align-items-center gap-2" role="search">
                    <input type="hidden" name="clinicType" value="@selectedClinicType" />
                    @if (!string.IsNullOrEmpty(selectedStandard))
                    {
                        <input type="hidden" name="standard" value="@selectedStandard" />
                    }
                    <div class="search-box">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" name="searchTerm" class="form-control form-control-sm" placeholder="@Localizer.T("Search.Templates")" value="@searchTerm" />
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search"></i></button>
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <a href="/SuperAdmin/DocumentTemplates?clinicType=@selectedClinicType@(string.IsNullOrEmpty(selectedStandard) ? "" : "&standard=" + selectedStandard)" class="btn btn-sm btn-secondary"><i class="fas fa-times"></i></a>
                    }
                </form>
                <a asp-action="Create" asp-route-clinicType="@selectedClinicType" asp-route-standard="@selectedStandard" class="btn btn-sm btn-success"><i class="fas fa-plus"></i> @Localizer.T("Button.Add") @Localizer.T("Clinic.Document")</a>
            </div>
        </div>

        <!-- Table -->
        <div class="table-container">
            <table class="table table-hover" role="table">
                <thead>
                    <tr>
                        <th scope="col">@Localizer.T("Common.Id")</th>
                        <th scope="col">@Localizer.T("Clinic.Document")</th>
                        <th scope="col">@Localizer.T("Clinic.Department")</th>
                        <th scope="col" class="text-center">@Localizer.T("Common.View")</th>
                        <th scope="col" class="text-center">@Localizer.T("Common.Active")</th>
                        <th scope="col" class="text-center">@Localizer.T("Common.Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Data.Any())
                    {
                        @foreach (var template in Model.Data)
                        {
                            <tr>
                                <td><span class="badge badge-info">@template.StandardCode</span></td>
                                <td class="fw-semibold">@template.TitleEn</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(template.DepartmentCategory))
                                    {
                                        @template.DepartmentCategory
                                    }
                                    else
                                    {
                                        <span class="text-muted">&mdash;</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(template.TemplateFilePath))
                                    {
                                        <a href="@template.TemplateFilePath" target="_blank" class="text-secondary text-decoration-none" title="@Localizer.T("Common.View") PDF">
                                            <i class="fas fa-eye me-1"></i>@Localizer.T("Common.View")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">&mdash;</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="status-pill @(template.IsActive ? "complete" : "inactive")">@Localizer.T(template.IsActive ? "Common.Active" : "Common.Inactive")</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Edit" asp-route-id="@template.Id" class="btn btn-sm btn-ghost" title="@Localizer.T("Common.Edit")">
                                            <i class="fas fa-edit text-warning"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-ghost"
                                                data-bs-toggle="modal" data-bs-target="#assignModal"
                                                data-template-id="@template.Id" data-template-code="@template.StandardCode"
                                                title="@Localizer.T("Clinic.AssignTemplates")">
                                            <i class="fas fa-hospital text-info"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-ghost text-danger"
                                                data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                data-template-id="@template.Id" data-template-code="@template.StandardCode"
                                                title="@Localizer.T("Common.Delete")">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fas fa-file fa-3x mb-2"></i><br />
                                @Localizer.T("Empty.NoTemplates")
                                @if (!string.IsNullOrEmpty(searchTerm))
                                {
                                    <span>@Localizer.T("Common.NoData")</span>
                                }
                                else
                                {
                                    <a asp-action="Create">@Localizer.T("Button.Create") @Localizer.T("Clinic.Document")</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (totalPages > 1)
            {
                <div class="table-footer">
                    <div class="pagination-info">
                        @Localizer.T("Common.Page") @currentPage @Localizer.T("Common.Of") @totalPages (@totalCount total)
                    </div>
                    <nav aria-label="Template table pagination">
                        <ul class="pagination">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="/SuperAdmin/DocumentTemplates?clinicType=@selectedClinicType@(string.IsNullOrEmpty(selectedStandard) ? "" : "&standard=" + selectedStandard)&page=1@(string.IsNullOrEmpty(searchTerm) ? "" : "&searchTerm=" + searchTerm)" aria-label="First">
                                    <i class="fas fa-angle-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="/SuperAdmin/DocumentTemplates?clinicType=@selectedClinicType@(string.IsNullOrEmpty(selectedStandard) ? "" : "&standard=" + selectedStandard)&page=@(currentPage - 1)@(string.IsNullOrEmpty(searchTerm) ? "" : "&searchTerm=" + searchTerm)" aria-label="Previous">
                                    <i class="fas fa-angle-left"></i>
                                </a>
                            </li>
                            @for (var i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="/SuperAdmin/DocumentTemplates?clinicType=@selectedClinicType@(string.IsNullOrEmpty(selectedStandard) ? "" : "&standard=" + selectedStandard)&page=@i@(string.IsNullOrEmpty(searchTerm) ? "" : "&searchTerm=" + searchTerm)">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="/SuperAdmin/DocumentTemplates?clinicType=@selectedClinicType@(string.IsNullOrEmpty(selectedStandard) ? "" : "&standard=" + selectedStandard)&page=@(currentPage + 1)@(string.IsNullOrEmpty(searchTerm) ? "" : "&searchTerm=" + searchTerm)" aria-label="Next">
                                    <i class="fas fa-angle-right"></i>
                                </a>
                            </li>
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" href="/SuperAdmin/DocumentTemplates?clinicType=@selectedClinicType@(string.IsNullOrEmpty(selectedStandard) ? "" : "&standard=" + selectedStandard)&page=@totalPages@(string.IsNullOrEmpty(searchTerm) ? "" : "&searchTerm=" + searchTerm)" aria-label="Last">
                                    <i class="fas fa-angle-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
    else
    {
        <!-- No clinic type selected -->
        <div class="text-center py-5">
            <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
            <h5 class="text-muted">@Localizer.T("Document.SelectClinicType")</h5>
            <p class="text-muted small">@Localizer.T("Document.SelectClinicTypeHint")</p>
            <div class="d-flex justify-content-center gap-3 mt-3">
                <a href="/SuperAdmin/DocumentTemplates?clinicType=AMB" class="btn btn-primary btn-lg">
                    <i class="fas fa-hospital me-2"></i>AMB CBAHI
                </a>
                <a href="/SuperAdmin/DocumentTemplates?clinicType=Dental" class="btn btn-secondary btn-lg">
                    <i class="fas fa-tooth me-2"></i>Dental CBAHI
                </a>
            </div>
        </div>
    }
</div>

<partial name="_DeleteConfirmation" model='new {
    ModalId = "deleteModal",
    Title = Localizer.T("Common.Confirm"),
    Message = Localizer.T("Template.DeleteConfirmMessage"),
    Warning = Localizer.T("Template.DeleteWarning"),
    FormAction = "Delete",
    HiddenInputId = "deleteTemplateId",
    DisplayTextId = "deleteTemplateCode"
}' />

<!-- Assign to All Clinics Modal -->
<div class="modal fade" id="assignModal" tabindex="-1" role="dialog" aria-labelledby="assignModalTitle" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="assignModalTitle"><i class="fas fa-hospital me-2"></i>Assign to All Clinics</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="AssignToAllClinics" id="assignForm">
                <input type="hidden" name="id" id="assignTemplateId" value="" />
                <div class="modal-body">
                    <p>Assign this template to all active clinics?</p>
                    <p class="fw-bold text-info" id="assignTemplateCode"></p>
                    <p class="text-muted small">ClinicDocument records will be created for each active clinic. Existing assignments will not be duplicated.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer.T("Button.Cancel")</button>
                    <button type="submit" class="btn btn-info"><i class="fas fa-check me-1"></i>@Localizer.T("Common.Submit")</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteModal = document.getElementById('deleteModal');
            if (deleteModal) {
                deleteModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    document.getElementById('deleteTemplateId').value = button.getAttribute('data-template-id');
                    document.getElementById('deleteTemplateCode').textContent = button.getAttribute('data-template-code');
                });
            }

            var assignModal = document.getElementById('assignModal');
            if (assignModal) {
                assignModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    document.getElementById('assignTemplateId').value = button.getAttribute('data-template-id');
                    document.getElementById('assignTemplateCode').textContent = button.getAttribute('data-template-code');
                });
            }
        });
    </script>
}