@model UpdateDocumentTemplateDto

@{
    ViewData["Title"] = Localizer.T("Page.EditDocumentTemplate");
    var templateFilePath = (string?)ViewBag.TemplateFilePath;
}

@section Styles {
    <link rel="stylesheet" href="~/css/document-templates.css" asp-append-version="true" />
}

<div class="fade-in">
    <div class="template-page-header">
        <div class="template-page-header-left">
            <div class="template-page-header-icon">
                <i class="fas fa-edit"></i>
            </div>
            <div>
                <h1>@Localizer.T("Page.EditDocumentTemplate")</h1>
                <p class="template-page-header-sub">@Localizer.T("Doc.EditTemplateHint", "Update standard code") <span class="standard-code-badge">@Model.StandardCode</span></p>
            </div>
        </div>
        <div class="template-page-header-actions">
            <a asp-action="Index" class="back-link">
                <i class="fas fa-arrow-left"></i>
                @Localizer.T("Common.Back")
            </a>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card">
                <div class="card-body p-4">
                    <form method="post" asp-action="Edit" asp-route-id="@Model.Id" enctype="multipart/form-data" role="form" aria-label="Edit template form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ClinicType" id="clinicTypeHidden" />

                        <!-- Standard Identification -->
                        <div class="form-section">
                            <div class="form-section-title">
                                <i class="fas fa-tag me-2"></i>@Localizer.T("Template.StandardIdentification", "Standard Identification")
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="StandardCode" class="form-label">Standard Code <span class="text-danger">*</span></label>
                                        <input asp-for="StandardCode" class="form-control" required aria-required="true" />
                                        <span asp-validation-for="StandardCode" class="form-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="ClinicType" class="form-label">@Localizer.T("Doc.ClinicType") <span class="text-danger">*</span></label>
                                        <select asp-for="ClinicType" class="form-control" id="clinicTypeSelect" asp-items="Html.GetEnumSelectList<ClinicType>()">
                                            <option value="">-- @Localizer.T("Doc.SelectClinicType") --</option>
                                        </select>
                                        <span asp-validation-for="ClinicType" class="form-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="DepartmentCategory" class="form-label">@Localizer.T("Template.DepartmentCategory") <span class="text-danger">*</span></label>
                                        <select asp-for="DepartmentCategory" class="form-control" id="departmentCategorySelect">
                                            <option value="">-- @Localizer.T("Doc.SelectStandard") --</option>
                                        </select>
                                        <span asp-validation-for="DepartmentCategory" class="form-error"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Title Information -->
                        <div class="form-section">
                            <div class="form-section-title">
                                <i class="fas fa-heading me-2"></i>@Localizer.T("Template.TitleInformation", "Title Information")
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="TitleEn" class="form-label">@Localizer.T("Doc.TitleEn") <span class="text-danger">*</span></label>
                                        <input asp-for="TitleEn" class="form-control" required aria-required="true" />
                                        <span asp-validation-for="TitleEn" class="form-error"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="TitleAr" class="form-label">@Localizer.T("Doc.TitleAr")</label>
                                        <input asp-for="TitleAr" class="form-control" dir="rtl" />
                                        <span asp-validation-for="TitleAr" class="form-error"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="form-section">
                            <div class="form-section-title">
                                <i class="fas fa-align-left me-2"></i>@Localizer.T("Template.Description", "Description")
                            </div>
                            <div class="form-group">
                                <label asp-for="Description" class="form-label">@Localizer.T("Doc.Description")</label>
                                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Description" class="form-error"></span>
                            </div>
                        </div>

                        <!-- Status -->
                        <div class="form-section">
                            <div class="form-section-title">
                                <i class="fas fa-toggle-on me-2"></i>@Localizer.T("Template.Status", "Status")
                            </div>
                            <label class="toggle-switch">
                                <input asp-for="IsActive" role="switch" />
                                <span class="toggle-track"></span>
                                <span class="toggle-label">@Localizer.T("Common.Active")</span>
                            </label>
                        </div>

                        <!-- Template File -->
                        <div class="form-section">
                            <div class="form-section-title">
                                <i class="fas fa-upload me-2"></i>@Localizer.T("Template.TemplateFile", "Template File")
                            </div>
                            @if (!string.IsNullOrEmpty(templateFilePath))
                            {
                                <div class="current-file">
                                    <i class="fas fa-file-word current-file-icon"></i>
                                    <div class="current-file-info">
                                        <span class="current-file-name">@System.IO.Path.GetFileName(templateFilePath)</span>
                                        <span class="current-file-hint">@Localizer.T("Template.UploadReplaceHint", "Upload a new file to replace the existing one.")</span>
                                    </div>
                                    <a href="@templateFilePath" target="_blank" class="btn btn-sm btn-outline-primary flex-shrink-0">
                                        <i class="fas fa-eye me-1"></i>@Localizer.T("Common.View")
                                    </a>
                                </div>
                            }
                            <div class="upload-zone" id="uploadArea">
                                <div class="upload-initial">
                                    <i class="fas fa-cloud-upload-alt upload-icon"></i>
                                    <h5>@Localizer.T("Template.DragDropUpload")</h5>
                                    <p>@Localizer.T("Template.SupportedFormats", "Supported format: .docx")</p>
                                    <input type="file" name="templateFile" class="d-none" id="templateFile" accept=".docx" aria-label="Template .docx file" />
                                    <button type="button" class="btn btn-outline-primary" id="uploadBtn">
                                        <i class="fas fa-folder-open me-1"></i>@Localizer.T("Button.Upload")
                                    </button>
                                </div>
                                <div class="upload-preview" id="uploadPreview">
                                    <i class="fas fa-file-word file-icon-lg"></i>
                                    <div class="file-details">
                                        <span class="file-name" id="fileName"></span>
                                        <span class="file-size" id="fileSize"></span>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-ghost text-danger" id="removeFile" title="Remove file">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="form-help mt-2">
                                <i class="fas fa-info-circle me-1"></i>
                                @Localizer.T("Template.UploadHint", "Upload a .docx file with placeholders like")
                                <code>{{ClinicName}}</code>, <code>{{LicenseNumber}}</code>, etc.
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="d-flex gap-3 mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary btn-lg flex-fill">
                                <i class="fas fa-save me-2"></i>@Localizer.T("Template.SaveChanges")
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times me-2"></i>@Localizer.T("Button.Cancel")
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function loadStandardsDropdown(clinicType) {
            return $.get('@Url.Action("GetStandards", "DocumentTemplates", new { area = "SuperAdmin" })', { clinicType: clinicType });
        }

        $('#clinicTypeSelect').on('change', function() {
            var val = $(this).val();
            var $deptSelect = $('#departmentCategorySelect').empty().append('<option value="">-- @Localizer.T("Doc.SelectStandard") --');

            if (!val) return;

            loadStandardsDropdown(val).done(function(data) {
                $.each(data.standards, function(i, s) {
                    $deptSelect.append('<option value="' + s + '">' + s + '</option>');
                });

                var savedDept = '@Model.DepartmentCategory';
                if (savedDept) {
                    $deptSelect.val(savedDept);
                }
            });
        });

        $(function() {
            var initialType = $('#clinicTypeSelect').val();
            if (initialType) {
                $('#clinicTypeSelect').trigger('change');
            }
        });

        document.getElementById('uploadBtn').addEventListener('click', function() {
            document.getElementById('templateFile').click();
        });

        document.getElementById('uploadArea').addEventListener('click', function(e) {
            if (e.target.closest('#uploadBtn')) return;
            if (e.target.closest('#removeFile')) return;
            document.getElementById('templateFile').click();
        });

        document.getElementById('templateFile').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            document.getElementById('uploadArea').classList.add('has-file');
            document.getElementById('fileName').textContent = file.name;
            document.getElementById('fileSize').textContent = (file.size / 1024).toFixed(1) + ' KB';
        });

        document.getElementById('removeFile').addEventListener('click', function(e) {
            e.stopPropagation();
            document.getElementById('templateFile').value = '';
            document.getElementById('uploadArea').classList.remove('has-file');
        });

        var uploadArea = document.getElementById('uploadArea');
        uploadArea.addEventListener('dragover', function(e) {
            e.preventDefault();
            this.classList.add('drag-over');
        });
        uploadArea.addEventListener('dragleave', function(e) {
            e.preventDefault();
            this.classList.remove('drag-over');
        });
        uploadArea.addEventListener('drop', function(e) {
            e.preventDefault();
            this.classList.remove('drag-over');
            var files = e.dataTransfer.files;
            if (files.length > 0) {
                document.getElementById('templateFile').files = files;
                var event = new Event('change', { bubbles: true });
                document.getElementById('templateFile').dispatchEvent(event);
            }
        });
    </script>
}
