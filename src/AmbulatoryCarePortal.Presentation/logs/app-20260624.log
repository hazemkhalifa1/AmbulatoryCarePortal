VALUES (@p0, @p1, @p2, @p3, @p4, @p5, @p6, @p7, @p8, @p9, @p10, @p11, @p12, @p13, @p14, @p15, 0),
(@p16, @p17, @p18, @p19, @p20, @p21, @p22, @p23, @p24, @p25, @p26, @p27, @p28, @p29, @p30, @p31, 1)) AS i ([ActionDate], [ActionType], [ClinicId], [CreatedAt], [CreatedBy], [Description], [IpAddress], [IsDeleted], [NewValues], [OldValues], [PolicyDocumentId], [TargetObjectId], [TargetObjectType], [UpdatedAt], [UpdatedBy], [UserId], _Position) ON 1=0
WHEN NOT MATCHED THEN
INSERT ([ActionDate], [ActionType], [ClinicId], [CreatedAt], [CreatedBy], [Description], [IpAddress], [IsDeleted], [NewValues], [OldValues], [PolicyDocumentId], [TargetObjectId], [TargetObjectType], [UpdatedAt], [UpdatedBy], [UserId])
VALUES (i.[ActionDate], i.[ActionType], i.[ClinicId], i.[CreatedAt], i.[CreatedBy], i.[Description], i.[IpAddress], i.[IsDeleted], i.[NewValues], i.[OldValues], i.[PolicyDocumentId], i.[TargetObjectId], i.[TargetObjectType], i.[UpdatedAt], i.[UpdatedBy], i.[UserId])
OUTPUT INSERTED.[Id], i._Position;
UPDATE [Clinics] SET [CityAr] = @p32, [CityEn] = @p33, [ClinicType] = @p34, [ComplianceScore] = @p35, [CreatedAt] = @p36, [CreatedBy] = @p37, [IsActive] = @p38, [IsDeleted] = @p39, [LicenseExpiry] = @p40, [LicenseNumber] = @p41, [LogoPath] = @p42, [Name] = @p43, [NameAr] = @p44, [UpdatedAt] = @p45, [UpdatedBy] = @p46
OUTPUT 1
WHERE [Id] = @p47;
INSERT INTO [ComplianceScoreSnapshot] ([CalculatedAt], [ChecklistScore], [ChecklistWeight], [ClinicId], [CreatedAt], [CreatedBy], [DocumentScore], [DocumentWeight], [HrScore], [HrWeight], [IsDeleted], [KpiScore], [KpiWeight], [OverallScore], [PolicyScore], [PolicyWeight], [UpdatedAt], [UpdatedBy])
OUTPUT INSERTED.[Id]
VALUES (@p48, @p49, @p50, @p51, @p52, @p53, @p54, @p55, @p56, @p57, @p58, @p59, @p60, @p61, @p62, @p63, @p64, @p65);
