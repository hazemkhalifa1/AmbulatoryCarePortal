@{
    ViewData["Title"] = "Error";
    var statusCode = ViewBag.StatusCode ?? 500;
    var message = ViewBag.ErrorMessage ?? "An unexpected error occurred. Please try again later.";
}

<div class="error-page">
    <h2 class="headline text-warning">@statusCode</h2>
    <div class="error-content">
        <h3><i class="fas fa-exclamation-triangle text-warning"></i> Oops! Something went wrong.</h3>
        <p>@message</p>
        <a href="/" class="btn btn-primary"><i class="fas fa-home"></i> Return to Home</a>
    </div>
</div>
