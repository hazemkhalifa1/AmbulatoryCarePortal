@{
    ViewData["Title"] = Localizer.T("App.Title");
    var statusCode = ViewBag.StatusCode ?? 500;
    var message = ViewBag.ErrorMessage ?? Localizer.T("Error.Message");
}

<div class="error-page fade-in">
    <div class="headline text-warning">@statusCode</div>
    <div class="error-content">
        <h3><i class="fas fa-exclamation-triangle text-warning me-2"></i> @Localizer.T("Error.Heading")</h3>
        <p>@message</p>
        <a href="/" class="btn btn-primary">
            <i class="fas fa-home"></i> @Localizer.T("Error.ReturnHome")
        </a>
    </div>
</div>
