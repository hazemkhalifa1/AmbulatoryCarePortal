@model dynamic

@{
    bool HasProp(object obj, string name) => obj.GetType().GetProperty(name) != null;
    string SafeStr(object val) => val?.ToString() ?? "";
    var icon = HasProp(Model, "Icon") ? SafeStr(Model.Icon) : "fa-inbox";
    var title = HasProp(Model, "Title") ? SafeStr(Model.Title) : "";
    var description = HasProp(Model, "Description") ? SafeStr(Model.Description) : "";
    var actionLink = HasProp(Model, "ActionLink") ? SafeStr(Model.ActionLink) : "";
    var actionText = HasProp(Model, "ActionText") ? SafeStr(Model.ActionText) : "";
}

<div class="empty-state text-center py-5">
    <div class="empty-state-icon mb-3">
        <i class="fas @icon fa-3x text-muted"></i>
    </div>
    <h5 class="text-muted">@title</h5>
    @if (!string.IsNullOrEmpty(description))
    {
        <p class="text-muted small">@description</p>
    }
    @if (!string.IsNullOrEmpty(actionLink))
    {
        <a href="@actionLink" class="btn btn-primary mt-3">@actionText</a>
    }
</div>
