@inject ITranslationService TranslationService

@{
    var lang = TranslationService.CurrentLanguage;
    var dir = TranslationService.IsRtl ? "rtl" : "ltr";
    var title = ViewData["Title"] ?? TranslationService.T("App.Title");
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#1A3A6B">
    <title>@title</title>

    @if (dir == "rtl")
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" id="bootstrap-rtl">
    }
    else
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    }

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <script>
        (function() {
            var savedLang = localStorage.getItem('lang');
            if (savedLang === 'ar') {
                document.documentElement.lang = 'ar';
                document.documentElement.dir = 'rtl';
                document.cookie = 'lang=ar; path=/; max-age=31536000';
            }
        })();
    </script>
</head>
<body class="login-page" dir="@dir">
    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>