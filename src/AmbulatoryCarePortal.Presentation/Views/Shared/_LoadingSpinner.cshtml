@model dynamic
@{
    var size = Model?.Size ?? "md";
    var text = Model?.Text ?? "";
    var isOverlay = Model?.IsOverlay == true;
    var sizeClass = size switch { "sm" => "ds-spinner-sm", "lg" => "ds-spinner-lg", _ => "" };
    var containerClass = isOverlay ? "ds-loading-overlay" : "ds-loading-inline";
}
<div class="@containerClass">
    <div class="ds-spinner @sizeClass" role="status" aria-hidden="true"></div>
    @if (!string.IsNullOrEmpty(text))
    {
        <span class="ds-loading-text">@text</span>
    }
</div>
