@inject ITranslationService TranslationService
@using Microsoft.AspNetCore.Routing
@{
    var lang = TranslationService.CurrentLanguage;
    var dir = TranslationService.IsRtl ? "rtl" : "ltr";
    var currentPath = Context.Request.Path.ToString();
    var currentQuery = Context.Request.Query;
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#0A224D">
    <meta name="description" content="@Localizer.T("App.Description")">
    <title>@ViewData["Title"] — @Localizer.T("App.Title")</title>

    @if (dir == "rtl")
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" id="bootstrap-rtl">
    }
    else
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    }

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <script>
        (function() {
            var savedLang = localStorage.getItem('lang');
            if (savedLang === 'ar') {
                document.documentElement.lang = 'ar';
                document.documentElement.dir = 'rtl';
                document.cookie = 'lang=ar; path=/; max-age=31536000';
            }
        })();
    </script>
</head>
<body class="@(ViewData["LoginPage"] != null ? "login-page" : "")">
    @if (ViewData["LoginPage"] == null)
    {
        <div class="app-shell">
            <!-- ===== SIDEBAR ===== -->
            <aside id="appSidebar" class="app-sidebar" aria-label="@Localizer.T("Nav.MainMenu")">
                <div class="sidebar-brand">
                    <div class="sidebar-brand-icon" aria-hidden="true">
                        <i class="fas fa-heartbeat"></i>
                    </div>
                    <div class="sidebar-brand-text">
                        @Localizer.T("App.Name")
                        <small>@Localizer.T("App.Tagline")</small>
                    </div>
                </div>

                <nav class="sidebar-nav" aria-label="@Localizer.T("Nav.MainMenu")">
                    <ul class="nav-section">
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-section-header">@Localizer.T("Nav.MainMenu")</li>

                            <li class="nav-item">
                                <a is-active-route asp-area="SuperAdmin" asp-controller="Dashboard" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-tachometer-alt" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.Dashboard")</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a is-active-route asp-area="SuperAdmin" asp-controller="Dashboard" asp-action="Clinics" class="nav-link">
                                    <i class="nav-icon fas fa-hospital" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.ManageClinics")</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a href="#docSubMenu" class="nav-link" data-bs-toggle="collapse" role="button" aria-expanded="@(currentPath.Contains("DocumentTemplates") ? "true" : "false")" aria-controls="docSubMenu">
                                    <i class="nav-icon fas fa-file" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.ManageDocuments")</p>
                                    <i class="nav-chevron fas fa-chevron-down" aria-hidden="true"></i>
                                </a>
                                <ul class="nav-sub collapse @(currentPath.Contains("DocumentTemplates") ? "show" : "")" id="docSubMenu">
                                    <li class="nav-item">
                                        <a asp-area="SuperAdmin" asp-controller="DocumentTemplates" asp-action="Index" asp-route-clinicType="AMB" class="nav-link @(currentQuery["clinicType"].ToString() == "AMB" ? "active" : "")">
                                            <i class="nav-icon fas fa-circle" aria-hidden="true"></i>
                                            <p>AMB CBAHI</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a asp-area="SuperAdmin" asp-controller="DocumentTemplates" asp-action="Index" asp-route-clinicType="Dental" class="nav-link @(currentQuery["clinicType"].ToString() == "Dental" ? "active" : "")">
                                            <i class="nav-icon fas fa-circle" aria-hidden="true"></i>
                                            <p>Dental CBAHI</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a is-active-route asp-area="SuperAdmin" asp-controller="UserManagement" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-users-cog" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.ManageUsers")</p>
                                </a>
                            </li>

                            <li class="nav-section-header">@Localizer.T("Nav.System")</li>

                            <li class="nav-item">
                                <a is-active-route asp-area="SuperAdmin" asp-controller="Dashboard" asp-action="AuditLog" class="nav-link">
                                    <i class="nav-icon fas fa-history" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.AuditLogs")</p>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a is-active-route asp-area="SuperAdmin" asp-controller="Settings" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-cog" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.SystemSettings")</p>
                                </a>
                            </li>
                        }
                        else if (User.IsInRole("ClinicAdmin") || User.IsInRole("ClinicViewer"))
                        {
                            <li class="nav-section-header">@Localizer.T("Nav.MainMenu")</li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="Dashboard" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-tachometer-alt" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.Dashboard")</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="ClinicDocuments" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-file" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.Documents")</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="DepartmentManagement" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-building" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.Departments")</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="KPIManagement" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-chart-line" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.KPIMonitoring")</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="ChecklistManagement" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-clipboard-check" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.Checklists")</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="Forms" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-file-alt" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.FormsLibrary")</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="Dashboard" asp-action="ComplianceCalendar" class="nav-link">
                                    <i class="nav-icon fas fa-calendar-check" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.ComplianceCalendar")</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="Dashboard" asp-action="ComplianceScore" class="nav-link">
                                    <i class="nav-icon fas fa-shield-alt" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.ComplianceScore")</p>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="ClinicSignatures" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-signature" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.Signatures")</p>
                                </a>
                            </li>
                            <li class="nav-section-header">@Localizer.T("Nav.Staff")</li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="HRManagement" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-users" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.HRCredentialing")</p>
                                </a>
                            </li>
                            <li class="nav-section-header">@Localizer.T("Nav.Communication")</li>
                            <li class="nav-item">
                                <a is-active-route asp-area="ClinicAdmin" asp-controller="Notifications" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-bell" aria-hidden="true"></i>
                                    <p>@Localizer.T("Nav.Notifications")</p>
                                </a>
                            </li>
                            @if (User.HasClaim("Permission", "reports.generate"))
                            {
                                <li class="nav-item">
                                    <a is-active-route asp-area="ClinicAdmin" asp-controller="Reporting" asp-action="Index" class="nav-link">
                                        <i class="nav-icon fas fa-chart-bar" aria-hidden="true"></i>
                                        <p>@Localizer.T("Nav.Reports")</p>
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </nav>
            </aside>

            <!-- Sidebar Overlay (mobile) -->
            <div class="sidebar-overlay" tabindex="-1" aria-hidden="true"></div>

            <!-- ===== HEADER ===== -->
            <header class="app-header">
                <div class="header-left">
                    <button class="header-hamburger" type="button" aria-label="@Localizer.T("Nav.ToggleMenu")" aria-controls="appSidebar">
                        <i class="fas fa-bars" aria-hidden="true"></i>
                    </button>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="header-brand" aria-label="@Localizer.T("App.Name")">
                        <span class="header-brand-icon" aria-hidden="true">
                            <i class="fas fa-heartbeat"></i>
                        </span>
                        <span class="header-brand-text">
                            @Localizer.T("App.NameCompact")
                            <small>@Localizer.T("App.Tagline")</small>
                        </span>
                    </a>
                </div>

                <div class="header-right">
                    <!-- Notifications -->
                    <div class="dropdown">
                        <button class="header-btn" id="notificationsDropdown" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@Localizer.T("Nav.Notifications")" aria-haspopup="true">
                            <i class="fas fa-bell" aria-hidden="true"></i>
                            <span class="header-badge" id="notificationBadge" style="display:none">0</span>
                        </button>
                        <div class="dropdown-menu header-dropdown notif-dropdown" aria-labelledby="notificationsDropdown">
                            <div class="notif-header">
                                <span>@Localizer.T("Nav.Notifications")</span>
                                <button type="button" class="mark-read" aria-label="@Localizer.T("Button.MarkAllRead")">@Localizer.T("Button.MarkAllRead")</button>
                            </div>
                            <div id="notifList">
                                <div class="notif-item unread" role="option" aria-selected="false">
                                    <span class="notif-dot" aria-hidden="true"></span>
                                    <div class="notif-content">
                                        <div class="notif-title">@Localizer.T("Notification.ChecklistReminder")</div>
                                        <div class="notif-desc">@Localizer.T("Notification.ChecklistDue", "Daily Safety Checklist", "daily")</div>
                                        <span class="notif-time">2 @Localizer.T("Common.HoursAgo")</span>
                                    </div>
                                </div>
                                <div class="notif-item unread" role="option" aria-selected="false">
                                    <span class="notif-dot" aria-hidden="true"></span>
                                    <div class="notif-content">
                                        <div class="notif-title">@Localizer.T("Notification.ComplianceAlert")</div>
                                        <div class="notif-desc">@Localizer.T("Notification.ComplianceAlertBody", "Clinic A", "3", "2")</div>
                                        <span class="notif-time">5 @Localizer.T("Common.HoursAgo")</span>
                                    </div>
                                </div>
                                <div class="notif-item read" role="option" aria-selected="false">
                                    <span class="notif-dot" aria-hidden="true"></span>
                                    <div class="notif-content">
                                        <div class="notif-title">@Localizer.T("Notification.ComplianceDigest")</div>
                                        <div class="notif-desc">@Localizer.T("Notification.ComplianceDigestBody", "Clinic B", "45", "3")</div>
                                        <span class="notif-time">1 @Localizer.T("Common.DayAgo")</span>
                                    </div>
                                </div>
                            </div>
                            <a asp-area="ClinicAdmin" asp-controller="Notifications" asp-action="Index" class="notif-footer">@Localizer.T("Common.ViewAll")</a>
                        </div>
                    </div>

                    <!-- Language Toggle -->
                    <div class="header-lang" role="group" aria-label="@Localizer.T("Common.Language")">
                        <button type="button" class="header-lang-btn @(TranslationService.CurrentLanguage == "en" ? "active" : "")" data-lang="en" aria-pressed="@(TranslationService.CurrentLanguage == "en" ? "true" : "false")">EN</button>
                        <button type="button" class="header-lang-btn @(TranslationService.CurrentLanguage == "ar" ? "active" : "")" data-lang="ar" aria-pressed="@(TranslationService.CurrentLanguage == "ar" ? "true" : "false")">AR</button>
                    </div>

                    <!-- User Menu -->
                    <div class="dropdown">
                        <button class="user-menu" id="navbarDropdown" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@Localizer.T("User.MyProfile")" aria-haspopup="true">
                            <span class="user-avatar" aria-hidden="true">
                                @User.Identity?.Name?.Substring(0, 1)?.ToUpper()
                            </span>
                            <span class="user-name">@User.Identity?.Name</span>
                        </button>
                        <div class="dropdown-menu header-dropdown" aria-labelledby="navbarDropdown">
                            <div class="user-card-header">
                                <div class="user-card-avatar" aria-hidden="true">
                                    @User.Identity?.Name?.Substring(0, 1)?.ToUpper()
                                </div>
                                <div class="user-card-name">@User.Identity?.Name</div>
                                <div class="user-card-email">@User.Identity?.Name</div>
                                <span class="user-card-role">
                                    @if (User.IsInRole("SuperAdmin")) { @Localizer.T("Nav.SuperAdmin.Panel") }
                                    else if (User.IsInRole("ClinicAdmin")) { @Localizer.T("User.ClinicAdmin") }
                                    else if (User.IsInRole("ClinicViewer")) { @Localizer.T("User.ClinicViewer") }
                                    else { @Localizer.T("User.User") }
                                </span>
                            </div>
                            <div class="user-card-body">
                                <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile">
                                    <i class="fas fa-user-circle" aria-hidden="true"></i> @Localizer.T("User.MyProfile")
                                </a>
                                <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile">
                                    <i class="fas fa-cog" aria-hidden="true"></i> @Localizer.T("Nav.SystemSettings")
                                </a>
                            </div>
                            <div class="user-card-footer">
                                <form method="post" asp-area="" asp-controller="Account" asp-action="Logout">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item">
                                        <i class="fas fa-sign-out-alt" aria-hidden="true"></i> @Localizer.T("User.Logout")
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <!-- ===== CONTENT ===== -->
            <div class="content-wrapper">
                <div class="content-area">
                    @if (ViewData["ShowBreadcrumb"] == null || (bool)ViewData["ShowBreadcrumb"]!)
                    {
                        <partial name="_Breadcrumb" />
                    }

                    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"] as string))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle" aria-hidden="true"></i>
                            <div class="alert-content">@TempData["SuccessMessage"]</div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="@Localizer.T("Common.Close")"></button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(TempData["ErrorMessage"] as string))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle" aria-hidden="true"></i>
                            <div class="alert-content">@TempData["ErrorMessage"]</div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="@Localizer.T("Common.Close")"></button>
                        </div>
                    }

                    @RenderBody()
                </div>

                <!-- Footer -->
                <footer class="app-footer">
                    <strong>@Localizer.T("App.Name")</strong> @Localizer.T("App.Copyright")
                    <span class="ms-2">
                        <a href="#" class="developer-branding" data-dev-card aria-label="@Localizer.T("Developer.Branding")">@Localizer.T("Developer.Branding")</a>
                    </span>
                </footer>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
