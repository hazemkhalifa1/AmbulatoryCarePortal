@inject ITranslationService TranslationService
@{
    var lang = TranslationService.CurrentLanguage;
    var dir = TranslationService.IsRtl ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#1A3A6B">
    <title>@ViewData["Title"] - @Localizer.T("App.Title")</title>

    <!-- Bootstrap CSS -->
    @if (dir == "rtl")
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" id="bootstrap-rtl">
    }
    else
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    }

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- AdminLTE (layout only) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/admin-lte/3.2.0/css/adminlte.min.css">

    <!-- Custom Design System -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <script>
        (function() {
            var savedLang = localStorage.getItem('lang');
            if (savedLang === 'ar') {
                document.documentElement.lang = 'ar';
                document.documentElement.dir = 'rtl';
                document.cookie = 'lang=ar; path=/; max-age=31536000';
            }
        })();
    </script>
</head>
<body class="hold-transition sidebar-mini">
    <div class="wrapper">

        <!-- ===== SIDEBAR ===== -->
        <aside class="main-sidebar">
            <a href="/" class="brand-link">
                <span class="brand-icon">
                    <i class="fas fa-heartbeat"></i>
                </span>
                <span class="brand-text">
                    @Localizer.T("App.Name")
                    <small>@Localizer.T("App.Tagline")</small>
                </span>
            </a>

            <div class="sidebar">
                <nav class="mt-2" aria-label="@Localizer.T("Nav.MainMenu")">
                    <ul class="nav-sidebar" role="menubar">
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-header" role="presentation">@Localizer.T("Nav.MainMenu")</li>
                            <li class="nav-item" role="none">
                                <a href="/SuperAdmin/Dashboard" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-tachometer-alt"></i>
                                    <p>@Localizer.T("Nav.Dashboard")</p>
                                </a>
                            </li>
                            <li class="nav-item" role="none">
                                <a href="/SuperAdmin/Dashboard/Clinics" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-hospital"></i>
                                    <p>@Localizer.T("Nav.ManageClinics")</p>
                                </a>
                            </li>
                            <li class="nav-header" role="presentation">@Localizer.T("Nav.System")</li>
                            <li class="nav-item" role="none">
                                <a href="/SuperAdmin/Dashboard/AuditLog" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-history"></i>
                                    <p>@Localizer.T("Nav.AuditLogs")</p>
                                </a>
                            </li>
                        }
                        else if (User.IsInRole("HospitalAdmin") || User.IsInRole("ClinicAdmin") || User.IsInRole("DepartmentUser") || User.IsInRole("Auditor") || User.IsInRole("Viewer"))
                        {
                            <li class="nav-header" role="presentation">@Localizer.T("Nav.MainMenu")</li>
                            <li class="nav-item" role="none">
                                <a href="/ClinicAdmin/Dashboard" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-tachometer-alt"></i>
                                    <p>@Localizer.T("Nav.Dashboard")</p>
                                </a>
                            </li>
                            <li class="nav-item" role="none">
                                <a href="/ClinicAdmin/PolicyManagement" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-file-shield"></i>
                                    <p>@Localizer.T("Nav.Policies")</p>
                                </a>
                            </li>
                            <li class="nav-item" role="none">
                                <a href="/ClinicAdmin/KPIManagement" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-chart-line"></i>
                                    <p>@Localizer.T("Nav.KPIMonitoring")</p>
                                </a>
                            </li>
                            <li class="nav-item" role="none">
                                <a href="/ClinicAdmin/ChecklistManagement" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-clipboard-check"></i>
                                    <p>@Localizer.T("Nav.Checklists")</p>
                                </a>
                            </li>
                            <li class="nav-item" role="none">
                                <a href="/ClinicAdmin/Forms" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-file-alt"></i>
                                    <p>@Localizer.T("Nav.FormsLibrary")</p>
                                </a>
                            </li>
                            <li class="nav-header" role="presentation">@Localizer.T("Nav.Staff")</li>
                            <li class="nav-item" role="none">
                                <a href="/ClinicAdmin/HRManagement" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-users"></i>
                                    <p>@Localizer.T("Nav.HRCredentialing")</p>
                                </a>
                            </li>
                            <li class="nav-header" role="presentation">@Localizer.T("Nav.Communication")</li>
                            <li class="nav-item" role="none">
                                <a href="/ClinicAdmin/Notifications" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-bell"></i>
                                    <p>@Localizer.T("Nav.Notifications")</p>
                                </a>
                            </li>
                            <li class="nav-item" role="none">
                                <a href="/ClinicAdmin/Reporting" class="nav-link" role="menuitem">
                                    <i class="nav-icon fas fa-chart-bar"></i>
                                    <p>@Localizer.T("Nav.Reports")</p>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Sidebar Overlay (mobile) -->
        <div class="sidebar-overlay" tabindex="-1"></div>

        <!-- ===== TOP NAVBAR ===== -->
        <nav class="main-header navbar navbar-expand" role="navigation" aria-label="@Localizer.T("Nav.MainMenu")">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button" aria-label="@Localizer.T("Nav.MainMenu")">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav ms-auto">
                <!-- Notifications -->
                <li class="nav-item dropdown">
                    <a class="nav-link" href="#" id="notificationsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@Localizer.T("Nav.Notifications")">
                        <i class="fas fa-bell"></i>
                        <span class="navbar-badge" id="notificationBadge" style="display:none">0</span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end notification-dropdown" aria-labelledby="notificationsDropdown">
                        <span class="dropdown-header">@Localizer.T("Nav.Notifications")</span>
                        <div class="dropdown-divider"></div>
                        <a href="/ClinicAdmin/Notifications" class="dropdown-item dropdown-footer">@Localizer.T("Common.ViewAll")</a>
                    </div>
                </li>

                <!-- Language Toggle -->
                <li class="nav-item">
                    <a class="nav-link" href="#" id="langToggle" role="button" aria-label="@Localizer.T("Common.Language")">
                        <i class="fas fa-globe"></i>
                        <span id="langLabel">@TranslationService.CurrentLanguage.ToUpper()</span>
                    </a>
                </li>

                <!-- User Menu -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle user-menu" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@Localizer.T("User.MyProfile")">
                        <span class="user-avatar">
                            @User.Identity?.Name?.Substring(0, 1)?.ToUpper()
                        </span>
                        <span class="user-name">@User.Identity?.Name</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                        <li>
                            <h6 class="dropdown-header">@User.Identity?.Name</h6>
                        </li>
                        <li class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item" href="/Account/Profile">
                                <i class="fas fa-user-circle"></i> @Localizer.T("User.MyProfile")
                            </a>
                        </li>
                        <li class="dropdown-divider"></li>
                        <li>
                            <form method="post" action="/Account/Logout">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item">
                                    <i class="fas fa-sign-out-alt"></i> @Localizer.T("User.Logout")
                                </button>
                            </form>
                        </li>
                    </ul>
                </li>
            </ul>
        </nav>

        <!-- ===== CONTENT WRAPPER ===== -->
        <div class="content-wrapper">
            <!-- Content Header -->
            <section class="content-header">
                <div class="container-fluid">
                    <div class="row align-items-center">
                        <div class="col">
                            <h1>
                                @{
                                    var iconMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                                    {
                                        { "dashboard", "fa-tachometer-alt" },
                                        { "polic", "fa-file-shield" },
                                        { "kpi", "fa-chart-line" },
                                        { "checklist", "fa-clipboard-check" },
                                        { "form", "fa-file-alt" },
                                        { "hr", "fa-users" },
                                        { "notif", "fa-bell" },
                                        { "report", "fa-chart-bar" },
                                        { "clinic", "fa-hospital" },
                                        { "audit", "fa-history" },
                                        { "user", "fa-user-cog" },
                                        { "profile", "fa-user-circle" }
                                    };
                                    var title = ViewData["Title"]?.ToString() ?? "";
                                    var icon = "fa-tachometer-alt";
                                    foreach (var kv in iconMap) {
                                        if (title.Contains(kv.Key, StringComparison.OrdinalIgnoreCase)) {
                                            icon = kv.Value;
                                            break;
                                        }
                                    }
                                    <i class="fas @icon"></i>
                                }
                                @ViewData["Title"]
                            </h1>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Main Content -->
            <section class="content">
                <div class="container-fluid">
                    @if (!string.IsNullOrEmpty(TempData["SuccessMessage"] as string))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i>
                            <div class="alert-content">@TempData["SuccessMessage"]</div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="@Localizer.T("Common.Close")"></button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(TempData["ErrorMessage"] as string))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i>
                            <div class="alert-content">@TempData["ErrorMessage"]</div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="@Localizer.T("Common.Close")"></button>
                        </div>
                    }

                    @RenderBody()
                </div>
            </section>
        </div>

        <!-- ===== FOOTER ===== -->
        <footer class="main-footer">
            <span>
                <strong>@Localizer.T("App.Name")</strong> @Localizer.T("App.Copyright")
            </span>
            <span class="float-end d-none d-sm-inline-block">
                <b>@Localizer.T("App.Version")</b> 2.0.0
                <a href="#" class="developer-branding" data-dev-card aria-label="@Localizer.T("Developer.Branding")">
                    | @Localizer.T("Developer.Branding")
                </a>
            </span>
        </footer>
    </div>

    <!-- Developer Contact Card -->
    <partial name="_DeveloperContactCard" />

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/admin-lte/3.2.0/js/adminlte.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
