@{
    ViewData["Title"] = Localizer.T("App.Title");
}

<div class="error-page fade-in">
    <div class="headline text-danger">403</div>
    <div class="error-content">
        <h3><i class="fas fa-lock text-danger me-2"></i> @Localizer.T("AccessDenied.Heading")</h3>
        <p>@Localizer.T("AccessDenied.Message")</p>
        <a href="/" class="btn btn-primary">
            <i class="fas fa-home"></i> @Localizer.T("AccessDenied.ReturnHome")
        </a>
    </div>
</div>
