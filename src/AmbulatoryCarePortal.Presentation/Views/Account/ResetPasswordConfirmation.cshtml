@{
    ViewData["Title"] = Localizer.T("ResetConfirmation.Title");
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-container">
    <partial name="_AuthBrandPanel" />

    <div class="login-form-panel">
        <div class="login-form-wrapper">
            <div class="login-card">
                <div class="auth-status">
                    <div class="auth-status-icon auth-status-success" aria-hidden="true">
                        <i class="fas fa-check"></i>
                    </div>
                    <h3>@Localizer.T("ResetConfirmation.Heading")</h3>
                    <p>@Localizer.T("ResetConfirmation.Message")</p>
                    <a asp-controller="Account" asp-action="Login" class="login-btn auth-status-btn">
                        <i class="fas fa-arrow-right" aria-hidden="true"></i> @Localizer.T("ResetConfirmation.SignIn")
                    </a>
                </div>
            </div>

            <div class="login-form-footer">
                @Localizer.T("App.FullCopyright")
            </div>
        </div>
    </div>
</div>
