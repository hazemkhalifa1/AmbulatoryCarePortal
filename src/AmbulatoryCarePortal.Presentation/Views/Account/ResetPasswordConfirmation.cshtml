@{
    ViewData["Title"] = Localizer.T("ResetConfirmation.Title");
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-container" style="min-height:100vh">
    <div class="login-brand-panel">
        <div class="grid-pattern"></div>
        <div class="login-brand-content">
            <div class="brand-icon-large">
                <i class="fas fa-heartbeat"></i>
            </div>
            <h1>@Localizer.T("App.Name")</h1>
            <p class="brand-subtitle">@Localizer.T("App.Tagline")</p>
        </div>
        <div class="login-brand-footer">
            <p>@Localizer.T("App.Copyright")</p>
        </div>
    </div>

    <div class="login-form-panel">
        <div class="login-form-wrapper">
            <div class="login-card">
                <div class="login-success">
                    <div class="success-icon">
                        <i class="fas fa-check"></i>
                    </div>
                    <h3>@Localizer.T("ResetConfirmation.Heading")</h3>
                    <p>@Localizer.T("ResetConfirmation.Message")</p>
                    <a asp-controller="Account" asp-action="Login" class="login-btn" style="display:inline-flex;width:auto">
                        <i class="fas fa-arrow-right"></i> @Localizer.T("ResetConfirmation.SignIn")
                    </a>
                </div>
            </div>

            <div class="login-form-footer">
                @Localizer.T("App.FullCopyright")
            </div>
        </div>
    </div>
</div>
