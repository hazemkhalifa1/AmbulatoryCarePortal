@model AmbulatoryCarePortal.Presentation.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = Localizer.T("App.Title");
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-container">
    <partial name="_AuthBrandPanel" />

    <div class="login-form-panel">
        <div class="login-form-wrapper">
            <div class="form-header">
                <div class="form-badge">
                    <i class="fas fa-lock" aria-hidden="true"></i> @Localizer.T("ResetPassword.Title")
                </div>
                <h2>@Localizer.T("ResetPassword.Heading")</h2>
                <p>@Localizer.T("ResetPassword.Subtitle")</p>
            </div>

            <div class="login-card">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="login-error" role="alert" aria-live="assertive">
                        <i class="fas fa-exclamation-circle" aria-hidden="true"></i>
                        <div>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    </div>
                }

                <form method="post" asp-action="ResetPassword" novalidate>
                    <input type="hidden" asp-for="Code" />
                    <input type="hidden" asp-for="Email" />

                    <div class="form-group">
                        <label for="Password">@Localizer.T("ResetPassword.NewPassword")</label>
                        <div class="input-group">
                            <span class="input-icon" aria-hidden="true"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control" id="Password" placeholder="@Localizer.T("ResetPassword.NewPasswordPlaceholder")" asp-for="Password" required autocomplete="new-password" aria-required="true" data-password-strength="true">
                            <button type="button" class="toggle-password" aria-label="@Localizer.T("ResetPassword.NewPassword")" aria-controls="Password" tabindex="0">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="form-error" role="alert"></span>
                        <div class="password-strength" aria-live="polite" aria-atomic="true">
                            <div class="password-strength-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="4"></div>
                            <span class="password-strength-text"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="ConfirmPassword">@Localizer.T("ResetPassword.ConfirmPassword")</label>
                        <div class="input-group">
                            <span class="input-icon" aria-hidden="true"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control" id="ConfirmPassword" placeholder="@Localizer.T("ResetPassword.ConfirmPasswordPlaceholder")" asp-for="ConfirmPassword" required autocomplete="new-password" aria-required="true">
                            <button type="button" class="toggle-password" aria-label="@Localizer.T("ResetPassword.ConfirmPassword")" aria-controls="ConfirmPassword" tabindex="0">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="form-error" role="alert"></span>
                    </div>

                    <button type="submit" class="login-btn" data-loading>
                        <span class="btn-text">@Localizer.T("ResetPassword.ResetBtn")</span>
                        <span class="btn-loading">
                            <span class="spinner spinner-sm" aria-hidden="true"></span>
                            @Localizer.T("ResetPassword.Resetting")
                        </span>
                    </button>
                </form>
            </div>

            <div class="login-form-footer">
                @Localizer.T("Login.Footer")
            </div>
        </div>
    </div>
</div>
