@model AmbulatoryCarePortal.Presentation.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = Localizer.T("App.Title");
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-container">
    <div class="login-brand-panel">
        <div class="grid-pattern"></div>
        <div class="login-brand-content">
            <div class="brand-icon-large">
                <i class="fas fa-heartbeat"></i>
            </div>
            <h1>@Localizer.T("App.Name")</h1>
            <p class="brand-subtitle">@Localizer.T("App.Tagline")</p>
        </div>
        <div class="login-brand-footer">
            <p>@Localizer.T("App.Copyright")</p>
        </div>
    </div>

    <div class="login-form-panel">
        <div class="login-form-wrapper">
            <div class="form-header">
                <div class="form-badge">
                    <i class="fas fa-lock"></i> @Localizer.T("ResetPassword.Title")
                </div>
                <h2>@Localizer.T("ResetPassword.Heading")</h2>
                <p>@Localizer.T("ResetPassword.Subtitle")</p>
            </div>

            <div class="login-card">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="login-error" role="alert">
                        <i class="fas fa-exclamation-circle"></i>
                        <div>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    </div>
                }

                <form method="post" asp-action="ResetPassword" novalidate>
                    <input type="hidden" asp-for="Code" />
                    <input type="hidden" asp-for="Email" />

                    <div class="form-group">
                        <label for="Password">@Localizer.T("ResetPassword.NewPassword")</label>
                        <div class="input-group">
                            <span class="input-icon"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control" id="Password" placeholder="@Localizer.T("ResetPassword.NewPasswordPlaceholder")" asp-for="Password" required autocomplete="new-password">
                            <button type="button" class="toggle-password" aria-label="@Localizer.T("ResetPassword.NewPassword")">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label for="ConfirmPassword">@Localizer.T("ResetPassword.ConfirmPassword")</label>
                        <div class="input-group">
                            <span class="input-icon"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control" id="ConfirmPassword" placeholder="@Localizer.T("ResetPassword.ConfirmPasswordPlaceholder")" asp-for="ConfirmPassword" required autocomplete="new-password">
                            <button type="button" class="toggle-password" aria-label="@Localizer.T("ResetPassword.ConfirmPassword")">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>

                    <button type="submit" class="login-btn" data-loading>
                        <span class="btn-text">@Localizer.T("ResetPassword.ResetBtn")</span>
                        <span class="btn-loading">
                            <span class="spinner"></span>
                            @Localizer.T("ResetPassword.Resetting")
                        </span>
                    </button>
                </form>
            </div>

            <div class="login-form-footer">
                @Localizer.T("Login.Footer")
            </div>
        </div>
    </div>
</div>
