@model AmbulatoryCarePortal.Presentation.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = Localizer.T("App.Title");
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-container">
    <div class="login-brand-panel">
        <div class="grid-pattern"></div>
        <div class="login-brand-content">
            <div class="brand-icon-large">
                <i class="fas fa-heartbeat"></i>
            </div>
            <h1>@Localizer.T("App.Name")</h1>
            <p class="brand-subtitle">@Localizer.T("App.Tagline")</p>
        </div>
        <div class="login-brand-footer">
            <p>@Localizer.T("App.Copyright")</p>
        </div>
    </div>

    <div class="login-form-panel">
        <div class="login-form-wrapper">
            <div class="form-header">
                <div class="form-badge">
                    <i class="fas fa-key"></i> @Localizer.T("ForgotPassword.Title")
                </div>
                <h2>@Localizer.T("ForgotPassword.Heading")</h2>
                <p>@Localizer.T("ForgotPassword.Subtitle")</p>
            </div>

            <div class="login-card">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="login-error" role="alert">
                        <i class="fas fa-exclamation-circle"></i>
                        <div>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    </div>
                }

                <form method="post" asp-action="ForgotPassword" novalidate>
                    <div class="form-group">
                        <label for="Email">@Localizer.T("ForgotPassword.Email")</label>
                        <div class="input-group">
                            <span class="input-icon"><i class="fas fa-envelope"></i></span>
                            <input type="email" class="form-control" id="Email" placeholder="@Localizer.T("ForgotPassword.EmailPlaceholder")" asp-for="Email" required autocomplete="email" autofocus>
                        </div>
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <button type="submit" class="login-btn" data-loading>
                        <span class="btn-text">@Localizer.T("ForgotPassword.SendLink")</span>
                        <span class="btn-loading">
                            <span class="spinner"></span>
                            @Localizer.T("ForgotPassword.Sending")
                        </span>
                    </button>

                    <div class="text-center mt-4">
                        <a asp-controller="Account" asp-action="Login" class="forgot-link">
                            <i class="fas fa-arrow-left"></i> @Localizer.T("ForgotPassword.BackToLogin")
                        </a>
                    </div>
                </form>
            </div>

            <div class="login-form-footer">
                @Localizer.T("Login.Footer")
            </div>
        </div>
    </div>
</div>
