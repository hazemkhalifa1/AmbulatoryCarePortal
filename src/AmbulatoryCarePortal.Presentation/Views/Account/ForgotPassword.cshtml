@model AmbulatoryCarePortal.Presentation.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = Localizer.T("App.Title");
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-container">
    <partial name="_AuthBrandPanel" />

    <div class="login-form-panel">
        <div class="login-form-wrapper">
            <div class="form-header">
                <div class="form-badge">
                    <i class="fas fa-key" aria-hidden="true"></i> @Localizer.T("ForgotPassword.Title")
                </div>
                <h2>@Localizer.T("ForgotPassword.Heading")</h2>
                <p>@Localizer.T("ForgotPassword.Subtitle")</p>
            </div>

            <div class="login-card">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="login-error" role="alert" aria-live="assertive">
                        <i class="fas fa-exclamation-circle" aria-hidden="true"></i>
                        <div>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    </div>
                }

                <form method="post" asp-action="ForgotPassword" novalidate>
                    <div class="form-group">
                        <label for="Email">@Localizer.T("ForgotPassword.Email")</label>
                        <div class="input-group">
                            <span class="input-icon" aria-hidden="true"><i class="fas fa-envelope"></i></span>
                            <input type="email" class="form-control" id="Email" placeholder="@Localizer.T("ForgotPassword.EmailPlaceholder")" asp-for="Email" required autocomplete="email" autofocus aria-required="true">
                        </div>
                        <span asp-validation-for="Email" class="form-error" role="alert"></span>
                    </div>

                    <button type="submit" class="login-btn" data-loading>
                        <span class="btn-text">@Localizer.T("ForgotPassword.SendLink")</span>
                        <span class="btn-loading">
                            <span class="spinner spinner-sm" aria-hidden="true"></span>
                            @Localizer.T("ForgotPassword.Sending")
                        </span>
                    </button>

                    <div class="auth-back-link">
                        <a asp-controller="Account" asp-action="Login" class="forgot-link">
                            <i class="fas fa-arrow-left" aria-hidden="true"></i> @Localizer.T("ForgotPassword.BackToLogin")
                        </a>
                    </div>
                </form>
            </div>

            <div class="login-form-footer">
                @Localizer.T("Login.Footer")
            </div>
        </div>
    </div>
</div>
