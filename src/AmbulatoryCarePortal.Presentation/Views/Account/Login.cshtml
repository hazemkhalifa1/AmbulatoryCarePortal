@model AmbulatoryCarePortal.Presentation.ViewModels.LoginViewModel

@{
    ViewData["Title"] = Localizer.T("App.Title");
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-container">
    <div class="login-brand">
        <div class="grid-pattern"></div>
        <div class="login-brand-content">
            <div class="login-brand-icon">
                <i class="fas fa-heartbeat"></i>
            </div>
            <h1>@Localizer.T("App.Name")</h1>
            <p class="login-brand-subtitle">@Localizer.T("App.Tagline")</p>
            <div class="login-features">
                <div class="login-feature">
                    <span class="feature-icon"><i class="fas fa-check"></i></span>
                    <span>@Localizer.T("Login.Feature.Policy")</span>
                </div>
                <div class="login-feature">
                    <span class="feature-icon"><i class="fas fa-check"></i></span>
                    <span>@Localizer.T("Login.Feature.KPI")</span>
                </div>
                <div class="login-feature">
                    <span class="feature-icon"><i class="fas fa-check"></i></span>
                    <span>@Localizer.T("Login.Feature.Staff")</span>
                </div>
                <div class="login-feature">
                    <span class="feature-icon"><i class="fas fa-check"></i></span>
                    <span>@Localizer.T("Login.Feature.Audit")</span>
                </div>
            </div>
        </div>
        <div class="login-brand-footer">
            <p>@Localizer.T("App.Copyright")</p>
        </div>
    </div>

    <div class="login-form-panel">
        <div class="login-form-wrapper">
            <div class="login-form-header">
                <div class="form-badge">
                    <i class="fas fa-lock"></i> @Localizer.T("Login.SecureLogin")
                </div>
                <h2>@Localizer.T("Login.WelcomeBack")</h2>
                <p>@Localizer.T("Login.Subtitle")</p>
            </div>

            <div class="login-card">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="login-error" role="alert">
                        <i class="fas fa-exclamation-circle"></i>
                        <div>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    </div>
                }

                <form method="post" asp-action="Login" novalidate>
                    <div class="form-group">
                        <label for="Email" class="form-label">@Localizer.T("Login.Email")</label>
                        <div class="input-group">
                            <span class="input-icon"><i class="fas fa-envelope"></i></span>
                            <input type="email" class="form-control" id="Email" placeholder="@Localizer.T("Login.EmailPlaceholder")" asp-for="Email" required autocomplete="email" autofocus>
                        </div>
                        <span asp-validation-for="Email" class="form-error"></span>
                    </div>

                    <div class="form-group">
                        <label for="Password" class="form-label">@Localizer.T("Login.Password")</label>
                        <div class="input-group">
                            <span class="input-icon"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control" id="Password" placeholder="@Localizer.T("Login.PasswordPlaceholder")" asp-for="Password" required autocomplete="current-password">
                            <button type="button" class="toggle-password" aria-label="@Localizer.T("Login.Password")">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="form-error"></span>
                    </div>

                    <div class="login-options">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe" asp-for="RememberMe">
                            <label class="form-check-label" for="rememberMe">@Localizer.T("Login.RememberMe")</label>
                        </div>
                        <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-link">@Localizer.T("Login.ForgotPassword")</a>
                    </div>

                    <button type="submit" class="login-btn" data-loading>
                        <span class="btn-text">@Localizer.T("Login.SignIn")</span>
                        <span class="btn-loading">
                            <span class="spinner spinner-sm"></span>
                            @Localizer.T("Login.SigningIn")
                        </span>
                    </button>
                </form>

                <div class="login-form-footer">
                    @Localizer.T("Login.Footer")
                </div>
            </div>
        </div>
    </div>
</div>
