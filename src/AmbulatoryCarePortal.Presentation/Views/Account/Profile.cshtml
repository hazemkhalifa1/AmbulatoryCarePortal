@model AmbulatoryCarePortal.Presentation.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = Localizer.T("Profile.Title");
}

<div class="row fade-in">
    <div class="col-lg-6 mx-auto">
        <div class="profile-card">
            <div class="profile-header">
                <div class="profile-avatar" aria-hidden="true">
                    <span>@Model.FullNameEn?.Substring(0, 1)?.ToUpper()</span>
                </div>
                <h3>@Model.FullNameEn</h3>
                @if (!string.IsNullOrEmpty(Model.FullNameAr))
                {
                    <p class="profile-name-ar" dir="rtl">@Model.FullNameAr</p>
                }
            </div>

            <div class="profile-body">
                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Profile.Email")</span>
                    <span class="detail-value">@Model.Email</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                {
                    <div class="detail-row">
                        <span class="detail-label">@Localizer.T("Profile.Phone")</span>
                        <span class="detail-value">@Model.PhoneNumber</span>
                    </div>
                }

                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Profile.Role")</span>
                    <span class="detail-value">
                        <span class="badge badge-primary">@Model.Role</span>
                    </span>
                </div>

                <div class="detail-row">
                    <span class="detail-label">@Localizer.T("Profile.EmailStatus")</span>
                    <span class="detail-value">
                        @if (Model.EmailConfirmed)
                        {
                            <span class="badge badge-success"><i class="fas fa-check-circle" aria-hidden="true"></i> @Localizer.T("Profile.EmailConfirmed")</span>
                        }
                        else
                        {
                            <span class="badge badge-warning"><i class="fas fa-exclamation-circle" aria-hidden="true"></i> @Localizer.T("Profile.EmailNotConfirmed")</span>
                        }
                    </span>
                </div>

                @if (Model.LastLoginAt.HasValue)
                {
                    <div class="detail-row">
                        <span class="detail-label">@Localizer.T("Profile.LastLogin")</span>
                        <span class="detail-value">@Model.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                }
            </div>

            <div class="profile-actions">
                @if (!Model.EmailConfirmed)
                {
                    <form method="post" asp-action="ResendConfirmationEmail">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="profile-btn profile-btn-warning">
                            <i class="fas fa-envelope" aria-hidden="true"></i> @Localizer.T("Profile.ResendConfirmation")
                        </button>
                    </form>
                }
                <form method="post" asp-area="" asp-controller="Account" asp-action="Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="profile-btn profile-btn-danger">
                        <i class="fas fa-sign-out-alt" aria-hidden="true"></i> @Localizer.T("Profile.Logout")
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
